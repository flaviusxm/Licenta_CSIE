        // ─── Layer 3: Friendships ─────────────────────────────────────────────
        private static async Task SeedFriendshipsAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.Friendships.AnyAsync()) return;

            int sampleSize = Math.Min(users.Count, 3_000);
            var sample = users.Take(sampleSize).ToArray();
            var seeded = new HashSet<(string, string)>();
            var list = new List<Friendship>(sampleSize * 8);
            var statuses = new[] { FriendshipStatus.Accepted, FriendshipStatus.Pending, FriendshipStatus.Blocked };
            var weights = new[] { 0.70, 0.85, 1.00 };

            foreach (var user in sample)
            {
                int degree = Rng.Next(5, 16);
                foreach (var other in sample.OrderBy(_ => Rng.NextDouble()).Take(degree))
                {
                    if (other.Id == user.Id) continue;
                    var pair = Ordered(user.Id, other.Id);
                    if (!seeded.Add(pair)) continue;

                    double roll = Rng.NextDouble();
                    var status = roll < weights[0] ? statuses[0]
                               : roll < weights[1] ? statuses[1]
                               : statuses[2];

                    list.Add(new Friendship
                    {
                        RequesterId = user.Id,
                        AddresseeId = other.Id,
                        Status = status,
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 365)), DateTimeKind.Utc),
                    });
                }
            }
            await BulkInsertAsync(ctx, list, "Friendships", cfg.BatchSize, "Friendships", profile);
        }

        // ─── Layer 4: Communities ─────────────────────────────────────────────
        private static async Task<List<Community>> SeedCommunitiesAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, List<Tag> tags, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.Communities.AnyAsync())
                return await ctx.Communities.AsNoTracking().ToListAsync();

            var defs = new[]
            {
                ("Informatica Economica",      "ineconomica",   "Comunitate dedicata studentilor de la IE"),
                ("Cibernetica si Statistica",  "cibernetica",   "Matematica, statistica si modelare"),
                ("Inginerie Software",         "ing-software",  "Arhitecturi, design patterns, best practices"),
                ("Machine Learning & AI",      "ml-ai",         "Invatare automata si inteligenta artificiala"),
                ("Securitate Informatica",     "securitate",    "Cybersecurity, pentest, CTF"),
                ("Web & Mobile Development",   "web-mobile",    "Frontend, backend, aplicatii mobile"),
                ("Data Science",               "data-science",  "Analiza de date, vizualizare, BI"),
                ("Cloud & DevOps",             "cloud-devops",  "AWS, Azure, GCP, Kubernetes, CI/CD"),
                ("Algoritmi & Competitive",    "algorithms",    "Competitive programming, olimpiade"),
                ("Proiecte de Licenta",        "licenta",       "Ajutor si resurse pentru lucrari de licenta"),
            };

            var staff = users.Where(u => u.Role != Role.Member).ToList();
            if (!staff.Any()) staff = users.Take(2).ToList();

            var communities = new List<Community>();
            foreach (var (name, slug, desc) in defs)
            {
                var comm = new Community
                {
                    Id = Guid.NewGuid(),
                    Name = name,
                    Slug = slug,
                    Description = desc,
                    CreatorId = Pick(staff).Id,
                    CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddMonths(-Rng.Next(3, 24)), DateTimeKind.Utc),
                };
                ctx.Communities.Add(comm);
                communities.Add(comm);
            }
            await ctx.SaveChangesAsync();

            // Memberships – each user joins 2-6 communities (capped at 200k total rows)
            int maxMemberships = Math.Min(users.Count * 4, 200_000);
            var memberSet = new HashSet<(Guid, string)>();
            var memberships = new List<CommunityMembership>(maxMemberships);

            foreach (var user in users)
            {
                int joins = Rng.Next(2, 7);
                foreach (var comm in communities.OrderBy(_ => Rng.NextDouble()).Take(joins))
                {
                    if (!memberSet.Add((comm.Id, user.Id))) continue;
                    memberships.Add(new CommunityMembership
                    {
                        CommunityId = comm.Id,
                        UserId = user.Id,
                        Role = staff.Any(s => s.Id == user.Id) ? CommunityRole.Moderator : CommunityRole.Member,
                        JoinedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 365)), DateTimeKind.Utc),
                    });
                }
                if (memberships.Count >= maxMemberships) break;
            }
            await BulkInsertAsync(ctx, memberships, "CommunityMemberships", cfg.BatchSize, "CommunityMemberships", profile);
            Console.WriteLine($"[LoadSeeder]   Communities: {communities.Count} seeded.");
            return communities;
        }

