        public const string DefaultPassword = "Test@1234!";

        private static string ComputePasswordHash(string password)
        {
            const int saltSize = 16;
            const int keySize = 32;
            const int iterations = 100_000;

            var salt = RandomNumberGenerator.GetBytes(saltSize);
            var key = Rfc2898DeriveBytes.Pbkdf2(
                Encoding.UTF8.GetBytes(password), salt,
                iterations, HashAlgorithmName.SHA256, keySize);

            var output = new byte[1 + 4 + 4 + 4 + saltSize + keySize];
            output[0] = 0x01;
            WriteNetworkByteOrder(output, 1, (uint)HashAlgorithmName.SHA256.GetHashCode());
            WriteNetworkByteOrder(output, 5, (uint)iterations);
            WriteNetworkByteOrder(output, 9, (uint)saltSize);
            Buffer.BlockCopy(salt, 0, output, 13, saltSize);
            Buffer.BlockCopy(key, 0, output, 13 + saltSize, keySize);
            return Convert.ToBase64String(output);
        }

        private static void WriteNetworkByteOrder(byte[] buf, int offset, uint value)
        {
            buf[offset + 0] = (byte)(value >> 24);
            buf[offset + 1] = (byte)(value >> 16);
            buf[offset + 2] = (byte)(value >> 8);
            buf[offset + 3] = (byte)value;
        }

