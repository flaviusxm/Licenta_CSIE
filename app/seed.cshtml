        // ─── Public entry point ───────────────────────────────────────────────
        public static async Task SeedAsync(
            ApplicationDbContext context,
            UserManager<ApplicationUser> userManager,
            ScaleProfile profile = ScaleProfile.Enterprise)
        {
            var cfg = Profiles[profile];
            var sw = Stopwatch.StartNew();

            Console.WriteLine($"[LoadSeeder] ═══ Starting ENTERPRISE seed | profile={profile} | users={cfg.UserCount:N0} ═══");

            try
            {
                // 1. Base data (ranks, tags)
                var ranks = await SeedRanksAsync(context);
                var tags = await SeedTagsAsync(context);

                // 2. Users – parallel generation + bulk insert
                var users = await SeedUsersAsync(context, userManager, cfg, profile);

                // 3. Verification requests – for all verified users and some pending
                await SeedVerificationRequestsAsync(context, users, cfg, profile);

                // 4. Files, friendships
                var files = await SeedStoredFilesAsync(context, users, cfg, profile);
                await SeedFriendshipsAsync(context, users, cfg, profile);

                // 5. Communities and StudyGroups
                var communities = await SeedCommunitiesAsync(context, users, tags, cfg, profile);
                var groups = await SeedStudyGroupsAsync(context, users, cfg, profile);

                // 6. Group roles, categories, channels
                var (adminRoles, memberRoles) = await SeedGroupRolesAndMembershipsAsync(context, groups, users, cfg, profile);
                await SeedChannelCategoriesAsync(context, groups, cfg, profile);
                var channels = await SeedChannelsAsync(context, groups, cfg, profile);

                // 7. Posts – streaming generation to avoid memory bloat
                var posts = await SeedPostsAsync(context, communities, channels, users, tags, cfg, profile);

                // 8. Messages – streaming
                var messages = await SeedMessagesAsync(context, posts, channels, users, cfg, profile);

                // 9. Votes, views, reactions
                await SeedPostVotesAsync(context, posts, users, cfg, profile);
                await SeedPostViewsAsync(context, posts, users, cfg, profile);
                await SeedMessageReactionsAsync(context, messages, users, cfg, profile);

                // 10. Direct conversations
                await SeedDirectMessagingAsync(context, users, cfg, profile);

                // 11. Audit logs, reports, notifications
                await SeedAuditLogsAsync(context, users, posts, cfg, profile);
                await SeedReportsAsync(context, users, posts, messages, cfg, profile);
                await SeedNotificationsAsync(context, users, cfg, profile);

                // 12. Learning resources, events
                await SeedLearningResourcesAsync(context, users, groups, files, cfg, profile);
                await SeedEventsAsync(context, communities, users, cfg, profile);

                // 13. Group invites
                await SeedGroupInvitesAsync(context, groups, users, cfg, profile);

                sw.Stop();
                Console.WriteLine($"\n[LoadSeeder] ✅ Completed in {sw.Elapsed.TotalSeconds:F1}s");
                PrintSummary(profile, cfg);
            }
            catch (Exception ex)
            {
                Console.WriteLine("[LoadSeeder] ❌ FATAL:");
                for (var e = ex; e != null; e = e.InnerException)
                    Console.WriteLine($"  [{e.GetType().Name}] {e.Message}");
                throw;
            }
        }

        // ─── High-performance bulk insert (SQL Server only) ──────────────────
        private static async Task BulkInsertSqlAsync<T>(
            ApplicationDbContext ctx,
            IReadOnlyList<T> entities,
            string tableName,
            int batchSize,
            string label) where T : class
        {
            if (entities.Count == 0) return;
            var sw = Stopwatch.StartNew();

            var connection = ctx.Database.GetDbConnection() as SqlConnection;
            if (connection == null)
                throw new NotSupportedException("BulkInsertSqlAsync requires SQL Server.");

            await using (var bulkCopy = new SqlBulkCopy(connection))
            {
                bulkCopy.DestinationTableName = tableName;
                bulkCopy.BatchSize = batchSize;
                bulkCopy.EnableStreaming = true;

                var table = new DataTable();
                var props = typeof(T).GetProperties()
                    .Where(p => p.GetMethod != null && p.GetMethod.IsPublic && p.PropertyType.IsPublic)
                    .ToArray();

                foreach (var prop in props)
                {
                    var type = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;
                    table.Columns.Add(prop.Name, type);
                }

                foreach (var entity in entities)
                {
                    var row = table.NewRow();
                    foreach (var prop in props)
                    {
                        var val = prop.GetValue(entity);
                        row[prop.Name] = val ?? DBNull.Value;
                    }
                    table.Rows.Add(row);
                }

                await bulkCopy.WriteToServerAsync(table);
            }

            Console.WriteLine($"[LoadSeeder]   {label}: {entities.Count:N0} rows in {sw.Elapsed.TotalSeconds:F2}s");
        }

        // ─── Fallback bulk save using EF (for non-SQL Server) ─────────────────
        private static async Task BulkSaveAsync<T>(
            ApplicationDbContext ctx,
            IReadOnlyList<T> entities,
            int batchSize,
            string label) where T : class
        {
            if (entities.Count == 0) return;
            var sw = Stopwatch.StartNew();
            for (int i = 0; i < entities.Count; i += batchSize)
            {
                var batch = entities.Skip(i).Take(batchSize).ToList();
                await ctx.Set<T>().AddRangeAsync(batch);
                await ctx.SaveChangesAsync();
                ctx.ChangeTracker.Clear();
            }
            Console.WriteLine($"[LoadSeeder]   {label}: {entities.Count:N0} rows in {sw.Elapsed.TotalSeconds:F2}s");
        }

        // ─── Choose appropriate insert method based on profile and DB ────────
        private static async Task BulkInsertAsync<T>(
            ApplicationDbContext ctx,
            IReadOnlyList<T> entities,
            string tableName,
            int batchSize,
            string label,
            ScaleProfile profile,
            bool useSqlBulk = true) where T : class
        {
            if (entities.Count == 0) return;
            if (profile == ScaleProfile.Enterprise && useSqlBulk && ctx.Database.IsSqlServer())
            {
                await BulkInsertSqlAsync(ctx, entities, tableName, batchSize, label);
            }
            else
            {
                await BulkSaveAsync(ctx, entities, batchSize, label);
            }
        }

