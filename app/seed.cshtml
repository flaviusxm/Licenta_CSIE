        // ─── Layer 5: Roles, Memberships, Categories ──────────────────────────
        private static async Task<(List<GroupRole>, List<GroupRole>)> SeedGroupRolesAndMembershipsAsync(
            ApplicationDbContext ctx, List<StudyGroup> groups, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.GroupRoles.AnyAsync())
            {
                var ex = await ctx.GroupRoles.AsNoTracking().ToListAsync();
                return (ex.Where(r => r.Name == "Admin").ToList(), ex.Where(r => r.Name == "Member").ToList());
            }

            var adminRoles = new List<GroupRole>();
            var memberRoles = new List<GroupRole>();
            var allRoles = new List<GroupRole>();

            foreach (var g in groups)
            {
                var ar = new GroupRole { Id = Guid.NewGuid(), GroupId = g.Id, Name = "Admin", Permissions = "ALL" };
                var mr = new GroupRole { Id = Guid.NewGuid(), GroupId = g.Id, Name = "Moderator", Permissions = "MANAGE_MESSAGES,KICK" };
                var br = new GroupRole { Id = Guid.NewGuid(), GroupId = g.Id, Name = "Member", Permissions = "READ,WRITE" };
                allRoles.AddRange(new[] { ar, mr, br });
                adminRoles.Add(ar);
                memberRoles.Add(br);
            }
            await ctx.GroupRoles.AddRangeAsync(allRoles);
            await ctx.SaveChangesAsync();

            var memberships = new List<GroupMembership>();
            foreach (var g in groups)
            {
                var ar = adminRoles.First(r => r.GroupId == g.Id);
                var mr = memberRoles.First(r => r.GroupId == g.Id);

                if (g.OwnerId != null)
                    memberships.Add(new GroupMembership { GroupId = g.Id, UserId = g.OwnerId, GroupRoleId = ar.Id, JoinedAt = DateTime.UtcNow });

                // Up to 500 members per group for load coverage
                var members = users.Where(u => u.Id != g.OwnerId)
                                   .OrderBy(_ => Rng.NextDouble())
                                   .Take(Math.Min(500, users.Count / groups.Count + 50));
                foreach (var u in members)
                    memberships.Add(new GroupMembership
                    {
                        GroupId = g.Id,
                        UserId = u.Id,
                        GroupRoleId = mr.Id,
                        JoinedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 365)), DateTimeKind.Utc),
                    });
            }
            await BulkInsertAsync(ctx, memberships, "GroupMemberships", cfg.BatchSize, "GroupMemberships", profile);
            return (adminRoles, memberRoles);
        }

