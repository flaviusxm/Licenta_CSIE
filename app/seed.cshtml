        private static async Task SeedMessageReactionsAsync(
            ApplicationDbContext ctx, List<Message> messages, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.MessageReactions.AnyAsync()) return;

            int maxReactors = Math.Min(6, users.Count);
            var seen = new HashSet<(Guid, string, string)>(messages.Count * 3);
            var reactions = new List<MessageReaction>(messages.Count * 2);
            int uc = users.Count;
            int ec = Emojis.Length;

            foreach (var msg in messages.Where((_, i) => i % 2 == 0))
            {
                int reactors = Rng.Next(0, maxReactors + 1);
                for (int i = 0; i < reactors; i++)
                {
                    var uid = users[Rng.Next(uc)].Id;
                    var emoji = Emojis[Rng.Next(ec)];
                    if (!seen.Add((msg.Id, uid, emoji))) continue;
                    reactions.Add(new MessageReaction { MessageId = msg.Id, UserId = uid, EmojiCode = emoji });
                }
            }
            await BulkInsertAsync(ctx, reactions, "MessageReactions", cfg.BatchSize * 2, "MessageReactions", profile);
        }

        // ─── Layer 9: DirectMessaging ─────────────────────────────────────────
        private static async Task SeedDirectMessagingAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.DirectConversations.AnyAsync()) return;

            var seeded = new HashSet<(string, string)>();
            int convCount = 0;
            int maxConvs = cfg.DirectConvCount;
            int uc = users.Count;

            while (convCount < maxConvs)
            {
                var convBatch = new List<DirectConversation>(cfg.BatchSize);
                var partBatch = new List<DirectConversationParticipant>(cfg.BatchSize * 2);

                for (int i = 0; i < cfg.BatchSize && convCount < maxConvs; i++)
                {
                    var u1 = users[Rng.Next(uc)];
                    var u2 = users[Rng.Next(uc)];
                    if (u1.Id == u2.Id) continue;
                    var pair = Ordered(u1.Id, u2.Id);
                    if (!seeded.Add(pair)) continue;

                    var convId = Guid.NewGuid();
                    convBatch.Add(new DirectConversation
                    {
                        Id = convId,
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 180)), DateTimeKind.Utc),
                    });
                    partBatch.Add(new DirectConversationParticipant { ConversationId = convId, UserId = u1.Id });
                    partBatch.Add(new DirectConversationParticipant { ConversationId = convId, UserId = u2.Id });
                    convCount++;
                }

                if (convBatch.Count == 0) break;
                await BulkInsertAsync(ctx, convBatch, "DirectConversations", cfg.BatchSize, "DirectConversations", profile);
                await BulkInsertAsync(ctx, partBatch, "DirectConversationParticipants", cfg.BatchSize * 2, "DirectConversationParticipants", profile);
                ctx.ChangeTracker.Clear();
            }
            Console.WriteLine($"[LoadSeeder]   DirectConversations: {convCount:N0} seeded.");
        }

        // ─── Layer 10: AuditLogs, Reports, Notifications ─────────────────────
        private static async Task SeedAuditLogsAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, List<Post> posts, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.AuditLogs.AnyAsync()) return;

            var admins = users.Where(u => u.Role == Role.Admin || u.Role == Role.Moderator).ToList();
            if (!admins.Any()) admins = users.Take(2).ToList();

            var logs = new List<AuditLog>(cfg.AuditLogCount);
            for (int i = 0; i < cfg.AuditLogCount; i++)
            {
                logs.Add(new AuditLog
                {
                    Id = Guid.NewGuid(),
                    ActorId = Pick(admins).Id,
                    ActionType = Pick(AuditActions),
                    TargetEntity = Pick(new[] { "User", "Post", "Message", "Community", "Group" }),
                    TargetId = Guid.NewGuid(),
                    Changes = $"Auto-generated audit event #{i}",
                    CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 180)), DateTimeKind.Utc),
                });
            }
            await BulkInsertAsync(ctx, logs, "AuditLogs", cfg.BatchSize, "AuditLogs", profile);
        }

        private static async Task SeedReportsAsync(
            ApplicationDbContext ctx,
            List<ApplicationUser> users,
            List<Post> posts,
            List<Message> messages,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.Reports.AnyAsync()) return;

            var reasons = Enum.GetValues<ReportReason>();
            var statuses = Enum.GetValues<ReportStatus>();
            var reports = new List<Report>(cfg.PostReportCount + cfg.MsgReportCount);
            int uc = users.Count;

            for (int i = 0; i < cfg.PostReportCount; i++)
            {
                var post = posts[Rng.Next(posts.Count)];
                var reporter = users[Rng.Next(uc)];
                if (reporter.Id == post.AuthorId) continue;
                reports.Add(new Report
                {
                    Id = Guid.NewGuid(),
                    ReporterId = reporter.Id,
                    ReportedPostId = post.Id,
                    Reason = Pick(reasons),
                    Description = "Continut raportat automat (load test).",
                    Status = Pick(statuses),
                    CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 90)), DateTimeKind.Utc),
                });
            }

            for (int i = 0; i < cfg.MsgReportCount; i++)
            {
                var msg = messages[Rng.Next(messages.Count)];
                var reporter = users[Rng.Next(uc)];
                if (reporter.Id == msg.AuthorId) continue;
                reports.Add(new Report
                {
                    Id = Guid.NewGuid(),
                    ReporterId = reporter.Id,
                    ReportedMessageId = msg.Id,
                    Reason = Pick(reasons),
                    Description = "Mesaj raportat automat (load test).",
                    Status = Pick(statuses),
                    CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 90)), DateTimeKind.Utc),
                });
            }

            await BulkInsertAsync(ctx, reports, "Reports", cfg.BatchSize, "Reports", profile);
        }

        private static async Task SeedNotificationsAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.Notifications.AnyAsync()) return;

            var types = new[]
            {
                ("Bine ai venit!",         "Exploreaza comunitatile si grupurile de studiu."),
                ("Raspuns nou",            "Cineva a raspuns la postarea ta."),
                ("Vot primit",             "Postarea ta a primit un vot pozitiv."),
                ("Cerere de prietenie",    "Ai primit o cerere de prietenie."),
                ("Invitatie grup",         "Ai fost invitat intr-un grup de studiu."),
                ("Eveniment in curand",    "Un eveniment incepe in 24h."),
                ("Resursa noua",           "Resursa noua in grupul tau."),
                ("Verificare aprobata",    "Contul tau a fost verificat."),
                ("Badge nou deblocat",     "Ai obtinut un nou badge de reputatie!"),
                ("Post trending",          "Postarea ta este in trending astazi."),
            };

            var notifs = new List<Notification>(users.Count * cfg.NotifPerUser);
            foreach (var user in users)
            {
                int n = Rng.Next(cfg.NotifPerUser / 2, cfg.NotifPerUser + 1);
                for (int i = 0; i < n; i++)
                {
                    var (title, msg) = Pick(types);
                    notifs.Add(new Notification
                    {
                        Id = Guid.NewGuid(),
                        UserId = user.Id,
                        Title = title,
                        Message = msg,
                        IsRead = Rng.NextDouble() > 0.35,
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 60)), DateTimeKind.Utc),
                    });
                }
            }
            await BulkInsertAsync(ctx, notifs, "Notifications", cfg.BatchSize * 2, "Notifications", profile);
        }

        // ─── Layer 11: LearningResources & Events ─────────────────────────────
        private static async Task SeedLearningResourcesAsync(
            ApplicationDbContext ctx,
            List<ApplicationUser> users,
            List<StudyGroup> groups,
            List<StoredFile> files,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.LearningResources.AnyAsync()) return;

            var resTypes = new[] { "PDF", "Video", "Link", "Article", "Exercise", "Cheatsheet", "Notebook", "Slides" };
            var titles = new[] { "Ghid", "Tutorial", "Exercitii", "Note de curs", "Cheatsheet", "Rezumat", "Lab", "Demo" };
            var resources = new List<LearningResource>(groups.Count * cfg.ResourcesPerGroup);
            int uc = users.Count, fc = files.Count;

            foreach (var g in groups)
            {
                for (int i = 0; i < cfg.ResourcesPerGroup; i++)
                {
                    var hasFile = fc > 0 && Rng.NextDouble() > 0.4;
                    resources.Add(new LearningResource
                    {
                        Id = Guid.NewGuid(),
                        GroupId = g.Id,
                        UploaderId = users[Rng.Next(uc)].Id,
                        Title = $"Resursa {i + 1}: {Pick(titles)}",
                        Description = "Material util pentru pregatire.",
                        ResourceType = Pick(resTypes),
                        Url = hasFile ? files[Rng.Next(fc)].FilePath : $"https://example.com/resource/{Guid.NewGuid():N}",
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 365)), DateTimeKind.Utc),
                    });
                }
            }
            await BulkInsertAsync(ctx, resources, "LearningResources", cfg.BatchSize, "LearningResources", profile);
        }

        private static async Task SeedEventsAsync(
            ApplicationDbContext ctx,
            List<Community> communities,
            List<ApplicationUser> users,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.Events.AnyAsync()) return;

            var templates = new[]
            {
                ("Sesiune Q&A Live",    "Online (Microsoft Teams)", 1),
                ("Workshop Practic",    "Sala C201, ASE Bucuresti", 3),
                ("Hackathon 24h",       "Online (Discord)",         24),
                ("Prezentare Proiecte", "Amfiteatru Moxa",          2),
                ("Meetup Lunar",        "Hub-ul Antreprenorial",    2),
                ("Concurs Algoritmi",   "Online (Codeforces)",      4),
                ("Study Jam",           "Biblioteca ASE",           5),
                ("Tech Talk",           "Online (Zoom)",            1),
            };

            var events = new List<Event>(communities.Count * cfg.EventsPerCommunity);
            int uc = users.Count;

            foreach (var comm in communities)
            {
                for (int i = 0; i < cfg.EventsPerCommunity; i++)
                {
                    var (title, loc, hours) = Pick(templates);
                    var start = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(Rng.Next(-30, 60)), DateTimeKind.Utc);
                    events.Add(new Event
                    {
                        Id = Guid.NewGuid(),
                        CommunityId = comm.Id,
                        OrganizerId = users[Rng.Next(uc)].Id,
                        Title = $"{comm.Name} – {title}",
                        Description = $"Eveniment organizat pentru membrii comunitatii {comm.Name}.",
                        Location = loc,
                        StartTime = start,
                        EndTime = start.AddHours(hours),
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 30)), DateTimeKind.Utc),
                    });
                }
            }
            await BulkInsertAsync(ctx, events, "Events", cfg.BatchSize, "Events", profile);
        }

        // ─── Layer 12: GroupInvites ───────────────────────────────────────────
        private static async Task SeedGroupInvitesAsync(
            ApplicationDbContext ctx, List<StudyGroup> groups, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.GroupInvites.AnyAsync()) return;

            var invites = new List<GroupInvite>(groups.Count * cfg.InvitesPerGroup);
            int uc = users.Count;

            foreach (var g in groups)
            {
                for (int i = 0; i < cfg.InvitesPerGroup; i++)
                {
                    invites.Add(new GroupInvite
                    {
                        Id = Guid.NewGuid(),
                        GroupId = g.Id,
                        CreatorId = g.OwnerId!,
                        Code = $"INV-{Guid.NewGuid().ToString("N")[..8].ToUpper()}",
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 90)), DateTimeKind.Utc),
                        ExpiresAt = DateTime.UtcNow.AddDays(30),
                        MaxUses = Rng.Next(5, 100),
                        CurrentUses = Rng.Next(0, 10),
                    });
                }
            }
            await BulkInsertAsync(ctx, invites, "GroupInvites", cfg.BatchSize, "GroupInvites", profile);
        }

        // ─── Helpers ──────────────────────────────────────────────────────────
        private static T Pick<T>(IList<T> list) => list[Rng.Next(list.Count)];
        private static T Pick<T>(T[] arr) => arr[Rng.Next(arr.Length)];

        private static IEnumerable<T> PickRandom<T>(IList<T> list, int count)
        {
            return list.OrderBy(x => Rng.Next()).Take(count);
        }

        private static (string, string) Ordered(string a, string b) =>
            string.Compare(a, b, StringComparison.Ordinal) < 0 ? (a, b) : (b, a);

