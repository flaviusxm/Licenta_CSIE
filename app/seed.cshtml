        // ─── Layer 6: Posts (streaming) ───────────────────────────────────────
        private static async Task<List<Post>> SeedPostsAsync(
            ApplicationDbContext ctx,
            List<Community> communities,
            List<Channel> channels,
            List<ApplicationUser> users,
            List<Tag> tags,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.Posts.AnyAsync())
                return await ctx.Posts.AsNoTracking().ToListAsync();

            var posts = new List<Post>();
            var postTags = new List<PostTag>();
            int tagCount = tags.Count;

            // Community posts
            foreach (var comm in communities)
            {
                for (int i = 0; i < cfg.CommunitiesPostsPerCommunity; i++)
                {
                    var post = new Post
                    {
                        Id = Guid.NewGuid(),
                        CommunityId = comm.Id,
                        AuthorId = Pick(users).Id,
                        Title = Pick(PostTitles),
                        Content = Pick(PostContents) + "\n\n" + Pick(PostContents),
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 365)), DateTimeKind.Utc),
                        IsSolved = Rng.NextDouble() > 0.7,
                    };
                    posts.Add(post);

                    int numTags = Rng.Next(1, 4);
                    for (int t = 0; t < numTags; t++)
                        postTags.Add(new PostTag { PostId = post.Id, TagId = tags[Rng.Next(tagCount)].Id });
                }
            }

            // Channel discussion posts
            var textChannels = channels.Where(c => c.Type == ChannelType.Text).ToList();
            foreach (var chan in textChannels)
            {
                for (int i = 0; i < cfg.ChannelPostsPerChannel; i++)
                {
                    posts.Add(new Post
                    {
                        Id = Guid.NewGuid(),
                        ChannelId = chan.Id,
                        AuthorId = Pick(users).Id,
                        Title = $"Topic: {Pick(PostTitles)}",
                        Content = Pick(PostContents),
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 200)), DateTimeKind.Utc),
                        IsSolved = false,
                    });
                }
            }

            await BulkInsertAsync(ctx, posts, "Posts", cfg.BatchSize * 2, "Posts", profile);
            await BulkInsertAsync(ctx, postTags, "PostTags", cfg.BatchSize * 4, "PostTags", profile);
            return posts;
        }

        // ─── Layer 7: Messages (streaming) ────────────────────────────────────
        private static async Task<List<Message>> SeedMessagesAsync(
            ApplicationDbContext ctx,
            List<Post> posts,
            List<Channel> channels,
            List<ApplicationUser> users,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.Messages.AnyAsync()) return new List<Message>();

            var messages = new List<Message>(posts.Count * cfg.MessagesPerPost + channels.Count * cfg.ChannelMessagesPerChannel);
            int userCount = users.Count;

            // Post replies
            foreach (var post in posts)
            {
                int count = Rng.Next(cfg.MessagesPerPost / 2, cfg.MessagesPerPost + 1);
                Guid? prevId = null;
                for (int i = 0; i < count; i++)
                {
                    var id = Guid.NewGuid();
                    messages.Add(new Message
                    {
                        Id = id,
                        PostId = post.Id,
                        AuthorId = users[Rng.Next(userCount)].Id,
                        Content = Pick(MessageContents),
                        CreatedAt = DateTime.SpecifyKind(post.CreatedAt.AddMinutes(Rng.Next(1, 15000)), DateTimeKind.Utc),
                        ReplyToMessageId = (prevId.HasValue && Rng.NextDouble() > 0.65) ? prevId : null,
                        IsPinned = Rng.NextDouble() < 0.01,
                        IsEdited = Rng.NextDouble() < 0.1,
                        ModerationStatus = ModerationStatus.Approved,
                    });
                    prevId = id;
                }
            }

            // Channel messages
            var textChannels = channels.Where(c => c.Type == ChannelType.Text).ToList();
            foreach (var chan in textChannels)
            {
                int count = Rng.Next(cfg.ChannelMessagesPerChannel / 2, cfg.ChannelMessagesPerChannel + 1);
                for (int i = 0; i < count; i++)
                {
                    messages.Add(new Message
                    {
                        Id = Guid.NewGuid(),
                        ChannelId = chan.Id,
                        AuthorId = users[Rng.Next(userCount)].Id,
                        Content = Pick(ChannelMessages),
                        CreatedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddHours(-Rng.Next(1, 8760)), DateTimeKind.Utc),
                        IsPinned = Rng.NextDouble() < 0.01,
                        IsEdited = Rng.NextDouble() < 0.1,
                        ModerationStatus = ModerationStatus.Approved,
                    });
                }
            }

            await BulkInsertAsync(ctx, messages, "Messages", cfg.BatchSize * 2, "Messages", profile);
            return messages;
        }

        // ─── Layer 8: Votes, Views, Reactions ─────────────────────────────────
        private static async Task SeedPostVotesAsync(
            ApplicationDbContext ctx, List<Post> posts, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.PostVotes.AnyAsync()) return;

            var seen = new HashSet<(Guid, string)>(posts.Count * 10);
            var votes = new List<PostVote>(posts.Count * cfg.MaxVotersPerPost / 2);
            int uc = users.Count;

            foreach (var post in posts)
            {
                int voters = Rng.Next(0, cfg.MaxVotersPerPost + 1);
                for (int i = 0; i < voters; i++)
                {
                    var uid = users[Rng.Next(uc)].Id;
                    if (!seen.Add((post.Id, uid))) continue;
                    votes.Add(new PostVote
                    {
                        PostId = post.Id,
                        UserId = uid,
                        VoteValue = (short)(Rng.NextDouble() > 0.20 ? 1 : -1),
                    });
                }
            }
            await BulkInsertAsync(ctx, votes, "PostVotes", cfg.BatchSize * 2, "PostVotes", profile);
        }

