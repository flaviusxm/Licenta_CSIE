        private static async Task<List<ApplicationUser>> SeedUsersAsync(
            ApplicationDbContext ctx,
            UserManager<ApplicationUser> userManager,
            ScaleConfig cfg,
            ScaleProfile profile)
        {
            if (await ctx.Users.AnyAsync())
            {
                Console.WriteLine($"[LoadSeeder]   Users: already seeded, loading from DB...");
                return await ctx.Users.AsNoTracking().ToListAsync();
            }

            var sw = Stopwatch.StartNew();
            var users = new List<ApplicationUser>(cfg.UserCount + FixedAccounts.Length);

            // Fixed accounts via UserManager
            foreach (var (email, name, role, occ, inst, verified, rep) in FixedAccounts)
            {
                if (await userManager.FindByEmailAsync(email) != null) continue;
                var u = BuildUser(email, name, role, occ, inst, verified, rep, fixedDate: true);
                var r = await userManager.CreateAsync(u, DefaultPassword);
                if (r.Succeeded) users.Add(u);
            }

            // Bulk random users – generate in parallel batches
            var sharedHash = ComputePasswordHash(DefaultPassword);
            var repBuckets = new[] { 50, 300, 800, 1200, 2500, 5000, 10000, 18000 };

            var userBatches = Partitioner.Create(0, cfg.UserCount, cfg.BatchSize)
                .GetPartitions(Environment.ProcessorCount)
                .Select(part => Task.Run(() =>
                {
                    var localUsers = new List<ApplicationUser>();
                    while (part.MoveNext())
                    {
                        var (start, end) = part.Current;
                        for (int i = start; i < end; i++)
                        {
                            var idx = Interlocked.Increment(ref _uidCounter);
                            var first = Pick(FirstNames);
                            var last = Pick(LastNames);
                            var email = $"{first.ToLower()}.{last.ToLower()}{idx}{Pick(Domains)}";

                            // Assign role based on realistic distribution
                            double roleRand = Rng.NextDouble();
                            Role role;
                            if (roleRand < 0.02) // 2% admins
                                role = Role.Admin;
                            else if (roleRand < 0.07) // 5% moderators
                                role = Role.Moderator;
                            else
                                role = Role.Member;

                            var rep = Pick(repBuckets) + Rng.Next(0, 400);

                            // Verified status:
                            // - Admins and moderators always verified
                            // - Members with rep > 1000 have 70% chance to be verified
                            // - Others not verified
                            bool verified = role != Role.Member || (rep > 1000 && Rng.NextDouble() < 0.7);

                            var u = BuildUser(email, $"{first} {last}", role,
                                              Pick(Occupations), Pick(Institutions),
                                              verified, rep);
                            u.PasswordHash = sharedHash;
                            localUsers.Add(u);
                        }
                    }
                    return localUsers;
                }));

            var allBatches = await Task.WhenAll(userBatches);
            var bulk = allBatches.SelectMany(x => x).ToList();

            await BulkInsertAsync(ctx, bulk, "AspNetUsers", cfg.BatchSize, "Users (bulk)", profile);
            users.AddRange(bulk);

            Console.WriteLine($"[LoadSeeder]   Users total: {users.Count:N0} in {sw.Elapsed.TotalSeconds:F1}s");
            return await ctx.Users.AsNoTracking().ToListAsync();
        }

        private static ApplicationUser BuildUser(
            string email, string fullName, Role role,
            string occ, string inst, bool verified, int rep,
            bool fixedDate = false)
        {
            var createdAt = fixedDate
                ? DateTime.UtcNow.AddYears(-1)
                : DateTime.SpecifyKind(DateTime.UtcNow.AddMonths(-Rng.Next(1, 36)), DateTimeKind.Utc);

            // Generate random interests (2-5)
            var interests = string.Join(", ", PickRandom(Interests, Rng.Next(2, 6)));

            // Generate social links JSON
            var socialLinks = new Dictionary<string, string>();
            foreach (var platform in PickRandom(SocialPlatforms, Rng.Next(1, 4)))
            {
                socialLinks[platform] = $"https://{platform.ToLower()}.com/{fullName.Replace(" ", "")}";
            }
            var socialLinksJson = JsonSerializer.Serialize(socialLinks);

            return new ApplicationUser
            {
                Id = Guid.NewGuid().ToString(),
                UserName = email,
                Email = email,
                NormalizedEmail = email.ToUpperInvariant(),
                NormalizedUserName = email.ToUpperInvariant(),
                FullName = fullName,
                EmailConfirmed = true,
                Role = role,
                IsVerified = verified,
                ReputationPoints = rep,
                Level = rep / 100,
                Bio = $"{fullName} este {occ} la {inst}. Îi place {Pick(Interests)}.",
                Institution = inst,
                Occupation = occ,
                Interests = interests,
                SocialLinks = socialLinksJson,
                AvatarUrl = $"https://randomuser.me/api/portraits/{(Rng.Next(2) == 0 ? "men" : "women")}/{Rng.Next(1, 99)}.jpg",
                BannerUrl = $"https://picsum.photos/id/{Rng.Next(1, 100)}/1200/300",
                Status = Pick(new[] { "Online", "Offline", "Away", "DND" }),
                LastActive = createdAt.AddDays(Rng.Next(1, 180)),
                SecurityStamp = Guid.NewGuid().ToString(),
                CreatedAt = createdAt,
            };
        }

        // ─── Layer 3: Verification Requests (realistic linking) ──────────────
        private static async Task SeedVerificationRequestsAsync(
            ApplicationDbContext ctx, List<ApplicationUser> users, ScaleConfig cfg, ScaleProfile profile)
        {
            if (await ctx.VerificationRequests.AnyAsync()) return;

            var admins = users.Where(u => u.Role == Role.Admin || u.Role == Role.Moderator).ToList();
            if (!admins.Any()) admins = users.Take(1).ToList();

            var requests = new List<VerificationRequest>();

            foreach (var user in users)
            {
                // For verified users, create an approved request
                if (user.IsVerified)
                {
                    var submitted = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(5, 180)), DateTimeKind.Utc);
                    var processedAt = DateTime.SpecifyKind(submitted.AddDays(Rng.Next(1, 10)), DateTimeKind.Utc);
                    requests.Add(new VerificationRequest
                    {
                        Id = Guid.NewGuid(),
                        UserId = user.Id,
                        StudentIdUrl = $"/uploads/verification/id_{Guid.NewGuid():N}.jpg",
                        CarnetUrl = $"/uploads/verification/carnet_{Guid.NewGuid():N}.jpg",
                        Status = Status.Approved,
                        ProcessedBy = Pick(admins).Id,
                        ProcessedAt = processedAt,
                        SubmittedAt = submitted,
                    });
                }
                else
                {
                    // For unverified users, 10% chance to have a pending request (simulating submitted but not yet processed)
                    if (Rng.NextDouble() < 0.1)
                    {
                        requests.Add(new VerificationRequest
                        {
                            Id = Guid.NewGuid(),
                            UserId = user.Id,
                            StudentIdUrl = $"/uploads/verification/id_{Guid.NewGuid():N}.jpg",
                            CarnetUrl = $"/uploads/verification/carnet_{Guid.NewGuid():N}.jpg",
                            Status = Status.Pending,
                            SubmittedAt = DateTime.SpecifyKind(DateTime.UtcNow.AddDays(-Rng.Next(1, 30)), DateTimeKind.Utc),
                        });
                    }
                }
            }

            await BulkInsertAsync(ctx, requests, "VerificationRequests", cfg.BatchSize, "VerificationRequests", profile);
        }

