@using AskNLearn.Application.Features.Posts.Commands.CreatePost
@model CreatePostCommand
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Create New Post";
}

<div class="container py-5 max-w-4xl">
    <div class="d-flex flex-column gap-5 animate-entrance">
        <!-- Header -->
        <div>
            <h2 class="display-5 fw-bold text-white tracking-tight mb-2">Create New Post</h2>
            <p class="text-muted fw-bold text-uppercase tracking-widest fs-xs mb-0">Share your thoughts, questions, or resources with the community.</p>
        </div>

        <div class="glass-card p-4 p-md-5 shadow-lg border-glass-strong" style="border-radius: 2rem;">
            <form asp-action="CreatePost" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-4">
                <input type="hidden" asp-for="CommunityId" />
                
                <div class="form-group gap-2 d-flex flex-column">
                    <label asp-for="Title" class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Post Title</label>
                    <input asp-for="Title" class="form-control glass-input py-3 px-4 shadow-sm" placeholder="What's on your mind?" style="border-radius: 1rem;"/>
                    <span asp-validation-for="Title" class="text-danger small fw-bold"></span>
                </div>

                <div class="form-group gap-2 d-flex flex-column">
                    <label asp-for="Content" class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Description</label>
                    <textarea asp-for="Content" rows="8" class="form-control glass-input py-3 px-4 shadow-sm" placeholder="Provide more details..." style="border-radius: 1.25rem;"></textarea>
                    <span asp-validation-for="Content" class="text-danger small fw-bold"></span>
                </div>

                <div class="form-group gap-2 d-flex flex-column">
                    <label class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Attachments</label>
                    <div class="position-relative group" id="drop-zone" style="min-height: 160px;">
                        <input type="file" name="Attachments" id="file-upload" multiple class="position-absolute inset-0 w-100 h-100 opacity-0 cursor-pointer z-3" onchange="updateFileList(this)" />
                        <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center gap-3 transition-all border-dashed border-2 border-glass rounded-4 bg-glass-hover" style="min-height: 160px; pointer-events: none;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center bg-glass border-glass-strong" style="width: 56px; height: 56px;">
                                <span class="material-symbols-outlined fs-2 text-aurora">cloud_upload</span>
                            </div>
                            <div class="text-center">
                                <p class="text-white fw-bold mb-1">Click or drag files here to upload</p>
                                <p class="text-muted small fw-medium mb-0">PDF, DOCX, JPG, PNG up to 10MB each</p>
                            </div>
                        </div>
                    </div>
                    <div id="file-list" class="d-flex flex-wrap gap-2 mt-2"></div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-premium flex-grow-1 py-3 fw-bold text-uppercase tracking-widest shadow-lg">
                        Publish Post
                    </button>
                    <a asp-controller="Forum" asp-action="Details" asp-route-id="@Model.CommunityId" class="btn btn-glass px-5 py-3 fw-bold text-uppercase tracking-widest" style="border-radius: 1rem;">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function updateFileList(input) {
        const fileList = document.getElementById('file-list');
        fileList.innerHTML = '';
        
        if (input.files.length > 0) {
            Array.from(input.files).forEach(file => {
                const badge = document.createElement('div');
                badge.className = 'glass-card px-3 py-2 d-flex align-items-center gap-2 border-glass-strong animate-entrance';
                badge.style.borderRadius = '0.75rem';
                badge.style.fontSize = '0.75rem';
                
                let icon = 'description';
                if (file.type.includes('image')) icon = 'image';
                if (file.type.includes('pdf')) icon = 'picture_as_pdf';
                
                badge.innerHTML = `
                    <span class="material-symbols-outlined fs-6 text-aurora">${icon}</span>
                    <span class="text-white fw-medium">${file.name}</span>
                `;
                fileList.appendChild(badge);
            });
        }
    }
</script>
