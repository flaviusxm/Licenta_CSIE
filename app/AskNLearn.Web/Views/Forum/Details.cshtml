@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@using AskNLearn.Application.Features.Posts.Queries.GetPostsByCommunity
@model CommunityDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
    var posts = ViewBag.Posts as List<PostDto> ?? new List<PostDto>();
}

<div class="p-8 flex flex-col gap-8 pb-20">
    
    <!-- Forum Header -->
    <div class="bg-surface-light dark:bg-surface-dark rounded-3xl p-8 border border-border-light dark:border-border-dark shadow-sm flex flex-col md:flex-row gap-8 items-start md:items-center">
         <div class="size-20 rounded-3xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-4xl">groups</span>
        </div>
        <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-4 mb-2">
                <h1 class="text-4xl font-bold text-slate-900 dark:text-white">@Model.Name</h1>
                @if (!Model.IsPublic)
                {
                    <span class="px-3 py-1 rounded-full bg-orange-500/10 text-orange-500 text-xs font-bold uppercase tracking-wider border border-orange-500/20">Private Forum</span>
                }
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-lg leading-relaxed max-w-3xl">@Model.Description</p>
            <div class="flex items-center gap-6 mt-4 text-sm font-medium">
                <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                    <span class="material-symbols-outlined text-[18px]">calendar_today</span>
                    <span>Created @Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400">
                    <span class="material-symbols-outlined text-[18px]">forum</span>
                    <span>@Model.PostCount Total Posts</span>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-3 w-full md:w-auto">
            <a asp-action="CreatePost" asp-route-communityId="@Model.Id" class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-border-light dark:border-border-dark text-slate-700 dark:text-slate-300 font-bold hover:bg-slate-50 dark:hover:bg-surface-dark transition-all">
                <span class="material-symbols-outlined text-[20px]">add_circle</span>
                Create Post
            </a>
            <div class="flex gap-2">
                <a asp-controller="Explore" asp-action="Index" class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-border-light dark:border-border-dark text-slate-700 dark:text-slate-300 font-bold hover:bg-slate-50 dark:hover:bg-surface-dark transition-all">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Explore
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="px-4 py-2.5 rounded-xl border border-border-light dark:border-border-dark text-slate-400 hover:text-primary hover:border-primary transition-all flex items-center justify-center">
                    <span class="material-symbols-outlined text-[20px]">settings</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Posts Section -->
    <div class="flex flex-col gap-6">
        <div class="flex items-center justify-between border-b border-border-light dark:border-border-dark pb-4">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Recent Posts</h2>
            <div class="flex gap-2">
                <button class="text-sm font-bold text-primary px-3 py-1.5 rounded-lg bg-primary/10 border border-primary/20">Latest</button>
                <button class="text-sm font-bold text-slate-500 px-3 py-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">Top</button>
            </div>
        </div>

        @if (!posts.Any())
        {
            <div class="text-center py-20 bg-surface-light dark:bg-surface-dark rounded-3xl border border-dashed border-border-light dark:border-border-dark">
                <span class="material-symbols-outlined text-6xl text-slate-300 dark:text-slate-700 mb-4">post_add</span>
                <p class="text-slate-500 dark:text-slate-400 font-medium text-lg">No posts yet in this community.</p>
                <p class="text-slate-400 dark:text-slate-500 text-sm mt-1">Be the first to share something!</p>
                <a asp-action="CreatePost" asp-route-communityId="@Model.Id" class="mt-6 inline-flex items-center gap-2 px-6 py-2.5 bg-primary/10 text-primary border border-primary/20 rounded-xl font-bold hover:bg-primary/20 transition-all">
                    Start a Discussion
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6">
                @foreach (var post in posts)
                {
                    <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all shadow-sm group">
                        <div class="flex gap-4 items-start translate-y-0.5">
                            <div class="size-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-slate-900 dark:text-white">@post.AuthorName</span>
                                    <span class="text-xs text-slate-400">• @post.CreatedAt.ToString("MMM dd")</span>
                                    @if (post.IsSolved)
                                    {
                                        <span class="px-2 py-0.5 rounded bg-green-500/10 text-green-500 text-[10px] font-bold uppercase border border-green-500/20">Solved</span>
                                    }
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 group-hover:text-primary transition-colors">@post.Title</h3>
                                <p class="text-slate-600 dark:text-slate-400 line-clamp-2 text-sm leading-relaxed mb-4">@post.Content</p>
                                
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-4 text-slate-400 text-xs font-bold">
                                        <div class="flex items-center gap-1.5 hover:text-primary cursor-pointer transition-colors">
                                            <span class="material-symbols-outlined text-[18px]">chat_bubble</span>
                                            <span>@post.CommentCount Comments</span>
                                        </div>
                                        <div class="flex items-center gap-1.5 hover:text-primary cursor-pointer transition-colors">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                            <span>@post.ViewCount Views</span>
                                        </div>
                                    </div>
                                    
                                    <div class="flex gap-2">
                                        <a asp-action="EditPost" asp-route-id="@post.Id" asp-route-communityId="@Model.Id" class="text-slate-300 hover:text-primary transition-colors">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>
                                        <form asp-action="DeletePost" asp-route-id="@post.Id" asp-route-communityId="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this post?')">
                                            <button type="submit" class="text-slate-300 hover:text-red-500 transition-colors">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
