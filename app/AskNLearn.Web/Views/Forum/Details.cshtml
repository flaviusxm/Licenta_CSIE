@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@using AskNLearn.Application.Features.Posts.Queries.GetPostsByCommunity
@using System.Threading.Tasks
@model CommunityDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
    var posts = ViewBag.Posts as List<PostDto> ?? new List<PostDto>();
}

@functions {
    async Task RenderComments(List<CommentDto> allComments, Guid? parentId, int depth = 0)
    {
        var currentComments = allComments.Where(c => c.ReplyToMessageId == parentId).OrderBy(c => c.CreatedAt).ToList();
        foreach (var comment in currentComments)
        {
            <div class="flex flex-col gap-2 @(depth > 0 ? "border-l-2 border-slate-100 dark:border-white/5 ml-4 pl-4 mt-3" : "mt-4")">
                <div class="flex gap-3">
                    <div class="size-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400 shrink-0">
                        <span class="material-symbols-outlined text-sm">person</span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-0.5">
                            <span class="text-xs font-bold text-slate-900 dark:text-white">@comment.AuthorName</span>
                            <span class="text-[10px] text-slate-400">• @comment.CreatedAt.ToString("MMM dd, HH:mm")</span>
                        </div>
                        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">@comment.Content</p>

                        @if (comment.Attachments.Any())
                        {
                            <div class="mt-2 flex flex-wrap gap-2">
                                @foreach (var attachment in comment.Attachments)
                                {
                                    <a href="@attachment.Url" target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-slate-50 dark:bg-white/5 border border-border-light dark:border-border-dark rounded-lg hover:border-primary transition-all group">
                                        <span class="material-symbols-outlined text-[16px] text-slate-400 group-hover:text-primary">
                                            @(attachment.FileType?.Contains("image") == true ? "image" : "description")
                                        </span>
                                        <span class="text-[10px] font-medium text-slate-600 dark:text-slate-400 group-hover:text-primary truncate max-w-[150px]">
                                            @System.IO.Path.GetFileName(attachment.Url)
                                        </span>
                                    </a>
                                }
                            </div>
                        }
                        
                        <!-- Reply Button -->
                        <button onclick="toggleReplyForm('@comment.Id')" class="text-[10px] font-bold text-primary hover:underline mt-1">Reply</button>
                        
                        <!-- Reply Form (Hidden) -->
                        <div id="reply-form-@comment.Id" class="hidden mt-3">
                            <form asp-action="AddComment" method="post" enctype="multipart/form-data" class="flex flex-col gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="PostId" value="@ViewBag.CurrentPostId" />
                                <input type="hidden" name="CommunityId" value="@Model.Id" />
                                <input type="hidden" name="ReplyToMessageId" value="@comment.Id" />
                                <div class="flex gap-2">
                                    <input type="text" name="Content" class="flex-1 bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl px-4 py-2 text-xs outline-none focus:ring-1 focus:ring-primary transition-all text-slate-900 dark:text-white" placeholder="Write a reply..." required />
                                    <button type="submit" class="bg-primary text-white size-8 rounded-xl flex items-center justify-center hover:bg-primary/90 transition-all shrink-0">
                                        <span class="material-symbols-outlined text-[18px]">send</span>
                                    </button>
                                </div>
                                <div class="flex items-center gap-2 overflow-hidden">
                                     <label class="cursor-pointer flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border-light dark:border-border-dark text-[10px] font-bold text-slate-500 hover:bg-slate-50 dark:hover:bg-white/5 transition-all">
                                        <span class="material-symbols-outlined text-[14px]">attach_file</span>
                                        <span>Attach File</span>
                                         <input type="file" name="Attachment" class="hidden" onchange="updateFileName(this)" accept=".pdf,.docx,.jpeg,.jpg,.png" />
                                    </label>
                                    <span class="file-name text-[10px] text-slate-400 truncate"></span>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                @{ await RenderComments(allComments, comment.Id, depth + 1); }
            </div>
        }
    }
}

<div class="p-8 flex flex-col gap-8 pb-20">
     <div class="rounded-2xl p-5 shadow-sm flex flex-col md:flex-row md:items-center gap-4">

        <!-- Icon / Image -->
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="size-14 rounded-2xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
                <img src="@Model.ImageUrl" class="w-full h-full object-cover" alt="@Model.Name" />
            </div>
        }
        else
        {
            <div class="size-14 rounded-2xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-2xl">groups</span>
            </div>
        }

        <!-- Main Info -->
        <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-3">
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white truncate">
                    @Model.Name
                </h1>


            </div>

            <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-1 mt-1">
                @Model.Description
            </p>

            <div class="flex items-center gap-4 mt-2 text-xs text-slate-400">
                <span>@Model.PostCount posts</span>
                <span>•</span>
                <span>@Model.CreatedAt.ToString("MMM yyyy")</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-2">

            <a asp-action="CreatePost"
               asp-route-communityId="@Model.Id"
               class="flex items-center gap-2 px-4 py-2 rounded-lg border border-border-light dark:border-border-dark text-sm font-semibold hover:bg-slate-50 dark:hover:bg-white/10 transition-all">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Post
            </a>

            <a asp-controller="Explore"
               asp-action="Index"
               class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 hover:text-primary transition-colors">
                <span class="material-symbols-outlined text-[20px]">settings</span>
            </a>

        </div>
    </div>
    <!-- Posts Section -->
    <div class="flex flex-col gap-6">
        <div class="flex items-center justify-between border-b border-border-light dark:border-border-dark pb-4">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Recent Posts</h2>
         
        </div>

        @if (!posts.Any())
        {
            <div class="text-center py-20 bg-surface-light dark:bg-surface-dark rounded-3xl border border-dashed border-border-light dark:border-border-dark">
                <span class="material-symbols-outlined text-6xl text-slate-300 dark:text-slate-700 mb-4">post_add</span>
                <p class="text-slate-500 dark:text-slate-400 font-medium text-lg">No posts yet in this community.</p>
                <p class="text-slate-400 dark:text-slate-500 text-sm mt-1">Be the first to share something!</p>
                <a asp-action="CreatePost" asp-route-communityId="@Model.Id" class="mt-6 inline-flex items-center gap-2 px-6 py-2.5 border border-border-light dark:border-border-dark text-slate-700 dark:text-slate-300 rounded-xl font-bold hover:bg-slate-50 dark:hover:bg-surface-dark transition-all">
                    Start a Discussion
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6">
                @foreach (var post in posts)
                {
                    <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all shadow-sm group">
                        <div class="flex gap-4 items-start translate-y-0.5">
                            <div class="size-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-[20px]">person</span>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-slate-900 dark:text-white">@post.AuthorName</span>
                                    <span class="text-xs text-slate-400">• @post.CreatedAt.ToString("MMM dd")</span>
                                    @if (post.IsSolved)
                                    {
                                        <span class="px-2 py-0.5 rounded bg-green-500/10 text-green-500 text-[10px] font-bold uppercase border border-green-500/20">Solved</span>
                                    }
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 transition-colors">@post.Title</h3>
                                <p class="text-slate-600 dark:text-slate-400 line-clamp-2 text-sm leading-relaxed mb-4">@post.Content</p>
                                
                                @if (post.Attachments.Any())
                                {
                                    <div class="mb-4 flex flex-wrap gap-2">
                                        @foreach (var attachment in post.Attachments)
                                        {
                                            <a href="@attachment.Url" target="_blank" class="flex items-center gap-2 px-3 py-1.5 bg-slate-50 dark:bg-white/5 border border-border-light dark:border-border-dark rounded-xl hover:border-primary transition-all group">
                                                <span class="material-symbols-outlined text-[18px] text-slate-400 group-hover:text-primary">
                                                    @(attachment.FileType?.Contains("image") == true ? "image" : "description")
                                                </span>
                                                <span class="text-xs font-medium text-slate-600 dark:text-slate-400 group-hover:text-primary truncate max-w-[200px]">
                                                    @System.IO.Path.GetFileName(attachment.Url)
                                                </span>
                                            </a>
                                        }
                                    </div>
                                }
                                
                                <div class="flex flex-col gap-4">
                                    <div class="flex items-center justify-between border-b border-border-light dark:border-border-dark pb-3">
                                        <div class="flex items-center gap-4 text-slate-400 text-xs font-bold">
                                            <div onclick="toggleComments('@post.Id')"
                                                 class="flex items-center gap-1.5 cursor-pointer transition-colors">

                                                <span class="material-symbols-outlined text-[18px] hover:text-primary transition-colors">
                                                    chat_bubble
                                                </span>

                                                <span class="hover:text-primary transition-colors">
                                                    @post.CommentCount Comments
                                                </span>

                                                <div class="size-5 rounded-md bg-primary/10 text-primary
                        flex items-center justify-center
                        transition-all ml-1
                        hover:bg-primary hover:text-white">
                                                    <span class="material-symbols-outlined text-[14px]">
                                                        add
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-1.5">
                                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                                                <span>@post.ViewCount Views</span>
                                            </div>
                                        </div>
                                        
                                        <div class="flex gap-2">
                                            <form asp-action="DeletePost" asp-route-id="@post.Id" asp-route-communityId="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this post?')">
                                                <button type="submit" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 hover:text-red-500 transition-colors">
                                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>

                                    <!-- Inline Comments Tree -->
                                    <div id="comments-@post.Id" class="hidden animate-slide-down">
                                        <div class="bg-slate-50/50 dark:bg-white/5 rounded-2xl p-4 border border-border-light dark:border-white/5">
                                            <!-- Comment Input -->
                                            <form asp-action="AddComment" method="post" enctype="multipart/form-data" class="flex flex-col gap-3 mb-6">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="PostId" value="@post.Id" />
                                                <input type="hidden" name="CommunityId" value="@Model.Id" />
                                                <div class="flex gap-3">
                                                    <div class="size-9 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                                                        <span class="material-symbols-outlined text-sm">person</span>
                                                    </div>
                                                    <div class="flex-1 relative">
                                                        <input type="text" name="Content" class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl px-4 py-2.5 text-sm outline-none focus:ring-1 focus:ring-primary transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="Write a comment..." required />
                                                    </div>
                                                    <button type="submit" class="bg-primary text-white px-4 py-2 rounded-xl font-bold text-sm hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
                                                        Post
                                                    </button>
                                                </div>
                                                <div class="flex items-center gap-2 pl-12 overflow-hidden">
                                                    <label class="cursor-pointer flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border-light dark:border-border-dark text-[10px] font-bold text-slate-500 hover:bg-slate-50 dark:hover:bg-white/5 transition-all">
                                                        <span class="material-symbols-outlined text-[14px]">attach_file</span>
                                                        <span>Attach File</span>
                                                        <input type="file" name="Attachment" class="hidden" onchange="updateFileName(this)" accept=".pdf,.docx,.jpeg,.jpg,.png" />
                                                    </label>
                                                    <span class="file-name text-[10px] text-slate-400 truncate"></span>
                                                </div>
                                            </form>

                                            <!-- Recursive Tree Rendering -->
                                            @{
                                                ViewBag.CurrentPostId = post.Id;
                                                await RenderComments(post.Comments, null);
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function toggleComments(postId) {
        const el = document.getElementById(`comments-${postId}`);
        if (el) {
            el.classList.toggle('hidden');
        }
    }

    function toggleReplyForm(commentId) {
        const el = document.getElementById(`reply-form-${commentId}`);
        if (el) {
            el.classList.toggle('hidden');
            if (!el.classList.contains('hidden')) {
                const input = el.querySelector('input[type="text"]');
                if (input) input.focus();
            }
        }
    }

    function updateFileName(input) {
        const fileName = input.files[0] ? input.files[0].name : '';
        const container = input.closest('form').querySelector('.file-name');
        if (container) {
            container.textContent = fileName;
        }
    }
</script>

<style>
    @@keyframes slide-down {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-down {
        animation: slide-down 0.3s ease-out;
    }
</style>
