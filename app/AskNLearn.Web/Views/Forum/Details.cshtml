@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@using AskNLearn.Application.Features.Posts.Queries.GetPostsByCommunity
@model CommunityDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
    var posts = ViewBag.Posts as List<PostDto> ?? new List<PostDto>();
    var totalPostCount = ViewBag.TotalPostCount as int? ?? 0;
    var pageSize = ViewBag.PageSize as int? ?? 10;
    var hasMore = posts.Count >= pageSize && posts.Count < totalPostCount;
}

<div class="container-fluid py-5" style="max-width: 1000px;">
    <!-- Community Header -->
    <div class="glass-card p-4 p-md-5 mb-5 d-flex flex-column flex-md-row align-items-center gap-4 animate-entrance position-relative overflow-hidden">
        <div class="position-absolute rounded-circle" style="top: -20px; left: -20px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(0,217,245,0.15) 0%, transparent 70%); filter: blur(20px);"></div>

        <!-- Icon / Image -->
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="rounded-xl flex-shrink-0 overflow-hidden position-relative z-1" style="width: 80px; height: 80px; border: 1px solid var(--border-glass);">
                <img src="@Model.ImageUrl" class="w-100 h-100 object-cover" alt="@Model.Name" />
            </div>
        }
        else
        {
            <div class="rounded-xl flex-shrink-0 d-flex align-items-center justify-content-center position-relative z-1" style="width: 80px; height: 80px; background: rgba(0,217,245,0.1); border: 1px solid rgba(0,217,245,0.2);">
                <span class="material-symbols-outlined text-aurora" style="font-size: 2.5rem;">groups</span>
            </div>
        }

        <!-- Main Info -->
        <div class="flex-grow-1 min-w-0 text-center text-md-start position-relative z-1">
            <h1 class="display-6 fw-bold text-white text-truncate mb-2 tracking-tighter">
                @Model.Name
            </h1>
            <p class="text-muted fs-6 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @Model.Description
            </p>
            <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-3 mt-1 text-muted" style="font-size: 0.8rem;">
                <span class="fw-bold">@Model.PostCount posts</span>
                <span>•</span>
                <span>Created @Model.CreatedAt.ToString("MMM yyyy")</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex align-items-center gap-2 position-relative z-1">
            <a asp-controller="Explore" asp-action="Index" class="btn btn-glass p-2 d-flex align-items-center justify-content-center" title="Back">
                <span class="material-symbols-outlined fs-5">arrow_back</span>
            </a>
            @if (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.CreatorId)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-glass p-2 d-flex align-items-center justify-content-center" title="Settings">
                    <span class="material-symbols-outlined fs-5">settings</span>
                </a>
            }
        </div>
    </div>

    <!-- Posts Section -->
    <div class="position-relative">
        <div class="d-flex flex-column gap-4 animate-entrance delay-100">
            <div class="d-flex justify-content-between align-items-center pb-3 mb-2 border-bottom" style="border-color: var(--border-glass) !important;">
                <h2 class="h4 fw-bold text-white mb-0">Recent Discussions</h2>
                @if (totalPostCount > 0)
                {
                    <span class="text-muted" style="font-size: 0.8rem;">@totalPostCount posts total</span>
                }
            </div>
            @if (ViewBag.IsEmailVerified == true)
            {
                if (!posts.Any())
                {
                    <!-- Quick Post Interaction -->
                    <div id="quick-post-container" class="animate-entrance">
                        <div class="glass-card p-4 mb-4" onclick="toggleInlinePost(true)" style="cursor: pointer;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-md rounded-circle bg-glass d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <span class="material-symbols-outlined text-aurora">person</span>
                                </div>
                                <div class="flex-grow-1 bg-white bg-opacity-5 rounded-pill px-4 py-2 text-muted border border-glass hover-bg-glass transition-all" style="font-size: 0.9rem;">
                                    Start a discussion in @Model.Name...
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="no-posts-placeholder" class="glass-card text-center py-5">
                        <span class="material-symbols-outlined display-1 text-muted mb-4 opacity-50">post_add</span>
                        <p class="text-white fw-bold fs-5 mb-1">No posts yet in this community.</p>
                        <p class="text-muted mb-4">Be the first to share something!</p>
                        <button onclick="toggleInlinePost(true)" class="btn btn-premium d-inline-flex align-items-center gap-2 px-4 py-2">
                            Post Now
                        </button>
                    </div>
                }
                else
                {
                    <!-- Modern Inline Post Interaction -->
                    <div id="quick-post-container" class="animate-entrance">
                        <div class="glass-card p-4 mb-4 overflow-hidden position-relative" onclick="toggleInlinePost(true)" style="cursor: pointer;">
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-gradient-aurora opacity-5" style="pointer-events: none;"></div>
                            <div class="d-flex align-items-center gap-3 position-relative z-1">
                                <div class="flex-shrink-0">
                                    <div class="avatar-md rounded-xl bg-premium d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; box-shadow: 0 0 15px rgba(0,245,160,0.3);">
                                        <span class="material-symbols-outlined text-white">edit_square</span>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h4 class="h6 fw-bold text-white mb-1">Share something with the community</h4>
                                    <p class="text-muted small mb-0">What's on your mind? Click here to start a new discussion...</p>
                                </div>
                                <button type="submit" class="btn btn-premium px-5 py-3 rounded-pill fw-bold shadow-lg transition-transform hover-scale d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined">send</span>
                            Create post
                        </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (User.Identity?.IsAuthenticated == true)
            {
                <div class="glass-card p-4 mb-4 text-center animate-entrance">
                    <p class="text-muted mb-0">
                        <span class="material-symbols-outlined align-middle me-2">verified_user</span>
                        Verify your email to start a discussion in this hub.
                    </p>
                </div>
            }

            <!-- Hidden Inline Form -->
            <div id="inline-post-form" class="d-none animate-entrance mb-5">
                <div class="glass-card p-4 p-md-5 shadow-2xl border-aurora position-relative overflow-hidden">
                    <div class="position-absolute top-0 start-0 w-100 h-1 bg-gradient-aurora"></div>
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h3 class="h4 fw-bold text-white mb-1">Create a new post</h3>
                        <button onclick="toggleInlinePost(false)" class="btn btn-glass p-2 rounded-circle">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    
                    <form asp-action="CreatePost" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="CommunityId" value="@Model.Id" />
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-black text-uppercase tracking-widest" style="font-size: 0.6rem;">Discussion Title</label>
                            <input type="text" name="Title" class="form-control form-control-glass py-3 px-4 fw-bold text-white fs-5" placeholder="Give your post a clear, descriptive title..." required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-black text-uppercase tracking-widest" style="font-size: 0.6rem;">Content</label>
                            <textarea name="Content" class="form-control form-control-glass p-4 text-white" rows="6" placeholder="What would you like to discuss? Use markdown for better formatting..." required></textarea>
                        </div>
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-glass p-3 rounded-xl" title="Add Image">
                                    <span class="material-symbols-outlined fs-5">image</span>
                                </button>
                                <button type="button" class="btn btn-glass p-3 rounded-xl" title="Add Link">
                                    <span class="material-symbols-outlined fs-5">link</span>
                                </button>
                            </div>
                            <div class="d-flex gap-3">
                                <button type="button" onclick="toggleInlinePost(false)" class="btn btn-glass px-4 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Cancel</button>
                                <button type="submit" class="btn btn-premium px-5 py-3 fw-bold text-uppercase tracking-widest shadow-lg">Publish Discussion</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Posts Container — AJAX will append here -->
            <div id="posts-container" class="d-flex flex-column gap-4">
                @{
                    var partialVd = new ViewDataDictionary(ViewData);
                    partialVd["CommunityId"] = Model.Id;
                    partialVd["HasMorePosts"] = hasMore;
                    partialVd["CurrentPage"] = 1;
                    partialVd["CurrentUserId"] = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    partialVd["CommunityCreatorId"] = Model.CreatorId;
                }
                @await Html.PartialAsync("_PostListPartial", posts, partialVd)
            </div>

            <!-- Load More Area -->
            <div id="load-more-area" class="@(hasMore ? "" : "d-none") text-center mt-2">
                <button id="load-more-btn" onclick="loadMorePosts()" class="btn btn-glass d-inline-flex align-items-center gap-2 px-5 py-3">
                    <span class="material-symbols-outlined fs-5">expand_more</span>
                    Load More
                </button>
            </div>

            <!-- Sentinel for IntersectionObserver -->
            <div id="scroll-sentinel" style="height: 1px;"></div>
        </div>
        @* Removed Blur Overlay *@
    </div>
</div>

<script>
    // ─── State ─────────────────────────────────────────────────────────────────
    const communityId = '@Model.Id';
    let currentPage = 1;
    let isLoading = false;
    let hasMore = @hasMore.ToString().ToLower();

    // Track which posts have had their comments loaded
    const commentsLoaded = {};
    const commentsOpen = {};

    // ─── CSRF Token Helper ──────────────────────────────────────────────────────
    function getAntiForgeryToken() {
        const input = document.querySelector('input[name="__RequestVerificationToken"]');
        return input ? input.value : '';
    }

    // ─── Load More Posts ────────────────────────────────────────────────────────
    async function loadMorePosts() {
        if (isLoading || !hasMore) return;
        isLoading = true;

        const btn = document.getElementById('load-more-btn');
        if (btn) {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span> Loading...';
            btn.disabled = true;
        }

        try {
            const nextPage = currentPage + 1;
            const response = await fetch(`/Forum/LoadMorePosts?communityId=${communityId}&page=${nextPage}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!response.ok) throw new Error('Network error');

            const html = await response.text();

            // Parse the response to check for more posts
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newCards = doc.querySelectorAll('.post-card-animate');

            if (newCards.length === 0) {
                hasMore = false;
            } else {
                const container = document.getElementById('posts-container');

                // Inject cards with entrance animation
                newCards.forEach(card => {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    container.appendChild(card);
                    requestAnimationFrame(() => {
                        card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    });
                });

                currentPage = nextPage;

                // Check if more remain
                // We infer from whether we got a full page
                if (newCards.length < 10) {
                    hasMore = false;
                }
            }

            const loadMoreArea = document.getElementById('load-more-area');
            if (!hasMore && loadMoreArea) {
                loadMoreArea.classList.add('d-none');
            }

        } catch (err) {
            console.error('loadMorePosts error:', err);
        } finally {
            isLoading = false;
            if (btn && hasMore) {
                btn.innerHTML = '<span class="material-symbols-outlined fs-5">expand_more</span> Load More';
                btn.disabled = false;
            }
        }
    }

    // ─── IntersectionObserver for auto-load ────────────────────────────────────
    (function setupIntersectionObserver() {
        const sentinel = document.getElementById('scroll-sentinel');
        if (!sentinel || !hasMore) return;

        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting && hasMore && !isLoading) {
                loadMorePosts();
            }
        }, { rootMargin: '200px' });

        observer.observe(sentinel);
    })();

    // ─── Lazy Comments ──────────────────────────────────────────────────────────
    async function toggleLazyComments(postId, commId) {
        const container = document.getElementById(`comments-${postId}`);
        if (!container) return;

        const isCurrentlyHidden = container.classList.contains('d-none');
        const toggleIcon = document.querySelector(`.toggle-icon-${postId}`);

        if (!isCurrentlyHidden) {
            // Close
            container.classList.add('d-none');
            if (toggleIcon) toggleIcon.textContent = 'add';
            commentsOpen[postId] = false;
            return;
        }

        // Open
        container.classList.remove('d-none');
        if (toggleIcon) toggleIcon.textContent = 'remove';
        commentsOpen[postId] = true;

        // Load only if not already loaded
        if (!commentsLoaded[postId]) {
            commentsLoaded[postId] = true;
            try {
                const response = await fetch(`/Forum/GetPostComments?postId=${postId}&communityId=${commId}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                if (!response.ok) throw new Error('Error loading comments');
                const html = await response.text();
                container.innerHTML = html;
            } catch (err) {
                console.error('Error loading comments:', err);
                container.innerHTML = '<p class="text-danger p-3 mb-0">Failed to load comments.</p>';
                commentsLoaded[postId] = false; // Allow retry
            }
        }
    }

    // ─── Reply Form Toggle ──────────────────────────────────────────────────────
    function toggleReplyForm(commentId) {
        const el = document.getElementById(`reply-form-${commentId}`);
        if (el) {
            el.classList.toggle('d-none');
            if (!el.classList.contains('d-none')) {
                const input = el.querySelector('input[type="text"]');
                if (input) input.focus();
            }
        }
    }

    // ─── File Name Display ──────────────────────────────────────────────────────
    function updateFileName(input) {
        const fileName = input.files[0] ? input.files[0].name : '';
        const container = input.closest('form').querySelector('.file-name');
        if (container) container.textContent = fileName;
    }

    // ─── Vote Post ──────────────────────────────────────────────────────────────
    function votePost(postId, communityId, value) {
        const upBtn = document.querySelector(`.vote-btn-up-${postId}`);
        const downBtn = document.querySelector(`.vote-btn-down-${postId}`);
        const upIcon = upBtn?.querySelector('.material-symbols-outlined');
        const downIcon = downBtn?.querySelector('.material-symbols-outlined');

        if (upBtn) upBtn.style.pointerEvents = 'none';
        if (downBtn) downBtn.style.pointerEvents = 'none';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        fetch(`/Forum/VotePost?postId=${postId}&communityId=${communityId}&value=${value}`, {
            method: 'POST',
            headers: {
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
                'RequestVerificationToken': token
            }
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                document.querySelectorAll(`.vote-count-${postId}`).forEach(el => {
                    el.textContent = data.voteCount;
                    el.classList.remove('text-mint', 'text-danger', 'text-white');
                    el.classList.add(data.userVote === 1 ? 'text-mint' : data.userVote === -1 ? 'text-danger' : 'text-white');
                });
                document.querySelectorAll(`.vote-btn-up-${postId}`).forEach(el => {
                    el.classList.remove('text-mint', 'text-muted', 'font-weight-bold');
                    const icon = el.querySelector('.material-symbols-outlined');
                    if (icon) { icon.textContent = 'keyboard_arrow_up'; icon.classList.remove('spinning'); }
                    el.classList.add(data.userVote === 1 ? 'text-mint' : 'text-muted');
                    if (data.userVote === 1) el.classList.add('font-weight-bold');
                });
                document.querySelectorAll(`.vote-btn-down-${postId}`).forEach(el => {
                    el.classList.remove('text-danger', 'text-muted', 'font-weight-bold');
                    const icon = el.querySelector('.material-symbols-outlined');
                    if (icon) { icon.textContent = 'keyboard_arrow_down'; icon.classList.remove('spinning'); }
                    el.classList.add(data.userVote === -1 ? 'text-danger' : 'text-muted');
                    if (data.userVote === -1) el.classList.add('font-weight-bold');
                });
            }
        })
        .finally(() => {
            if (upBtn) upBtn.style.pointerEvents = 'auto';
            if (downBtn) downBtn.style.pointerEvents = 'auto';
        });
    }
</script>

<style>
    .blur-content {
        transition: filter 0.8s var(--ease-apple);
    }
    .blur-active {
        filter: blur(12px) saturate(1.5);
        pointer-events: none;
        user-select: none;
    }
    .blur-overlay {
        position: absolute;
        inset: -1rem;
        background: rgba(2, 6, 23, 0.4);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        z-index: 100;
        animation: fade-in 0.8s var(--ease-out-quint);
    }
    @@keyframes fade-in { from { opacity:0; } to { opacity:1; } }
    @@keyframes slide-down {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-down {
        animation: slide-down 0.3s ease-out;
    }
    .hover-text-danger:hover {
        color: #ff6b6b !important;
    }
    .text-mint {
        color: var(--color-mint-bright) !important;
    }
    .post-card-animate {
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
</style>
