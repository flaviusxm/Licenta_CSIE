@using AskNLearn.Application.Features.Communities.Commands.UpdateCommunity
@model UpdateCommunityCommand
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Edit Forum";
}

<div class="p-8 max-w-2xl mx-auto">
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Edit Forum</h2>
        <p class="text-slate-500 dark:text-slate-400">Update your community's settings and information.</p>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-surface-light dark:bg-surface-dark rounded-2xl p-8 border border-border-light dark:border-border-dark shadow-sm flex flex-col gap-6">
        <input type="hidden" asp-for="Id" />
        
        <div class="flex flex-col gap-2">
            <label asp-for="Name" class="text-sm font-bold text-slate-700 dark:text-slate-300">Forum Name</label>
            <input asp-for="Name" class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl py-3 px-4 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white" placeholder="e.g., Advanced Mathematics"/>
            <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex flex-col gap-2">
            <label asp-for="Description" class="text-sm font-bold text-slate-700 dark:text-slate-300">Description</label>
            <textarea asp-for="Description" rows="4" class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl py-3 px-4 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white" placeholder="What is this forum about?"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
        </div>

        <div class="flex flex-col gap-2">
            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Forum Banner / Image</label>
            <div class="relative group">
                <input type="file" asp-for="Image" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="updateFileName(this)" accept="image/*" />
                <div class="w-full bg-white dark:bg-surface-dark border-2 border-dashed border-border-light dark:border-border-dark rounded-xl py-8 px-4 flex flex-col items-center justify-center gap-2 group-hover:border-primary transition-all">
                    <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-2">
                        <span class="material-symbols-outlined">image</span>
                    </div>
                    <p class="text-sm text-slate-700 dark:text-slate-300 font-medium">Click to change forum image</p>
                    <p class="text-xs text-slate-500 dark:text-slate-400">JPG, PNG, WEBP (Landscape recommended)</p>
                </div>
            </div>
            <div id="file-name-display" class="text-xs font-medium text-primary mt-1 hidden"></div>
        </div>


        <div class="flex gap-4 mt-4">
            <button type="submit" class="flex-1 bg-primary text-white py-3 rounded-xl font-bold hover:bg-primary-dark transition-all shadow-lg shadow-primary/20">
                Save Changes
            </button>
            <a asp-controller="Explore" asp-action="Index" class="flex-1 border border-border-light dark:border-border-dark text-slate-700 dark:text-slate-300 py-3 rounded-xl font-bold hover:bg-slate-50 dark:hover:bg-white/10 transition-all text-center">
                Cancel
            </a>
        </div>
    </form>

    <!-- Danger Zone -->
    <div class="mt-12 bg-red-50/50 dark:bg-red-500/5 rounded-2xl border border-red-100 dark:border-red-500/20 p-8 overflow-hidden relative">
        <div class="absolute top-0 right-0 p-4 opacity-5 pointer-events-none">
            <span class="material-symbols-outlined text-red-500 text-6xl">warning</span>
        </div>
        
        <div class="relative z-10">
            <h3 class="text-xl font-bold text-red-600 dark:text-red-400 mb-2">Danger Zone</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Once you delete a forum, there is no going back. Please be certain.</p>
            
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you absolutely sure you want to delete this forum? All posts and comments will be permanently lost.');">
                <button type="submit" class="w-full md:w-auto px-8 py-3 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold transition-all flex items-center justify-center gap-2 group">
                    <span class="material-symbols-outlined text-[20px] group-hover:shake">delete</span>
                    Delete this Forum
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function updateFileName(input) {
        const display = document.getElementById('file-name-display');
        if (input.files && input.files[0]) {
            display.textContent = 'Selected: ' + input.files[0].name;
            display.classList.remove('hidden');
        } else {
            display.classList.add('hidden');
        }
    }
</script>
