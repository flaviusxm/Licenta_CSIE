@{
    ViewData["Title"] = "Email Confirmation";
    Layout = "_AuthLayout";
    bool isSuccess = ViewBag.Status?.Contains("Thank you") ?? false;
}

<div class="text-center animate-entrance">
    <div class="mb-5">
        @if (isSuccess)
        {
            <h1 class="h2 fw-bold text-white mb-2 tracking-tighter">Email Verified!</h1>
            <p class="text-muted fw-medium px-2">@ViewBag.Status</p>
            
            <div class="d-flex flex-column gap-3 mt-5">
                <a href="@Url.Action("SignIn", "Auth")" class="btn btn-premium btn-lg py-3 fw-bold text-uppercase tracking-widest shadow-2xl">
                    Sign In Now
                </a>
            </div>
        }
        else
        {
            <div class="rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center shadow-lg" style="width: 100px; height: 100px; box-shadow: 0 0 40px rgba(255, 69, 58, 0.2); background: linear-gradient(135deg, #FF453A 0%, #dc2626 100%);">
                <span class="material-symbols-outlined text-white fs-1">error</span>
            </div>
            <h1 class="h2 fw-bold text-white mb-2 tracking-tighter">Verification Failed</h1>
            <p class="text-muted fw-medium px-2">@ViewBag.Status</p>

            <div class="d-flex flex-column gap-3 mt-5">
                <a href="@Url.Action("Index", "Home")" class="btn btn-glass btn-lg py-3 fw-bold text-uppercase tracking-widest">
                    Back to Home
                </a>
            </div>
        }
    </div>
</div>
