@using AskNLearn.Application.Features.Auth.Commands.SignIn
@model SignInCommand
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_AuthLayout";
}

<form asp-controller="Auth" asp-action="SignIn" method="post" class="d-flex flex-column gap-4">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger small text-center fw-bold d-none" id="validation-summary"></div>

    <!-- Email -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="Email" class="text-muted small fw-bold" style="font-size: 0.75rem;">Email address</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">mail</span>
            <input asp-for="Email" class="form-control form-control-glass w-100" style="padding-left: 3rem;" />
        </div>
        <span asp-validation-for="Email" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
    </div>

    <!-- Password -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="Password" class="text-muted small fw-bold" style="font-size: 0.75rem;">Password</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">lock</span>
            <input asp-for="Password" id="PasswordSignIn" type="password" placeholder="••••••••" class="form-control form-control-glass w-100" style="padding-left: 3rem; padding-right: 3rem;" />
            <button type="button" id="togglePasswordSignIn" class="btn btn-link position-absolute top-50 translate-middle-y text-muted p-0 text-decoration-none" style="right: 1rem;">
                <span class="material-symbols-outlined fs-5">visibility</span>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
    </div>

    <!-- Remember Me -->
    <div class="d-flex align-items-center gap-3 mt-2">
        <div class="premium-checkbox-wrapper">
            <input asp-for="RememberMe" type="checkbox" class="premium-checkbox" id="rememberMeCheck" />
            <label for="rememberMeCheck" class="premium-checkbox-label"></label>
        </div>
        <label for="rememberMeCheck" class="text-muted small fw-bold cursor-pointer" style="font-size: 0.85rem; user-select: none;">
            Remember me on this device
        </label>
    </div>

    <style>
        .premium-checkbox-wrapper {
            position: relative;
            width: 24px;
            height: 24px;
        }
        .premium-checkbox {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }
        .premium-checkbox-label {
            position: absolute;
            top: 0;
            left: 0;
            height: 24px;
            width: 24px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--border-glass);
            border-radius: 6px;
            transition: all 0.2s var(--ease-apple);
            cursor: pointer;
        }
        .premium-checkbox:checked ~ .premium-checkbox-label {
            background: var(--color-accent);
            border-color: var(--color-accent);
        }
        .premium-checkbox-label:after {
            content: "";
            position: absolute;
            display: none;
            left: 8px;
            top: 4px;
            width: 5px;
            height: 10px;
            border: solid white;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg);
        }
        .premium-checkbox:checked ~ .premium-checkbox-label:after {
            display: block;
        }
        .premium-checkbox-wrapper:hover .premium-checkbox-label {
            border-color: var(--color-accent-soft);
            background: rgba(255, 255, 255, 0.1);
        }
    </style>

    <!-- Submit Button -->
    <button type="submit" class="btn btn-premium w-100 mt-3">
        Log In
        <span class="material-symbols-outlined fs-5">arrow_forward</span>
    </button>

    <p class="small text-center text-muted fw-bold mt-3 mb-0" style="font-size: 0.8rem;">
        No account?
        <a asp-controller="Auth" asp-action="SignUp" class="text-accent text-decoration-none ms-1">Register</a>
    </p>
</form>
