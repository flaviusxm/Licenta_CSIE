@using AskNLearn.Application.Features.Auth.Commands.SignUp
@model SignUpCommand
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_AuthLayout";
}

<form asp-controller="Auth" asp-action="SignUp" method="post" class="space-y-6">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs text-center"></div>

    <!-- Full Name -->
    <div class="space-y-1">
        <label asp-for="FullName" class="text-xs text-slate-400 uppercase">Full Name</label>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">badge</span>
            <input asp-for="FullName" placeholder="John Doe"
                   class="w-full py-3 pl-12 pr-4 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-slate-600
                       focus:outline-none focus:border-primary/60 focus:ring-2 focus:ring-primary/20 transition text-sm" />
        </div>
        <span asp-validation-for="FullName" class="text-red-400 text-xs"></span>
    </div>

    <!-- Email -->
    <div class="space-y-1">
        <label asp-for="Email" class="text-xs text-slate-400 uppercase">Email Address</label>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">mail</span>
            <input asp-for="Email" type="email" placeholder="student@education.edu"
                   class="w-full py-3 pl-12 pr-4 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-slate-600
                       focus:outline-none focus:border-primary/60 focus:ring-2 focus:ring-primary/20 transition text-sm" />
        </div>
        <span asp-validation-for="Email" class="text-red-400 text-xs"></span>
    </div>

    <!-- Password -->
    <div class="space-y-1">
        <label asp-for="Password" class="text-xs text-slate-400 uppercase">Password</label>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">lock</span>
            <input asp-for="Password" id="PasswordSignUp" type="password" placeholder="••••••••"
                   class="w-full py-3 pl-12 pr-10 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-slate-600
                       focus:outline-none focus:border-primary/60 focus:ring-2 focus:ring-primary/20 transition text-sm" />
            <button type="button" id="togglePasswordSignUp"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500">
                <span class="material-symbols-outlined">visibility</span>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-red-400 text-xs"></span>
    </div>

    <!-- Password Strength -->
    <div class="mt-1">
        <div class="w-full bg-slate-800 rounded h-1 overflow-hidden">
            <div id="passwordStrengthBar" class="h-1 w-0 bg-red-500 transition-all duration-300"></div>
        </div>
        <p id="passwordStrengthText" class="text-xs text-slate-500 mt-1">Password strength</p>
    </div>

    <!-- Confirm Password -->
    <div class="space-y-1">
        <label asp-for="ConfirmPassword" class="text-xs text-slate-400 uppercase">Confirm Password</label>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">verified_user</span>
            <input asp-for="ConfirmPassword" id="ConfirmPasswordSignUp" type="password" placeholder="••••••••"
                   class="w-full py-3 pl-12 pr-10 bg-white/5 border border-white/10 rounded-xl text-white placeholder:text-slate-600
                       focus:outline-none focus:border-primary/60 focus:ring-2 focus:ring-primary/20 transition text-sm" />
            <button type="button" id="toggleConfirmSignUp"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500">
                <span class="material-symbols-outlined">visibility</span>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs"></span>
        <p id="confirmMatchText" class="text-xs text-slate-500 mt-1"></p>
    </div>

    <!-- Submit Button -->
    <button type="submit"
            class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl bg-primary text-black font-semibold uppercase tracking-wider hover:bg-white transition active:scale-95">
        Create Account
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
    </button>

    <p class="text-xs text-center text-slate-500">
        Already have an account?
        <a asp-controller="Auth" asp-action="SignIn" class="text-primary hover:text-white ml-1">Sign In</a>
    </p>
</form>