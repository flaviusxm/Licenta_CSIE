@using AskNLearn.Application.Features.Auth.Commands.SignUp
@model SignUpCommand
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_AuthLayout";
}

<form asp-controller="Auth" asp-action="SignUp" method="post" class="d-flex flex-column gap-2">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger small text-center fw-bold d-none" id="validation-summary"></div>

    <!-- Full Name -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="FullName" class="text-muted small fw-bold" style="font-size: 0.75rem;">Full name</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">badge</span>
            <input asp-for="FullName" placeholder="John Doe" class="form-control form-control-glass w-100" style="padding-left: 3rem;" />
        </div>
        <span asp-validation-for="FullName" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
    </div>

    <!-- Email -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="Email" class="text-muted small fw-bold" style="font-size: 0.75rem;">Email address</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">mail</span>
            <input asp-for="Email" type="email" placeholder="student@education.edu" class="form-control form-control-glass w-100" style="padding-left: 3rem;" />
        </div>
        <span asp-validation-for="Email" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
    </div>

    <!-- Password -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="Password" class="text-muted small fw-bold" style="font-size: 0.75rem;">Password</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">lock</span>
            <input asp-for="Password" id="PasswordSignUp" type="password" placeholder="••••••••" class="form-control form-control-glass w-100" style="padding-left: 3rem; padding-right: 3rem;" />
            <button type="button" id="togglePasswordSignUp" class="btn btn-link position-absolute top-50 translate-middle-y text-muted p-0 text-decoration-none" style="right: 1rem;">
                <span class="material-symbols-outlined fs-5">visibility</span>
            </button>
        </div>
        <span asp-validation-for="Password" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
    </div>

    <!-- Password Strength -->
    <div class="mt-1">
        <div class="progress" style="height: 4px; background: rgba(255,255,255,0.1);">
            <div id="passwordStrengthBar" class="progress-bar bg-danger transition-all" role="progressbar" style="width: 0%;"></div>
        </div>
        <p id="passwordStrengthText" class="text-muted small fw-bold mt-1 mb-0" style="font-size: 0.7rem;">Password strength</p>
    </div>

    <!-- Confirm Password -->
    <div class="d-flex flex-column gap-1">
        <label asp-for="ConfirmPassword" class="text-muted small fw-bold" style="font-size: 0.75rem;">Confirm password</label>
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1rem;">verified_user</span>
            <input asp-for="ConfirmPassword" id="ConfirmPasswordSignUp" type="password" placeholder="••••••••" class="form-control form-control-glass w-100" style="padding-left: 3rem; padding-right: 3rem;" />
            <button type="button" id="toggleConfirmSignUp" class="btn btn-link position-absolute top-50 translate-middle-y text-muted p-0 text-decoration-none" style="right: 1rem;">
                <span class="material-symbols-outlined fs-5">visibility</span>
            </button>
        </div>
        <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold mt-1" style="font-size: 0.75rem;"></span>
        <p id="confirmMatchText" class="text-muted small fw-bold mt-1 mb-0" style="font-size: 0.7rem;"></p>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn btn-premium w-100 mt-3">
        Create Account
        <span class="material-symbols-outlined fs-5">arrow_forward</span>
    </button>

    <p class="small text-center text-muted fw-bold mt-3 mb-0" style="font-size: 0.8rem;">
        Already have an account?
        <a asp-controller="Auth" asp-action="SignIn" class="text-accent text-decoration-none ms-1">Sign In</a>
    </p>
</form>
