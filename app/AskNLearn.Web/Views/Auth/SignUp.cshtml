@model AskNLearn.Application.Features.Auth.Commands.SignUp.SignUpCommand
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AskNLearn - Sign Up</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
            extend: {
                colors: {
                "primary": "#13c8ec",
                "background-light": "#f6f8f8",
                "background-dark": "#101f22",
                "surface-dark": "#192f33",
                "surface-light": "#ffffff",
                "border-dark": "#234248",
                "border-light": "#e2e8f0",
                },
                fontFamily: {
                "display": ["Lexend", "sans-serif"]
                },
                borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px"},
            },
            },
        }
    </script>
    <style type="text/tailwindcss">
        .glass-card {
             @@apply bg-surface-dark border border-border-dark shadow-2xl;
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center relative overflow-hidden bg-background-dark text-white font-display">

    <!-- Background Glow -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
         <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]"></div>
    </div>

    <main class="relative z-10 w-full max-w-lg px-4 py-12">
        <div class="glass-card rounded-2xl p-8 md:p-12">

            <!-- Header -->
            <div class="text-center mb-10">
                <h1 class="text-3xl font-bold text-white tracking-tight">
                    Create your account
                </h1>
                <p class="text-slate-400 mt-2">
                    Join the AskNLearn student community
                </p>
            </div>

            <!-- FORM -->
            <form asp-controller="Auth"
                  asp-action="SignUp"
                  method="post"
                  class="flex flex-col gap-6">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-red-500 text-sm"></div>

                <!-- Full Name -->
                <div>
                    <label asp-for="FullName"
                           class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"></label>

                    <input asp-for="FullName"
                           class="w-full py-3 px-4 text-sm text-white bg-background-dark border border-border-dark rounded-xl focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                           placeholder="John Doe" />

                    <span asp-validation-for="FullName"
                          class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <!-- Email -->
                <div>
                    <label asp-for="Email"
                           class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"></label>

                    <input asp-for="Email"
                           type="email"
                           class="w-full py-3 px-4 text-sm text-white bg-background-dark border border-border-dark rounded-xl focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                           placeholder="student@university.edu" />

                    <span asp-validation-for="Email"
                          class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password"
                           class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"></label>

                    <input asp-for="Password"
                           type="password"
                           class="w-full py-3 px-4 text-sm text-white bg-background-dark border border-border-dark rounded-xl focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                           placeholder="••••••••" />

                    <span asp-validation-for="Password"
                          class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <!-- Confirm Password -->
                <div>
                    <label asp-for="ConfirmPassword"
                           class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"></label>

                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="w-full py-3 px-4 text-sm text-white bg-background-dark border border-border-dark rounded-xl focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary"
                           placeholder="••••••••" />

                    <span asp-validation-for="ConfirmPassword"
                          class="text-red-500 text-sm mt-1 block"></span>
                </div>

                <!-- Submit -->
                <button type="submit"
                        class="inline-flex items-center justify-center px-8 py-4 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold transition-all text-slate-700 dark:text-white">
                    Create Account
                    <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 transition-transform">login</span>
                </button>

            </form>

            <!-- Footer -->
            <div class="mt-8 pt-8 border-t border-border-dark text-center text-sm text-slate-400">
                Already have an account?
                <a href="@Url.Action("SignIn", "Auth")"
                   class="text-primary hover:text-white font-semibold ml-1 transition-colors">
                    Sign In
                </a>
            </div>

        </div>
    </main>

    <!-- Client Validation Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
