@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Reset Password";
}

<div class="vh-100 d-flex align-items-center justify-content-center dark-mesh-bg">
    <div class="glass-card p-5 animate-entrance" style="max-width: 450px; width: 100%; border-radius: 2.5rem;">
        <div class="text-center mb-5">
            <div class="avatar-lg bg-accent-soft text-accent rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 70px; height: 70px;">
                <span class="material-symbols-outlined fs-1">key</span>
            </div>
            <h1 class="display-6 fw-black text-white text-uppercase tracking-tighter m-0">Set New Password</h1>
            <p class="text-muted small mt-2">Enter your new secure password below.</p>
        </div>

        <form asp-action="ResetPassword" method="post" class="d-flex flex-column gap-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="d-flex flex-column gap-2">
                <label class="text-white text-uppercase tracking-widest fw-bold" style="font-size: 0.7rem;">New Password</label>
                <input type="password" name="newPassword" class="form-control form-control-glass py-3 px-4 rounded-4" placeholder="••••••••" required minlength="6" />
            </div>

            <div asp-validation-summary="All" class="text-danger small fw-bold"></div>

            <button type="submit" class="btn btn-accent py-3 fw-bold text-uppercase tracking-widest shadow-lg mt-2" style="border-radius: 1.25rem;">
                Update Password
            </button>
        </form>
    </div>
</div>
