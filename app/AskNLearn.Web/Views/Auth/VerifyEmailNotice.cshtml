@{
    ViewData["Title"] = "Verify Your Email";
    Layout = "_AuthLayout";
}

<div class="text-center animate-entrance">
    <div class="mb-5">
        <h1 class="h2 fw-bold text-white mb-2 tracking-tighter">Check your inbox</h1>
        <p class="text-muted fw-medium px-2">We've sent a verification link to your email address. Please click the link to activate your account.</p>
    </div>

    <div class="bg-black-alpha-20 mb-5 p-4 border-glass rounded-xl text-start">
        <div class="d-flex align-items-start gap-3">
            <span class="material-symbols-outlined text-accent">info</span>
            <p class="text-muted small m-0 fw-medium">Can't find the email? Check your <strong>spam or junk</strong> folder. It usually arrives within a minute.</p>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        <a href="@Url.Action("SignIn", "Auth")" class="btn btn-premium btn-lg py-3 fw-bold text-uppercase tracking-widest no-hover-effect">
            Back to Sign In
        </a>
        <p class="text-muted small mt-2">
            Need help? <a href="#" class="text-accent fw-bold text-decoration-none">Contact Support</a>
        </p>
    </div>
</div>

<style>
    .bg-black-alpha-20 { background: rgba(0, 0, 0, 0.2); }
    .no-hover-effect:hover {
        transform: none !important;
        box-shadow: 0 4px 15px rgba(0, 122, 255, 0.15) !important;
        background: var(--color-accent) !important;
    }
</style>
