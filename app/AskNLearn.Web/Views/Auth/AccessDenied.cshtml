@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Access Denied";
}

<div class="text-center animate-entrance p-4">
    <div class="mb-5">
        
        <h1 class="h2 fw-bold text-white mb-2 tracking-tighter">Access Denied</h1>
        
        <div class="d-flex items-center gap-3 justify-content-center mb-4">
            <div style="height: 1px; width: 30px; background: rgba(255, 69, 58, 0.3);"></div>
            <p class="text-danger fw-bold uppercase tracking-widest mb-0" style="font-size: 0.6rem;">Security Restriction</p>
            <div style="height: 1px; width: 30px; background: rgba(255, 69, 58, 0.3);"></div>
        </div>

        <p class="text-muted fw-medium px-4 mb-5" style="font-size: 0.9rem; line-height: 1.5;">
            You do not have the necessary permissions to access this area of the application. 
            Please contact a System Administrator if you believe this is an error.
        </p>

        <div class="d-flex flex-column gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-premium btn-lg py-3 fw-bold text-uppercase tracking-widest shadow-2xl">
                Return Home
            </a>
            <button onclick="history.back()" class="btn btn-glass btn-lg py-3 fw-bold text-uppercase tracking-widest text-muted">
                Go Back
            </button>
        </div>
    </div>
</div>

<style>
    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up {
        animation: slide-up 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
    .animate-pulse-slow {
        animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 0.1; }
        50% { opacity: 0.2; }
    }
</style>
