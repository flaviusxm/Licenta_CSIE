@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "AskNLearn: Access Denied";
}

<div class="flex flex-col items-center justify-center min-h-[70vh] text-center p-12 relative overflow-hidden animate-slide-up">
    <!-- Abstract Background Warning -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 size-[600px] bg-red-500/5 rounded-full blur-[120px] -z-10 animate-pulse-slow"></div>

    <div class="relative group mb-10">
        <div class="absolute inset-0 bg-red-500/20 rounded-[2.5rem] blur-[60px] animate-pulse"></div>
        <div class="size-32 rounded-[2.5rem] glass border border-red-500/20 flex items-center justify-center text-red-500 relative z-10 shadow-2xl group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-6xl font-bold">lock_open</span>
        </div>
    </div>

    <h2 class="text-5xl font-bold text-white tracking-tighter mb-4 leading-none animate-slide-up">
        Access <span class="text-red-500">Denied</span>
    </h2>
    
    <div class="flex items-center gap-3 justify-center mb-8 animate-slide-up [animation-delay:100ms]">
        <div class="h-px w-8 bg-red-500/30"></div>
        <p class="text-[10px] font-bold text-red-500 uppercase tracking-[0.4em] leading-none">Security Restriction</p>
        <div class="h-px w-8 bg-red-500/30"></div>
    </div>

    <p class="text-slate-400 max-w-lg mb-12 font-medium animate-slide-up [animation-delay:200ms]">
        You do not have the necessary permissions to access this area of the application. Please contact a System Administrator if you believe this is an error.
    </p>

    <div class="flex items-center gap-4 animate-slide-up [animation-delay:300ms]">
        <a asp-controller="Home" asp-action="Index" class="px-10 py-4 rounded-2xl bg-white text-background-dark text-xs font-bold shadow-2xl hover:bg-primary transition-all uppercase tracking-widest hover:scale-105 active:scale-95">
            Return Home
        </a>
        <button onclick="history.back()" class="px-10 py-4 rounded-2xl glass border border-white/10 text-xs font-bold text-slate-400 hover:text-white transition-all uppercase tracking-widest hover:scale-105 active:scale-95">
            Go Back
        </button>
    </div>
</div>

<style>
    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up {
        animation: slide-up 1s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
    .animate-pulse-slow {
        animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 0.1; }
        50% { opacity: 0.2; }
    }
</style>
