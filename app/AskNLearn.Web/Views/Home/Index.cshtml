@{
    Layout = "_DashboardLayout";
    ViewData["ActivePage"] = "Home";
    ViewData["Title"] = "Home";
}

<div class="container py-4" style="max-width:900px;">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-4 mb-4 fw-bold shadow-sm" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;" role="alert">
            <span class="material-symbols-outlined">error</span>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <div id="feed-content" class="d-flex flex-column gap-4 transition-all" style="animation: slide-up-fade 0.5s ease-out;">
        @if (User.Identity?.IsAuthenticated == true)
        {
        }
        else
        {
            <!-- Hero Card (Guest) -->
             <div class="glass-card p-4 p-md-5 text-center text-md-start position-relative overflow-hidden mb-2">
                <div class="position-absolute top-0 end-0 h-100 w-50 d-none d-md-block" style="background: radial-gradient(ellipse at right, rgba(52, 211, 153, 0.1), transparent); pointer-events: none;"></div>
                <div class="position-relative z-1 col-md-8">
                    <h1 class="display-5 fw-bold text-white mb-3" style="letter-spacing: -0.03em; line-height: 1.1;">
                        Master your studies with <span class="text-aurora">AskNLearn</span>
                    </h1>
                    <p class="fs-5 text-muted mb-4 opacity-75">
                        Join thousands of students collaborating in live study rooms, sharing resources, and helping each other succeed.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-md-start">
                        <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium px-4 py-3 shadow-lg">Get Started Free</a>
                        <a asp-controller="Auth" asp-action="SignIn" class="btn btn-glass px-4 py-3">Log In</a>
                    </div>
                </div>
            </div>
        }

        <!-- Personalized Filter Indicator -->
        <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom border-glass" style="border-width: 0.5px !important;">
            <div class="d-flex align-items-center gap-3">
                <!-- Sort Dropdown -->
                <div class="dropdown">
                    <button class="btn btn-link p-0 text-muted text-decoration-none d-flex align-items-center gap-1 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <span class="material-symbols-outlined fs-5">sort</span>
                        <span id="current-sort-label" class="small fw-bold">@(ViewBag.SortBy == "TopRated" ? "Top Rated" : "Latest Activity")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark glass-card border-glass overflow-hidden shadow-lg">
                        <li><a class="dropdown-item py-2 fw-bold @(ViewBag.SortBy == "Latest" ? "active" : "")" href="javascript:void(0)" onclick="changeFeedSort('Latest', 'Latest Activity')">Latest Activity</a></li>
                        <li><a class="dropdown-item py-2 fw-bold @(ViewBag.SortBy == "TopRated" ? "active" : "")" href="javascript:void(0)" onclick="changeFeedSort('TopRated', 'Top Rated')">Top Rated</a></li>
                    </ul>
                </div>
            </div>
            
            <a asp-controller="Profile" asp-action="Index" class="btn btn-glass-sm py-1 px-3 d-flex align-items-center gap-2 border-0" style="background: rgba(255,255,255,0.03);">
                <span class="material-symbols-outlined fs-6 opacity-50">tune</span>
                <span class="text-muted small fw-bold">Adjust Interests</span>
            </a>
        </div>
        
        <!-- Feed Content -->
        <div id="feed-container" class="d-flex flex-column gap-4 pb-0">
            @await Html.PartialAsync("_PostCards", ViewBag.RecentPosts as List<app_licenta.Controllers.HomeFeedPostDto>)
        </div>

        <!-- Loading Spinner -->
        <div id="feed-load-spinner" class="d-none text-center py-5">
            <div class="spinner-border text-aurora" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Sentinel -->
        <div id="feed-sentinel" class="py-2"></div>
    </div> 
</div>

@section Scripts {
    <script>
        // --- Infinite Scroll Logic (Home) ---
        let feedSkip = 10;
        let feedLoading = false;
        let feedAllLoaded = false;
        let currentSort = '@(ViewBag.SortBy ?? "Latest")';
        
        const feedSentinel = document.getElementById('feed-sentinel');
        const feedContainer = document.getElementById('feed-container');
        const feedSpinner = document.getElementById('feed-load-spinner');

        const feedObserver = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting && !feedLoading && !feedAllLoaded) {
                await loadMorePosts();
            }
        }, { threshold: 0.1 });

        if (feedSentinel) {
            feedObserver.observe(feedSentinel);
        }

        async function loadMorePosts() {
            feedLoading = true;
            feedSpinner.classList.remove('d-none');

            try {
                const response = await fetch(`/Home/GetFeed?skip=${feedSkip}&sortBy=${currentSort}`);
                if (response.ok) {
                    const html = await response.text();
                    
                    if (!html.trim()) {
                        feedAllLoaded = true;
                        feedSpinner.innerHTML = '';                    } else {
                        feedContainer.insertAdjacentHTML('beforeend', html);
                        feedSkip += 10;
                    }
                }
            } catch (error) {
                console.error('Error loading more posts:', error);
            } finally {
                feedLoading = false;
                if (!feedAllLoaded) feedSpinner.classList.add('d-none');
            }
        }

        async function changeFeedSort(sort, label) {
            currentSort = sort;
            document.getElementById('current-sort-label').innerText = label;
            
            // Reset state
            feedSkip = 0;
            feedAllLoaded = false;
            feedContainer.innerHTML = '';
            feedSpinner.classList.remove('d-none');
            feedSpinner.innerHTML = `
                <div class="spinner-border text-aurora" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>`;

            await loadMorePosts();
            
            // Update URL
            window.history.pushState({}, '', `/?sortBy=${sort}`);
            
            // Update active state in dropdown
            document.querySelectorAll('.dropdown-item').forEach(item => {
                item.classList.remove('active');
                if (item.innerText === label) item.classList.add('active');
            });
        }

        // --- Connection Actions Logic (Home) ---
        async function handleConnectionHome(userId, action, btn) {
            const container = btn.closest('div[id^="author-actions-home-"]');
            if (container) {
                container.style.opacity = '0.5';
                container.style.pointerEvents = 'none';
            }
            try {
                const resp = await fetch(`/Connections/${action}?userId=${userId}`, { method: 'POST' });
                if (resp.ok) {
                    if (action === 'SendRequest') {
                        container.innerHTML = `<span class="text-muted opacity-50 d-flex flex-center" title="Request Pending"><span class="material-symbols-outlined" style="font-size: 16px;">hourglass_empty</span></span>`;
                    } else if (action === 'AcceptRequest') {
                        container.innerHTML = `
                            <form action="/Direct/StartChat" method="post" class="m-0 p-0">
                                <input type="hidden" name="userId" value="${userId}" />
                                <button type="submit" class="btn btn-link p-0 text-aurora hover-glow text-decoration-none d-flex flex-center" title="Send Message" style="transition: transform 0.4s var(--ease-snappy);">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">chat</span>
                                </button>
                            </form>`;
                    }
                }
                if (container) {
                    container.style.opacity = '1';
                    container.style.pointerEvents = 'all';
                }
            } catch(e) { console.error(e); }
        }

        // --- Voting Logic (Home) ---
        function votePostHome(postId, communityId, value) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            
            fetch(`/Forum/VotePost?postId=${postId}&communityId=${communityId}&value=${value}`, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': token
                }
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    const countEl = document.querySelector(`.vote-count-${postId}`);
                    if (countEl) {
                        countEl.textContent = data.voteCount;
                        countEl.classList.remove('text-mint', 'text-danger', 'text-white');
                        countEl.classList.add(data.userVote === 1 ? 'text-mint' : data.userVote === -1 ? 'text-danger' : 'text-white');
                    }
                    
                    const upIcon = document.querySelector(`.vote-icon-up-${postId}`);
                    const downIcon = document.querySelector(`.vote-icon-down-${postId}`);
                    
                    if (upIcon) upIcon.style.color = data.userVote === 1 ? 'var(--color-mint-bright)' : '';
                    if (downIcon) downIcon.style.color = data.userVote === -1 ? '#ef4444' : '';
                }
            })
            .catch(e => console.error(e));
        }

        // --- Post Bookmarking Logic ---
        document.querySelectorAll('.bookmark-toggle').forEach(btn => {
            btn.addEventListener('click', function() {
                const icon = this.querySelector('.material-symbols-outlined');
                const isActive = icon.classList.contains('fill-icon');
                
                if (isActive) {
                    icon.classList.remove('fill-icon');
                    icon.style.fontVariationSettings = "'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24";
                    icon.style.color = '';
                    this.style.background = '';
                    this.style.borderColor = '';
                } else {
                    icon.classList.add('fill-icon');
                    icon.style.fontVariationSettings = "'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24";
                    icon.style.color = '#fbbf24';
                    this.style.background = 'rgba(251, 191, 36, 0.1)';
                    this.style.borderColor = 'rgba(251, 191, 36, 0.3)';
                    this.style.transform = 'scale(1.2)';
                    setTimeout(() => this.style.transform = '', 200);
                }
            });
        });

        // --- Lazy Comments (Home) ---
        const commentsLoaded = {};
        const commentsOpen = {};
        async function toggleLazyComments(postId, commId) {
            const container = document.getElementById(`comments-${postId}`);
            if (!container) return;

            const isCurrentlyHidden = container.classList.contains('d-none');
            const toggleIcon = document.querySelector(`.toggle-icon-${postId}`);

            if (!isCurrentlyHidden) {
                container.classList.add('d-none');
                commentsOpen[postId] = false;
                return;
            }

            container.classList.remove('d-none');
            commentsOpen[postId] = true;

            if (!commentsLoaded[postId]) {
                commentsLoaded[postId] = true;
                try {
                    const response = await fetch(`/Forum/GetPostComments?postId=${postId}&communityId=${commId}`, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    if (!response.ok) throw new Error('Error loading comments');
                    const html = await response.text();
                    container.innerHTML = html;
                } catch (err) {
                    console.error('Error loading comments:', err);
                    container.innerHTML = '<p class="text-danger p-3 mb-0">Failed to load comments.</p>';
                    commentsLoaded[postId] = false;
                }
            }
        }
    </script>
    <style>
        @@keyframes slide-down {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-down {
            animation: slide-down 0.3s ease-out;
        }

        /* Hover Card Styles */
        .premium-hover-card {
            position: absolute;
            z-index: 1060;
            width: 280px;
            background: rgba(17, 24, 39, 0.8) !important;
            backdrop-filter: blur(20px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            visibility: hidden;
            opacity: 0;
            transform: translateY(10px) scale(0.95);
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
        }

        .premium-hover-card.active {
            visibility: visible;
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: all;
        }

        .hover-card-trigger:hover {
            color: var(--color-mint-bright) !important;
        }
    </style>
    
    <!-- Hover Card Template -->
    <div id="global-hover-card" class="premium-hover-card rounded-xl overflow-hidden">
        <div id="hover-card-content">
            <!-- Dynamic Content -->
        </div>
    </div>

    <script>
        // --- Hover Card Logic ---
        document.addEventListener('DOMContentLoaded', () => {
            initHoverCards();
        });

        function initHoverCards() {
            const card = document.getElementById('global-hover-card');
            const triggers = document.querySelectorAll('.hover-card-trigger');
            let hideTimeout;

            triggers.forEach(trigger => {
                trigger.addEventListener('mouseenter', async () => {
                    clearTimeout(hideTimeout);
                    const type = trigger.dataset.hoverType;
                    const id = trigger.dataset.hoverId;
                    
                    // Initial Position
                    const rect = trigger.getBoundingClientRect();
                    card.style.top = `${window.scrollY + rect.bottom + 10}px`;
                    card.style.left = `${rect.left}px`;
                    
                    // Load Content
                    card.querySelector('#hover-card-content').innerHTML = `
                        <div class="p-4 text-center">
                            <div class="spinner-border spinner-border-sm text-aurora"></div>
                        </div>
                    `;
                    card.classList.add('active');

                    try {
                        const url = type === 'user' ? `/Profile/GetHoverCard/${id}` : `/Forum/GetHoverCard/${id}`;
                        const resp = await fetch(url);
                        if (resp.ok) {
                            const html = await resp.text();
                            card.querySelector('#hover-card-content').innerHTML = html;
                        }
                    } catch (e) { console.error(e); }
                });

                trigger.addEventListener('mouseleave', () => {
                    hideTimeout = setTimeout(() => {
                        card.classList.remove('active');
                    }, 300);
                });
            });

            card.addEventListener('mouseenter', () => clearTimeout(hideTimeout));
            card.addEventListener('mouseleave', () => {
                hideTimeout = setTimeout(() => {
                    card.classList.remove('active');
                }, 300);
            });
        }
    </script>
}
