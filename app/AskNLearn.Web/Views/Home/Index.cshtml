@{
    Layout = "_DashboardLayout";
    ViewData["ActivePage"] = "Home";
    ViewData["Title"] = "Home";
}

<div class="container py-4" style="max-width: 900px;">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-4 mb-4 fw-bold shadow-sm" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;" role="alert">
            <span class="material-symbols-outlined">error</span>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <div id="feed-content" class="d-flex flex-column gap-4 transition-all" style="animation: slide-up-fade 0.5s ease-out;">
        @if (User.Identity.IsAuthenticated)
        {
            <!-- Performance Dashboard Header -->
            <div class="glass-card mb-4 overflow-hidden border-0 shadow-lg" style="background: linear-gradient(135deg, rgba(6, 18, 14, 0.8) 0%, rgba(2, 8, 6, 0.9) 100%);">
                <div class="p-4 p-md-5 d-flex flex-column flex-md-row align-items-center justify-content-between gap-4 position-relative">
                    <div class="position-absolute translate-middle-y" style="top: 0; right: 10%; width: 300px; height: 300px; background: var(--gradient-aurora); filter: blur(100px); opacity: 0.1;"></div>
                    <div class="z-1">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="badge bg-aurora-glass text-aurora px-3 py-1 fw-black text-uppercase tracking-widest" style="font-size: 0.6rem;">Academic Performance</span>
                            <span class="text-muted small fw-bold">Active Streak: 5 Days</span>
                        </div>
                        <h2 class="display-6 fw-black text-white mb-2 tracking-tight">Focus & <span class="text-aurora">Flow.</span></h2>
                        <p class="text-muted fw-medium mb-0" style="max-width: 450px;">Your academic journey is accelerating. You have <span class="text-white fw-bold">2 upcoming exams</span> and <span class="text-white fw-bold">3 pending project milestones</span> this week.</p>
                    </div>
                    <div class="d-flex flex-column gap-2 z-1" style="min-width: 200px;">
                        <div class="glass-panel p-3 d-flex align-items-center justify-content-between mb-2" style="background: rgba(255,255,255,0.03);">
                            <div>
                                <p class="text-muted fw-bold m-0" style="font-size: 0.6rem; letter-spacing: 1px;">STUDY SCORE</p>
                                <p class="text-white fw-black m-0 fs-4">840</p>
                            </div>
                            <span class="material-symbols-outlined text-aurora fs-2">trending_up</span>
                        </div>
                        <button class="btn btn-premium w-100 py-2.5 fw-black text-uppercase tracking-widest" style="font-size: 0.7rem;">Analytics Dashboard</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Hero Card (Guest) -->
             <div class="glass-card p-4 p-md-5 text-center text-md-start position-relative overflow-hidden mb-2">
                <div class="position-absolute top-0 end-0 h-100 w-50 d-none d-md-block" style="background: radial-gradient(ellipse at right, rgba(52, 211, 153, 0.1), transparent); pointer-events: none;"></div>
                <div class="position-relative z-1 col-md-8">
                    <h1 class="display-5 fw-bold text-white mb-3" style="letter-spacing: -0.03em; line-height: 1.1;">
                        Master your studies with <span class="text-aurora">AskNLearn</span>
                    </h1>
                    <p class="fs-5 text-muted mb-4 opacity-75">
                        Join thousands of students collaborating in live study rooms, sharing resources, and helping each other succeed.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-md-start">
                        <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium px-4 py-3 shadow-lg">Get Started Free</a>
                        <a asp-controller="Auth" asp-action="SignIn" class="btn btn-glass px-4 py-3">Log In</a>
                    </div>
                </div>
            </div>
        }

        <!-- Personalized Filter Indicator -->
        <div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom border-glass" style="border-width: 0.5px !important;">
            <div class="d-flex align-items-center gap-3">
                <div class="badge rounded-pill px-3 py-1 d-flex align-items-center gap-2" style="background: rgba(52, 211, 153, 0.08); border: 1px solid rgba(52, 211, 153, 0.2);">
                    <span class="material-symbols-outlined text-aurora fs-6">psychology</span>
                    <span class="text-aurora small fw-black tracking-tight text-uppercase" style="font-size: 0.65rem;">TAILORED FOR YOUR FOCUS</span>
                </div>
                <!-- Sort Dropdown -->
                <div class="dropdown">
                    <button class="btn btn-link p-0 text-muted text-decoration-none d-flex align-items-center gap-1 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <span class="material-symbols-outlined fs-5">sort</span>
                        <span class="small fw-bold">Relevance</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark glass-card border-glass overflow-hidden shadow-lg">
                        <li><a class="dropdown-item py-2 fw-bold active" href="#" style="font-size: 0.75rem;">Relevance</a></li>
                        <li><a class="dropdown-item py-2 fw-bold" href="#" style="font-size: 0.75rem;">Latest Activity</a></li>
                        <li><a class="dropdown-item py-2 fw-bold" href="#" style="font-size: 0.75rem;">Top Rated</a></li>
                    </ul>
                </div>
            </div>
            
            <a asp-controller="Profile" asp-action="Index" class="btn btn-glass-sm py-1 px-3 d-flex align-items-center gap-2 border-0" style="background: rgba(255,255,255,0.03);">
                <span class="material-symbols-outlined fs-6 opacity-50">tune</span>
                <span class="text-muted small fw-bold">Adjust Interests</span>
            </a>
        </div>
        
        <!-- Feed Content -->
        <div class="d-flex flex-column gap-4 pb-5">
            <!-- Activity Insight 1 -->
            <article class="glass-card p-4 transition-all hover-glow border-0" style="background: rgba(15, 23, 42, 0.4); border-radius: 1.5rem;">
                <div class="d-flex align-items-start gap-4">
                    <!-- Community Badge / Vertical ID -->
                    <div class="d-flex flex-column align-items-center gap-2" style="width: 50px;">
                        <div class="avatar-md rounded-lg d-flex flex-center text-primary fw-black shadow-lg" style="background: rgba(0,245,160,0.1); color: var(--color-mint-bright) !important; border: 1px solid rgba(0,245,160,0.2);">CS</div>
                        <div class="d-flex flex-column align-items-center py-2 px-1 rounded-pill" style="background: rgba(255,255,255,0.03);">
                             <button class="btn btn-link p-0 text-muted hover-text-white transition-colors"><span class="material-symbols-outlined" style="font-size: 1.25rem;">keyboard_arrow_up</span></button>
                             <span class="text-white fw-black small my-1">42</span>
                             <button class="btn btn-link p-0 text-muted hover-text-danger transition-colors"><span class="material-symbols-outlined" style="font-size: 1.25rem;">keyboard_arrow_down</span></button>
                        </div>
                    </div>
                    
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-aurora fw-bold" style="font-size: 0.75rem;">CS Student Community</span>
                                <span class="text-muted opacity-50 small">•</span>
                                <span class="text-muted small">Posted by SarahDev</span>
                            </div>
                            <span class="text-muted small fw-bold opacity-75">2h ago</span>
                        </div>
                        
                        <h3 class="fs-4 fw-bold text-white mb-3 tracking-tight">Recursive Algorithms: Deep-Dive Collaboration Session</h3>
                        <p class="text-muted mb-4 lh-relaxed" style="font-size: 0.9rem;">
                            Exploring advanced memoization techniques in Java. We're hosting a live peer-review session in 15 minutes to analyze performance bottlenecks in the current assignment modules. All senior contributors welcome.
                        </p>
                        
                        <div class="d-flex align-items-center gap-4">
                            <div class="d-flex align-items-center gap-1 text-muted fw-bold" style="font-size: 0.7rem;">
                                <span class="material-symbols-outlined fs-5">chat_bubble</span>
                                12 Contributions
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted fw-bold" style="font-size: 0.7rem;">
                                <span class="material-symbols-outlined fs-5">visibility</span>
                                2.4k Views
                            </div>
                            <div class="ms-auto d-flex gap-2">
                                <button class="btn btn-glass-sm p-2 d-flex align-items-center justify-content-center bookmark-toggle" title="Bookmark Post">
                                    <span class="material-symbols-outlined fs-5 transition-all">star</span>
                                </button>
                                <button class="btn btn-premium-sm px-4 py-1">Join Session</button>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

            <!-- Activity Insight 2 -->
            <article class="glass-card p-4 transition-all hover-glow border-0" style="background: rgba(15, 23, 42, 0.4); border-radius: 1.5rem;">
                <div class="d-flex align-items-start gap-4">
                    <div class="d-flex flex-column align-items-center gap-2" style="width: 50px;">
                        <div class="avatar-md rounded-lg d-flex flex-center text-success fw-black shadow-lg" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright) !important; border: 1px solid rgba(52, 211, 153, 0.2);">MA</div>
                        <div class="d-flex flex-column align-items-center py-2 px-1 rounded-pill" style="background: rgba(255,255,255,0.03);">
                             <button class="btn btn-link p-0 text-muted hover-text-white transition-colors"><span class="material-symbols-outlined" style="font-size: 1.25rem;">keyboard_arrow_up</span></button>
                             <span class="text-white fw-black small my-1">15</span>
                             <button class="btn btn-link p-0 text-muted hover-text-danger transition-colors"><span class="material-symbols-outlined" style="font-size: 1.25rem;">keyboard_arrow_down</span></button>
                        </div>
                    </div>
                    
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-aurora fw-bold" style="font-size: 0.75rem;">Mathematics & Logic Group</span>
                                <span class="text-muted opacity-50 small">•</span>
                                <span class="text-muted small">Posted by MathWhiz</span>
                            </div>
                            <span class="text-muted small fw-bold opacity-75">5h ago</span>
                        </div>
                        
                        <h3 class="fs-4 fw-bold text-white mb-3 tracking-tight">Advanced Calculus: Integration Techniques Reference</h3>
                        <p class="text-muted mb-4 lh-relaxed" style="font-size: 0.9rem;">
                            The comprehensive PDF resource for integration by parts and trigonometric substitution is now available in the community archives. Categorized under "Exam Prep".
                        </p>
                        
                        <div class="d-flex align-items-center gap-4">
                            <div class="d-flex align-items-center gap-1 text-muted fw-bold" style="font-size: 0.7rem;">
                                <span class="material-symbols-outlined fs-5">description</span>
                                Resource Attached (PDF)
                            </div>
                            <div class="d-flex align-items-center gap-1 text-muted fw-bold" style="font-size: 0.7rem;">
                                <span class="material-symbols-outlined fs-5">chat_bubble</span>
                                8 Contributions
                            </div>
                            <div class="ms-auto d-flex gap-2">
                                <button class="btn btn-glass-sm p-2 d-flex align-items-center justify-content-center bookmark-toggle" title="Bookmark Resource">
                                    <span class="material-symbols-outlined fs-5 transition-all">star</span>
                                </button>
                                <button class="btn btn-premium-sm px-4 py-1">Download Resource</button>
                            </div>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </div> 
</div>

<script>
    // --- Post Bookmarking Logic ---
    document.querySelectorAll('.bookmark-toggle').forEach(btn => {
        btn.addEventListener('click', function() {
            const icon = this.querySelector('.material-symbols-outlined');
            const isActive = icon.classList.contains('fill-icon');
            
            if (isActive) {
                icon.classList.remove('fill-icon');
                icon.style.fontVariationSettings = "'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24";
                icon.style.color = '';
                this.style.background = '';
                this.style.borderColor = '';
            } else {
                icon.classList.add('fill-icon');
                icon.style.fontVariationSettings = "'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24";
                icon.style.color = '#fbbf24';
                this.style.background = 'rgba(251, 191, 36, 0.1)';
                this.style.borderColor = 'rgba(251, 191, 36, 0.3)';
                this.style.transform = 'scale(1.2)';
                setTimeout(() => this.style.transform = '', 200);
            }
        });
    });
</script>
