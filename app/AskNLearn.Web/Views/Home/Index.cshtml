@{
    Layout = "_DashboardLayout";
    ViewData["ActivePage"] = "Home";
    ViewData["Title"] = "Home";
}

<div class="container py-4" style="max-width: 900px;">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-4 mb-4 fw-bold shadow-sm" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;" role="alert">
            <span class="material-symbols-outlined">error</span>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <div id="feed-content" class="d-flex flex-column gap-4 transition-all" style="animation: slide-up-fade 0.5s ease-out;">
        @if (User.Identity.IsAuthenticated)
        {
            <!-- Welcome Card (Authenticated) -->
            <div class="glass-card p-4 p-md-5 position-relative overflow-hidden mb-2">
                <div class="row align-items-center position-relative z-1">
                    <div class="col-md-8 text-center text-md-start mb-4 mb-md-0">
                        <h2 class="fs-3 fw-bold text-white mb-2">Welcome back! 👋</h2>
                        <p class="text-muted mb-4">You're on a <span class="text-aurora fw-bold">5-day study streak</span>. Keep up the momentum!</p>
                        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start">
                            <span class="badge rounded-pill d-flex align-items-center gap-1 px-3 py-2 text-success fw-bold" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); font-size: 0.85rem;">
                                <span class="material-symbols-outlined fs-6">check_circle</span> 3 Tasks Done
                            </span>
                            <span class="badge rounded-pill d-flex align-items-center gap-1 px-3 py-2 text-warning fw-bold" style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); font-size: 0.85rem;">
                                <span class="material-symbols-outlined fs-6">schedule</span> Exam in 2 days
                            </span>
                        </div>
                    </div>
                    <div class="col-md-4 text-center text-md-end">
                        <button class="btn btn-glass w-100 w-md-auto fw-bold px-4 py-2">
                            View Stats
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Hero Card (Guest) -->
             <div class="glass-card p-4 p-md-5 text-center text-md-start position-relative overflow-hidden mb-2">
                <div class="position-absolute top-0 end-0 h-100 w-50 d-none d-md-block" style="background: radial-gradient(ellipse at right, rgba(52, 211, 153, 0.1), transparent); pointer-events: none;"></div>
                <div class="position-relative z-1 col-md-8">
                    <h1 class="display-5 fw-bold text-white mb-3" style="letter-spacing: -0.03em; line-height: 1.1;">
                        Master your studies with <span class="text-aurora">AskNLearn</span>
                    </h1>
                    <p class="fs-5 text-muted mb-4 opacity-75">
                        Join thousands of students collaborating in live study rooms, sharing resources, and helping each other succeed.
                    </p>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-md-start">
                        <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium px-4 py-3 shadow-lg">Get Started Free</a>
                        <a asp-controller="Auth" asp-action="SignIn" class="btn btn-glass px-4 py-3">Log In</a>
                    </div>
                </div>
            </div>
        }

        <!-- Feed Tabs -->
        <div class="sticky-top bg-transparent z-3 pb-2" style="top: 0; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border-glass-strong); margin: 0 -1rem 1rem -1rem; padding: 1rem 1rem 0 1rem;">
            <ul class="nav nav-pills gap-4 border-bottom border-secondary border-opacity-25 pb-0 mb-0 flex-nowrap overflow-auto hide-scrollbar" style="border-bottom: 1px solid var(--border-glass);">
                <li class="nav-item">
                    <a href="#" class="nav-link active bg-transparent text-white fw-bold d-flex align-items-center gap-2 p-0 pb-3 h-100 rounded-0" style="border-bottom: 2px solid var(--color-mint-bright);">
                        <span class="material-symbols-outlined text-aurora">auto_awesome</span>
                        For You
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link bg-transparent text-muted hover-text-white fw-bold d-flex align-items-center gap-2 p-0 pb-3 h-100 rounded-0 border-bottom border-transparent hover-border-white transition-colors">
                        <span class="material-symbols-outlined">trending_up</span>
                        Trending
                    </a>
                </li>
                <li class="nav-item">
                    <a href="#" class="nav-link bg-transparent text-muted hover-text-white fw-bold d-flex align-items-center gap-2 p-0 pb-3 h-100 rounded-0 border-bottom border-transparent hover-border-white transition-colors">
                        <span class="material-symbols-outlined">new_releases</span>
                        New
                    </a>
                </li>
            </ul>
        </div>
        
        <!-- Feed Content -->
        <div class="d-flex flex-column gap-4 pb-5">
            <!-- Example Post 1 -->
            <article class="glass-panel p-4 position-relative hover-glow transition-all" style="border-radius: 1.5rem;">
                <div class="d-flex gap-3">
                    <!-- Voting Column -->
                    <div class="d-flex flex-column align-items-center" style="width: 40px; flex-shrink: 0;">
                        <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none transition-colors"><span class="material-symbols-outlined fs-4">keyboard_arrow_up</span></button>
                        <span class="fw-bold text-white small my-1">42</span>
                        <button class="btn btn-link p-0 text-muted text-hover-danger text-decoration-none transition-colors"><span class="material-symbols-outlined fs-4">keyboard_arrow_down</span></button>
                    </div>
                    
                    <!-- Content Column -->
                    <div class="flex-grow-1 min-vw-0">
                        <div class="d-flex flex-wrap align-items-center gap-2 small text-muted mb-2 fw-semibold">
                            <span class="badge bg-primary text-white rounded-2 px-2 py-1">CS</span>
                            <span class="text-light">Comp Sci 101</span>
                            <span class="opacity-50">•</span>
                            <span>Posted by u/SarahDev</span>
                            <span class="opacity-50">•</span>
                            <span>2h ago</span>
                        </div>
                        
                        <h3 class="fs-5 fw-bold text-white mb-2 text-decoration-none cursor-pointer hover-glow">
                            Late Night Java Coding Session ☕️
                        </h3>
                        <p class="text-muted small mb-3 lh-base">
                            Hey everyone! I'm struggling with the recursion assignment. Starting a study room in 10 mins if anyone wants to join and debug together. Beginners welcome!
                        </p>
                        
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex align-items-center gap-2 p-3 rounded-4 mb-3" style="background: rgba(0,0,0,0.3); border: 1px solid var(--border-glass-strong);">
                                <span class="material-symbols-outlined text-aurora fs-5">lock</span>
                                <span class="fw-bold text-light small">Join to enable live collaboration</span>
                            </div>
                        }
                        
                        <div class="d-flex align-items-center gap-4 mt-3 pt-2">
                            <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none d-flex align-items-center gap-1 small fw-bold transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">chat_bubble</span> 12 Comments
                            </button>
                            <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none d-flex align-items-center gap-1 small fw-bold transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">share</span> Share
                            </button>
                            <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none d-flex align-items-center gap-1 small fw-bold ms-auto transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">bookmark</span> Save
                            </button>
                        </div>
                    </div>
                </div>
            </article>

             <!-- Example Post 2 -->
             <article class="glass-panel p-4 position-relative hover-glow transition-all" style="border-radius: 1.5rem;">
                <div class="d-flex gap-3">
                     <div class="d-flex flex-column align-items-center" style="width: 40px; flex-shrink: 0;">
                        <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none transition-colors"><span class="material-symbols-outlined fs-4">keyboard_arrow_up</span></button>
                        <span class="fw-bold text-white small my-1">15</span>
                        <button class="btn btn-link p-0 text-muted text-hover-danger text-decoration-none transition-colors"><span class="material-symbols-outlined fs-4">keyboard_arrow_down</span></button>
                    </div>
                     <div class="flex-grow-1 min-vw-0">
                         <div class="d-flex flex-wrap align-items-center gap-2 small text-muted mb-2 fw-semibold">
                            <span class="badge bg-success text-white rounded-2 px-2 py-1" style="background: var(--color-mint-deep) !important;">MA</span>
                            <span class="text-light">Calculus II</span>
                            <span class="opacity-50">•</span>
                            <span>Posted by u/MathWhiz</span>
                            <span class="opacity-50">•</span>
                            <span>5h ago</span>
                        </div>
                        <h3 class="fs-5 fw-bold text-white mb-2 text-decoration-none cursor-pointer hover-glow">
                            Integration Techniques Cheat Sheet (PDF) 📚
                        </h3>
                        <p class="text-muted small mb-3 lh-base">
                            Compiled all the major integration formulas and techniques into a single page reference sheet.
                        </p>
                        <div class="d-flex align-items-center gap-4 mt-3 pt-2">
                            <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none d-flex align-items-center gap-1 small fw-bold transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">chat_bubble</span> 8 Comments
                            </button>
                            <button class="btn btn-link p-0 text-muted hover-text-white text-decoration-none d-flex align-items-center gap-1 small fw-bold transition-colors">
                                <span class="material-symbols-outlined" style="font-size: 1.1rem;">share</span> Share
                            </button>
                        </div>
                     </div>
                </div>
             </article>
        </div>
    </div> 
</div>
