@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model List<StudyGroupDto>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Study Groups";
}

<div class="p-8 flex flex-col gap-8 pb-20">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Study Groups</h2>
            <p class="text-slate-500 dark:text-slate-400">Collaborate with peers in dedicated study sessions.</p>
        </div>
        <div class="flex gap-3">
            <a asp-controller="StudyGroups" asp-action="Create" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold transition-all text-slate-700 dark:text-white">
                <span class="material-symbols-outlined">add_circle</span>
                Create New Group
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <form method="get" asp-action="Index" class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input name="searchTerm" class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl py-3 pl-12 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="Search for a study group..." type="text" value="@Context.Request.Query["searchTerm"]"/>
        </div>
    </form>

    <!-- Group List -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        @if (!Model.Any())
        {
            <div class="col-span-full text-center py-20 rounded-2xl">
                <span class="material-symbols-outlined text-6xl text-slate-300 dark:text-slate-700 mb-4">groups</span>
                <p class="text-slate-500">No study groups found. Why not lead one yourself?</p>
            </div>
        }
        else
        {
            @foreach (var group in Model)
            {
                <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all group flex flex-col gap-4 shadow-sm relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-2 h-full bg-primary/20 group-hover:bg-primary transition-colors"></div>
                    
                    <div class="flex justify-between items-start gap-4">
                        <div class="flex items-center gap-4">
                            <div class="size-14 rounded-2xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-2xl">school</span>
                            </div>
                            <div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">
                                    <a asp-controller="StudyGroups" asp-action="Details" asp-route-id="@group.Id">@group.Name</a>
                                </h3>
                                <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded-full uppercase">@group.SubjectArea</span>
                            </div>
                        </div>
                        <div class="flex gap-2">
                             @if (User.Identity.IsAuthenticated && group.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                             {
                                <a asp-action="Edit" asp-route-id="@group.Id" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </a>
                                <form asp-action="Delete" asp-route-id="@group.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this group?')">
                                    <button type="submit" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 hover:text-red-500 transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </form>
                             }
                        </div>
                    </div>

                    <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2 min-h-[40px]">@group.Description</p>

                    <div class="flex items-center justify-between mt-2 pt-4 border-t border-border-light dark:border-border-dark">
                        <div class="flex items-center gap-2">
                            <span class="text-xs text-slate-400">Created @group.CreatedAt.ToString("MMM dd")</span>
                        </div>
                        <a asp-action="Details" asp-route-id="@group.Id" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold transition-all text-slate-700 dark:text-white">
                            Join Now
                            <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>
