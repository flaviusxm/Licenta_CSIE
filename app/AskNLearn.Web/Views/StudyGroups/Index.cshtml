@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model List<StudyGroupDto>
@{
    Layout = "_DashboardLayout";
    ViewData["ActivePage"] = "Groups";
    ViewData["Title"] = "Study Groups";
}

<div class="container py-5 max-w-7xl">
    
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-4 mb-5">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2 tracking-tight">Study Groups</h2>
            <p class="text-muted fs-5 m-0">Collaborate with peers in academic study groups.</p>
        </div>
        <div class="flex-shrink-0">
            <a asp-controller="StudyGroups" asp-action="Create" class="btn btn-premium d-inline-flex align-items-center gap-2 px-4 py-3 shadow-lg justify-content-center">
                <span class="material-symbols-outlined fs-5">add_circle</span>
                New Group
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="mb-5">
        <form method="get" asp-action="Index" class="d-flex flex-column flex-md-row gap-3">
            <div class="position-relative flex-grow-1">
                <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1.5rem;">search</span>
                <input name="searchTerm" class="form-control form-control-glass w-100 h-100 shadow-lg text-uppercase fw-bold tracking-wider fs-6" style="padding: 1rem 1.5rem 1rem 3.5rem; border-radius: 1rem;" placeholder="Search Groups..." type="text" value="@Context.Request.Query["searchTerm"]"/>
            </div>
            <button type="submit" class="btn btn-glass px-5 py-3 text-uppercase fw-bold tracking-wider shadow-lg" style="border-radius: 1rem;">
                Search
            </button>
        </form>
    </div>

    <!-- Group List -->
    <div id="groups-container" class="row g-4">
        @await Html.PartialAsync("_GroupCards", Model)
    </div>

    <!-- Loading Spinner -->
    <div id="groups-load-spinner" class="d-none text-center py-5">
        <div class="spinner-border text-aurora" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-muted mt-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">Synchronizing more groups...</p>
    </div>

    <!-- Sentinel -->
    <div id="groups-sentinel" class="py-2"></div>
</div>

@section Scripts {
    <script>
        let groupsSkip = 8;
        let groupsLoading = false;
        let groupsAllLoaded = false;
        const searchTerm = '@Context.Request.Query["searchTerm"]';
        
        const groupsSentinel = document.getElementById('groups-sentinel');
        const groupsContainer = document.getElementById('groups-container');
        const groupsSpinner = document.getElementById('groups-load-spinner');

        const groupsObserver = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting && !groupsLoading && !groupsAllLoaded) {
                await loadMoreGroups();
            }
        }, { threshold: 0.1 });

        if (groupsSentinel) {
            groupsObserver.observe(groupsSentinel);
        }

        async function loadMoreGroups() {
            groupsLoading = true;
            groupsSpinner.classList.remove('d-none');

            try {
                const url = `/StudyGroups/GetGroups?skip=${groupsSkip}${searchTerm ? '&searchTerm=' + encodeURIComponent(searchTerm) : ''}`;
                const response = await fetch(url);
                if (response.ok) {
                    const html = await response.text();
                    
                    if (!html.trim()) {
                        groupsAllLoaded = true;
                        groupsSpinner.innerHTML = '<p class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">All study groups have been synchronized.</p>';
                    } else {
                        groupsContainer.insertAdjacentHTML('beforeend', html);
                        groupsSkip += 8;
                    }
                }
            } catch (error) {
                console.error('Error loading more groups:', error);
            } finally {
                groupsLoading = false;
                if (!groupsAllLoaded) groupsSpinner.classList.add('d-none');
            }
        }

        window.joinGroup = function(groupId, btn) {
            const container = document.getElementById(`join-container-${groupId}`);
            if (!container || btn.disabled) return;
            
            btn.disabled = true;
            btn.style.opacity = '0.5';
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Joining...';

            fetch(`/StudyGroups/Join/${groupId}`, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(resp => {
                if (resp.ok) {
                    container.innerHTML = `
                        <a href="/StudyGroups/Details/${groupId}" class="btn btn-premium d-flex align-items-center justify-content-center gap-2 fw-bold text-uppercase tracking-wider py-2 px-4 shadow-lg transition-transform hover-scale" style="font-size: 0.7rem; border-radius: 1rem;">
                            Enter Hub
                            <span class="material-symbols-outlined text-aurora" style="font-size: 1rem;">arrow_forward</span>
                        </a>
                    `;
                } else {
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    btn.innerHTML = 'Join <span class="material-symbols-outlined text-aurora" style="font-size: 1rem;">person_add</span>';
                }
            }).catch(err => {
                console.error(err);
                btn.disabled = false;
                btn.style.opacity = '1';
                btn.innerHTML = 'Join <span class="material-symbols-outlined text-aurora" style="font-size: 1rem;">person_add</span>';
            });
        };
    </script>
}
