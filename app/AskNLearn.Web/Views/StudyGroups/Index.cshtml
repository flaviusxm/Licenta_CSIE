@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model List<StudyGroupDto>
@{
    Layout = "_DashboardLayout";
    ViewData["ActivePage"] = "Groups";
    ViewData["Title"] = "Study Groups";
}

<div class="container py-5 max-w-7xl">
    
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-4 mb-5">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2 tracking-tight">Study Groups</h2>
            <p class="text-muted fs-5 m-0">Collaborate with peers in academic study groups.</p>
        </div>
        <div class="flex-shrink-0">
            <a asp-controller="StudyGroups" asp-action="Create" class="btn btn-premium d-inline-flex align-items-center gap-2 px-4 py-3 shadow-lg justify-content-center">
                <span class="material-symbols-outlined fs-5">add_circle</span>
                New Group
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="mb-5">
        <form method="get" asp-action="Index" class="d-flex flex-column flex-md-row gap-3">
            <div class="position-relative flex-grow-1">
                <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1.5rem;">search</span>
                <input name="searchTerm" class="form-control form-control-glass w-100 h-100 shadow-lg text-uppercase fw-bold tracking-wider fs-6" style="padding: 1rem 1.5rem 1rem 3.5rem; border-radius: 1rem;" placeholder="Search Groups..." type="text" value="@Context.Request.Query["searchTerm"]"/>
            </div>
            <button type="submit" class="btn btn-glass px-5 py-3 text-uppercase fw-bold tracking-wider shadow-lg" style="border-radius: 1rem;">
                Search
            </button>
        </form>
    </div>

    <!-- Group List -->
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="glass-card text-center py-5 d-flex flex-column align-items-center justify-content-center shadow-lg" style="min-height: 400px; border-radius: 2rem;">
                    <div class="rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; background: rgba(52, 211, 153, 0.1);">
                        <span class="material-symbols-outlined text-aurora display-4">groups_3</span>
                    </div>
                    <h4 class="fs-2 fw-bold text-white tracking-tight text-uppercase mb-2">No Groups Active</h4>
                    <p class="text-muted fs-5 m-0">Be the first to create a study group.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var group in Model)
            {
                <div class="col-12 col-lg-6">
                    <div class="glass-card h-100 p-4 p-md-5 d-flex flex-column gap-4 position-relative overflow-hidden group transition-all hover-glow shadow-lg border-glass-strong" style="border-radius: 2rem;">
                        <div class="position-absolute top-0 start-0 h-100 transition-colors" style="width: 4px; background: var(--color-mint-deep); opacity: 0.5;"></div>
                        
                        <div class="d-flex justify-content-between align-items-start position-relative z-1 mb-2">
                            <div class="d-flex align-items-center gap-4">
                                <div class="rounded-4 d-flex align-items-center justify-content-center flex-shrink-0 transition-transform hover-scale" style="width: 64px; height: 64px; background: rgba(52, 211, 153, 0.05); border: 1px solid rgba(52, 211, 153, 0.1);">
                                    <span class="material-symbols-outlined text-aurora fs-1">school</span>
                                </div>
                                <div>
                                    <h3 class="fs-4 fw-bold text-white mb-2 tracking-tight transition-colors text-truncate" style="max-width: 250px;">
                                        <a asp-controller="StudyGroups" asp-action="Details" asp-route-id="@group.Id" class="stretched-link text-decoration-none text-white hover-glow">
                                            @group.Name
                                        </a>
                                    </h3>
                                    <span class="badge rounded-pill fw-bold text-uppercase tracking-wider" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2); padding: 0.35rem 0.65rem; font-size: 0.65rem;">
                                        @group.SubjectArea
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex gap-2 position-relative z-3">
                                @if (User.Identity?.IsAuthenticated == true && group.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <a asp-action="Edit" asp-route-id="@group.Id" class="btn btn-sm btn-link d-flex align-items-center justify-content-center text-muted hover-text-white transition-colors" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-radius: 0.75rem;">
                                        <span class="material-symbols-outlined fs-5">edit_note</span>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@group.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this group?')" class="m-0 p-0">
                                        <button type="submit" class="btn btn-sm btn-link d-flex align-items-center justify-content-center text-muted text-hover-danger transition-colors" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-radius: 0.75rem;">
                                            <span class="material-symbols-outlined fs-5">delete_sweep</span>
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <p class="text-muted small m-0 lh-base position-relative z-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px;">
                            @group.Description
                        </p>

                        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between mt-auto pt-4 gap-3 position-relative z-1" style="border-top: 1px solid var(--border-glass);">
                            <div class="d-flex align-items-center gap-3">
                                <div class="d-flex" style="margin-left: 0.5rem;">
                                    @for(int i = 0; i < 3; i++) {
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 32px; height: 32px; background: var(--bg-universe); border: 2px solid var(--border-glass-strong); font-size: 0.7rem; margin-left: -0.5rem; z-index: @(3 - i);">U</div>
                                    }
                                </div>
                                <span class="text-muted fw-bold text-uppercase tracking-wider" style="font-size: 0.7rem;">Active Members</span>
                            </div>
                            <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-glass d-flex align-items-center justify-content-center gap-2 fw-bold text-uppercase tracking-wider py-2 position-relative z-3 shadow-lg" style="font-size: 0.75rem;">
                                Synchronize
                                <span class="material-symbols-outlined text-aurora" style="font-size: 1rem;">bolt</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
