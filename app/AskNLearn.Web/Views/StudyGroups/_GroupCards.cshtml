@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model List<StudyGroupDto>

@if (Model != null)
{
    @foreach (var group in Model)
    {
        <div class="col-12 col-md-6 col-lg-4 animate-entrance">
            <div class="glass-card p-4 d-flex flex-column h-100 gap-3 group transition-all hover-glow border-glass-strong shadow-lg position-relative">
                
                <div class="d-flex justify-content-between align-items-start position-relative z-1">
                    <div class="rounded-4 flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: rgba(52, 211, 153, 0.1); border: 1px solid rgba(52, 211, 153, 0.2);">
                        <span class="material-symbols-outlined fs-1 text-aurora">groups</span>
                    </div>
                    <div class="d-flex gap-2 position-relative z-3">
                        @if (User.Identity?.IsAuthenticated == true && group.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                        {
                            <a asp-action="Edit" asp-route-id="@group.Id" class="btn btn-sm btn-link d-flex align-items-center justify-content-center text-muted hover-text-white transition-colors" style="width: 32px; height: 32px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-radius: 0.5rem;">
                                <span class="material-symbols-outlined fs-6">edit_note</span>
                            </a>
                            <form asp-action="Delete" asp-route-id="@group.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this group?')" class="m-0 p-0">
                                <button type="submit" class="btn btn-sm btn-link d-flex align-items-center justify-content-center text-muted text-hover-danger transition-colors" style="width: 32px; height: 32px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-radius: 0.5rem;">
                                    <span class="material-symbols-outlined fs-6">delete_sweep</span>
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <div class="flex-grow-1 mt-2">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <h3 class="fs-5 fw-bold text-white mb-0 text-truncate transition-colors" style="max-width: 100%;">
                            <a asp-controller="StudyGroups" asp-action="Details" asp-route-id="@group.Id" class="stretched-link text-decoration-none text-white hover-glow">
                                @group.Name
                            </a>
                        </h3>
                    </div>
                    <div class="text-muted small lh-base" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @group.Description
                    </div>
                </div>
                
                <div class="mt-3 pt-3 d-flex align-items-center justify-content-between position-relative z-3" style="border-top: 1px solid var(--border-glass);">
                    <div class="d-flex align-items-center gap-2">
                        <div class="d-flex" style="margin-left: 0.3rem;">
                            @for(int i = 0; i < 3; i++) {
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" style="width: 24px; height: 24px; background: var(--bg-universe); border: 1px solid var(--border-glass); opacity: 0.8; font-size: 0.6rem; margin-left: -0.3rem; z-index: @(3 - i);">U</div>
                            }
                        </div>
                    </div>

                    <div id="join-container-@group.Id">
                        @if (group.IsMember)
                        {
                            <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-premium d-flex align-items-center justify-content-center gap-2 fw-bold text-uppercase tracking-wider py-2 px-3 shadow-lg transition-transform hover-scale" style="font-size: 0.65rem; border-radius: 0.75rem;">
                                Enter <span class="material-symbols-outlined" style="font-size: 0.9rem;">arrow_forward</span>
                            </a>
                        }
                        else
                        {
                            <button onclick="joinGroup('@group.Id', this)" class="btn btn-premium d-flex align-items-center justify-content-center gap-2 fw-bold text-uppercase tracking-wider py-2 px-3 shadow-lg transition-transform hover-scale" style="font-size: 0.65rem; border-radius: 0.75rem;">
                                Join <span class="material-symbols-outlined" style="font-size: 0.9rem;">person_add</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

