@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model StudyGroupDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
}

@section Sidebar {
    <div class="flex flex-col h-full bg-surface-light dark:bg-background-dark border-r border-border-light dark:border-border-dark w-72 shrink-0">
        <div class="p-6 flex-1 overflow-y-auto space-y-8 scrollbar-hide">
            <!-- Text Channels -->
            <div>
                <div class="flex items-center justify-between px-2 mb-4">
                    <h3 class="text-[11px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[2px]">Text Channels</h3>
                    @if (Model.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                    {
                        <button onclick="openCreateChannelModal('@AskNLearn.Domain.Entities.StudyGroup.Type.Text')" class="size-6 flex items-center justify-center rounded-lg hover:bg-primary/10 text-slate-400 hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-lg">add</span>
                        </button>
                    }
                </div>
                <div class="space-y-1">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == ChannelType.Text))
                    {
                        <a href="#" class="group flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary dark:hover:bg-primary/20 dark:hover:text-primary transition-all font-bold text-sm">
                            <span class="text-xl font-bold text-slate-300 dark:text-slate-600 group-hover:text-primary/60 transition-colors">#</span>
                            <span class="truncate">@channel.Name</span>
                        </a>
                    }
                    @if (!Model.Channels.Any(c => c.Type == ChannelType.Text))
                    {
                        <div class="px-4 py-8 text-center rounded-2xl border-2 border-dashed border-border-light dark:border-border-dark/30">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">No text channels</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Voice Channels -->
            <div>
                <div class="flex items-center justify-between px-2 mb-4">
                    <h3 class="text-[11px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[2px]">Voice Channels</h3>
                    @if (Model.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                    {
                        <button onclick="openCreateChannelModal('@AskNLearn.Domain.Entities.StudyGroup.Type.Voice')" class="size-6 flex items-center justify-center rounded-lg hover:bg-primary/10 text-slate-400 hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-lg">add</span>
                        </button>
                    }
                </div>
                <div class="space-y-1" id="voiceChannelList">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == ChannelType.Voice))
                    {
                        <div class="group/voice">
                            <button onclick="joinVoice('@channel.Id', '@channel.Name')" 
                                    class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-primary/10 hover:text-primary dark:hover:bg-primary/20 dark:hover:text-primary transition-all font-bold text-sm">
                                <span class="material-symbols-outlined text-lg opacity-40 group-hover/voice:opacity-100 transition-opacity">volume_up</span>
                                <span class="truncate">@channel.Name</span>
                            </button>
                            <!-- Connected Users List for this channel -->
                            <div id="users-@channel.Id" class="hidden pl-9 pr-2 py-1 flex flex-col gap-1 animating-pulse">
                                <div class="flex items-center gap-2 group/user cursor-pointer">
                                    <div class="relative">
                                        <div id="voiceAvatar" class="size-5 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center text-[8px] text-primary font-black transition-all">
                                            @User.Identity.Name?[0]
                                        </div>
                                        <div class="absolute -bottom-0.5 -right-0.5 size-2 bg-emerald-500 rounded-full border border-white dark:border-[#1a1c1e]"></div>
                                    </div>
                                    <span class="text-[11px] font-bold text-slate-500 dark:text-slate-300 group-hover/user:text-primary transition-colors">@User.Identity.Name</span>
                                    <div class="ml-auto flex items-center gap-1">
                                        <span id="micOffIcon" class="material-symbols-outlined text-[10px] text-red-500 hidden">mic_off</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!Model.Channels.Any(c => c.Type == ChannelType.Voice))
                    {
                        <div class="px-4 py-8 text-center rounded-2xl border-2 border-dashed border-border-light dark:border-border-dark/30">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">No voice channels</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Footer & Voice Status -->
        <div class="mt-auto border-t border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-black/20">
            <!-- Voice Status Panel (Visible when connected) -->
            <div id="voiceStatusPanel" class="hidden animate-in slide-in-from-bottom-2 duration-300">
                <div class="p-4 flex items-center justify-between border-b border-border-light/50 dark:border-white/5">
                    <div class="flex flex-col gap-0.5">
                        <div class="flex items-center gap-1.5">
                             <span class="material-symbols-outlined text-emerald-500 text-sm font-black animate-pulse">wifi</span>
                            <span class="text-[10px] font-black text-emerald-500 uppercase tracking-widest">Voice Connected</span>
                        </div>
                        <p id="connectedChannelName" class="text-xs font-black text-slate-900 dark:text-white truncate max-w-[120px]">Channel Name</p>
                    </div>
                    <div class="flex items-center gap-1">
                        <button onclick="leaveVoice()" class="size-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-red-500/10 hover:text-red-500 transition-all group" title="Disconnect">
                            <span class="material-symbols-outlined text-xl">call_end</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Profile & Group Settings -->
            <div class="p-3 flex items-center justify-between">
                <div class="flex items-center gap-2 px-2 py-1 rounded-xl hover:bg-black/5 dark:hover:bg-white/5 transition-colors cursor-pointer group flex-1">
                    <div class="relative">
                        <div class="size-8 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center text-primary font-black text-[10px]">
                             @User.Identity.Name?[0]
                        </div>
                        <div class="absolute -bottom-0.5 -right-0.5 size-3 bg-emerald-500 border-2 border-white dark:border-[#1a1c1e] rounded-full"></div>
                    </div>
                    <div class="flex-1 min-w-0">
                         <p class="text-[11px] font-black text-slate-900 dark:text-white truncate">@User.Identity.Name</p>
                         <p class="text-[9px] font-bold text-slate-500 uppercase tracking-tighter">Online</p>
                    </div>
                </div>
                <div class="flex items-center gap-1">
                     <button onclick="toggleMic()" id="micButton" class="size-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-primary/10 hover:text-primary transition-all" title="Toggle Microphone">
                        <span id="micIcon" class="material-symbols-outlined text-lg">mic</span>
                    </button>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="size-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-primary/10 hover:text-primary transition-all" title="Group Settings">
                        <span class="material-symbols-outlined text-lg">settings</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .voice-talking {
        box-shadow: 0 0 0 2px #13c8ec;
        animation: voice-pulse 1.5s infinite;
    }

    @@keyframes voice-pulse {
        0% { box-shadow: 0 0 0 0px rgba(19, 200, 236, 0.4); }
        70% { box-shadow: 0 0 0 6px rgba(19, 200, 236, 0); }
        100% { box-shadow: 0 0 0 0px rgba(19, 200, 236, 0); }
    }
</style>

<div class="flex flex-col h-full bg-background-light dark:bg-background-dark overflow-hidden">
    <!-- Main Content Area -->
    <div class="flex-1 flex overflow-hidden w-full">
        <!-- Center Feed (Restored Symmetry) -->
        <main class="flex-1 flex flex-col bg-background-light dark:bg-background-dark min-w-0 relative">
            <div class="flex-1 overflow-y-auto p-10 scroll-smooth scrollbar-hide">
                <div class="max-w-3xl mx-auto space-y-12">
                    <!-- Welcome Section -->
                    <section class="py-16 text-center">
                        <div class="size-28 flex items-center justify-center mx-auto mb-8 relative">
                           <div class="absolute inset-0 bg-primary/10 blur-3xl rounded-full"></div>
                           <div class="size-24 rounded-[2rem] bg-gradient-to-br from-primary to-blue-500 text-white flex items-center justify-center rotate-6 hover:rotate-0 transition-all duration-500 shadow-2xl relative">
                                <span class="material-symbols-outlined text-5xl font-bold">auto_awesome</span>
                           </div>
                        </div>
                        <h2 class="text-5xl font-black text-slate-900 dark:text-white mb-6 tracking-tighter leading-tight italic">
                            Welcome to <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-500 uppercase not-italic">@Model.Name</span>
                        </h2>
                        <p class="text-xl text-slate-500 dark:text-slate-400 leading-relaxed font-medium max-w-xl mx-auto">
                            @(string.IsNullOrEmpty(Model.Description) ? "This is the start of your learning journey. Collaborate, study, and grow together!" : Model.Description)
                        </p>
                    </section>

                    <div class="h-px bg-gradient-to-r from-transparent via-border-light dark:via-border-dark to-transparent opacity-50"></div>
                </div>
            </div>
            
            <!-- Quick Input Bar -->
            <div class="p-8 bg-gradient-to-t from-background-light dark:from-background-dark to-transparent absolute bottom-0 left-0 right-0 pointer-events-none">
                <div class="max-w-4xl mx-auto w-full pointer-events-auto">
                    <div class="bg-white/80 dark:bg-surface-dark/80 backdrop-blur-xl border border-white dark:border-white/10 rounded-3xl p-3 px-6 shadow-2xl flex items-center gap-5 transition-all focus-within:ring-2 focus-within:ring-primary/20">
                        <button class="text-slate-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-2xl">add_circle</span>
                        </button>
                        <input type="text" placeholder="Message to @Model.Name..." class="flex-1 bg-transparent border-none outline-none text-base font-medium text-slate-700 dark:text-slate-200 placeholder:text-slate-400">
                        <div class="flex items-center gap-4">
                            <button class="text-slate-400 hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-2xl">mood</span>
                            </button>
                            <button class="px-7 py-2.5 bg-primary text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-primary-dark shadow-xl shadow-primary/20 transition-all active:scale-95">Send</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Right Sidebar: Members (Restored Symmetry) -->
        <aside class="w-72 flex-shrink-0 bg-surface-light dark:bg-background-dark border-l border-border-light dark:border-border-dark hidden xl:flex flex-col p-6">
            <div class="flex items-center justify-between mb-8 px-2">
                <h3 class="text-[11px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[2px]">Members — @Model.MemberCount</h3>
                <button class="size-8 flex items-center justify-center rounded-lg hover:bg-primary/10 text-slate-400 hover:text-primary transition-all">
                    <span class="material-symbols-outlined text-lg">person_add</span>
                </button>
            </div>
            <div class="space-y-4 flex-1 overflow-y-auto scrollbar-hide">
                <div class="p-3.5 rounded-2xl hover:bg-white dark:hover:bg-white/5 transition-all group cursor-pointer border border-transparent hover:border-border-light dark:hover:border-white/10 flex items-center gap-4">
                    <div class="relative">
                        <div class="size-11 rounded-2xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center font-bold text-sm shadow-sm transition-transform group-hover:scale-110">
                            <span class="material-symbols-outlined text-2xl">account_circle</span>
                        </div>
                        <div class="absolute -top-1 -right-1 size-5 bg-amber-400 border-[3px] border-surface-light dark:border-[#101f22] rounded-full flex items-center justify-center shadow-sm">
                            <span class="material-symbols-outlined text-[9px] text-white font-black">star</span>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-black text-slate-900 dark:text-white truncate">@(Model.OwnerUserName ?? "Owner")</p>
                        <span class="text-[9px] font-black text-primary uppercase bg-primary/10 px-2 py-0.5 rounded-md tracking-tighter">Group Creator</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<!-- Modal: Create Channel -->
<div id="createChannelModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6 sm:p-0">
    <div class="absolute inset-0 bg-slate-900/40 dark:bg-black/60 backdrop-blur-sm" onclick="closeCreateChannelModal()"></div>
    <div class="bg-white dark:bg-surface-dark w-full max-w-lg rounded-[2.5rem] shadow-2xl relative z-10 overflow-hidden border border-white dark:border-white/10 animate-in fade-in zoom-in duration-300">
        <div class="p-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Create <span id="modalChannelTypeLabel">Channel</span></h2>
                    <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mt-1">Setup a new space for collaboration.</p>
                </div>
                <button onclick="closeCreateChannelModal()" class="size-10 rounded-2xl bg-slate-50 dark:bg-background-dark text-slate-400 flex items-center justify-center hover:bg-red-50 hover:text-red-500 dark:hover:bg-red-500/10 transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form asp-action="CreateChannel" method="post" class="space-y-8">
                <input type="hidden" name="GroupId" value="@Model.Id" />
                <input type="hidden" name="Type" id="modalChannelTypeInput" value="0" />

                <div class="space-y-3">
                    <label class="text-[11px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[2px] ml-1">Channel Name</label>
                    <div class="relative group">
                        <div class="absolute left-5 top-1/2 -translate-y-1/2 text-2xl font-bold text-slate-300 dark:text-slate-600 transition-colors group-focus-within:text-primary">#</div>
                        <input type="text" name="Name" required placeholder="new-channel" 
                               class="w-full pl-12 pr-6 py-4 rounded-2xl bg-slate-50 dark:bg-background-dark border-2 border-transparent focus:border-primary/30 focus:bg-white dark:focus:bg-surface-dark outline-none transition-all font-bold text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-700 shadow-inner" />
                    </div>
                </div>

                <div class="space-y-3">
                    <label class="text-[11px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-[2px] ml-1">Topic (Optional)</label>
                    <textarea name="Topic" rows="2" placeholder="What is this channel about?" 
                              class="w-full p-6 rounded-2xl bg-slate-50 dark:bg-background-dark border-2 border-transparent focus:border-primary/30 focus:bg-white dark:focus:bg-surface-dark outline-none transition-all font-medium text-slate-900 dark:text-white placeholder:text-slate-300 dark:placeholder:text-slate-700 shadow-inner"></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeCreateChannelModal()" class="flex-1 py-4 rounded-2xl border-2 border-slate-100 dark:border-white/5 font-black text-xs uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-white/5 transition-all">Cancel</button>
                    <button type="submit" class="flex-[2] py-4 rounded-2xl bg-primary text-white font-black text-xs uppercase tracking-widest hover:bg-primary-dark transition-all shadow-xl shadow-primary/20">Create Channel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let currentVoiceChannelId = null;

    function joinVoice(id, name) {
        // If already in this channel, do nothing
        if (currentVoiceChannelId === id) return;

        // Leave previous channel UI
        if (currentVoiceChannelId) {
            document.getElementById(`users-${currentVoiceChannelId}`).classList.add('hidden');
        }

        // Update state
        currentVoiceChannelId = id;
        
        // Update UI
        document.getElementById(`users-${id}`).classList.remove('hidden');
        document.getElementById('voiceStatusPanel').classList.remove('hidden');
        document.getElementById('connectedChannelName').innerText = name;
        
        if (!isMuted) {
            document.getElementById('voiceAvatar').classList.add('voice-talking');
        }
        
        console.log(`Joined voice channel: ${name}`);
    }

    function leaveVoice() {
        if (!currentVoiceChannelId) return;

        // Update UI
        document.getElementById(`users-${currentVoiceChannelId}`).classList.add('hidden');
        document.getElementById('voiceStatusPanel').classList.add('hidden');
        
        // Reset state
        currentVoiceChannelId = null;
        console.log("Left voice channel");
    }

    let isMuted = false;
    function toggleMic() {
        isMuted = !isMuted;
        const micIcon = document.getElementById('micIcon');
        const micButton = document.getElementById('micButton');
        const micOffIcon = document.getElementById('micOffIcon');
        const avatar = document.getElementById('voiceAvatar');

        if (isMuted) {
            micIcon.innerText = 'mic_off';
            micButton.classList.add('text-red-500', 'bg-red-500/10');
            micOffIcon.classList.remove('hidden');
            avatar.classList.remove('voice-talking');
        } else {
            micIcon.innerText = 'mic';
            micButton.classList.remove('text-red-500', 'bg-red-500/10');
            micOffIcon.classList.add('hidden');
            if (currentVoiceChannelId) {
                avatar.classList.add('voice-talking');
            }
        }
    }

    function openCreateChannelModal(type) {
        const modal = document.getElementById('createChannelModal');
        const label = document.getElementById('modalChannelTypeLabel');
        const input = document.getElementById('modalChannelTypeInput');
        
        label.innerText = type === 'Text' ? 'Text Channel' : 'Voice Channel';
        input.value = type === 'Text' ? '0' : '1'; // 0 = Text, 1 = Voice based on Enum
        
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeCreateChannelModal() {
        const modal = document.getElementById('createChannelModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    // Close on escape
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeCreateChannelModal();
    });
</script>
