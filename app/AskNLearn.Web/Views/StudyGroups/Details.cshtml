@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model StudyGroupDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
    ViewData["HideProfileCompletion"] = true;
    ViewData["AppLayout"] = true;
}

@section Sidebar {
    <div class="d-flex flex-column h-100 bg-transparent animate-entrance w-100">
        <div class="p-4 flex-grow-1 overflow-y-auto custom-scrollbar d-flex flex-column gap-4">
            <!-- Text Channels -->
            <div>
                <div class="d-flex align-items-center justify-content-between px-2 mb-3">
                    <h3 class="text-muted fw-black text-uppercase m-0" style="font-size: 0.65rem; letter-spacing: 2px;">Text Channels</h3>
                    @if (Model.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                    {
                        <button onclick="openCreateChannelModal('Text')" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex align-items-center justify-content-center lh-1 p-0">
                            <span class="material-symbols-outlined fs-6">add</span>
                        </button>
                    }
                </div>
                <div class="d-flex flex-column gap-1">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Text))
                    {
                        <a href="javascript:void(0)" onclick="joinTextChannel('@channel.Id', '@channel.Name')" class="text-decoration-none d-flex align-items-center gap-3 px-3 py-2 rounded-lg text-muted fw-bold transition-all hover-glow" style="font-size: 0.85rem;">
                            <span class="fs-5 fw-bold text-aurora opacity-75">#</span>
                            <span class="text-truncate">@channel.Name</span>
                        </a>
                    }
                    @if (!Model.Channels.Any(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Text))
                    {
                        <div class="px-3 py-4 text-center rounded-lg border border-dashed" style="border-color: var(--border-glass) !important;">
                            <p class="text-muted fw-bold text-uppercase m-0" style="font-size: 0.6rem; letter-spacing: 1px;">No text channels</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Voice Channels -->
            <div>
                <div class="d-flex align-items-center justify-content-between px-2 mb-3">
                    <h3 class="text-muted fw-black text-uppercase m-0" style="font-size: 0.65rem; letter-spacing: 2px;">Voice Channels</h3>
                    @if (Model.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                    {
                        <button onclick="openCreateChannelModal('Voice')" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex align-items-center justify-content-center lh-1 p-0">
                            <span class="material-symbols-outlined fs-6">add</span>
                        </button>
                    }
                </div>
                <div class="d-flex flex-column gap-1" id="voiceChannelList">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Voice || c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Video))
                    {
                        <div>
                            <button onclick="joinVoice('@channel.Id', '@channel.Name')" 
                                    class="w-100 btn btn-link text-decoration-none d-flex align-items-center gap-3 px-3 py-2 rounded-lg text-muted fw-bold transition-all hover-glow" style="font-size: 0.85rem;">
                                <span class="material-symbols-outlined fs-6 opacity-75">@(channel.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Video ? "videocam" : "volume_up")</span>
                                <span class="text-truncate">@channel.Name</span>
                            </button>
                            <!-- Connected Users List -->
                            <div id="users-@channel.Id" class="d-none d-flex flex-column gap-1 ps-5 pe-2 py-1"></div>
                        </div>
                    }
                    @if (!Model.Channels.Any(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Voice || c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Video))
                    {
                        <div class="px-3 py-4 text-center rounded-lg border border-dashed" style="border-color: var(--border-glass) !important;">
                            <p class="text-muted fw-bold text-uppercase m-0" style="font-size: 0.6rem; letter-spacing: 1px;">No voice channels</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar Footer & Voice Status -->
        <div class="mt-auto border-top p-0 bg-transparent" style="border-color: var(--border-glass) !important;">
            <!-- Voice Status Panel -->
            <div id="voiceStatusPanel" class="d-none animate-entrance">
                <div class="p-3 d-flex align-items-center justify-content-between border-bottom" style="border-color: var(--border-glass) !important;">
                    <div class="d-flex flex-column gap-1">
                        <div class="d-flex align-items-center gap-1">
                             <span class="material-symbols-outlined text-aurora fw-bold" style="font-size: 0.8rem;">wifi</span>
                            <span class="text-aurora fw-bold text-uppercase tracking-wider" style="font-size: 0.6rem;">Voice Connected</span>
                        </div>
                        <p id="connectedChannelName" class="text-white fw-bold mb-0 text-truncate" style="font-size: 0.75rem; max-width: 120px;">Channel Name</p>
                    </div>
                    <button onclick="leaveVoice()" class="btn btn-link p-2 text-muted hover-text-danger text-decoration-none d-flex align-items-center justify-content-center rounded-lg transition-all" title="Disconnect">
                        <span class="material-symbols-outlined fs-5">call_end</span>
                    </button>
                </div>
            </div>

            <!-- Profile & Group Settings -->
            <div class="p-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2 p-1 rounded-3 flex-grow-1 hover-glow" style="cursor: pointer; background: rgba(255,255,255,0.02);">
                    <div class="position-relative">
                        <div id="voiceAvatar" class="avatar-sm rounded-circle d-flex flex-center text-aurora fw-black shadow" style="background: rgba(0,245,160,0.1); border: 1px solid var(--color-emerald); font-size: 0.65rem;">
                             @(User.Identity?.Name?[0] ?? '?')
                        </div>
                        <div class="position-absolute rounded-circle" style="bottom: -2px; right: -2px; width: 12px; height: 12px; background: var(--color-emerald); border: 2px solid var(--bg-universe);"></div>
                    </div>
                    <div class="flex-grow-1 min-w-0">
                         <p class="fw-bold text-white text-truncate mb-0" style="font-size: 0.75rem;">@(User.Identity?.Name ?? "User")</p>
                         <p class="fw-semibold text-muted text-uppercase mb-0 tracking-normal" style="font-size: 0.6rem;">Online</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-1 ms-2">
                    <button onclick="toggleCamera()" id="videoButton" class="btn btn-link p-1 text-muted hover-glow text-decoration-none rounded-lg d-flex align-items-center justify-content-center" title="Toggle Camera" style="width: 32px; height: 32px;">
                        <span id="videoIcon" class="material-symbols-outlined fs-6">videocam_off</span>
                    </button>
                     <button onclick="toggleMic()" id="micButton" class="btn btn-link p-1 text-muted hover-glow text-decoration-none rounded-lg d-flex align-items-center justify-content-center" title="Toggle Microphone" style="width: 32px; height: 32px;">
                        <span id="micIcon" class="material-symbols-outlined fs-6">mic</span>
                    </button>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-link p-1 text-muted hover-glow text-decoration-none rounded-lg d-flex align-items-center justify-content-center" title="Group Settings" style="width: 32px; height: 32px;">
                        <span class="material-symbols-outlined fs-6">settings</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .voice-talking {
        box-shadow: 0 0 0 2px var(--color-emerald);
        animation: voice-pulse 1.5s infinite;
    }

    @@keyframes voice-pulse {
        0% { box-shadow: 0 0 0 0px rgba(0,245,160, 0.4); }
        70% { box-shadow: 0 0 0 6px rgba(0,245,160, 0); }
        100% { box-shadow: 0 0 0 0px rgba(0,245,160, 0); }
    }
</style>

<div id="drop-zone" class="d-none position-fixed top-0 bottom-0 start-0 end-0 z-3 align-items-center justify-content-center" style="background: rgba(15,23,42,0.8); backdrop-filter: blur(5px); z-index: 1060; pointer-events: none;">
    <div class="glass-card p-5 d-flex flex-column align-items-center gap-4 animate-entrance" style="border: 2px dashed var(--color-emerald);">
        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: rgba(0,245,160,0.1);">
            <span class="material-symbols-outlined text-aurora" style="font-size: 3rem;">upload_file</span>
        </div>
        <p class="fs-4 fw-bold text-white mb-0">Release to upload files</p>
    </div>
</div>

<!-- Unified Video Grid Overlay -->
<div id="videoGrid" class="d-none position-fixed z-3 d-grid gap-3 p-4 p-md-5 pointer-events-none transition-all" style="top: 80px; bottom: 100px; left: 300px; right: 300px;">
    <div id="localVideoContainer" class="d-none position-relative bg-black rounded-lg overflow-hidden border shadow-lg pointer-events-auto group animate-entrance" style="border-color: var(--border-glass) !important;">
        <video id="localVideo" autoplay muted playsinline class="w-100 h-100 object-cover"></video>
        <div class="position-absolute bottom-0 start-0 m-3 px-3 py-1 glass-card rounded-lg" style="background: rgba(0,0,0,0.5);">
            <span class="fw-black text-white text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">You</span>
        </div>
    </div>
</div>

<!-- Main Content Area -->
<div class="d-flex flex-column flex-md-row h-100 flex-grow-1 overflow-hidden w-100 position-relative bg-transparent">
    <!-- Center Feed -->
    <main class="d-flex flex-column flex-grow-1 min-w-0 position-relative">
        <div class="flex-grow-1 overflow-y-auto p-4 p-md-5 custom-scrollbar">
            <div class="mx-auto" style="max-width: 800px;">
                <!-- Welcome Section -->
                <section class="py-5 text-center position-relative">
                    <div class="position-absolute start-50 top-50 translate-middle rounded-circle" style="width: 200px; height: 200px; background: var(--gradient-aurora); filter: blur(60px); opacity: 0.15;"></div>
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-4 position-relative z-1">
                        <div class="rounded-lg d-flex align-items-center justify-content-center shadow-lg transition-transform" style="width: 80px; height: 80px; background: var(--gradient-aurora); color: var(--bg-universe); transform: rotate(5deg);">
                            <span class="material-symbols-outlined fw-bold" style="font-size: 2.5rem;">auto_awesome</span>
                        </div>
                    </div>
                    <h2 class="display-5 fw-black text-white mb-4 tracking-tighter position-relative z-1">
                        Welcome to <span class="text-aurora text-uppercase" style="font-style: italic;">@Model.Name</span>
                    </h2>
                    <p class="fs-5 text-muted fw-medium mx-auto position-relative z-1" style="max-width: 600px;">
                        @(string.IsNullOrEmpty(Model.Description) ? "This is the start of your learning journey. Collaborate, study, and grow together!" : Model.Description)
                    </p>
                </section>
                <hr class="w-100 border-top" style="border-color: var(--border-glass) !important;" />
            </div>
        </div>
        
        <!-- Quick Input Bar -->
        <div class="p-4 position-absolute bottom-0 start-0 end-0 pointer-events-none" style="background: linear-gradient(to top, var(--bg-universe) 40%, transparent);">
            <div class="mx-auto w-100 pointer-events-auto position-relative" style="max-width: 800px;">
                <!-- Emoji/GIF Picker Popup -->
                <div id="picker-popup" class="d-none position-absolute bottom-100 start-0 mb-3 glass-card flex-column overflow-hidden animate-entrance" style="width: 320px; height: 380px; z-index: 1050; display: flex;">
                    <div class="d-flex border-bottom" style="border-color: var(--border-glass) !important;">
                        <button onclick="switchPickerTab('emoji')" id="tab-emoji" class="btn btn-link flex-grow-1 py-3 px-0 rounded-0 text-decoration-none fw-black text-uppercase tracking-widest text-aurora" style="font-size: 0.65rem; border-bottom: 2px solid var(--color-emerald) !important;">Emojis</button>
                        <button onclick="switchPickerTab('gif')" id="tab-gif" class="btn btn-link flex-grow-1 py-3 px-0 rounded-0 text-decoration-none fw-black text-uppercase tracking-widest text-muted hover-glow" style="font-size: 0.65rem; border-bottom: 2px solid transparent !important;">GIFs</button>
                    </div>
                    <div id="emoji-picker-container" class="flex-grow-1 overflow-hidden"></div>
                    <div id="gif-picker-container" class="d-none flex-grow-1 flex-column p-3 overflow-hidden" style="display: flex;">
                        <div class="position-relative mb-3">
                            <input type="text" id="gif-search" placeholder="Search Giphy..." class="form-control form-control-glass ps-5 text-white" style="font-size: 0.8rem; border-radius: 0.75rem;">
                            <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                        </div>
                        <div id="gif-results" class="flex-grow-1 overflow-y-auto d-grid custom-scrollbar gap-2" style="grid-template-columns: 1fr 1fr;">
                            <!-- GIFs via JS -->
                        </div>
                    </div>
                </div>

                <div id="input-container" class="glass-card d-flex align-items-center gap-3 p-2 px-4 shadow-lg transition-all" style="border-radius: 2rem;">
                    <button id="attachment-btn" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center">
                        <span class="material-symbols-outlined fs-4">add_circle</span>
                    </button>
                    <input type="text" id="message-input" placeholder="Message to @Model.Name..." class="form-control bg-transparent border-0 text-white shadow-none ps-0" style="font-size: 0.95rem;">
                    <div class="d-flex align-items-center gap-3">
                        <button id="emoji-btn" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center">
                            <span class="material-symbols-outlined fs-4">mood</span>
                        </button>
                        <button id="send-btn" class="btn btn-premium d-flex align-items-center justify-content-center rounded-pill px-4" style="height: 40px; font-size: 0.75rem;">SEND</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Right Sidebar: Members -->
    <aside class="d-none d-xl-flex flex-column p-4 flex-shrink-0 animate-entrance" style="background: rgba(15,23,42,0.1); width: 280px; border-left: 1px solid var(--border-glass); backdrop-filter: blur(10px);">
        <div class="d-flex align-items-center justify-content-between mb-4 px-2">
            <h3 class="text-muted fw-black text-uppercase m-0" style="font-size: 0.65rem; letter-spacing: 2px;">Members — @Model.MemberCount</h3>
            <button class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center rounded-lg lh-1 p-0">
                <span class="material-symbols-outlined fs-6">person_add</span>
            </button>
        </div>
        <div class="d-flex flex-column gap-3 flex-grow-1 overflow-y-auto custom-scrollbar">
            <div class="d-flex align-items-center gap-3 p-2 rounded-lg hover-glow transition-all" style="cursor: pointer; border: 1px solid transparent;">
                <div class="position-relative">
                    <div class="avatar-sm rounded-lg d-flex flex-center text-aurora shadow-sm" style="background: rgba(0,245,160,0.1); border: 1px solid rgba(0,245,160,0.2);">
                        <span class="material-symbols-outlined fs-6">account_circle</span>
                    </div>
                    <div class="position-absolute d-flex flex-center shadow-sm" style="top: -4px; right: -4px; width: 14px; height: 14px; background: #fbbf24; border: 2px solid var(--bg-universe); border-radius: 50%;">
                        <span class="material-symbols-outlined text-white fw-black" style="font-size: 8px;">star</span>
                    </div>
                </div>
                <div class="flex-grow-1 min-w-0">
                    <p class="fw-bold text-white text-truncate mb-0" style="font-size: 0.8rem;">@(Model.OwnerUserName ?? "Owner")</p>
                    <span class="fw-black text-aurora text-uppercase px-1 rounded d-inline-block" style="font-size: 0.55rem; letter-spacing: -0.5px; background: rgba(0,245,160,0.1);">Group Creator</span>
                </div>
            </div>
        </div>
    </aside>
</div>

<!-- Modal: Create Channel -->
<div id="createChannelModal" class="d-none position-fixed top-0 bottom-0 start-0 end-0 z-3 align-items-center justify-content-center p-3" style="z-index: 1060; display: flex;">
    <div class="position-absolute top-0 bottom-0 start-0 end-0" style="background: rgba(2,6,23,0.8); backdrop-filter: blur(5px);" onclick="closeCreateChannelModal()"></div>
    <div class="glass-card position-relative z-1 w-100 animate-entrance" style="max-width: 500px; padding: 2.5rem;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="h3 fw-black text-white tracking-tighter mb-1">Create <span id="modalChannelTypeLabel" class="text-aurora">Channel</span></h2>
                <p class="small fw-medium text-muted mb-0">Setup a new space for collaboration.</p>
            </div>
            <button onclick="closeCreateChannelModal()" class="btn btn-link p-2 text-muted hover-text-danger d-flex flex-center rounded-lg bg-dark border-0">
                <span class="material-symbols-outlined fs-5">close</span>
            </button>
        </div>

        <form asp-action="CreateChannel" method="post" class="d-flex flex-column gap-4">
            <input type="hidden" name="GroupId" value="@Model.Id" />
            <input type="hidden" name="Type" id="modalChannelTypeInput" value="0" />

            <div class="d-flex flex-column gap-2">
                <label class="fw-black text-muted text-uppercase tracking-widest ms-1" style="font-size: 0.65rem;">Channel Name</label>
                <div class="position-relative">
                    <span class="position-absolute top-50 translate-middle-y fw-bold text-muted transition-colors" style="left: 1rem; font-size: 1.25rem;">#</span>
                    <input type="text" name="Name" required placeholder="new-channel" 
                           class="form-control form-control-glass w-100 fw-bold text-white ps-5 py-3" style="border-radius: 1rem;" />
                </div>
            </div>

            <div class="d-flex flex-column gap-2">
                <label class="fw-black text-muted text-uppercase tracking-widest ms-1" style="font-size: 0.65rem;">Topic (Optional)</label>
                <textarea name="Topic" rows="2" placeholder="What is this channel about?" 
                          class="form-control form-control-glass w-100 fw-medium text-white p-3" style="border-radius: 1rem;"></textarea>
            </div>

            <div class="d-flex gap-3 mt-2">
                <button type="button" onclick="closeCreateChannelModal()" class="btn btn-glass flex-grow-1 fw-black text-uppercase py-3" style="font-size: 0.75rem; letter-spacing: 1px;">Cancel</button>
                <button type="submit" class="btn btn-premium flex-grow-1 fw-black text-uppercase py-3" style="font-size: 0.75rem; letter-spacing: 1px; flex: 2;">Create Channel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        let currentVoiceChannelId = null;
        let currentTextChannelId = null;
        let connection = null;
        
        let localStream = null;
        const peers = {}; 
        const iceServers = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };

        async function startSignalR() {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/communicationHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveMessage", (message) => {
                if (currentTextChannelId === message.channelId) {
                    appendMessage(message);
                }
            });

            connection.on("UserJoinedVoice", async (data) => {
                const container = document.getElementById(`users-${data.channelId}`);
                if (container && !document.getElementById(`user-indicator-${data.connectionId}`)) {
                    container.classList.remove('d-none');
                    const userHtml = `
                        <div id="user-indicator-${data.connectionId}" class="d-flex align-items-center gap-2 py-1 animate-entrance">
                            <div class="position-relative">
                                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${data.userName}" class="avatar-xs rounded-lg object-cover" />
                                <div id="micOffIcon" class="d-none position-absolute d-flex flex-center bg-danger rounded-circle border border-dark shadow-sm" style="bottom: -4px; right: -4px; width: 14px; height: 14px;">
                                    <span class="material-symbols-outlined text-white fw-black" style="font-size: 8px;">mic_off</span>
                                </div>
                            </div>
                            <span class="fw-bold text-muted transition-colors hover-glow" style="font-size: 0.65rem;">${data.userName}</span>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', userHtml);
                }
                if (currentVoiceChannelId) await createPeerConnection(data.connectionId, true);
            });

            connection.on("UserLeftVoice", (connectionId) => {
                if (peers[connectionId]) {
                    peers[connectionId].pc.close();
                    delete peers[connectionId];
                    const el = document.getElementById(`peer-audio-${connectionId}`);
                    if (el) el.remove();
                    const uiEl = document.getElementById(`user-indicator-${connectionId}`);
                    if (uiEl) uiEl.remove();
                }
            });

            connection.on("ReceiveSignal", async (signal, fromConnectionId) => {
                const data = JSON.parse(signal);
                let peer = peers[fromConnectionId];
                if (data.sdp) {
                    if (!peer) peer = await createPeerConnection(fromConnectionId, false);
                    await peer.pc.setRemoteDescription(new RTCSessionDescription(data.sdp));
                    if (data.sdp.type === "offer") {
                        const answer = await peer.pc.createAnswer();
                        await peer.pc.setLocalDescription(answer);
                        connection.invoke("SendSignal", JSON.stringify({ sdp: answer }), fromConnectionId);
                    }
                } else if (data.candidate) {
                    if (peer) await peer.pc.addIceCandidate(new RTCIceCandidate(data.candidate));
                }
            });

            connection.on("UserMuteChanged", (connectionId, isMuted) => {
                const icon = document.querySelector(`#user-indicator-${connectionId} #micOffIcon`);
                if (icon) {
                    if (isMuted) icon.classList.remove('d-none');
                    else icon.classList.add('d-none');
                }
            });

            try {
                await connection.start();
                const initialChannelId = "@Model.Channels.FirstOrDefault(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Text)?.Id";
                if (initialChannelId) joinTextChannel(initialChannelId, "@Model.Channels.FirstOrDefault(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Text)?.Name");
            } catch (err) { console.error("SignalR Error:", err); }
        }

        async function createPeerConnection(connectionId, isOffer) {
            const pc = new RTCPeerConnection(iceServers);
            peers[connectionId] = { pc };
            pc.onicecandidate = (event) => {
                if (event.candidate) connection.invoke("SendSignal", JSON.stringify({ candidate: event.candidate }), connectionId);
            };
            pc.ontrack = (event) => {
                if (event.track.kind === 'audio') {
                    let audio = document.getElementById(`peer-audio-${connectionId}`);
                    if (!audio) {
                        audio = document.createElement('audio');
                        audio.id = `peer-audio-${connectionId}`;
                        audio.autoplay = true;
                        document.body.appendChild(audio);
                    }
                    audio.srcObject = event.streams[0];
                } else if (event.track.kind === 'video') {
                    let container = document.getElementById(`peer-video-container-${connectionId}`);
                    if (!container) {
                        container = document.createElement('div');
                        container.id = `peer-video-container-${connectionId}`;
                        container.className = 'position-relative bg-black rounded-lg overflow-hidden border shadow-lg pointer-events-auto animate-entrance';
                        container.style.borderColor = 'var(--border-glass)';
                        container.innerHTML = `
                            <video id="peer-video-${connectionId}" autoplay playsinline class="w-100 h-100 object-cover"></video>
                            <div class="position-absolute bottom-0 start-0 m-3 px-3 py-1 glass-card rounded-lg" style="background: rgba(0,0,0,0.5);">
                                <span id="peer-name-${connectionId}" class="fw-black text-white text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">Peer</span>
                            </div>
                        `;
                        document.getElementById('videoGrid').appendChild(container);
                        document.getElementById('videoGrid').classList.replace('d-none', 'd-grid');
                    }
                    const video = document.getElementById(`peer-video-${connectionId}`);
                    video.srcObject = event.streams[0];
                    updateVideoGrid();
                }
            };
            if (localStream) localStream.getTracks().forEach(track => pc.addTrack(track, localStream));
            if (isOffer) {
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);
                connection.invoke("SendSignal", JSON.stringify({ sdp: offer }), connectionId);
            }
            return peers[connectionId];
        }

        async function joinTextChannel(id, name) {
            if (currentTextChannelId === id) return;
            if (currentTextChannelId) await connection.invoke("LeaveChannel", currentTextChannelId);
            currentTextChannelId = id;
            await connection.invoke("JoinChannel", id);
            
            document.getElementById('message-input').placeholder = `Message to #${name}...`;
            const welcome = document.querySelector('section.py-5');
            if (welcome) welcome.classList.add('d-none');
            const hr = document.querySelector('hr.border-top');
            if (hr) hr.classList.add('d-none');
            
            let list = document.getElementById('message-list');
            if (!list) {
                const container = document.querySelector('main .mx-auto');
                list = document.createElement('div');
                list.id = 'message-list';
                list.className = 'd-flex flex-column gap-4 pb-5 mb-5';
                container.appendChild(list);
            }
            list.innerHTML = `
                <div class="py-5 text-center opacity-50 animate-entrance">
                    <div class="rounded-circle d-flex flex-center mx-auto mb-4" style="width: 64px; height: 64px; background: rgba(0,245,160,0.1); color: var(--color-emerald);">
                        <span class="material-symbols-outlined fs-2">chat_bubble</span>
                    </div>
                    <p class="fw-bold text-uppercase tracking-widest text-aurora mb-2" style="font-size: 0.65rem;">Connected to #${name}</p>
                    <p class="fw-medium text-muted mb-0" style="font-size: 0.75rem;">Start a conversation with your group members.</p>
                </div>
            `;
        }

        async function joinVoice(id, name) {
            if (currentVoiceChannelId === id) return;
            if (currentVoiceChannelId) await leaveVoice();
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
                currentVoiceChannelId = id;
                await connection.invoke("JoinVoice", id);

                document.getElementById('voiceStatusPanel').classList.remove('d-none');
                document.getElementById('connectedChannelName').innerText = name;
                
                const container = document.getElementById(`users-${id}`);
                if (container) {
                    container.classList.remove('d-none');
                    const myUserName = "@(User.Identity?.Name ?? "User")";
                    const userHtml = `
                        <div id="user-indicator-local" class="d-flex align-items-center gap-2 py-1 animate-entrance">
                            <div class="position-relative">
                                <div id="localVoiceAvatar" class="avatar-xs rounded-circle d-flex flex-center text-primary fw-bold text-uppercase transition-all ${isMuted ? '' : 'voice-talking'}" style="background: rgba(0,245,160,0.2); font-size: 10px; border: 1px solid var(--color-emerald);">
                                    ${myUserName.charAt(0)}
                                </div>
                                <div id="localMicOffIcon" class="${isMuted ? '' : 'd-none'} position-absolute d-flex flex-center bg-danger rounded-circle border border-dark shadow-sm" style="bottom: -4px; right: -4px; width: 14px; height: 14px;">
                                    <span class="material-symbols-outlined text-white fw-black" style="font-size: 8px;">mic_off</span>
                                </div>
                            </div>
                            <span class="fw-bold text-aurora" style="font-size: 0.65rem;">${myUserName} (You)</span>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', userHtml);
                }
            } catch (err) { alert("Microphone access denied."); }
        }

        let isVideoOn = false;
        async function toggleCamera() {
            if (!currentVoiceChannelId) return;
            isVideoOn = !isVideoOn;
            try {
                if (isVideoOn) {
                    const videoStream = await navigator.mediaDevices.getUserMedia({ video: true });
                    const videoTrack = videoStream.getVideoTracks()[0];
                    localStream.addTrack(videoTrack);
                    Object.entries(peers).forEach(async ([connId, p]) => {
                        p.pc.addTrack(videoTrack, localStream);
                        const offer = await p.pc.createOffer();
                        await p.pc.setLocalDescription(offer);
                        connection.invoke("SendSignal", JSON.stringify({ sdp: offer }), connId);
                    });
                } else {
                    const videoTrack = localStream.getVideoTracks()[0];
                    if (videoTrack) {
                        videoTrack.stop();
                        localStream.removeTrack(videoTrack);
                    }
                }
                connection.invoke("ToggleVideo", currentVoiceChannelId, isVideoOn);
                document.getElementById('videoIcon').innerText = isVideoOn ? 'videocam' : 'videocam_off';
                document.getElementById('videoButton').classList.toggle('text-aurora', isVideoOn);
                document.getElementById('videoButton').classList.toggle('bg-primary-subtle', isVideoOn);
                updateVideoGrid();
            } catch (err) { isVideoOn = false; }
        }

        async function leaveVoice() {
            if (!currentVoiceChannelId) return;
            await connection.invoke("LeaveVoice", currentVoiceChannelId);
            Object.keys(peers).forEach(id => {
                peers[id].pc.close();
                const el = document.getElementById(`peer-audio-${id}`);
                if (el) el.remove();
            });
            if (localStream) {
                localStream.getTracks().forEach(t => t.stop());
                localStream = null;
            }
            const myIndicator = document.getElementById('user-indicator-local');
            if (myIndicator) myIndicator.remove();
            const container = document.getElementById(`users-${currentVoiceChannelId}`);
            if (container && container.children.length === 0) container.classList.add('d-none');
            document.getElementById('voiceStatusPanel').classList.add('d-none');
            currentVoiceChannelId = null;
        }

        function updateVideoGrid() {
            const grid = document.getElementById('videoGrid');
            const containers = grid.querySelectorAll('div[id$="-container"]');
            const count = containers.length + (isVideoOn ? 1 : 0);
            if (count === 0) {
                grid.classList.add('d-none');
                grid.classList.remove('d-grid');
                return;
            }
            grid.classList.remove('d-none');
            grid.classList.add('d-grid');
            if (isVideoOn) document.getElementById('localVideoContainer').classList.remove('d-none');
            else document.getElementById('localVideoContainer').classList.add('d-none');
            
            const localVideo = document.getElementById('localVideo');
            if (isVideoOn && localStream && localStream.getVideoTracks().length > 0) {
                localVideo.srcObject = new MediaStream([localStream.getVideoTracks()[0]]);
            } else {
                localVideo.srcObject = null;
            }
            const cols = count > 4 ? 3 : count > 1 ? 2 : 1;
            grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
        }

        function appendMessage(msg) {
            let list = document.getElementById('message-list');
            if (!list) return;
            const isMine = msg.authorId === "@User.FindFirst(ClaimTypes.NameIdentifier)?.Value";
            
            const msgHtml = `
                <div class="d-flex w-100 ${isMine ? 'justify-content-end' : 'justify-content-start'} animate-entrance">
                    <div class="d-flex ${isMine ? 'flex-row-reverse' : ''} gap-3 align-items-end" style="max-width: 85%;">
                        ${!isMine ? `<img src="${msg.authorAvatar}" class="avatar-sm rounded-lg shadow-sm border" style="border-color: var(--border-glass) !important;"/>` : ''}
                        <div class="d-flex flex-column gap-1 ${isMine ? 'align-items-end' : 'align-items-start'}">
                            <div class="d-flex align-items-center gap-2 px-1">
                                <span class="fw-black text-muted text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">${msg.authorName}</span>
                                <span class="fw-bold text-muted" style="font-size: 0.55rem;">${msg.createdAt}</span>
                            </div>
                            <div class="p-3 shadow-lg" style="border-radius: 1.5rem; ${isMine ? 'background: var(--gradient-aurora); color: var(--bg-universe); border-top-right-radius: 0.25rem;' : 'background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white; border-top-left-radius: 0.25rem; backdrop-filter: blur(10px);'}">
                                ${msg.content.startsWith('http') && msg.content.includes('giphy.com') ? `<img src="${msg.content}" class="img-fluid rounded-3" style="max-width: 250px;" />` : `<p class="mb-0 fw-medium" style="font-size: 0.9rem; line-height: 1.5;">${msg.content}</p>`}
                            </div>
                        </div>
                    </div>
                </div>
            `;
            list.insertAdjacentHTML('beforeend', msgHtml);
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
        }

        async function sendMessage() {
            const input = document.getElementById('message-input');
            const content = input.value.trim();
            if (!content || !currentTextChannelId) return;
            try {
                await connection.invoke("SendMessage", currentTextChannelId, content);
                input.value = '';
                input.focus();
            } catch (err) {}
        }

        document.addEventListener('DOMContentLoaded', () => {
            startSignalR();
            const input = document.getElementById('message-input');
            const sendBtn = document.getElementById('send-btn');
            if (sendBtn) sendBtn.onclick = sendMessage;
            if (input) input.onkeydown = (e) => { if (e.key === 'Enter') sendMessage(); };
        });

        let isMuted = false;
        function toggleMic() {
            isMuted = !isMuted;
            if (currentVoiceChannelId) connection.invoke("ToggleMute", currentVoiceChannelId, isMuted);
            if (localStream) localStream.getAudioTracks().forEach(track => track.enabled = !isMuted);
            
            const micIcon = document.getElementById('micIcon');
            const micButton = document.getElementById('micButton');
            micIcon.innerText = isMuted ? 'mic_off' : 'mic';
            
            if(isMuted) {
                micButton.classList.add('text-danger');
            } else {
                micButton.classList.remove('text-danger');
            }
            
            const avatar = document.getElementById('voiceAvatar');
            if (avatar) {
                if(!isMuted && currentVoiceChannelId) avatar.classList.add('voice-talking');
                else avatar.classList.remove('voice-talking');
            }
            
            const localAvatarList = document.getElementById('localVoiceAvatar');
            if (localAvatarList) {
                if(!isMuted) localAvatarList.classList.add('voice-talking');
                else localAvatarList.classList.remove('voice-talking');
            }
            
            const localMicIcon = document.getElementById('localMicOffIcon');
            if (localMicIcon) {
                if(isMuted) localMicIcon.classList.remove('d-none');
                else localMicIcon.classList.add('d-none');
            }
        }

        function openCreateChannelModal(type) {
            const modal = document.getElementById('createChannelModal');
            const label = document.getElementById('modalChannelTypeLabel');
            const input = document.getElementById('modalChannelTypeInput');
            label.innerText = (type === 'Text' ? 'Text' : type === 'Voice' ? 'Voice' : 'Video') + ' Channel';
            input.value = type === 'Text' ? '0' : type === 'Voice' ? '1' : '2';
            modal.classList.remove('d-none');
        }

        function closeCreateChannelModal() {
            document.getElementById('createChannelModal').classList.add('d-none');
        }

        const emojiBtn = document.getElementById('emoji-btn');
        const pickerPopup = document.getElementById('picker-popup');
        const messageInput = document.getElementById('message-input');
        const emojiContainer = document.getElementById('emoji-picker-container');
        let picker = null;

        async function initEmojiPicker() {
            if (picker) return;
            try {
                if (!window.createPicker) {
                    const picmoModule = await import('https://unpkg.com/picmo@latest/dist/index.js');
                    window.createPicker = picmoModule.createPicker;
                }
                picker = window.createPicker({ rootElement: emojiContainer, theme: 'dark' });
                picker.addEventListener('emoji:select', (selection) => { messageInput.value += selection.emoji; });
            } catch (err) {}
        }

        emojiBtn.onclick = (e) => {
            e.stopPropagation();
            pickerPopup.classList.toggle('d-none');
            if (!pickerPopup.classList.contains('d-none')) { initEmojiPicker(); switchPickerTab('emoji'); }
        };

        const GIPHY_API_KEY = 'dc6zaTOxFJmzC';
        const gifResults = document.getElementById('gif-results');
        async function searchGifs(query = 'trending') {
            const url = `https://api.giphy.com/v1/gifs/${query === 'trending' ? 'trending' : 'search'}?api_key=${GIPHY_API_KEY}&limit=20${query !== 'trending' ? '&q=' + encodeURIComponent(query) : ''}`;
            try {
                const resp = await fetch(url);
                const data = await resp.json();
                renderGifs(data.data);
            } catch (err) {}
        }

        function renderGifs(gifs) {
            gifResults.innerHTML = '';
            gifs.forEach(gif => {
                const img = document.createElement('img');
                img.src = gif.images.fixed_height_small.url;
                img.className = 'w-100 object-cover rounded-3 pointer hover-glow transition-all';
                img.style.height = '100px';
                img.onclick = () => { if (currentTextChannelId) connection.invoke("SendMessage", currentTextChannelId, gif.images.original.url); pickerPopup.classList.add('d-none'); };
                gifResults.appendChild(img);
            });
        }

        document.getElementById('gif-search').oninput = (e) => {
            clearTimeout(window.searchTimeout);
            window.searchTimeout = setTimeout(() => searchGifs(e.target.value.trim() || 'trending'), 500);
        };

        window.switchPickerTab = (tab) => {
            const isEmoji = tab === 'emoji';
            if(isEmoji) {
                document.getElementById('emoji-picker-container').style.display = 'block';
                document.getElementById('gif-picker-container').style.display = 'none';
                document.getElementById('tab-emoji').style.borderBottomColor = 'var(--color-emerald)';
                document.getElementById('tab-emoji').classList.replace('text-muted', 'text-aurora');
                document.getElementById('tab-gif').style.borderBottomColor = 'transparent';
                document.getElementById('tab-gif').classList.replace('text-aurora', 'text-muted');
            } else {
                document.getElementById('emoji-picker-container').style.display = 'none';
                document.getElementById('gif-picker-container').style.display = 'flex';
                document.getElementById('tab-gif').style.borderBottomColor = 'var(--color-emerald)';
                document.getElementById('tab-gif').classList.replace('text-muted', 'text-aurora');
                document.getElementById('tab-emoji').style.borderBottomColor = 'transparent';
                document.getElementById('tab-emoji').classList.replace('text-aurora', 'text-muted');
                searchGifs();
            }
        };

        const dropZone = document.getElementById('drop-zone');
        window.ondragenter = (e) => { e.preventDefault(); dropZone.classList.remove('d-none'); dropZone.classList.add('d-flex'); };
        dropZone.ondragleave = (e) => { if (e.relatedTarget === null || !dropZone.contains(e.relatedTarget)) { dropZone.classList.add('d-none'); dropZone.classList.remove('d-flex'); } };
        dropZone.ondrop = (e) => { e.preventDefault(); dropZone.classList.add('d-none'); dropZone.classList.remove('d-flex'); alert('Files detected.'); };
    </script>
}
