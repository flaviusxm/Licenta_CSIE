@using AskNLearn.Application.Features.StudyGroups.Queries
@using System.Security.Claims
@model StudyGroupDto
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
}

<div class="flex flex-col h-full bg-background-light dark:bg-background-dark">
    <!-- Hero / Header Section -->
    <div class="relative bg-surface-light dark:bg-surface-dark border-b border-border-light dark:border-border-dark p-8">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div class="flex items-center gap-6">
                <div class="size-20 rounded-2xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-4xl">groups</span>
                </div>
                <div>
                    <div class="flex items-center gap-3 mb-1">
                        <h1 class="text-3xl font-bold text-slate-900 dark:text-white">@Model.Name</h1>
                        <span class="text-xs font-bold bg-primary/10 text-primary px-3 py-1 rounded-full uppercase tracking-wider">@Model.SubjectArea</span>
                    </div>
                    <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">person</span>
                            Owned by @(Model.OwnerUserName ?? "Unknown")
                        </span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">calendar_today</span>
                            Created @Model.CreatedAt.ToString("MMMM dd, yyyy")
                        </span>
                    </div>
                </div>
            </div>
            <div class="flex gap-3">
                 @if (User.Identity.IsAuthenticated && Model.OwnerId == User.FindFirst(ClaimTypes.NameIdentifier)?.Value)
                 {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="px-6 py-3 rounded-xl border border-border-light dark:border-border-dark font-bold text-slate-700 dark:text-white hover:bg-slate-50 dark:hover:bg-background-dark transition-all">
                        Edit Group
                    </a>
                 }
                <button class="px-6 py-3 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold transition-all shadow-lg shadow-primary/20">
                    Join Conversation
                </button>
            </div>
        </div>
    </div>

    <!-- Content Area -->
    <div class="max-w-6xl mx-auto w-full p-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Column -->
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-8 border border-border-light dark:border-border-dark shadow-sm">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">info</span>
                    About this Group
                </h2>
                <div class="prose dark:prose-invert max-w-none text-slate-600 dark:text-slate-400">
                    @if (string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="italic text-slate-400">No description provided for this group.</p>
                    }
                    else
                    {
                        @Model.Description
                    }
                </div>
            </div>

            <!-- Feed Placeholder -->
            <div class="space-y-4">
                <h3 class="font-bold text-slate-900 dark:text-white">Recent Activity</h3>
                <div class="text-center py-12 bg-slate-50 dark:bg-surface-dark border border-dashed border-border-light dark:border-border-dark rounded-2xl">
                    <span class="material-symbols-outlined text-4xl text-slate-300 dark:text-slate-700 mb-2">history</span>
                    <p class="text-sm text-slate-500">No recent activity. Start a discussion!</p>
                </div>
            </div>
        </div>

        <!-- Sidebar Column -->
        <div class="space-y-8">
            <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark shadow-sm">
                <h3 class="font-bold text-slate-900 dark:text-white mb-4">Group Members</h3>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                         <div class="size-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">person</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-slate-900 dark:text-white">@(Model.OwnerUserName ?? "Owner")</p>
                            <span class="text-[10px] font-bold text-primary uppercase bg-primary/10 px-1.5 py-0.5 rounded">Owner</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
