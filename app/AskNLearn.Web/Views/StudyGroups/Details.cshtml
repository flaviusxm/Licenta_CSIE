@using AskNLearn.Application.Common.Interfaces
@model StudyGroupDto
@inject IPresenceTracker PresenceTracker
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Name;
    ViewData["HideProfileCompletion"] = true;
    ViewData["AppLayout"] = true;
}

@section Sidebar {
    <div class="position-relative h-100 w-100">
        <div class="blur-content d-flex flex-column h-100 bg-transparent animate-entrance w-100">
        <!-- Tabs for Channels / Members -->
        <div class="d-flex px-4 pt-4 pb-2 border-bottom" style="border-color: var(--border-glass) !important;">
            <button onclick="switchSidebarView('channels')" id="btn-view-channels" class="btn btn-link flex-grow-1 py-2 px-0 rounded-0 text-decoration-none fw-black text-uppercase tracking-widest text-aurora sidebar-tab-btn" style="font-size: 0.6rem; border-bottom: 2px solid var(--color-mint-bright) !important;">Channels</button>
            <button onclick="switchSidebarView('members')" id="btn-view-members" class="btn btn-link flex-grow-1 py-2 px-0 rounded-0 text-decoration-none fw-black text-uppercase tracking-widest text-muted sidebar-tab-btn" style="font-size: 0.6rem; border-bottom: 2px solid transparent !important;">Members</button>
        </div>

        <div id="sidebar-view-container" class="flex-grow-1 overflow-hidden d-flex flex-column">
            <div id="sidebar-slider-track" class="sidebar-slider-track flex-grow-1">
                <!-- Channels View -->
                <div id="sidebar-view-channels" class="sidebar-view-pane p-4 custom-scrollbar overflow-y-auto d-flex flex-column gap-4">
                    <!-- Text Channels -->
                    <div>
                        <div class="d-flex align-items-center justify-content-between px-2 mb-3">
                            <h3 class="text-muted fw-black text-uppercase m-0" style="font-size: 0.65rem; letter-spacing: 2px;">Text Channels</h3>
                            @if (Model.IsMember)
                            {
                                <button onclick="openCreateChannelModal('Text')" class="btn btn-link p-1 text-muted hover-aurora text-decoration-none d-flex align-items-center justify-content-center lh-1 p-0">
                                    <span class="material-symbols-outlined fs-6">add</span>
                                </button>
                            }
                        </div>
                        <div class="d-flex flex-column gap-1">
                            @foreach (var channel in Model.Channels.Where(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Text))
                            {
                                <div class="d-flex align-items-center justify-content-between group-channel-wrapper">
                                    <a href="javascript:void(0)" onclick="joinTextChannel('@channel.Id', '@channel.Name')" class="channel-item flex-grow-1 text-decoration-none d-flex align-items-center gap-3 px-3 py-2 rounded-lg text-muted fw-bold" style="font-size: 0.85rem;">
                                        <span class="fs-5 fw-bold text-aurora opacity-75">#</span>
                                        <span class="text-truncate">@channel.Name</span>
                                    </a>
                                    @if(Model.IsMember) {
                                        <form asp-action="DeleteChannel" asp-route-id="@channel.Id" asp-route-groupId="@Model.Id" method="post" onsubmit="return confirm('Delete this channel?');" class="m-0 pe-2 delete-channel-form d-none">
                                            <button type="submit" class="btn btn-link p-1 text-muted hover-text-danger text-decoration-none d-flex flex-center">
                                                <span class="material-symbols-outlined fs-6" style="font-size: 14px;">delete</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Voice Channels -->
                    <div>
                        <div class="d-flex align-items-center justify-content-between px-2 mb-3">
                            <h3 class="text-muted fw-black text-uppercase m-0" style="font-size: 0.65rem; letter-spacing: 2px;">Voice Channels</h3>
                            @if (Model.IsMember)
                            {
                                <button onclick="openCreateChannelModal('Voice')" class="btn btn-link p-1 text-muted hover-aurora text-decoration-none d-flex align-items-center justify-content-center lh-1 p-0">
                                    <span class="material-symbols-outlined fs-6">add</span>
                                </button>
                            }
                        </div>
                        <div class="d-flex flex-column gap-1" id="voiceChannelList">
                            @foreach (var channel in Model.Channels.Where(c => c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Voice || c.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Video))
                            {
                                <div class="group-channel-wrapper">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <button onclick="joinVoice('@channel.Id', '@channel.Name')"
                                                class="channel-item flex-grow-1 btn btn-link text-decoration-none d-flex align-items-center gap-3 px-3 py-2 rounded-lg text-muted fw-bold" style="font-size: 0.85rem;">
                                            <span class="material-symbols-outlined fs-6 opacity-75">@(channel.Type == AskNLearn.Application.Features.StudyGroups.Queries.ChannelType.Video ? "videocam" : "volume_up")</span>
                                            <span class="text-truncate">@channel.Name</span>
                                        </button>
                                        @if(Model.IsMember) {
                                            <form asp-action="DeleteChannel" asp-route-id="@channel.Id" asp-route-groupId="@Model.Id" method="post" onsubmit="return confirm('Delete this channel?');" class="m-0 pe-2 delete-channel-form d-none">
                                                <button type="submit" class="btn btn-link p-1 text-muted hover-text-danger text-decoration-none d-flex flex-center">
                                                    <span class="material-symbols-outlined fs-6" style="font-size: 14px;">delete</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                    <div id="users-@channel.Id" class="d-none d-flex flex-column gap-1 ps-5 pe-2 py-1"></div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Members View -->
                <div id="sidebar-view-members" class="sidebar-view-pane d-flex flex-column overflow-hidden h-100">
                    <div class="px-4 py-3 border-bottom flex-shrink-0" style="border-color: rgba(255,255,255,0.05) !important;">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="badge rounded-pill glass-card border-0 px-2 py-1 fw-bold text-aurora" style="font-size: 0.65rem; background: rgba(0,245,160,0.1);">@Model.MemberCount MEMBERS</span>
                        </div>
                    </div>
                    
                    <div id="members-scroll-area" class="flex-grow-1 overflow-y-auto custom-scrollbar p-4 d-flex flex-column gap-2">
                        <div id="members-items-container" class="d-flex flex-column gap-2">
                            @foreach (var member in Model.TopMembers)
                            {
                                var isMe = member.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                var isOwner = member.UserId == Model.OwnerId;
                                var avatarBg = isOwner 
                                    ? "rgba(0,245,160,0.1); border:1px solid rgba(0,245,160,0.2);" 
                                    : "rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08);";
                                
                                <div class="member-card d-flex align-items-center gap-3 p-2 rounded-lg transition-all animate-entrance hover-card-trigger" 
                                     data-hover-type="user" data-hover-id="@member.UserId"
                                     style="background: rgba(255,255,255,0.02); min-height: 52px; cursor: pointer;">
                                    <div class="position-relative">
                                        @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                        {
                                            <div class="avatar-xs rounded-lg overflow-hidden border shadow-sm" style="background:@avatarBg">
                                                <img src="@member.AvatarUrl" class="w-100 h-100 object-cover" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="avatar-xs rounded-lg d-flex flex-center @(isOwner ? "text-aurora" : "text-muted") shadow-sm" 
                                                 style="background:@avatarBg">
                                                <span class="material-symbols-outlined fs-6">account_circle</span>
                                            </div>
                                        }
                                        @{
                                            var onlineUsers = ViewBag.OnlineUsers as string[] ?? new string[0];
                                            var isOnline = onlineUsers.Contains(member.UserId);
                                        }
                                        <div id="status-dot-@member.UserId" class="position-absolute rounded-circle border border-dark status-dot @(isOnline ? "online" : "offline")" 
                                             style="bottom: -2px; right: -2px; width: 10px; height: 10px; z-index: 2;"></div>
                                        @if(isOwner) {
                                            <div class="position-absolute d-flex flex-center shadow-sm" 
                                                 style="top:-4px;left:-4px;width:14px;height:14px; background:#fbbf24;border:2px solid var(--bg-universe);border-radius:50%; z-index: 3;">
                                                <span class="material-symbols-outlined text-white fw-black" style="font-size:8px;">star</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 min-w-0">
                                        <p class="fw-bold text-white text-truncate mb-0" style="font-size:0.75rem;">@(member.FullName ?? member.UserName ?? member.UserId)</p>
                                        @if(isOwner) {
                                            <span class="badge bg-aurora-glass text-aurora rounded-pill px-3 py-1 fw-semibold" style="font-size: 0.7rem;">Owner</span>
                                        } else {
                                            <span class="fw-bold text-muted" style="font-size:0.7rem;" id="role-badge-@member.UserId">@member.RoleName</span>
                                        }
                                    </div>

                                    @if (!isMe)
                                    {
                                        <div class="d-flex align-items-center gap-1 border-start ps-2" style="border-color: rgba(255,255,255,0.05) !important;" id="member-actions-@member.UserId">
                                            @if (Model.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value && member.RoleName == "Member")
                                            {
                                                <button onclick="promoteMember('@member.UserId')" class="btn btn-link p-1 text-warning hover-glow text-decoration-none d-flex flex-center shadow-none" title="Promote to Admin">
                                                    <span class="material-symbols-outlined fs-6">shield_person</span>
                                                </button>
                                            }
                                            @switch (member.ConnectionStatus)
                                            {
                                                case AskNLearn.Application.Common.Models.ConnectionStatus.Accepted:
                                                    <form asp-controller="Direct" asp-action="StartChat" method="post" class="mb-0">
                                                        <input type="hidden" name="userId" value="@member.UserId" />
                                                        <button type="submit" class="btn btn-link p-1 text-aurora hover-text-white text-decoration-none d-flex flex-center shadow-none" title="Send Message">
                                                            <span class="material-symbols-outlined fs-6">chat</span>
                                                        </button>
                                                    </form>
                                                    break;
                                                case AskNLearn.Application.Common.Models.ConnectionStatus.PendingSent:
                                                    <button class="btn btn-link p-1 text-muted opacity-50 text-decoration-none d-flex flex-center cursor-default shadow-none" title="Request Pending">
                                                        <span class="material-symbols-outlined fs-6">hourglass_empty</span>
                                                    </button>
                                                    break;
                                                case AskNLearn.Application.Common.Models.ConnectionStatus.PendingReceived:
                                                    <button onclick="acceptConnection('@member.UserId')" class="btn btn-link p-1 text-success hover-text-white text-decoration-none d-flex flex-center shadow-none" title="Accept Request">
                                                        <span class="material-symbols-outlined fs-6">check_circle</span>
                                                    </button>
                                                    break;
                                                default:
                                                    <button onclick="sendConnectionRequest('@member.UserId')" class="btn btn-link p-1 text-muted hover-text-white text-decoration-none d-flex flex-center shadow-none" title="Connect">
                                                        <span class="material-symbols-outlined fs-6">add</span>
                                                    </button>
                                                    break;
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        
                        <div id="members-load-spinner" class="@(Model.MemberCount <= 20 ? "d-none" : "") p-3 text-center">
                            <div class="spinner-border spinner-border-sm text-aurora" role="status"></div>
                        </div>
                        <div id="members-sentinel" class="py-1"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Footer & Voice Status -->
        <div class="mt-auto border-top p-0 bg-transparent" style="border-color: var(--border-glass) !important;">
            <!-- Voice Status Panel -->
            <div id="voiceStatusPanel" class="d-none animate-entrance">
                <div class="p-3 d-flex align-items-center justify-content-between border-bottom" style="border-color: var(--border-glass) !important;">
                    <div class="d-flex flex-column gap-1">
                        <div class="d-flex align-items-center gap-1">
                             <span class="material-symbols-outlined text-aurora fw-bold" style="font-size: 0.8rem;">wifi</span>
                            <span class="text-aurora fw-bold" style="font-size: 0.7rem;">Voice Connected</span>
                        </div>
                        <p id="connectedChannelName" class="text-white fw-bold mb-0 text-truncate" style="font-size: 0.75rem; max-width: 120px;">Channel Name</p>
                    </div>
                    <button onclick="leaveVoice()" class="btn btn-link p-2 text-muted hover-text-danger text-decoration-none d-flex align-items-center justify-content-center rounded-lg transition-all" title="Disconnect">
                        <span class="material-symbols-outlined fs-5">call_end</span>
                    </button>
                </div>
            </div>

            <!-- Discord-style Profile & Settings Footer -->
            <div class="user-panel-discord p-2">
                <div class="d-flex align-items-center justify-content-between discord-bg-dark p-2 rounded-lg">
                    <div class="d-flex align-items-center gap-2 flex-grow-1 min-w-0 user-clickable-zone px-1 py-1 rounded-3">
                        <div class="position-relative flex-shrink-0">
                            <div class="discord-avatar">
                                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@User.Identity?.Name" alt="avatar" class="rounded-circle w-100 h-100" />
                                <div class="discord-status-dot online"></div>
                            </div>
                        </div>
                        <div class="flex-grow-1 min-w-0 d-flex flex-column lh-tight">
                            <span class="fw-bold text-white text-truncate discord-username">@(User.Identity?.Name?.Split('@')[0] ?? "User")</span>
                            <div class="d-flex align-items-center gap-1 opacity-75">
                                <span class="material-symbols-outlined text-aurora" style="font-size: 0.8rem;">smart_toy</span>
                                <span class="text-white fw-bold" style="font-size: 0.65rem;">27</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center gap-0">
                        <button onclick="toggleMic()" id="micButton" class="btn btn-icon-discord" title="Mute">
                            <span id="micIcon" class="material-symbols-outlined">mic</span>
                        </button>
                        <button onclick="toggleDeafen()" id="deafenButton" class="btn btn-icon-discord" title="Deafen">
                            <span id="deafenIcon" class="material-symbols-outlined">headphones</span>
                        </button>
                        <a asp-controller="Profile" asp-action="Index" class="btn btn-icon-discord" title="User Settings">
                            <span class="material-symbols-outlined">settings</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        </div>
        @if (!Model.IsMember)
        {
            <div class="blur-overlay d-flex flex-column gap-3 p-4 text-center">
                <span class="material-symbols-outlined text-white display-1">lock</span>
                <h4 class="text-white fw-bold">Join to reveal content</h4>
                <button onclick="joinGroup()" class="btn btn-premium px-5 py-3">Join Study Group</button>
            </div>
        }
    </div>
}

<style>
    .voice-talking {
        box-shadow: 0 0 0 2px var(--color-emerald);
        animation: voice-pulse 1.5s infinite;
    }

    @@keyframes voice-pulse {
        0% { box-shadow: 0 0 0 0px rgba(0,245,160, 0.4); }
        70% { box-shadow: 0 0 0 6px rgba(0,245,160, 0); }
        100% { box-shadow: 0 0 0 0px rgba(0,245,160, 0); }
    }

    /* Smooth channel item hover — cubic-bezier matching sidebar feel */
    .channel-item {
        transition: background 0.3s var(--ease-smooth), color 0.25s var(--ease-smooth), transform 0.25s var(--ease-snappy), box-shadow 0.3s var(--ease-smooth);
        border-radius: 0.5rem;
        position: relative;
        overflow: hidden;
    }

    .channel-item::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(0,245,160,0.07) 0%, transparent 100%);
        opacity: 0;
        transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        border-radius: inherit;
    }
        .channel-item:hover {
            background: rgba(255,255,255,0.07) !important;
            color: white !important;
            transform: translateX(4px);
        }
    .channel-item:hover::before { opacity: 1; }
    .channel-item:hover .channel-icon { color: var(--color-aurora) !important; }
    .channel-item.active-channel {
        background: rgba(0,245,160,0.08) !important;
        color: white !important;
    }
    .channel-item.active-channel::before { opacity: 1; }

    /* Slider specific */
    .sidebar-slider-track {
        display: flex;
        width: 200%;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sidebar-view-pane {
        width: 50%;
        flex-shrink: 0;
        height: 100%;
        background: transparent !important;
    }

    .member-card {
        transition: all 0.25s var(--ease-smooth);
        border: 1px solid transparent;
    }
    .member-card:hover {
        background: rgba(255, 255, 255, 0.05) !important;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.05);
    }
    .member-card:hover .avatar-xs {
        transform: scale(1.05);
    }
    .view-members-active #sidebar-slider-track {
        transform: translateX(-50%);
    }

    /* Tab Button Hover */
    .sidebar-tab-btn {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        opacity: 0.7;
    }
    .sidebar-tab-btn:hover {
        opacity: 1;
        transform: scale(1.05);
        text-shadow: 0 0 12px rgba(0, 245, 160, 0.5);
    }
    .sidebar-tab-btn.text-aurora {
        opacity: 1;
    }

    /* Status Dots */
    :root {
        --color-status-online: #22c55e;
        --color-status-offline: #64748b;
        --color-status-away: #eab308;
    }

    .status-dot {
        transition: background-color 0.3s ease, box-shadow 0.3s ease;
    }
    .status-dot.online {
        background-color: var(--color-status-online) !important;
        box-shadow: 0 0 8px rgba(34, 197, 94, 0.4);
    }
    .status-dot.offline {
        background-color: var(--color-status-offline) !important;
    }

    /* Discord User Panel Styles */
    .user-panel-discord {
        background: rgba(0, 0, 0, 0.2);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }
    .discord-bg-dark {
        background: rgba(30, 31, 34, 0.6);
        transition: background 0.2s ease;
    }
    .user-clickable-zone:hover {
        background: rgba(255, 255, 255, 0.05);
        cursor: pointer;
    }
    .discord-avatar {
        width: 32px;
        height: 32px;
        background: #313338;
        border-radius: 50%;
        position: relative;
    }
    .discord-status-dot {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid #232428;
    }
    .discord-username {
        font-size: 0.85rem;
        letter-spacing: -0.2px;
    }
    .btn-icon-discord {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #b5bac1;
        border-radius: 4px;
        border: none;
        background: transparent;
        transition: all 0.2s ease;
    }
    .btn-icon-discord:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #dbdee1;
    }
    .btn-icon-discord .material-symbols-outlined {
        font-size: 1.25rem;
    }

    /* Channel Management Hover */
    .group-channel-wrapper:hover .delete-channel-form {
        display: flex !important;
        animation: fadeIn 0.2s ease-out;
    }
    
    .hover-aurora:hover {
        color: var(--color-mint-bright) !important;
        transform: scale(1.1);
    }
    .discord-muted {
        color: #f23f42 !important;
    }
    .btn-icon-discord.discord-muted:hover {
        background: rgba(242, 63, 66, 0.1) !important;
    }
    .discord-status-dot.online {
        background-color: #23a55a !important;
        box-shadow: 0 0 0 2px #2b2d31;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes animate-entrance {
        0% { opacity: 0; transform: scale(0.95) translateY(10px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    .animate-entrance {
        animation: animate-entrance 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>


<div id="drop-zone" class="d-none position-fixed top-0 bottom-0 start-0 end-0 z-3 align-items-center justify-content-center" style="background: rgba(15,23,42,0.8); backdrop-filter: blur(5px); z-index: 1060; pointer-events: none;">
    <div class="glass-card p-5 d-flex flex-column align-items-center gap-4 animate-entrance" style="border: 2px dashed var(--color-emerald);">
        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: rgba(0,245,160,0.1);">
            <span class="material-symbols-outlined text-aurora" style="font-size: 3rem;">upload_file</span>
        </div>
        <p class="fs-4 fw-bold text-white mb-0">Release to upload files</p>
    </div>
</div>

<!-- Ambient Glow -->
<div class="position-absolute top-0 start-50 translate-middle-x rounded-circle opacity-10" style="width: 800px; height: 400px; background: radial-gradient(circle, var(--color-mint-bright) 0%, transparent 70%); filter: blur(100px); pointer-events: none;"></div>

<!-- Main Content Area -->
<div class="d-flex flex-column flex-md-row h-100 flex-grow-1 overflow-hidden w-100 position-relative bg-transparent">
    <div class="blur-content d-flex flex-column flex-md-row h-100 flex-grow-1 overflow-hidden w-100 position-relative bg-transparent">
    <!-- Center Feed -->
    <main class="d-flex flex-column flex-grow-1 min-w-0 position-relative">
        <!-- Video Strip -->
        <div id="videoGrid" class="d-none flex-row gap-3 p-3 overflow-x-auto custom-scrollbar transition-all" style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border-glass); min-height: 180px; max-height: 180px;">
            <div id="localVideoContainer" class="d-none position-relative bg-black rounded-lg overflow-hidden border shadow-lg flex-shrink-0 animate-entrance" style="width: 240px; height: 148px; border-color: var(--border-glass) !important;">
                <video id="localVideo" autoplay muted playsinline class="w-100 h-100 object-cover"></video>
                <div class="position-absolute bottom-0 start-0 m-2 px-2 py-0.5 glass-card rounded-lg" style="background: rgba(0,0,0,0.5);">
                    <span class="fw-black text-white" style="font-size: 0.6rem;">You</span>
                </div>
            </div>
        </div>

        <div class="flex-grow-1 overflow-y-auto p-4 p-md-5 custom-scrollbar">
            <div class="mx-auto" style="max-width: 800px;">
                <!-- Welcome Section -->
                @if (!Model.IsMember && !User.IsInRole("Admin") && !User.IsInRole("Moderator"))
                {
                <section class="py-5 text-center position-relative mb-5" id="welcome-hero">
                    <div class="position-absolute start-50 top-50 translate-middle rounded-circle" style="width: 200px; height: 200px; background: var(--gradient-aurora); filter: blur(60px); opacity: 0.15;"></div>
                    <div class="d-flex align-items-center justify-content-center mx-auto mb-4 position-relative z-1">
                        <div class="rounded-lg d-flex align-items-center justify-content-center shadow-lg transition-transform" style="width: 80px; height: 80px; background: var(--gradient-aurora); color: var(--bg-universe); transform: rotate(5deg);">
                            <span class="material-symbols-outlined fw-bold" style="font-size: 2.5rem;">auto_awesome</span>
                        </div>
                    </div>
                    <h2 class="display-5 fw-black text-white mb-4 position-relative z-1">
                        Welcome to <span class="text-aurora" style="font-style: italic;">@Model.Name</span>
                    </h2>
                    <p class="fs-5 text-muted fw-medium mx-auto mb-5 position-relative z-1" style="max-width: 600px;">
                        @(string.IsNullOrEmpty(Model.Description) ? "This is the start of your learning journey. Collaborate, study, and grow together!" : Model.Description)
                    </p>
                    @if (!Model.IsMember)
                    {
                        <div class="position-relative z-1">
                            <button onclick="joinGroup('@Model.Id')" id="main-join-btn" class="btn btn-premium btn-lg px-5 py-3 rounded-pill fw-black shadow-lg animate-pulse">
                                JOIN STUDY GROUP
                            </button>
                        </div>
                    }
                </section>
                }
                <hr class="w-100 border-top" style="border-color: var(--border-glass) !important;" />
            </div>
        </div>
        
        <!-- Quick Input Bar -->
        <div class="p-4 position-absolute bottom-0 start-0 end-0 pointer-events-none" style="background: linear-gradient(to top, var(--bg-universe) 40%, transparent);">
            <div class="mx-auto w-100 pointer-events-auto position-relative" style="max-width: 800px;">
                <div id="picker-popup" class="d-none position-absolute bottom-100 start-0 mb-3 glass-card flex-column overflow-hidden animate-entrance" style="width: 320px; height: 380px; z-index: 1050;">
                    <div class="d-flex border-bottom" style="border-color: var(--border-glass) !important;">
                        <button onclick="switchPickerTab('emoji')" id="tab-emoji" class="btn btn-link flex-grow-1 py-3 px-0 rounded-0 text-decoration-none d-flex flex-center" style="border-bottom: 2px solid var(--color-emerald) !important;">
                            <span class="material-symbols-outlined text-aurora">mood</span>
                        </button>
                        <button onclick="switchPickerTab('gif')" id="tab-gif" class="btn btn-link flex-grow-1 py-3 px-0 rounded-0 text-decoration-none d-flex flex-center" style="border-bottom: 2px solid transparent !important;">
                            <span class="material-symbols-outlined text-muted hover-glow">gif_box</span>
                        </button>
                    </div>
                    <div id="emoji-picker-container" class="flex-grow-1 overflow-hidden"></div>
                    <div id="gif-picker-container" class="d-none flex-grow-1 flex-column p-3 overflow-hidden" style="display: flex;">
                        <div class="position-relative mb-3">
                            <input type="text" id="gif-search" placeholder="Search Giphy..." class="form-control form-control-glass ps-5 text-white" style="font-size: 0.8rem; border-radius: 0.75rem;">
                            <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                        </div>
                        <div id="gif-results" class="flex-grow-1 overflow-y-auto d-grid custom-scrollbar gap-2" style="grid-template-columns: 1fr 1fr;">
                            <!-- GIFs via JS -->
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div id="input-container" class="glass-card d-flex align-items-center flex-grow-1 gap-3 p-2 px-4 shadow-lg transition-all" style="border-radius: 2rem; background: rgba(255,255,255,0.03) !important; border-color: var(--border-glass) !important;">
                        <input type="file" id="chat-attachment-input" class="d-none" multiple onchange="handleChatAttachment(this)" />
                        <button id="attachment-btn" onclick="document.getElementById('chat-attachment-input').click()" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center">
                            <span class="material-symbols-outlined fs-4">add_circle</span>
                        </button>
                        <input type="text" id="message-input" placeholder="Message to @Model.Name..." class="form-control bg-transparent border-0 text-white shadow-none ps-0" style="font-size: 0.95rem;">
                        <button id="emoji-btn" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center">
                            <span class="material-symbols-outlined fs-4">mood</span>
                        </button>
                    </div>
                    <button id="send-btn" onclick="sendMessage()" class="btn btn-premium d-flex align-items-center justify-content-center rounded-pill px-4" style="height: 52px; min-width: 100px; font-size: 0.85rem; font-weight: 800;">SEND</button>
                </div>
            </div>
        </div>
    </div>
    @if (!Model.IsMember && !User.IsInRole("Admin") && !User.IsInRole("Moderator"))
    {
        <div class="blur-overlay d-flex flex-column gap-3 p-4 text-center">
            <span class="material-symbols-outlined text-white display-1">lock</span>
            <h4 class="text-white fw-bold" style="font-size: 1.5rem;">Join to participate</h4>
            <p class="text-muted mb-4">You need to be a member to see messages and use voice channels.</p>
            <button onclick="joinGroup('@Model.Id')" class="btn btn-premium px-5 py-3 rounded-pill shadow-lg animate-pulse">Join Study Group</button>
        </div>
    }
</div>

<!-- Modal: Create Channel -->
<div id="createChannelModal" class="d-none position-fixed top-0 bottom-0 start-0 end-0 z-3 align-items-center justify-content-center p-3" style="z-index: 1060; display: flex;">
    <div class="position-absolute top-0 bottom-0 start-0 end-0" style="background: rgba(2,6,23,0.8); backdrop-filter: blur(5px);" onclick="closeCreateChannelModal()"></div>
    <div class="glass-card position-relative z-1 w-100 animate-entrance" style="max-width: 500px; padding: 2.5rem;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="h3 fw-black text-white mb-1">Create <span id="modalChannelTypeLabel" class="text-aurora">Channel</span></h2>
                <p class="small fw-medium text-muted mb-0">Setup a new space for collaboration.</p>
            </div>
            <button onclick="closeCreateChannelModal()" class="btn btn-link p-2 text-muted hover-text-danger d-flex flex-center rounded-lg bg-dark border-0">
                <span class="material-symbols-outlined fs-5">close</span>
            </button>
        </div>

        <form asp-action="CreateChannel" method="post" class="d-flex flex-column gap-4">
            <input type="hidden" name="GroupId" value="@Model.Id" />
            <input type="hidden" name="Type" id="modalChannelTypeInput" value="0" />

            <div class="d-flex flex-column gap-2">
                <label class="fw-bold text-muted ms-1" style="font-size: 0.7rem;">Channel Name</label>
                <div class="position-relative">
                    <span class="position-absolute top-50 translate-middle-y fw-bold text-muted transition-colors" style="left: 1rem; font-size: 1.25rem;">#</span>
                    <input type="text" name="Name" required placeholder="new-channel" 
                           class="form-control form-control-glass w-100 fw-bold text-white ps-5 py-3" style="border-radius: 1rem;" />
                </div>
            </div>

            <div class="d-flex flex-column gap-2">
                <label class="fw-bold text-muted ms-1" style="font-size: 0.7rem;">Topic (Optional)</label>
                <textarea name="Topic" rows="2" placeholder="What is this channel about?" 
                          class="form-control form-control-glass w-100 fw-medium text-white p-3" style="border-radius: 1rem;"></textarea>
            </div>

            <div class="d-flex gap-3 mt-2">
                <button type="button" onclick="closeCreateChannelModal()" class="btn btn-glass flex-grow-1 fw-bold py-3" style="font-size: 0.85rem;">Cancel</button>
                <button type="submit" class="btn btn-premium flex-grow-1 fw-bold py-3" style="font-size: 0.85rem; flex: 2;">Create Channel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/emoji-mart@latest/dist/browser.js"></script>
    <script>
        // ── State & Constants ──────────────────────────────────────────────────
        const GROUP_ID = '@Model.Id';
        const CURRENT_USER_ID = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
        const IS_OWNER = @Json.Serialize(Model.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value);
        
        // Final access check: Member OR Admin OR Moderator
        const IS_MEMBER = @( (Model.IsMember || User.IsInRole("Admin") || User.IsInRole("Moderator")) ? "true" : "false" );

        document.addEventListener('DOMContentLoaded', () => {
            // Auto-select first channel if member and no channel selected (Welcome hidden)
            if (IS_MEMBER) {
                const firstChannel = document.querySelector('.group-channel-wrapper');
                if (firstChannel) {
                    console.log("[UI] Auto-selecting first channel for member...");
                    firstChannel.click();
                }
            }
        });

        function switchSidebarView(view) {
            const container = document.getElementById('sidebar-view-container');
            const btnChannels = document.getElementById('btn-view-channels');
            const btnMembers = document.getElementById('btn-view-members');

            if (view === 'members') {
                container.classList.add('view-members-active');
                
                // Update Buttons
                btnMembers.classList.add('text-aurora');
                btnMembers.classList.remove('text-muted');
                btnMembers.style.borderBottom = '2px solid var(--color-mint-bright) !important';
                
                btnChannels.classList.remove('text-aurora');
                btnChannels.classList.add('text-muted');
                btnChannels.style.borderBottom = '2px solid transparent !important';

                // Initialize members lazy load if needed
                initMembersLazyLoad();
            } else {
                container.classList.remove('view-members-active');
                
                // Update Buttons
                btnChannels.classList.add('text-aurora');
                btnChannels.classList.remove('text-muted');
                btnChannels.style.borderBottom = '2px solid var(--color-mint-bright) !important';
                
                btnMembers.classList.remove('text-aurora');
                btnMembers.classList.add('text-muted');
                btnMembers.style.borderBottom = '2px solid transparent !important';
            }
        }

        function openCreateChannelModal(type) {
            const modal = document.getElementById('createChannelModal');
            const typeLabel = document.getElementById('modalChannelTypeLabel');
            const typeInput = document.getElementById('modalChannelTypeInput');
            
            if (typeLabel) typeLabel.innerText = type;
            if (typeInput) typeInput.value = (type === 'Text') ? 0 : 1;
            
            if (modal) {
                modal.classList.remove('d-none');
                modal.classList.add('animate-entrance');
            }
        }

        function closeCreateChannelModal() {
            const modal = document.getElementById('createChannelModal');
            if (modal) modal.classList.add('d-none');
        }

        let currentTextChannelId = null;
        let currentVoiceChannelId = null;
        let localStream = null;
        let isMuted = false;
        let isVideoOn = false;
        let isDeafened = false;
        const peers = {};
        const iceServers = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };

        // Members lazy load state
        let membersSkip = 20;
        let membersLoading = false;
        let membersAllLoaded = @(Model.MemberCount <= 20 ? "true" : "false");
        let membersObserver = null;

        // ── SignalR Lifecycle ──────────────────────────────────────────────────
        window.onSignalRConnected = () => {
            setupStudyGroupHandlers();
            if (!IS_MEMBER) {
                document.querySelectorAll('.blur-content').forEach(el => el.classList.add('blur-active'));
            }
        };

        window.onSignalRReconnected = () => {
            if (currentTextChannelId) connection.invoke("JoinChannel", currentTextChannelId);
            if (currentVoiceChannelId) connection.invoke("JoinVoice", currentVoiceChannelId);
        };

        async function ensureConnection() {
            if (!window.signalRReady) {
                await new Promise(resolve => {
                    const check = setInterval(() => {
                        if (window.signalRReady) { clearInterval(check); resolve(); }
                    }, 100);
                });
            }
            if (connection.state !== signalR.HubConnectionState.Connected) {
                await window.startSignalR();
            }
        }

        // ── SignalR Handlers ───────────────────────────────────────────────────
        function setupStudyGroupHandlers() {
            if (!window.connection) return;

            connection.on("ReceiveMessage", (message) => {
                if (currentTextChannelId === message.channelId) {
                    appendMessage(message);
                }
            });

            connection.on("UserJoinedVoice", async (data) => {
                const container = document.getElementById(`users-${data.channelId}`);
                if (container && !document.getElementById(`user-indicator-${data.connectionId}`)) {
                    container.classList.remove('d-none');
                    const userHtml = `
                        <div id="user-indicator-${data.connectionId}" class="d-flex align-items-center gap-2 py-1 animate-entrance px-2">
                            <div class="position-relative">
                                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=${data.userName}" class="avatar-xs rounded-lg object-cover" />
                                <div id="micOffIcon-${data.connectionId}" class="d-none position-absolute d-flex flex-center bg-danger rounded-circle border border-dark shadow-sm" style="bottom: -4px; right: -4px; width: 14px; height: 14px;">
                                    <span class="material-symbols-outlined text-white fw-black" style="font-size: 8px;">mic_off</span>
                                </div>
                            </div>
                            <span class="fw-bold text-muted" style="font-size: 0.65rem;">${data.userName}</span>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', userHtml);
                }
                if (currentVoiceChannelId && data.connectionId !== connection.connectionId) {
                    await createPeerConnection(data.connectionId, true);
                }
            });

            connection.on("UserLeftVoice", (connectionId) => {
                if (peers[connectionId]) {
                    peers[connectionId].pc.close();
                    delete peers[connectionId];
                }
                const el = document.getElementById(`peer-audio-${connectionId}`);
                if (el) el.remove();
                const uiEl = document.getElementById(`user-indicator-${connectionId}`);
                if (uiEl) uiEl.remove();
            });

            connection.on("UserMuteChanged", (connectionId, muted) => {
                const icon = document.getElementById(`micOffIcon-${connectionId}`);
                if (icon) {
                    if (muted) icon.classList.remove('d-none');
                    else icon.classList.add('d-none');
                }
            });
            
            connection.on("UserSpeakingChanged", (connectionId, speaking) => {
                const avatar = document.querySelector(`#user-indicator-${connectionId} img`);
                if (avatar) {
                    if (speaking) avatar.classList.add('voice-talking');
                    else avatar.classList.remove('voice-talking');
                }
            });
        }

        // ── WebRTC ─────────────────────────────────────────────────────────────
        async function createPeerConnection(connectionId, isOffer) {
            const pc = new RTCPeerConnection(iceServers);
            peers[connectionId] = { pc };
            pc.onicecandidate = (event) => {
                if (event.candidate) connection.invoke("SendSignal", JSON.stringify({ candidate: event.candidate }), connectionId);
            };
            pc.ontrack = (event) => {
                if (event.track.kind === 'audio') {
                    let audio = document.getElementById(`peer-audio-${connectionId}`);
                    if (!audio) {
                        audio = document.createElement('audio');
                        audio.id = `peer-audio-${connectionId}`;
                        audio.autoplay = true;
                        document.body.appendChild(audio);
                    }
                    audio.srcObject = event.streams[0];
                }
            };
            if (localStream) localStream.getTracks().forEach(track => pc.addTrack(track, localStream));
            if (isOffer) {
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);
                connection.invoke("SendSignal", JSON.stringify({ sdp: offer }), connectionId);
            }
            return peers[connectionId];
        }

        // ── Voice / Video Controls ──────────────────────────────────────────────
        async function joinVoice(id, name) {
            if (!IS_MEMBER) { alert("Join the group to use voice channels."); return; }
            await ensureConnection();
            if (currentVoiceChannelId === id) return;
            if (currentVoiceChannelId) await leaveVoice();
            try {
                localStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
                currentVoiceChannelId = id;
                await connection.invoke("JoinVoice", id);
                document.getElementById('voiceStatusPanel').classList.remove('d-none');
                document.getElementById('connectedChannelName').innerText = name;
                
                // Local indicator for voice panel
                const container = document.getElementById(`users-${id}`);
                if (container) {
                    container.classList.remove('d-none');
                    const myUserName = "@(User.Identity?.Name ?? "User")";
                    const userHtml = `
                        <div id="user-indicator-local" class="d-flex align-items-center gap-2 py-1 animate-entrance px-2">
                            <div class="position-relative">
                                <div id="localVoiceAvatar" class="avatar-xs rounded-circle d-flex flex-center text-primary fw-bold text-uppercase transition-all" style="background: rgba(0,245,160,0.2); font-size: 10px; border: 1px solid var(--color-emerald);">
                                    ${myUserName.charAt(0)}
                                </div>
                                <div id="localMicOffIcon" class="${isMuted ? '' : 'd-none'} position-absolute d-flex flex-center bg-danger rounded-circle border border-dark shadow-sm" style="bottom: -4px; right: -4px; width: 14px; height: 14px;">
                                    <span class="material-symbols-outlined text-white fw-black" style="font-size: 8px;">mic_off</span>
                                </div>
                            </div>
                            <span class="fw-bold text-aurora" style="font-size: 0.65rem;">${myUserName} (You)</span>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', userHtml);
                }
            } catch (err) { alert("Microphone access denied."); }
        }

        async function leaveVoice() {
            if (!currentVoiceChannelId) return;
            await connection.invoke("LeaveVoice", currentVoiceChannelId);
            Object.keys(peers).forEach(id => {
                peers[id].pc.close();
                delete peers[id];
            });
            if (localStream) {
                localStream.getTracks().forEach(t => t.stop());
                localStream = null;
            }
            const myIndicator = document.getElementById('user-indicator-local');
            if (myIndicator) myIndicator.remove();
            document.getElementById('voiceStatusPanel').classList.add('d-none');
            currentVoiceChannelId = null;
        }

        function toggleMic() {
            if (!localStream) return;
            isMuted = !isMuted;
            localStream.getAudioTracks().forEach(track => track.enabled = !isMuted);
            document.getElementById('micIcon').innerText = isMuted ? 'mic_off' : 'mic';
            document.getElementById('micButton').classList.toggle('text-danger', isMuted);
            const localMicOff = document.getElementById('localMicOffIcon');
            if (localMicOff) localMicOff.classList.toggle('d-none', !isMuted);
            if (currentVoiceChannelId) connection.invoke("ToggleMute", currentVoiceChannelId, isMuted);
        }

        function toggleDeafen() {
            isDeafened = !isDeafened;
            document.getElementById('deafenIcon').innerText = isDeafened ? 'headphones_off' : 'headphones';
            document.getElementById('deafenButton').classList.toggle('text-danger', isDeafened);
            if (isDeafened && !isMuted) toggleMic();
            else if (!isDeafened && isMuted) toggleMic();
        }

        // ── Channel & Message Logic ───────────────────────────────────────────────
        async function joinTextChannel(id, name) {
            if (!IS_MEMBER) { alert("Join the group to view messages."); return; }
            await ensureConnection();
            if (currentTextChannelId === id) return;
            if (currentTextChannelId) await connection.invoke("LeaveChannel", currentTextChannelId);
            currentTextChannelId = id;
            await connection.invoke("JoinChannel", id);
            
            document.getElementById('message-input').placeholder = `Message to #${name}...`;
            
            // UI Active State
            document.querySelectorAll('.channel-item').forEach(el => el.classList.remove('active-channel'));
            const activeEl = document.querySelector(`.channel-item[onclick*="${id}"]`);
            if (activeEl) activeEl.classList.add('active-channel');

            // Toggle Welcome visibility
            const welcome = document.querySelector('section.py-5');
            const hr = document.querySelector('hr.border-top');
            if (welcome) welcome.classList.add('d-none');
            if (hr) hr.classList.add('d-none');

            // Load and display messages
            const container = document.getElementById('messages-container');
            if (container) {
                container.innerHTML = `<div class="py-5 text-center opacity-75"><div class="spinner-border text-aurora mb-3"></div><p class="text-muted small fw-bold">Loading history...</p></div>`;
                try {
                    const resp = await fetch(`/StudyGroups/GetChannelMessages?channelId=${id}`);
                    const messages = await resp.json();
                    container.innerHTML = '';
                    if (messages.length === 0) {
                        container.innerHTML = `<div class="py-5 text-center opacity-50"><p class="text-aurora fw-bold">Welcome to #${name}</p></div>`;
                    } else {
                        messages.forEach(appendMessage);
                    }
                    container.scrollTop = container.scrollHeight;
                } catch (e) { container.innerHTML = '<p class="text-danger text-center py-5">Error loading history.</p>'; }
            }
        }

        function appendMessage(msg) {
            const container = document.getElementById('messages-container');
            if (!container) return;
            const isMine = msg.authorId === CURRENT_USER_ID;
            const msgHtml = `
                <div class="d-flex w-100 ${isMine ? 'justify-content-end' : 'justify-content-start'} animate-entrance mb-4">
                    <div class="d-flex ${isMine ? 'flex-row-reverse' : ''} gap-3" style="max-width: 80%;">
                        <img src="${msg.authorAvatar}" class="avatar-sm rounded-lg shadow-sm border" style="border-color: var(--border-glass) !important;"/>
                        <div class="d-flex flex-column ${isMine ? 'align-items-end' : ''}">
                             <div class="d-flex align-items-center gap-2 mb-1 px-1">
                                <span class="fw-bold text-muted" style="font-size: 0.6rem;">${msg.authorName}</span>
                                <span class="text-muted" style="font-size: 0.55rem;">${msg.createdAt}</span>
                             </div>
                             <div class="p-3 shadow-lg" style="border-radius: 1rem; ${isMine ? 'background: var(--gradient-aurora); color: var(--bg-universe);' : 'background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white;'}">
                                ${msg.content.startsWith('http') ? `<img src="${msg.content}" class="img-fluid rounded" />` : `<p class="mb-0" style="font-size: 0.9rem;">${msg.content}</p>`}
                             </div>
                        </div>
                    </div>
                </div>`;
            container.insertAdjacentHTML('beforeend', msgHtml);
            container.scrollTop = container.scrollHeight;
        }

        window.sendMessage = async function() {
            if (!IS_MEMBER) { alert("Join group to send messages."); return; }
            const input = document.getElementById('message-input');
            const content = input.value.trim();
            if (!content || !currentTextChannelId) return;
            await ensureConnection();
            try {
                await connection.invoke("SendMessage", currentTextChannelId, content);
                input.value = '';
                input.focus();
            } catch (err) { console.error("SignalR Send Error:", err); }
        }

        // ── Join Group Logic ───────────────────────────────────────────────────────
        window.joinGroup = async function(id = GROUP_ID) {
            const btn = document.getElementById('main-join-btn') || event?.currentTarget;
            if(btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Joining...';
            }
            try {
                const resp = await fetch(`/StudyGroups/Join/${id}`, { method: 'POST' });
                if (resp.ok) {
                    location.reload(true); // Force fresh reload
                } else {
                    alert("Failed to join group.");
                    if(btn) { btn.disabled = false; btn.innerText = 'JOIN STUDY GROUP'; }
                }
            } catch (e) { 
                alert("Connection error.");
                if(btn) { btn.disabled = false; btn.innerText = 'JOIN STUDY GROUP'; }
            }
        }

        // ── Member Management ──────────────────────────────────────────────────────
        function buildMemberHtml(m) {
            const name = m.fullName || m.userName || m.id;
            const isMe = m.id === CURRENT_USER_ID;
            return `<div class="d-flex align-items-center gap-3 p-2 rounded-lg hover-glow transition-all" style="background:rgba(255,255,255,0.02);">
                <div class="position-relative">
                    <div class="avatar-xs rounded-lg d-flex flex-center bg-glass text-muted"><span class="material-symbols-outlined fs-6">account_circle</span></div>
                    <div id="status-dot-${m.id}" class="position-absolute rounded-circle border border-dark status-dot offline" style="bottom:-2px;right:-2px;width:10px;height:10px;"></div>
                </div>
                <div class="flex-grow-1 min-w-0">
                    <p class="fw-bold text-white text-truncate mb-0" style="font-size:0.75rem;">${name}</p>
                    <span class="fw-bold text-muted" style="font-size:0.7rem;">${m.roleName || 'Member'}</span>
                </div>
            </div>`;
        }

        async function loadMoreMembers() {
            if (membersLoading || membersAllLoaded) return;
            membersLoading = true;
            try {
                const resp = await fetch(`/StudyGroups/LoadMoreMembers?groupId=${GROUP_ID}&skip=${membersSkip}&take=20`);
                const data = await resp.json();
                const container = document.getElementById('members-items-container');
                if (container) data.members.forEach(m => container.insertAdjacentHTML('beforeend', buildMemberHtml(m)));
                membersSkip = data.nextSkip;
                membersAllLoaded = !data.hasMore;
                }
            } catch(e) { console.error('Members load error:', e); }
            finally {
                membersLoading = false;
                if (spinner) spinner.classList.add('d-none');
            }
        }

        function initMembersLazyLoad() {
            if (membersAllLoaded || (membersObserver && document.getElementById('members-items-container')?.children.length > 20)) return;
            const sentinel = document.getElementById('members-sentinel');
            const scrollArea = document.getElementById('members-scroll-area');
            if (!sentinel || !scrollArea) return;
            
            if (membersObserver) membersObserver.disconnect();
            
            membersObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting) loadMoreMembers();
            }, { 
                root: scrollArea,
                threshold: 0.1 
            });
            membersObserver.observe(sentinel);
        }

        // Connection Actions JS
        async function sendConnectionRequest(userId) {
            const resp = await fetch(`/Connections/SendRequest?userId=${userId}`, { method: 'POST' });
            if (resp.ok) {
                const data = await resp.json();
                document.getElementById(`member-actions-${userId}`).innerHTML = 
                    `<button class="btn btn-link p-1 text-muted opacity-50 text-decoration-none d-flex flex-center cursor-default" title="Request Pending"><span class="material-symbols-outlined fs-6">hourglass_empty</span></button>`;
            }
        }

        async function acceptConnection(userId) {
            const resp = await fetch(`/Connections/AcceptRequest?userId=${userId}`, { method: 'POST' });
            if (resp.ok) {
                document.getElementById(`member-actions-${userId}`).innerHTML = `
                    <form action="/Direct/StartChat" method="post" class="mb-0">
                        <input type="hidden" name="userId" value="${userId}" />
                        <button type="submit" class="btn btn-link p-1 text-aurora hover-glow text-decoration-none d-flex flex-center" title="Send Message">
                            <span class="material-symbols-outlined fs-6">chat</span>
                        </button>
                    </form>`;
            }
        }

        async function declineConnection(userId) {
            const resp = await fetch(`/Connections/DeclineRequest?userId=${userId}`, { method: 'POST' });
            if (resp.ok) {
                document.getElementById(`member-actions-${userId}`).innerHTML = `
                    <button onclick="sendConnectionRequest('${userId}')" class="btn btn-link p-1 text-muted hover-text-white hover-glow text-decoration-none d-flex flex-center" title="Connect">
                        <span class="material-symbols-outlined fs-6">person_add</span>
                    </button>`;
            }
        }
        async function promoteMember(userId) {
            if (!confirm('Are you sure you want to promote this member to Admin?')) return;
            const resp = await fetch(`/StudyGroups/PromoteMember?groupId=${GROUP_ID}&userId=${userId}`, { method: 'POST' });
            if (resp.ok) {
                showToast('Success', 'Member promoted to Admin', 'success');
                const badge = document.getElementById(`role-badge-${userId}`);
                if (badge) {
                    badge.innerText = 'Admin';
                    badge.classList.remove('text-muted');
                    badge.classList.add('text-warning');
                }
                // Try to remove the button
                if (event && event.currentTarget) {
                    event.currentTarget.remove();
                }
            } else {
                showToast('Error', 'Failed to promote member', 'error');
            }
        }
    </script>
}
