@using AskNLearn.Web.Models
@using AskNLearn.Application.Features.StudyGroups.Queries
@model EditStudyGroupViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Edit Study Group";
}

<div class="p-8 max-w-2xl mx-auto pb-20">
    <div class="mb-8">
        <a asp-action="Details" asp-route-id="@Model.Command.Id" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-primary transition-colors mb-4">
            <span class="material-symbols-outlined text-sm mr-1">arrow_back</span>
            Back to Group
        </a>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Edit Study Group</h2>
        <p class="text-slate-500 dark:text-slate-400">Update your group settings and manage channels.</p>
    </div>

    <div class="space-y-8">
        <!-- Group Settings Form -->
        <section>
            <form asp-action="Edit" method="post" class="space-y-6 bg-surface-light dark:bg-surface-dark p-8 rounded-2xl border border-border-light dark:border-border-dark shadow-sm">
                <input type="hidden" asp-for="Command.Id" />
                
                <div class="space-y-2">
                    <label asp-for="Command.Name" class="text-sm font-bold text-slate-700 dark:text-slate-300">Group Name</label>
                    <input asp-for="Command.Name" class="w-full bg-white dark:bg-background-dark border border-border-light dark:border-border-dark rounded-xl py-3 px-4 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white" />
                    <span asp-validation-for="Command.Name" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Command.SubjectArea" class="text-sm font-bold text-slate-700 dark:text-slate-300">Subject Area</label>
                    <input asp-for="Command.SubjectArea" class="w-full bg-white dark:bg-background-dark border border-border-light dark:border-border-dark rounded-xl py-3 px-4 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white" />
                    <span asp-validation-for="Command.SubjectArea" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Command.Description" class="text-sm font-bold text-slate-700 dark:text-slate-300">Description</label>
                    <textarea asp-for="Command.Description" rows="4" class="w-full bg-white dark:bg-background-dark border border-border-light dark:border-border-dark rounded-xl py-3 px-4 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white"></textarea>
                    <span asp-validation-for="Command.Description" class="text-xs text-red-500"></span>
                </div>

                <div class="flex items-center gap-3 p-4 rounded-xl bg-slate-50 dark:bg-background-dark border border-border-light dark:border-border-dark">
                    <input asp-for="Command.IsPublic" type="checkbox" class="size-5 rounded border-border-light dark:border-border-dark text-primary focus:ring-primary bg-white dark:bg-surface-dark" />
                    <div>
                        <label asp-for="Command.IsPublic" class="text-sm font-bold text-slate-700 dark:text-slate-300">Public Group</label>
                        <p class="text-xs text-slate-500">Note: Changing to private will hide it from the explore page.</p>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-primary text-white font-bold hover:bg-primary-dark transition-all shadow-lg shadow-primary/20 w-full">
                        <span class="material-symbols-outlined mr-2 text-xl">save</span>
                        Save Changes
                    </button>
                </div>
            </form>
        </section>

        <!-- Channel Management -->
        <section class="space-y-6">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white px-2">Manage Channels</h3>
            
            <!-- Text Channels -->
            <div class="bg-surface-light dark:bg-surface-dark rounded-2xl border border-border-light dark:border-border-dark overflow-hidden shadow-sm">
                <div class="px-6 py-4 border-b border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-black/20">
                    <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest">Text Channels</h4>
                </div>
                <div class="divide-y divide-border-light dark:divide-border-dark">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == ChannelType.Text))
                    {
                        <div class="flex items-center justify-between p-4 group hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                            <div class="flex items-center gap-3">
                                <span class="text-xl font-bold text-slate-300 dark:text-slate-600">#</span>
                                <span class="text-sm font-bold text-slate-700 dark:text-slate-200">@channel.Name</span>
                            </div>
                            <button onclick="confirmDeleteChannel('@channel.Id', '@channel.Name')" class="size-9 rounded-xl flex items-center justify-center text-slate-400 hover:bg-red-500/10 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100">
                                <span class="material-symbols-outlined text-xl">delete</span>
                            </button>
                        </div>
                    }
                    @if (!Model.Channels.Any(c => c.Type == ChannelType.Text))
                    {
                        <div class="p-8 text-center">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-tighter">No text channels found</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Voice Channels -->
            <div class="bg-surface-light dark:bg-surface-dark rounded-2xl border border-border-light dark:border-border-dark overflow-hidden shadow-sm">
                <div class="px-6 py-4 border-b border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-black/20">
                    <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest">Voice Channels</h4>
                </div>
                <div class="divide-y divide-border-light dark:divide-border-dark">
                    @foreach (var channel in Model.Channels.Where(c => c.Type == ChannelType.Voice))
                    {
                        <div class="flex items-center justify-between p-4 group hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                            <div class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-lg text-slate-300 dark:text-slate-600">volume_up</span>
                                <span class="text-sm font-bold text-slate-700 dark:text-slate-200">@channel.Name</span>
                            </div>
                            <button onclick="confirmDeleteChannel('@channel.Id', '@channel.Name')" class="size-9 rounded-xl flex items-center justify-center text-slate-400 hover:bg-red-500/10 hover:text-red-500 transition-all opacity-0 group-hover:opacity-100">
                                <span class="material-symbols-outlined text-xl">delete</span>
                            </button>
                        </div>
                    }
                    @if (!Model.Channels.Any(c => c.Type == ChannelType.Voice))
                    {
                        <div class="p-8 text-center">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-tighter">No voice channels found</p>
                        </div>
                    }
                </div>
            </div>
        </section>

        <!-- Danger Zone -->
        <section class="pt-8 border-t border-red-500/10">
             <form asp-action="Delete" asp-route-id="@Model.Command.Id" method="post" onsubmit="return confirm('WARNING: This will permanently delete this study group and all its history. Proceed?')">
                <button type="submit" class="flex items-center justify-center gap-2 px-6 py-4 rounded-2xl bg-red-500/10 text-red-500 font-bold hover:bg-red-500 hover:text-white transition-all w-full">
                    <span class="material-symbols-outlined">delete_forever</span>
                    Delete Study Group
                </button>
            </form>
        </section>
    </div>
</div>

<!-- Modal: Delete Channel Confirmation -->
<div id="deleteChannelModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-slate-900/40 dark:bg-black/60 backdrop-blur-sm" onclick="closeDeleteChannelModal()"></div>
    <div class="bg-white dark:bg-surface-dark w-full max-w-md rounded-[2rem] shadow-2xl relative z-10 overflow-hidden border border-white dark:border-white/10 animate-in fade-in zoom-in duration-300">
        <div class="p-8 text-center">
            <div class="size-16 rounded-full bg-red-500/10 text-red-500 flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-3xl">delete</span>
            </div>
            <h3 class="text-2xl font-black text-slate-900 dark:text-white mb-2 italic uppercase tracking-tighter">Delete Channel?</h3>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-8">
                Are you sure you want to delete <span id="deleteChannelName" class="font-bold text-slate-900 dark:text-white"></span>? This action cannot be undone.
            </p>

            <form asp-action="DeleteChannel" method="post">
                <input type="hidden" name="id" id="deleteChannelIdInput" />
                <input type="hidden" name="groupId" value="@Model.Command.Id" />
                <div class="flex gap-3">
                    <button type="button" onclick="closeDeleteChannelModal()" class="flex-1 py-3 px-6 rounded-xl border-2 border-slate-100 dark:border-white/5 font-bold text-slate-500 hover:bg-slate-50 transition-all">Cancel</button>
                    <button type="submit" class="flex-1 py-3 px-6 rounded-xl bg-red-500 text-white font-bold hover:bg-red-600 transition-all shadow-lg shadow-red-500/20">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function confirmDeleteChannel(id, name) {
            document.getElementById('deleteChannelIdInput').value = id;
            document.getElementById('deleteChannelName').innerText = name;
            document.getElementById('deleteChannelModal').classList.remove('hidden');
        }

        function closeDeleteChannelModal() {
            document.getElementById('deleteChannelModal').classList.add('hidden');
        }
    </script>
}
