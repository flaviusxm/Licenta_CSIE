@using AskNLearn.Domain.Entities.Core
@model IEnumerable<VerificationRequest>

@foreach (var request in Model)
{
    <div class="verification-item d-flex align-items-center gap-4 p-3 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft animate-entrance">
        <div class="rounded-4 d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm" 
             style="width: 52px; height: 52px; background: rgba(52, 211, 153, 0.05); border: 1px solid var(--border-glass-strong);">
            @if (!string.IsNullOrEmpty(request.User.AvatarUrl))
            {
                <img src="@request.User.AvatarUrl" class="w-100 h-100 object-cover rounded-4" />
            }
            else
            {
                <span class="material-symbols-outlined fs-3 text-aurora">badge</span>
            }
        </div>

        <div class="flex-grow-1 min-w-0">
            <div class="d-flex align-items-center justify-content-between mb-1">
                <h4 class="h6 fw-bold text-white mb-0 text-truncate">@request.User.FullName</h4>
                <span class="text-muted" style="font-size: 0.65rem;">@request.SubmittedAt.ToString("MMM dd, HH:mm")</span>
            </div>
            <div class="text-muted small text-truncate">@@@request.User.UserName • @request.User.Institution</div>
            
            <div class="d-flex gap-2 mt-2">
                <a href="@request.StudentIdUrl" target="_blank" class="rounded-lg border border-glass overflow-hidden hover-border-aurora transition-all" style="width: 40px; height: 40px;">
                    <img src="@request.StudentIdUrl" class="w-100 h-100 object-cover opacity-75 hover-opacity-100" title="Student ID" />
                </a>
                <a href="@request.CarnetUrl" target="_blank" class="rounded-lg border border-glass overflow-hidden hover-border-aurora transition-all" style="width: 40px; height: 40px;">
                    <img src="@request.CarnetUrl" class="w-100 h-100 object-cover opacity-75 hover-opacity-100" title="Carnet Evidence" />
                </a>
            </div>
        </div>

        <div class="d-flex gap-2">
            @if (request.Status == Status.Pending)
            {
                <form asp-action="Approve" method="post" class="m-0">
                    <input type="hidden" name="id" value="@request.Id" />
                    <button class="btn btn-glass btn-icon-sm text-success" title="Approve">
                        <span class="material-symbols-outlined fs-5">check</span>
                    </button>
                </form>
                <button onclick="openRejectModal('@request.Id')" class="btn btn-glass btn-icon-sm text-danger" title="Reject">
                    <span class="material-symbols-outlined fs-5">close</span>
                </button>
            }
            else
            {
                <span class="badge glass-badge @(request.Status == Status.Approved ? "glass-badge-aurora" : "glass-badge-danger")">
                    @request.Status
                </span>
            }
        </div>
    </div>
}
