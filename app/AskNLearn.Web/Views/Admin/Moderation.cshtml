@model AskNLearn.Web.Models.ModerationViewModel
@using AskNLearn.Domain.Entities.Core
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Moderation Center";
    int aiTotal = (int)ViewBag.FlaggedPostsCount + (int)ViewBag.FlaggedMessagesCount;
    int userTotal = (int)ViewBag.PendingReportsCount;
}


<div class="max-w-6xl mx-auto p-4">
    <!-- Header & Source Selection -->
    <div class="mb-5">
        <div class="row g-4 align-items-center">
            <div class="col-xl-4">
                <h2 class="h4 fw-black text-white mb-1">Moderation Center</h2>
                <p class="text-muted small mb-0">Review AI-flagged content and user-submitted reports.</p>
            </div>
            <div class="col-xl-8">
                <div class="d-flex flex-wrap align-items-center justify-content-xl-end gap-3">
                    <!-- Source Tabs -->
                    <div class="nav nav-pills glass-pills p-1 rounded-2xl shadow-sm" id="moderationTab" role="tablist">
                        <button class="nav-link-filter active px-4 py-2 border-0" id="ai-tab" data-bs-toggle="tab" data-bs-target="#ai-reports" type="button">
                            <span class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">smart_toy</span>
                                AI Flags
                                <span class="small fw-bold opacity-50 ms-1" id="ai-count-tab-badge">@aiTotal</span>
                            </span>
                        </button>
                        <button class="nav-link-filter px-4 py-2 border-0" id="user-tab" data-bs-toggle="tab" data-bs-target="#user-reports" type="button">
                            <span class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined fs-5">flag</span>
                                User Reports
                                <span class="small fw-bold opacity-50 ms-1" id="user-count-tab-badge">@userTotal</span>
                            </span>
                        </button>
                    </div>

                   
                    

                    <div id="user-filters" class="tab-filters d-none d-flex gap-1">
                        <button class="nav-link-filter-sm active sub-filter-btn" data-target="user" data-filter="ALL">All</button>
                        <button class="nav-link-filter-sm sub-filter-btn" data-target="user" data-filter="POST">Posts</button>
                        <button class="nav-link-filter-sm sub-filter-btn" data-target="user" data-filter="COMMENT">Comments</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-content" id="moderationTabContent">
        <!-- AI Reports Tab -->
        <div class="tab-pane fade show active" id="ai-reports" role="tabpanel">
            <div id="ai-reports-container" class="d-flex flex-column gap-3">
                <!-- Content loaded via AJAX -->
            </div>
            <div id="ai-sentinel" class="py-5 text-center @(aiTotal > 0 ? "" : "d-none")">
                <div class="spinner-border text-aurora" role="status" style="width: 2.5rem; height: 2.5rem;"></div>
            </div>
        </div>

        <!-- User Reports Tab -->
        <div class="tab-pane fade" id="user-reports" role="tabpanel">
            <div id="user-reports-container" class="d-flex flex-column gap-3">
                <!-- Content loaded via AJAX -->
            </div>
            <div id="user-sentinel" class="py-5 text-center @(userTotal > 0 ? "" : "d-none")">
                <div class="spinner-border text-warning" role="status" style="width: 2.5rem; height: 2.5rem;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const take = 15;
            let aiSkip = 0;
            let userSkip = 0;
            let currentAiFilter = "ALL";
            let currentUserFilter = "ALL";
            let aiFinished = false;
            let userFinished = false;
            let aiLoading = false;
            let userLoading = false;

            // Handle Tab Switches
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                const targetId = $(e.target).attr('id');
                $('.tab-filters').addClass('d-none');
                if (targetId === 'ai-tab') $('#ai-filters').removeClass('d-none').addClass('d-flex');
                else $('#user-filters').removeClass('d-none').addClass('d-flex');
            });

            // Observers
            const aiObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !aiLoading && !aiFinished) loadAI();
            }, { threshold: 0.1 });

            const userObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !userLoading && !userFinished) loadUser();
            }, { threshold: 0.1 });

            const aiSentinel = document.getElementById('ai-sentinel');
            const userSentinel = document.getElementById('user-sentinel');
            if (aiSentinel) aiObserver.observe(aiSentinel);
            if (userSentinel) userObserver.observe(userSentinel);

            loadAI();
            loadUser();

            $('.sub-filter-btn').click(function() {
                const target = $(this).data('target');
                const filter = $(this).data('filter');
                $(`.sub-filter-btn[data-target="${target}"]`).removeClass('active');
                $(this).addClass('active');

                if (target === 'ai') {
                    currentAiFilter = filter;
                    resetAI();
                } else {
                    currentUserFilter = filter;
                    resetUser();
                }
            });

            function resetAI() {
                aiSkip = 0;
                aiFinished = false;
                $('#ai-reports-container').empty();
                $('#ai-sentinel').removeClass('d-none');
                loadAI();
            }

            function resetUser() {
                userSkip = 0;
                userFinished = false;
                $('#user-reports-container').empty();
                $('#user-sentinel').removeClass('d-none');
                loadUser();
            }

            function loadAI() {
                if (aiLoading || aiFinished) return;
                aiLoading = true;
                
                $.ajax({
                    url: `/management/administration/v1/moderation/ai-reports?skip=${aiSkip}&take=${take}&filter=${currentAiFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        aiLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#ai-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#ai-reports-container').append(data);
                            aiSkip += take;
                            if (aiSkip >= total) {
                                aiFinished = true;
                                $('#ai-sentinel').addClass('d-none');
                            }
                        } else {
                            aiFinished = true;
                            $('#ai-sentinel').addClass('d-none');
                            if (aiSkip === 0) {
                                $('#ai-reports-container').html('<div class="glass-card p-5 text-center border-glass opacity-50 rounded-3xl"><span class="material-symbols-outlined display-4 mb-3">check_circle</span><p class="fw-bold">No flags found here.</p></div>');
                            }
                        }
                    }
                });
            }

            function loadUser() {
                if (userLoading || userFinished) return;
                userLoading = true;

                $.ajax({
                    url: `/management/administration/v1/moderation/user-reports?skip=${userSkip}&take=${take}&filter=${currentUserFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        userLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#user-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#user-reports-container').append(data);
                            userSkip += take;
                            if (userSkip >= total) {
                                userFinished = true;
                                $('#user-sentinel').addClass('d-none');
                            }
                        } else {
                            userFinished = true;
                            $('#user-sentinel').addClass('d-none');
                            if (userSkip === 0) {
                                $('#user-reports-container').html('<div class="glass-card p-5 text-center border-glass opacity-50 rounded-3xl"><span class="material-symbols-outlined display-4 mb-3">sentiment_satisfied</span><p class="fw-bold">Clean record! No user reports.</p></div>');
                            }
                        }
                    }
                });
            }

            $(document).on('submit', '.ajax-action', function(e) {
                e.preventDefault();
                const form = $(this);
                const item = form.closest('.moderation-item');
                
                $.post(form.attr('action'), form.serialize(), function() {
                    item.fadeOut(300, function() { 
                        $(this).remove();
                    });
                }).fail(function() {
                    if (window.Notify) window.Notify.error("Action failed.");
                    else alert("Action failed.");
                });
            });
        });
    </script>
}

<style>
    .glass-pills {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
    }

    .nav-link-filter {
        padding: 0.6rem 1.25rem;
        border-radius: 0.75rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 700;
        transition: all 0.3s var(--ease-apple);
        border: 1px solid transparent;
        background: transparent;
    }
    .nav-link-filter:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
    .nav-link-filter.active {
        background: rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .nav-link-filter-sm {
        padding: 0.4rem 0.8rem;
        border-radius: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        background: transparent;
    }
    .nav-link-filter-sm:hover {
        color: white;
    }
    .nav-link-filter-sm.active {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.1);
        color: white;
    }
</style>
}
