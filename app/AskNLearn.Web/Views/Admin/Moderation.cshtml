@model AskNLearn.Web.Models.ModerationViewModel
@using AskNLearn.Domain.Entities.Core
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Moderation Center";
    int aiTotal = (int)ViewBag.FlaggedPostsCount + (int)ViewBag.FlaggedMessagesCount;
    int userTotal = (int)ViewBag.PendingReportsCount;
}

@section Sidebar {
    <div class="p-4 border-bottom border-glass">
        <h2 class="h5 fw-bold text-white mb-2 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-danger">security</span>
            Moderation Center
        </h2>
        <p class="text-muted small mb-4">Review AI automated flags and community reports.</p>
    </div>

    <div class="flex-grow-1 p-3 overflow-y-auto custom-scrollbar">
        <div class="mb-4">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Source</label>
            <div class="nav nav-pills d-flex flex-column gap-1" id="moderationTab" role="tablist">
                <button class="nav-link-flat active text-start d-flex align-items-center justify-content-between" id="ai-tab" data-bs-toggle="tab" data-bs-target="#ai-reports" type="button">
                    <span><span class="material-symbols-outlined fs-6 me-2">smart_toy</span> AI Flags</span>
                    <span class="glass-badge glass-badge-danger" id="ai-count-tab-badge">@aiTotal</span>
                </button>
                <button class="nav-link-flat text-start d-flex align-items-center justify-content-between" id="user-tab" data-bs-toggle="tab" data-bs-target="#user-reports" type="button">
                    <span><span class="material-symbols-outlined fs-6 me-2">flag</span> User Reports</span>
                    <span class="glass-badge glass-badge-warning" id="user-count-tab-badge">@userTotal</span>
                </button>
            </div>
        </div>

        <div id="ai-filters" class="mb-4 tab-filters">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">AI Filter</label>
            <div class="d-flex flex-column gap-1">
                <button class="nav-link-flat active sub-filter-btn" data-target="ai" data-filter="ALL">Active Flags</button>
                <button class="nav-link-flat sub-filter-btn" data-target="ai" data-filter="SUSPECT">Suspect Content</button>
                <button class="nav-link-flat sub-filter-btn" data-target="ai" data-filter="HISTORY">Review History</button>
            </div>
        </div>

        <div id="user-filters" class="mb-4 tab-filters d-none">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Report Type</label>
            <div class="d-flex flex-column gap-1">
                <button class="nav-link-flat active sub-filter-btn" data-target="user" data-filter="ALL">All Reports</button>
                <button class="nav-link-flat sub-filter-btn" data-target="user" data-filter="POST">Post Reports</button>
                <button class="nav-link-flat sub-filter-btn" data-target="user" data-filter="COMMENT">Comment Reports</button>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="d-flex align-items-center justify-content-center gap-2 py-4 mt-auto text-muted hover-text-white transition-all text-decoration-none border-top border-glass">
        <span class="material-symbols-outlined fs-5">arrow_back</span>
        <span class="fw-bold text-uppercase tracking-widest fs-xs">Dashboard</span>
    </a>
}

<div class="max-w-5xl mx-auto p-4 animate-entrance">
    <div class="tab-content" id="moderationTabContent">
        <!-- AI Reports Tab -->
        <div class="tab-pane fade show active" id="ai-reports" role="tabpanel">
            <div id="ai-reports-container" class="d-flex flex-column gap-2">
                <!-- Content loaded via AJAX into _AIReportsTable -->
            </div>
            <div id="ai-sentinel" class="py-5 text-center @(aiTotal > 0 ? "" : "d-none")">
                <div class="spinner-border text-aurora" role="status"></div>
            </div>
        </div>

        <!-- User Reports Tab -->
        <div class="tab-pane fade" id="user-reports" role="tabpanel">
            <div id="user-reports-container" class="d-flex flex-column gap-2">
                <!-- Content loaded via AJAX into _UserReportsTable -->
            </div>
            <div id="user-sentinel" class="py-5 text-center @(userTotal > 0 ? "" : "d-none")">
                <div class="spinner-border text-warning" role="status"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const take = 15;
            let aiSkip = 0;
            let userSkip = 0;
            let currentAiFilter = "ALL";
            let currentUserFilter = "ALL";
            let aiFinished = false;
            let userFinished = false;
            let aiLoading = false;
            let userLoading = false;

            // Handle Tab Switches to show/hide filters
            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                const targetId = $(e.target).attr('id');
                $('.tab-filters').addClass('d-none');
                if (targetId === 'ai-tab') $('#ai-filters').removeClass('d-none');
                else $('#user-filters').removeClass('d-none');
            });

            // Observers
            const aiObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !aiLoading && !aiFinished) loadAI();
            }, { threshold: 0.1 });

            const userObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !userLoading && !userFinished) loadUser();
            }, { threshold: 0.1 });

            const aiSentinel = document.getElementById('ai-sentinel');
            const userSentinel = document.getElementById('user-sentinel');
            if (aiSentinel) aiObserver.observe(aiSentinel);
            if (userSentinel) userObserver.observe(userSentinel);

            // Initial load
            loadAI();
            loadUser();

            // Sub-filtering
            $('.sub-filter-btn').click(function() {
                const target = $(this).data('target');
                const filter = $(this).data('filter');
                $(`.sub-filter-btn[data-target="${target}"]`).removeClass('active');
                $(this).addClass('active');

                if (target === 'ai') {
                    currentAiFilter = filter;
                    resetAI();
                } else {
                    currentUserFilter = filter;
                    resetUser();
                }
            });

            function resetAI() {
                aiSkip = 0;
                aiFinished = false;
                $('#ai-reports-container').empty();
                $('#ai-sentinel').removeClass('d-none');
                loadAI();
            }

            function resetUser() {
                userSkip = 0;
                userFinished = false;
                $('#user-reports-container').empty();
                $('#user-sentinel').removeClass('d-none');
                loadUser();
            }

            function loadAI() {
                if (aiLoading || aiFinished) return;
                aiLoading = true;
                
                $.ajax({
                    url: `/management/administration/v1/moderation/ai-reports?skip=${aiSkip}&take=${take}&filter=${currentAiFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        aiLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#ai-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#ai-reports-container').append(data);
                            aiSkip += take;
                            if (aiSkip >= total) {
                                aiFinished = true;
                                $('#ai-sentinel').addClass('d-none');
                            }
                        } else {
                            aiFinished = true;
                            $('#ai-sentinel').addClass('d-none');
                            if (aiSkip === 0) {
                                $('#ai-reports-container').html('<div class="text-center py-5 opacity-50"><span class="material-symbols-outlined display-4 mb-3">check_circle</span><p class="fw-bold">No flags found here.</p></div>');
                            }
                        }
                    }
                });
            }

            function loadUser() {
                if (userLoading || userFinished) return;
                userLoading = true;

                $.ajax({
                    url: `/management/administration/v1/moderation/user-reports?skip=${userSkip}&take=${take}&filter=${currentUserFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        userLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#user-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#user-reports-container').append(data);
                            userSkip += take;
                            if (userSkip >= total) {
                                userFinished = true;
                                $('#user-sentinel').addClass('d-none');
                            }
                        } else {
                            userFinished = true;
                            $('#user-sentinel').addClass('d-none');
                            if (userSkip === 0) {
                                $('#user-reports-container').html('<div class="text-center py-5 opacity-50"><span class="material-symbols-outlined display-4 mb-3">sentiment_satisfied</span><p class="fw-bold">Clean record! No user reports.</p></div>');
                            }
                        }
                    }
                });
            }

            // AJAX actions
            $(document).on('submit', '.ajax-action', function(e) {
                e.preventDefault();
                const form = $(this);
                const item = form.closest('.moderation-item');
                
                $.post(form.attr('action'), form.serialize(), function() {
                    item.fadeOut(300, function() { 
                        $(this).remove();
                    });
                }).fail(function() {
                    if (window.Notify) window.Notify.error("Action failed.");
                    else alert("Action failed.");
                });
            });
        });
    </script>
}

<style>
    .nav-link-flat {
        display: block;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        border: none;
        background: transparent;
        width: 100%;
    }
    .nav-link-flat:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-pure);
    }
    .nav-link-flat.active {
        background: rgba(0, 122, 255, 0.15);
        color: var(--text-pure);
    }
    #user-filters .nav-link-flat.active {
        background: rgba(0, 122, 255, 0.15);
    }
</style>
}
