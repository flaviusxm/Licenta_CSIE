@model AskNLearn.Web.Models.ModerationViewModel
@using AskNLearn.Domain.Entities.Core
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Moderation Center";
    int aiTotal = (int)ViewBag.FlaggedPostsCount + (int)ViewBag.FlaggedMessagesCount;
    int userTotal = (int)ViewBag.PendingReportsCount;
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2">Moderation</h2>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <div class="rounded-circle bg-danger shadow-glow" style="width: 8px; height: 8px;"></div>
                Advanced moderation tools. Review AI automated flags and user community reports.
            </div>
        </div>
        <div class="d-flex gap-3">
             <ul class="nav nav-pills glass-panel p-1 border-glass-strong" id="moderationTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link nav-link-premium active px-4 py-2" id="ai-tab" data-bs-toggle="tab" data-bs-target="#ai-reports" type="button" role="tab" aria-controls="ai-reports" aria-selected="true">
                        AI Flagged <span class="glass-badge glass-badge-danger ms-2" id="ai-count-tab-badge">@aiTotal</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link nav-link-premium px-4 py-2" id="user-tab" data-bs-toggle="tab" data-bs-target="#user-reports" type="button" role="tab" aria-controls="user-reports" aria-selected="false">
                        User Reports <span class="glass-badge glass-badge-warning ms-2" id="user-count-tab-badge">@userTotal</span>
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <!-- Tab Content -->
    <div class="tab-content" id="moderationTabContent">
        <!-- AI Reports Tab -->
        <div class="tab-pane fade show active" id="ai-reports" role="tabpanel" aria-labelledby="ai-tab">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-pill-glass active sub-filter-btn" data-target="ai" data-filter="ALL">All Content</button>
                    <button class="btn btn-pill-glass sub-filter-btn" data-target="ai" data-filter="POST">Posts Only</button>
                    <button class="btn btn-pill-glass sub-filter-btn" data-target="ai" data-filter="COMMENT">Comments Only</button>
                </div>
            </div>

            <div class="glass-card border-glass-strong overflow-hidden mb-4 shadow-lg">
                <div class="table-responsive bg-transparent" style="min-height: 450px;">
                    <table class="table table-borderless table-hover mb-0 align-middle text-white bg-transparent">
                        <thead style="background: rgba(0,0,0,0.3); border-bottom: 1px solid var(--border-glass-strong);">
                            <tr>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Type</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Content Details</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">AI Verdict</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Status</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="ai-reports-body">
                            <!-- Content loaded via AJAX -->
                        </tbody>
                    </table>
                    <!-- Loading Sentinel -->
                    <div id="ai-sentinel" class="py-4 text-center @(aiTotal > 0 ? "" : "d-none")">
                        <div class="spinner-border text-aurora spinner-border-sm" role="status"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Reports Tab -->
        <div class="tab-pane fade" id="user-reports" role="tabpanel" aria-labelledby="user-tab">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex gap-2">
                    <button class="btn btn-pill-glass active sub-filter-btn" data-target="user" data-filter="ALL">All Reports</button>
                    <button class="btn btn-pill-glass sub-filter-btn" data-target="user" data-filter="POST">Post Reports</button>
                    <button class="btn btn-pill-glass sub-filter-btn" data-target="user" data-filter="COMMENT">Comment Reports</button>
                </div>
            </div>

             <div class="glass-card border-glass-strong overflow-hidden mb-4 shadow-lg">
                <div class="table-responsive bg-transparent" style="min-height: 450px;">
                    <table class="table table-borderless table-hover mb-0 align-middle text-white bg-transparent">
                        <thead style="background: rgba(0,0,0,0.3); border-bottom: 1px solid var(--border-glass-strong);">
                            <tr>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Reported By</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Target Content</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Reason</th>
                                <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="user-reports-body">
                            <!-- Content loaded via AJAX -->
                        </tbody>
                    </table>
                    <!-- Loading Sentinel -->
                    <div id="user-sentinel" class="py-4 text-center @(userTotal > 0 ? "" : "d-none")">
                        <div class="spinner-border text-warning spinner-border-sm" role="status"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const take = 15;
            let aiSkip = 0;
            let userSkip = 0;
            let currentAiFilter = "ALL";
            let currentUserFilter = "ALL";
            let aiFinished = false;
            let userFinished = false;
            let aiLoading = false;
            let userLoading = false;

            // Observers
            const aiObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !aiLoading && !aiFinished) loadAI();
            }, { threshold: 0.1 });

            const userObserver = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !userLoading && !userFinished) loadUser();
            }, { threshold: 0.1 });

            const aiSentinel = document.getElementById('ai-sentinel');
            const userSentinel = document.getElementById('user-sentinel');
            if (aiSentinel) aiObserver.observe(aiSentinel);
            if (userSentinel) userObserver.observe(userSentinel);

            // Initial load
            loadAI();
            loadUser();

            // Sub-filtering
            $('.sub-filter-btn').click(function() {
                const target = $(this).data('target');
                const filter = $(this).data('filter');
                $(`.sub-filter-btn[data-target="${target}"]`).removeClass('active');
                $(this).addClass('active');

                if (target === 'ai') {
                    currentAiFilter = filter;
                    resetAI();
                } else {
                    currentUserFilter = filter;
                    resetUser();
                }
            });

            function resetAI() {
                aiSkip = 0;
                aiFinished = false;
                $('#ai-reports-body').empty();
                $('#ai-sentinel').removeClass('d-none');
                loadAI();
            }

            function resetUser() {
                userSkip = 0;
                userFinished = false;
                $('#user-reports-body').empty();
                $('#user-sentinel').removeClass('d-none');
                loadUser();
            }

            function loadAI() {
                if (aiLoading || aiFinished) return;
                aiLoading = true;
                
                $.ajax({
                    url: `/Admin/LoadAIReports?skip=${aiSkip}&take=${take}&filter=${currentAiFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        aiLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#ai-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#ai-reports-body').append(data);
                            aiSkip += take;
                            if (aiSkip >= total) {
                                aiFinished = true;
                                $('#ai-sentinel').addClass('d-none');
                            }
                        } else {
                            aiFinished = true;
                            $('#ai-sentinel').addClass('d-none');
                            if (aiSkip === 0) {
                                $('#ai-reports-body').html('<tr><td colspan="5" class="py-5 text-center text-muted italic small">No flagged items found.</td></tr>');
                            }
                        }
                    }
                });
            }

            function loadUser() {
                if (userLoading || userFinished) return;
                userLoading = true;

                $.ajax({
                    url: `/Admin/LoadUserReports?skip=${userSkip}&take=${take}&filter=${currentUserFilter}`,
                    type: 'GET',
                    success: function(data, textStatus, request) {
                        userLoading = false;
                        const total = parseInt(request.getResponseHeader('X-Total-Count')) || 0;
                        $('#user-count-tab-badge').text(total);

                        if (data.trim().length > 0) {
                            $('#user-reports-body').append(data);
                            userSkip += take;
                            if (userSkip >= total) {
                                userFinished = true;
                                $('#user-sentinel').addClass('d-none');
                            }
                        } else {
                            userFinished = true;
                            $('#user-sentinel').addClass('d-none');
                            if (userSkip === 0) {
                                $('#user-reports-body').html('<tr><td colspan="4" class="py-5 text-center text-muted italic small">No community reports found.</td></tr>');
                            }
                        }
                    }
                });
            }

            // AJAX actions
            $(document).on('submit', '.ajax-action', function(e) {
                e.preventDefault();
                const form = $(this);
                const row = form.closest('tr');
                
                $.post(form.attr('action'), form.serialize(), function() {
                    row.fadeOut(300, function() { 
                        $(this).remove();
                    });
                }).fail(function() {
                    alert("Action failed.");
                });
            });
        });
    </script>
}
}
