@model IEnumerable<AskNLearn.Domain.Entities.Core.Report>

@foreach (var report in Model)
{
    var reportType = report.ReportedPostId.HasValue ? "POST" : "COMMENT";
    <tr class="transition-colors hover-bg-glass user-row" data-type="@reportType" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td class="py-4 px-4">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-aurora fw-bold border border-glass-strong" style="width: 32px; height: 32px; font-size: 0.7rem; background: rgba(255,255,255,0.05);">
                    @(report.Reporter?.UserName?.Substring(0, 2).ToUpper() ?? "??")
                </div>
                <div class="d-flex flex-column">
                    <span class="fw-bold">@@@report.Reporter?.UserName</span>
                    <span class="text-muted small">@report.CreatedAt.ToString("g")</span>
                </div>
            </div>
        </td>
        <td class="py-4 px-4">
            <div class="d-flex flex-column gap-1">
                @if (report.ReportedPostId.HasValue)
                {
                    <span class="badge bg-opacity-10 bg-primary text-primary border border-primary border-opacity-25 px-2 py-1 small self-start mb-1" style="font-size: 0.55rem; width: fit-content;">POST</span>
                    <p class="text-white mb-0 fw-bold">@report.ReportedPost?.Title</p>
                }
                else if (report.ReportedMessageId.HasValue)
                {
                    <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-2 py-1 small self-start mb-1" style="font-size: 0.55rem; width: fit-content;">COMMENT</span>
                    <p class="text-white mb-0" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">"@report.ReportedMessage?.Content"</p>
                }
                else if (report.ReportedResourceId.HasValue)
                {
                    <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-2 py-1 small self-start mb-1" style="font-size: 0.55rem; width: fit-content; background: rgba(0, 245, 160, 0.1) !important; color: var(--color-mint-bright) !important; border-color: rgba(0, 245, 160, 0.2) !important;">RESOURCE</span>
                    <p class="text-white mb-0 fw-bold">@report.ReportedResource?.Title</p>
                }
            </div>
        </td>
        <td class="py-4 px-4">
            <div class="d-flex flex-column">
                <span class="badge rounded-pill bg-opacity-10 bg-warning text-warning border border-warning border-opacity-25 px-3 py-1 fw-bold text-uppercase mb-2" style="font-size: 0.6rem; width: fit-content;">
                    @report.Reason
                </span>
                <p class="small text-muted mb-0 italic">"@report.Description"</p>
            </div>
        </td>
        <td class="py-4 px-4 text-end">
            <div class="d-flex justify-content-end gap-2">
                <form asp-action="ResolveReport" method="post" class="m-0 ajax-action">
                    <input type="hidden" name="id" value="@report.Id" />
                    <button class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-success" title="Resolve (Delete content if needed)">
                        <span class="material-symbols-outlined fs-6">done_all</span>
                    </button>
                </form>
                <form asp-action="DismissReport" method="post" class="m-0 ajax-action">
                    <input type="hidden" name="id" value="@report.Id" />
                    <button class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-danger" title="Dismiss Report">
                        <span class="material-symbols-outlined fs-6">close</span>
                    </button>
                </form>
            </div>
        </td>
    </tr>
}
