@model IEnumerable<AskNLearn.Domain.Entities.Core.Report>

@foreach (var report in Model)
{
    var reportType = report.ReportedPostId.HasValue ? "POST" : "COMMENT";
    <div class="moderation-item d-flex align-items-center gap-4 p-3 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft animate-entrance">
        <div class="rounded-4 d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm" 
             style="width: 48px; height: 48px; background: rgba(245, 158, 11, 0.05); border: 1px solid var(--border-glass-strong);">
            <span class="material-symbols-outlined fs-4 text-warning">
                report
            </span>
        </div>

        <div class="flex-grow-1 min-w-0">
            <div class="d-flex align-items-center justify-content-between mb-1">
                <div class="d-flex align-items-center gap-2">
                    <h4 class="h6 fw-bold text-white mb-0">Report from @report.Reporter?.UserName</h4>
                    <span class="badge glass-badge glass-badge-warning" style="font-size: 0.55rem;">@reportType</span>
                </div>
                <span class="text-muted" style="font-size: 0.65rem;">@report.CreatedAt.ToString("MMM dd, HH:mm")</span>
            </div>
            
            <div class="d-flex flex-column gap-1">
                <p class="text-white small mb-0 fw-bold">Target: @(report.ReportedPost?.Title ?? "Comment")</p>
                <p class="text-muted text-truncate small mb-0" style="max-width: 90%;">"@report.Description"</p>
            </div>
            
            <div class="mt-2">
                <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-0 fw-bold text-uppercase" style="font-size: 0.55rem;">
                    @report.Reason
                </span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <form asp-action="ResolveReport" method="post" class="m-0 ajax-action">
                <input type="hidden" name="id" value="@report.Id" />
                <button class="btn btn-glass btn-icon-sm text-success" title="Resolve">
                    <span class="material-symbols-outlined fs-5">done_all</span>
                </button>
            </form>
            <form asp-action="DismissReport" method="post" class="m-0 ajax-action">
                <input type="hidden" name="id" value="@report.Id" />
                <button class="btn btn-glass btn-icon-sm text-muted" title="Dismiss">
                    <span class="material-symbols-outlined fs-5">close</span>
                </button>
            </form>
        </div>
    </div>
}
