@model IEnumerable<dynamic>

@foreach (var item in Model)
{
    <tr class="transition-colors hover-bg-glass ai-row" data-type="@item.Type" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <td class="py-4 px-4">
            <span class="badge @(item.Type == "POST" ? "bg-primary" : "bg-info") bg-opacity-10 @(item.Type == "POST" ? "text-primary" : "text-info") border @(item.Type == "POST" ? "border-primary" : "border-info") border-opacity-25 px-2 py-1 fw-bold text-uppercase tracking-tighter" style="font-size: 0.55rem;">
                @item.Type
            </span>
        </td>
        <td class="py-4 px-4">
            <div class="d-flex flex-column gap-1">
                @if (!string.IsNullOrEmpty(item.Title))
                {
                    <p class="fw-bold text-white mb-0">@item.Title</p>
                }
                <p class="text-muted small mb-0" style="max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @item.Content
                </p>
                @if (item.Type == "COMMENT" && !string.IsNullOrEmpty(item.ParentTitle))
                {
                    <p class="text-muted extra-small mb-0">On: <span class="text-aurora">@item.ParentTitle</span></p>
                }
                <p class="text-aurora small mb-0 mt-1">@@@item.Author • @item.CreatedAt.ToString("g")</p>
            </div>
        </td>
        <td class="py-4 px-4">
            <div class="p-2 rounded-3 bg-dark bg-opacity-50 border border-glass-strong">
                <p class="small mb-0 text-light italic">"@(string.IsNullOrEmpty(item.Reason) ? "Pending AI analysis" : item.Reason)"</p>
            </div>
        </td>
        <td class="py-4 px-4">
            @if (item.Status == AskNLearn.Domain.Entities.Core.ModerationStatus.Flagged)
            {
                <span class="badge rounded-pill bg-opacity-10 bg-danger text-danger border border-danger border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                    Flagged
                </span>
            }
            else if (item.Status == AskNLearn.Domain.Entities.Core.ModerationStatus.Approved)
            {
                <span class="badge rounded-pill bg-opacity-10 bg-success text-success border border-success border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                    Approved
                </span>
            }
            else
            {
                <span class="badge rounded-pill bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                    Pending
                </span>
            }
        </td>
        <td class="py-4 px-4 text-end">
            <div class="d-flex justify-content-end gap-2">
                @if (item.Status != AskNLearn.Domain.Entities.Core.ModerationStatus.Approved)
                {
                    <form asp-action="@(item.Type == "POST" ? "ApprovePost" : "ApproveComment")" method="post" class="m-0 ajax-action">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-success" title="Approve">
                            <span class="material-symbols-outlined fs-6">check</span>
                        </button>
                    </form>
                }
                @if (item.Status != AskNLearn.Domain.Entities.Core.ModerationStatus.Flagged)
                {
                    <form asp-action="@(item.Type == "POST" ? "FlagPost" : "FlagComment")" method="post" class="m-0 ajax-action">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-danger" title="Flag as Inappropriate">
                            <span class="material-symbols-outlined fs-6">flag</span>
                        </button>
                    </form>
                }
            </div>
        </td>
    </tr>
}
