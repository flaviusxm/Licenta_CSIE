@model IEnumerable<dynamic>

@foreach (var item in Model)
{
    <div class="moderation-item d-flex align-items-center gap-4 p-3 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft animate-entrance">
        <div class="rounded-4 d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm" 
             style="width: 48px; height: 48px; background: rgba(52, 211, 153, 0.05); border: 1px solid var(--border-glass-strong);">
            <span class="material-symbols-outlined fs-4 @(item.Type == "POST" ? "text-primary" : "text-info")">
                @(item.Type == "POST" ? "article" : "forum")
            </span>
        </div>

        <div class="flex-grow-1 min-w-0">
            <div class="d-flex align-items-center justify-content-between mb-1">
                <div class="d-flex align-items-center gap-2">
                    @if (!string.IsNullOrEmpty(item.Title))
                    {
                        <h4 class="h6 fw-bold text-white mb-0 text-truncate">@item.Title</h4>
                    }
                    else
                    {
                        <h4 class="h6 fw-bold text-white mb-0 italic opacity-50">Comment on @item.ParentTitle</h4>
                    }
                    <span class="badge @(item.Type == "POST" ? "glass-badge-aurora" : "glass-badge-warning") glass-badge" style="font-size: 0.55rem;">@item.Type</span>
                </div>
                <span class="text-muted" style="font-size: 0.65rem;">@item.CreatedAt.ToString("MMM dd, HH:mm")</span>
            </div>
            
            <p class="text-muted text-truncate small mb-1" style="max-width: 90%;">@item.Content</p>
            
            <div class="d-flex align-items-center gap-3">
                <span class="text-aurora fw-bold" style="font-size: 0.7rem;">@@@item.Author</span>
                <span class="text-muted">•</span>
                <span class="text-danger-soft italic" style="font-size: 0.7rem;">AI: @(string.IsNullOrEmpty(item.Reason) ? "No reason specified" : item.Reason)</span>
            </div>
        </div>

        <div class="d-flex gap-2">
            @if (item.Status != AskNLearn.Domain.Entities.Core.ModerationStatus.Approved)
            {
                <form asp-action="@(item.Type == "POST" ? "ApprovePost" : "ApproveComment")" method="post" class="m-0 ajax-action">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button class="btn btn-glass btn-icon-sm text-success" title="Approve">
                        <span class="material-symbols-outlined fs-5">check</span>
                    </button>
                </form>
            }
            @if (item.Status != AskNLearn.Domain.Entities.Core.ModerationStatus.Flagged)
            {
                <form asp-action="@(item.Type == "POST" ? "FlagPost" : "FlagComment")" method="post" class="m-0 ajax-action">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button class="btn btn-glass btn-icon-sm text-danger" title="Flag Content">
                        <span class="material-symbols-outlined fs-5">flag</span>
                    </button>
                </form>
            }
        </div>
    </div>
}
