@using AskNLearn.Domain.Entities.Core
@model IEnumerable<VerificationRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Verification Requests";
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2">Student Verifications</h2>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <div class="rounded-circle bg-aurora shadow-glow" style="width: 8px; height: 8px;"></div>
                Validate student credentials for full platform access.
            </div>
        </div>
        <div class="d-flex gap-3">
             <button class="btn btn-glass d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">filter_alt</span>
                <span>Filter</span>
            </button>
            <button onclick="window.location.reload()" class="btn btn-premium d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">sync</span>
                <span>Refresh Queue</span>
            </button>
        </div>
    </div>

    <!-- Stats Mini Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-card p-4 border-glass-strong">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div class="p-2 rounded-3 bg-opacity-10 bg-info text-info border border-info border-opacity-25">
                        <span class="material-symbols-outlined fs-5">analytics</span>
                    </div>
                </div>
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Pending Requests</p>
                <div class="d-flex align-items-baseline gap-2">
                    <h3 class="fw-bold text-white mb-0">@Model.Count(r => r.Status == Status.Pending)</h3>
                    <span class="text-success small fw-bold">+5 new</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="glass-card overflow-hidden border-glass-strong">
        <div class="table-responsive bg-transparent">
            <table class="table table-borderless table-hover mb-0 align-middle text-white bg-transparent">
                <thead style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border-glass-strong);">
                    <tr>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Student / Username</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-center">ID Evidence</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Submission</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Status</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody style="border-top: none;">
                    @foreach (var request in Model)
                    {
                        <tr class="transition-colors hover-bg-glass" style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                            <td class="py-4 px-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle border border-glass-strong overflow-hidden" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05);">
                                         @if (!string.IsNullOrEmpty(request.User.AvatarUrl))
                                        {
                                            <img src="@request.User.AvatarUrl" class="w-100 h-100 object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-aurora fw-bold">
                                                @request.User.FullName?.Substring(0, 1)
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <p class="fw-bold text-white mb-0">@request.User.FullName</p>
                                        <p class="text-muted small mb-0">@@@request.User.UserName • @request.User.Institution</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="@request.StudentIdUrl" target="_blank" class="rounded-3 border border-glass-strong overflow-hidden hover-border-aurora transition-all" style="width: 48px; height: 48px; background: rgba(0,0,0,0.2);">
                                        <img src="@request.StudentIdUrl" class="w-100 h-100 object-cover opacity-75 hover-opacity-100" />
                                    </a>
                                    <a href="@request.CarnetUrl" target="_blank" class="rounded-3 border border-glass-strong overflow-hidden hover-border-aurora transition-all" style="width: 48px; height: 48px; background: rgba(0,0,0,0.2);">
                                        <img src="@request.CarnetUrl" class="w-100 h-100 object-cover opacity-75 hover-opacity-100" />
                                    </a>
                                </div>
                            </td>
                            <td class="py-4 px-4">
                                 <p class="fw-medium text-white mb-0">@request.SubmittedAt.ToString("MMM dd, yyyy")</p>
                                 <p class="text-muted mb-0" style="font-size: 0.7rem;">@request.SubmittedAt.ToString("hh:mm tt")</p>
                            </td>
                            <td class="py-4 px-4">
                                @switch (request.Status)
                                {
                                    case Status.Pending:
                                        <span class="badge rounded-pill bg-opacity-10 bg-info text-info border border-info border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                                            <span class="spinner-grow spinner-grow-sm me-1" role="status" style="width: 8px; height: 8px;"></span>
                                            Pending
                                        </span>
                                        break;
                                    case Status.Approved:
                                        <span class="badge rounded-pill bg-opacity-10 bg-success text-success border border-success border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                                            Approved
                                        </span>
                                        break;
                                    case Status.Rejected:
                                        <span class="badge rounded-pill bg-opacity-10 bg-danger text-danger border border-danger border-opacity-25 px-3 py-2 fw-bold text-uppercase tracking-widest" style="font-size: 0.6rem;">
                                            Rejected
                                        </span>
                                        break;
                                }
                            </td>
                            <td class="py-4 px-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (request.Status == Status.Pending)
                                    {
                                        <form asp-action="Approve" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@request.Id" />
                                            <button class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-success" title="Approve">
                                                <span class="material-symbols-outlined fs-6">check</span>
                                            </button>
                                        </form>
                                        <button onclick="openRejectModal('@request.Id')" class="btn btn-sm btn-glass rounded-circle p-2 d-flex align-items-center justify-content-center hover-text-danger" title="Reject">
                                            <span class="material-symbols-outlined fs-6">close</span>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination -->
        <div class="p-4 border-top border-glass-strong d-flex justify-content-between align-items-center small text-muted" style="background: rgba(0,0,0,0.1);">
            <p class="mb-0">Showing 1-10 of @Model.Count() records</p>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item"><button class="btn btn-glass btn-sm border-0">❮</button></li>
                    <li class="page-item"><button class="btn btn-premium btn-sm active px-3">1</button></li>
                    <li class="page-item"><button class="btn btn-glass btn-sm border-0 px-3">2</button></li>
                    <li class="page-item"><button class="btn btn-glass btn-sm border-0">❯</button></li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="d-none position-fixed top-0 start-0 w-100 h-100 z-3 d-flex align-items-center justify-content-center p-4" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
    <div class="glass-card p-4 border-glass-strong w-100 shadow-lg animate-entrance" style="max-width: 450px;">
        <h4 class="fw-bold text-white mb-4">Reject Verification</h4>
        <form asp-action="Reject" method="post">
            <input type="hidden" name="id" id="rejectId" />
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase tracking-widest">Reason for rejection</label>
                <textarea name="notes" rows="4" class="form-control form-control-glass" placeholder="e.g., Student ID is not clear enough..."></textarea>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="closeRejectModal()" class="btn btn-glass flex-grow-1">Cancel</button>
                <button type="submit" class="btn btn-premium bg-danger border-danger text-white flex-grow-1">Confirm Reject</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openRejectModal(id) {
        document.getElementById('rejectId').value = id;
        document.getElementById('rejectModal').classList.remove('d-none');
        document.getElementById('rejectModal').classList.add('d-flex');
    }
    function closeRejectModal() {
        document.getElementById('rejectModal').classList.add('d-none');
        document.getElementById('rejectModal').classList.remove('d-flex');
    }
</script>
