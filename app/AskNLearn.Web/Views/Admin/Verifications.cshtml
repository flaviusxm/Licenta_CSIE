@using AskNLearn.Domain.Entities.Core
@model AskNLearn.Web.Models.PaginatedList<VerificationRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Verification Requests";
}


<div class="max-w-6xl mx-auto p-4 animate-entrance">
    <!-- Header & Controls -->
    <div class="glass-card p-4 rounded-2xl border-glass-strong mb-5 shadow-lg">
        <div class="row g-4 align-items-center">
            <div class="col-md-6">
                <h2 class="h4 fw-black text-white mb-1">Verification Queue</h2>
                <p class="text-muted small mb-0">@(ViewBag.OnlyPending ? "Review identity documents and verify user accounts." : "View history of processed verification requests.")</p>
            </div>
            <div class="col-md-6">
                <div class="d-flex align-items-center justify-content-md-end gap-2">
                    <a asp-action="Verifications" asp-route-onlyPending="true" class="nav-link-filter @(ViewBag.OnlyPending ? "active" : "")">Pending Requests</a>
                    <a asp-action="Verifications" asp-route-onlyPending="false" class="nav-link-filter @(!ViewBag.OnlyPending ? "active" : "")">Processed History</a>
                </div>
            </div>
        </div>
    </div>

    <div id="verification-container" class="d-flex flex-column gap-3">
        <partial name="_VerificationRows" model="Model" />
    </div>

    <!-- Loading Sentinel -->
    <div id="loading-sentinel" class="py-5 text-center @(Model.HasNextPage ? "" : "d-none")">
        <div class="spinner-border text-aurora" role="status" style="width: 2.5rem; height: 2.5rem;"></div>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center p-4" style="background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); z-index: 2000;">
    <div class="glass-card p-5 border-glass-strong w-100 shadow-2xl animate-entrance" style="max-width: 500px; border-radius: 2rem;">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <span class="material-symbols-outlined text-danger">warning</span>
            </div>
            <h4 class="fw-bold text-white mb-0">Reject Verification</h4>
        </div>
        
        <form asp-action="Reject" method="post">
            <input type="hidden" name="id" id="rejectId" />
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase tracking-widest ms-1 mb-2">Reason for rejection</label>
                <textarea name="notes" rows="4" class="form-control form-control-glass p-3" placeholder="e.g., Student ID is not clear enough or has expired..." style="border-radius: 1rem;"></textarea>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="closeRejectModal()" class="btn btn-glass flex-grow-1 py-2">Cancel</button>
                <button type="submit" class="btn btn-premium bg-danger border-danger text-white flex-grow-1 py-2">Confirm Reject</button>
            </div>
        </form>
    </div>
</div>

<!-- AI Report Modal -->
<div id="aiReportModal" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center p-4" style="background: rgba(0,0,0,0.85); backdrop-filter: blur(15px); z-index: 2100;">
    <div class="glass-card border-glass-strong w-100 shadow-2xl animate-entrance overflow-hidden" style="max-width: 700px; border-radius: 2rem;">
        <div class="p-4 border-bottom border-glass-soft d-flex align-items-center justify-content-between bg-glass-dark">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle bg-aurora bg-opacity-20 p-2 d-flex align-items-center justify-content-center">
                    <span class="material-symbols-outlined text-aurora fs-4">neurology</span>
                </div>
                <div>
                    <h5 class="fw-bold text-white mb-0">Guardian AI Full Analysis</h5>
                    <p class="text-muted small mb-0">Detailed document extraction & verification logs</p>
                </div>
            </div>
            <button onclick="closeAiReportModal()" class="btn-close btn-close-white opacity-50 hover-opacity-100 transition-all"></button>
        </div>
        
        <div class="p-5" style="max-height: 70vh; overflow-y: auto; background: rgba(0,0,0,0.3);">
            <div id="aiReportContent" class="text-white-50 family-mono" style="white-space: pre-wrap; font-size: 0.9rem; line-height: 1.6; letter-spacing: 0.02em;">
                <!-- Content will be injected here -->
            </div>
        </div>

        <div class="p-4 border-top border-glass-soft d-flex justify-content-end bg-glass-dark">
            <button onclick="closeAiReportModal()" class="btn btn-glass px-5 py-2 fw-bold text-uppercase fs-xs">Close Analysis</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-verifications.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            VerificationManager.init({
                currentPage: @Model.PageIndex,
                totalPages: @Model.TotalPages,
                onlyPending: @(ViewBag.OnlyPending.ToString().ToLower()),
                verificationUrl: '@Url.Action("Verifications")'
            });
        });
    </script>
}

<style>
    .nav-link-filter {
        padding: 0.5rem 1.25rem;
        border-radius: 0.75rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s var(--ease-apple);
        border: 1px solid transparent;
        background: transparent;
    }
    .nav-link-filter:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
    .nav-link-filter.active {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.1);
        color: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
</style>
