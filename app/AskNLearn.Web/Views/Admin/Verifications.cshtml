@using AskNLearn.Domain.Entities.Core
@model AskNLearn.Web.Models.PaginatedList<VerificationRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Verification Requests";
    int pendingCount = ViewBag.PendingVerificationsCount ?? 0;
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2">Student Verifications</h2>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <div class="rounded-circle bg-aurora shadow-glow" style="width: 8px; height: 8px;"></div>
                Validate student credentials for full platform access.
            </div>
        </div>
        <div class="d-flex gap-3">
             <button class="btn btn-glass d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">filter_alt</span>
                <span>Filter</span>
            </button>
            <button onclick="window.location.reload()" class="btn btn-premium d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">sync</span>
                <span>Refresh Queue</span>
            </button>
        </div>
    </div>


    <!-- Table Card -->
    <div class="glass-card overflow-hidden border-glass-strong">
        <div class="table-responsive bg-transparent">
            <table class="table table-borderless table-hover mb-0 align-middle text-white bg-transparent">
                <thead style="background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border-glass-strong);">
                    <tr>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Student / Username</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-center">ID Evidence</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Submission</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold">Status</th>
                        <th class="py-4 px-4 text-muted text-uppercase tracking-widest small fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="verification-tbody" style="border-top: none;">
                    <partial name="_VerificationRows" model="Model" />
                </tbody>
            </table>
        </div>
        
        <!-- Loading Sentinel -->
        <div id="loading-sentinel" class="py-4 text-center @(Model.HasNextPage ? "" : "d-none")">
            <div class="spinner-border text-aurora spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
</div>

<script>
    let currentPage = @Model.PageIndex;
    const totalPages = @Model.TotalPages;
    let isLoading = false;

    const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && currentPage < totalPages) {
            loadNextPage();
        }
    }, { threshold: 0.1 });

    const sentinel = document.getElementById('loading-sentinel');
    if (sentinel) observer.observe(sentinel);

    function loadNextPage() {
        isLoading = true;
        currentPage++;

        fetch(`@Url.Action("Verifications")?pageNumber=${currentPage}`, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('verification-tbody').insertAdjacentHTML('beforeend', html);
            isLoading = false;
            if (currentPage >= totalPages) {
                sentinel.classList.add('d-none');
            }
        })
        .catch(err => {
            console.error('Error loading verifications:', err);
            isLoading = false;
        });
    }
</script>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="d-none position-fixed top-0 start-0 w-100 h-100 z-3 d-flex align-items-center justify-content-center p-4" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
    <div class="glass-card p-4 border-glass-strong w-100 shadow-lg animate-entrance" style="max-width: 450px;">
        <h4 class="fw-bold text-white mb-4">Reject Verification</h4>
        <form asp-action="Reject" method="post">
            <input type="hidden" name="id" id="rejectId" />
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase tracking-widest">Reason for rejection</label>
                <textarea name="notes" rows="4" class="form-control form-control-glass" placeholder="e.g., Student ID is not clear enough..."></textarea>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="closeRejectModal()" class="btn btn-glass flex-grow-1">Cancel</button>
                <button type="submit" class="btn btn-premium bg-danger border-danger text-white flex-grow-1">Confirm Reject</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openRejectModal(id) {
        document.getElementById('rejectId').value = id;
        document.getElementById('rejectModal').classList.remove('d-none');
        document.getElementById('rejectModal').classList.add('d-flex');
    }
    function closeRejectModal() {
        document.getElementById('rejectModal').classList.add('d-none');
        document.getElementById('rejectModal').classList.remove('d-flex');
    }
</script>
