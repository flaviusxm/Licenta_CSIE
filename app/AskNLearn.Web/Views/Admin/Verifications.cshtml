@using AskNLearn.Domain.Entities.Core
@model AskNLearn.Web.Models.PaginatedList<VerificationRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Verification Requests";
}

@section Sidebar {
    <div class="p-4 border-bottom border-glass">
        <h2 class="h5 fw-bold text-white mb-2 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-aurora">verified_user</span>
            Verification Queue
        </h2>
        <p class="text-muted small mb-4">Validate student credentials for full platform access.</p>
    </div>

    <div class="flex-grow-1 p-3 overflow-y-auto custom-scrollbar">
        <div class="mb-4">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Status Filter</label>
            <div class="d-flex flex-column gap-1">
                <button class="nav-link-flat active">Pending Requests</button>
                <button class="nav-link-flat">Processed History</button>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="d-flex align-items-center justify-content-center gap-2 py-4 mt-auto text-muted hover-text-white transition-all text-decoration-none border-top border-glass">
        <span class="material-symbols-outlined fs-5">arrow_back</span>
        <span class="fw-bold text-uppercase tracking-widest fs-xs">Dashboard</span>
    </a>
}

<div class="max-w-5xl mx-auto p-4 animate-entrance">
    <div id="verification-container" class="d-flex flex-column gap-2">
        <partial name="_VerificationRows" model="Model" />
    </div>

    <!-- Loading Sentinel -->
    <div id="loading-sentinel" class="py-5 text-center @(Model.HasNextPage ? "" : "d-none")">
        <div class="spinner-border text-aurora" role="status"></div>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="d-none position-fixed top-0 start-0 w-100 h-100 z-3 d-flex align-items-center justify-content-center p-4" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
    <div class="glass-card p-4 border-glass-strong w-100 shadow-lg animate-entrance" style="max-width: 450px;">
        <h4 class="fw-bold text-white mb-4">Reject Verification</h4>
        <form asp-action="Reject" method="post">
            <input type="hidden" name="id" id="rejectId" />
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase tracking-widest">Reason for rejection</label>
                <textarea name="notes" rows="4" class="form-control form-control-glass" placeholder="e.g., Student ID is not clear enough..."></textarea>
            </div>
            <div class="d-flex gap-3">
                <button type="button" onclick="closeRejectModal()" class="btn btn-glass flex-grow-1">Cancel</button>
                <button type="submit" class="btn btn-premium bg-danger border-danger text-white flex-grow-1">Confirm Reject</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    let currentPage = @Model.PageIndex;
    const totalPages = @Model.TotalPages;
    let isLoading = false;

    const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !isLoading && currentPage < totalPages) {
            loadNextPage();
        }
    }, { threshold: 0.1 });

    const sentinel = document.getElementById('loading-sentinel');
    if (sentinel) observer.observe(sentinel);

    function loadNextPage() {
        isLoading = true;
        currentPage++;

        fetch(`@Url.Action("Verifications")?pageNumber=${currentPage}`, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('verification-container').insertAdjacentHTML('beforeend', html);
            isLoading = false;
            if (currentPage >= totalPages) {
                sentinel.classList.add('d-none');
            }
        })
        .catch(err => {
            console.error('Error loading verifications:', err);
            isLoading = false;
        });
    }

    function openRejectModal(id) {
        document.getElementById('rejectId').value = id;
        document.getElementById('rejectModal').classList.remove('d-none');
        document.getElementById('rejectModal').classList.add('d-flex');
    }
    function closeRejectModal() {
        document.getElementById('rejectModal').classList.add('d-none');
        document.getElementById('rejectModal').classList.remove('d-flex');
    }
</script>
}

<style>
    .nav-link-flat {
        display: block;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
    }
    .nav-link-flat:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-pure);
    }
    .nav-link-flat.active {
        background: rgba(0, 122, 255, 0.15);
        color: var(--text-pure);
    }
</style>
