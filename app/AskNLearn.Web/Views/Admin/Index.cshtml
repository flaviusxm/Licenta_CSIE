@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header Area -->
    <div class="d-flex align-items-end justify-content-between mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2 tracking-tight">System Pulse</h2>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <div class="rounded-circle bg-aurora shadow-glow animate-pulse" style="width: 8px; height: 8px;"></div>
                Real-time platform metrics and security overview.
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="AuditLogs" class="btn btn-glass btn-sm px-3 py-2 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-6">history</span>
                View Activity
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Stats & Pulse -->
        <div class="col-12">
            <div class="glass-card p-5 border-glass-strong shadow-2xl overflow-hidden position-relative">
                <div class="position-absolute top-0 end-0 p-5 opacity-10">
                    <span class="material-symbols-outlined" style="font-size: 120px;">analytics</span>
                </div>

                <div class="row g-5 mb-5 position-relative z-1">
                    <div class="col-6 col-sm-3">
                        <label class="text-muted small fw-bold text-uppercase tracking-widest d-block mb-2" style="font-size: 0.6rem;">Users</label>
                        <h3 class="h2 fw-black text-white m-0">@ViewBag.TotalUsers.ToString("N0")</h3>
                    </div>
                    <div class="col-6 col-sm-3">
                        <label class="text-muted small fw-bold text-uppercase tracking-widest d-block mb-2" style="font-size: 0.6rem;">Communities</label>
                        <h3 class="h2 fw-black text-white m-0">@ViewBag.TotalCommunities.ToString("N0")</h3>
                    </div>
                    <div class="col-6 col-sm-3">
                        <label class="text-muted small fw-bold text-uppercase tracking-widest d-block mb-2" style="font-size: 0.6rem;">AI Resolved</label>
                        <h3 class="h2 fw-black text-aurora m-0">@ViewBag.AiApprovedCount.ToString("N0")</h3>
                    </div>
                    <div class="col-6 col-sm-3">
                        <label class="text-muted small fw-bold text-uppercase tracking-widest d-block mb-2" style="font-size: 0.6rem;">Flagged</label>
                        <h3 class="h2 fw-black text-danger m-0">@ViewBag.AiFlaggedCount.ToString("N0")</h3>
                    </div>
                </div>

                <div class="p-4 rounded-4 bg-black bg-opacity-30 border border-glass d-flex align-items-center justify-content-between">
                     <div class="d-flex align-items-center gap-4">
                        <div class="text-center">
                            <span class="text-muted small d-block mb-1">Awaiting Review</span>
                            <span class="badge glass-badge glass-badge-warning fs-6 px-3">@ViewBag.AiSuspectCount</span>
                        </div>
                        <div class="border-start border-glass h-30px mx-2"></div>
                        <div class="text-center">
                            <span class="text-muted small d-block mb-1">Pending ID</span>
                            <span class="badge glass-badge glass-badge-aurora fs-6 px-3">@ViewBag.PendingVerifications</span>
                        </div>
                     </div>
                     <a asp-action="Moderation" class="btn btn-premium px-4 shadow-glow">Review Queue</a>
                </div>
            </div>

            <!-- Recent Activity List (Mock/Placeholder for now) -->
            <div class="mt-5">
                <h5 class="text-white fw-bold mb-4 px-1 d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-accent">history</span>
                    Recent System Activity
                </h5>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center gap-4 p-4 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft">
                        <div class="rounded-circle bg-aurora-soft text-aurora p-3"><span class="material-symbols-outlined fs-4">person_add</span></div>
                        <div class="flex-grow-1"><span class="text-white fw-bold">New User Registration</span><p class="text-muted small mb-0">User 'flavius_xm' joined the platform from University node.</p></div>
                        <div class="text-end">
                            <span class="text-muted tiny d-block">2m ago</span>
                            <span class="badge glass-badge glass-badge-aurora mt-1">Real-time</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-4 p-4 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft">
                        <div class="rounded-circle bg-danger-soft text-danger p-3"><span class="material-symbols-outlined fs-4">security</span></div>
                        <div class="flex-grow-1"><span class="text-white fw-bold">AI Block Action</span><p class="text-muted small mb-0">Inappropriate content flagged and hidden in 'Web Dev' forum.</p></div>
                        <div class="text-end">
                            <span class="text-muted tiny d-block">15m ago</span>
                            <span class="badge glass-badge glass-badge-danger mt-1">Blocked</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-4 p-4 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft">
                        <div class="rounded-circle bg-primary-soft text-primary p-3"><span class="material-symbols-outlined fs-4">verified</span></div>
                        <div class="flex-grow-1"><span class="text-white fw-bold">Identity Approved</span><p class="text-muted small mb-0">Stefan Ionescu verified their student ID (UPB).</p></div>
                        <div class="text-end">
                            <span class="text-muted tiny d-block">1h ago</span>
                            <span class="badge glass-badge glass-badge-aurora mt-1">Verified</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .h-30px { height: 30px; }
    .tiny { font-size: 0.6rem; }
    .animate-pulse { animation: pulse 2s infinite; }
    @@keyframes pulse {
        0% { transform: scale(0.95); opacity: 0.5; }
        50% { transform: scale(1.05); opacity: 1; }
        100% { transform: scale(0.95); opacity: 0.5; }
    }
</style>
