@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2">Dashboard Overview</h2>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <div class="rounded-circle bg-success shadow-glow" style="width: 8px; height: 8px;"></div>
                Platform performance and student verification pulse.
            </div>
        </div>
        <div class="d-flex gap-3">
            <button class="btn btn-glass d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">filter_list</span>
                <span>Filter</span>
            </button>
            <button onclick="window.location.reload()" class="btn btn-premium d-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">refresh</span>
                <span>Refresh Queue</span>
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-glass-strong">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-opacity-10 bg-info text-info border border-info border-opacity-25">
                        <span class="material-symbols-outlined">pending_actions</span>
                    </div>
                </div>
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Queue Size</p>
                <div class="d-flex align-items-baseline gap-2">
                    <h3 class="display-5 fw-bold text-white mb-0">@ViewBag.PendingVerifications</h3>
                    <span class="text-success small fw-bold">+5 new today</span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-glass-strong">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-opacity-10 bg-success text-success border border-success border-opacity-25">
                        <span class="material-symbols-outlined">check_circle</span>
                    </div>
                </div>
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Success Rate</p>
                <div class="d-flex align-items-baseline gap-2">
                    <h2 class="display-5 fw-bold text-white mb-0">92%</h2>
                    <span class="text-muted small">Global Avg</span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card p-4 h-100 border-glass-strong">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="p-3 rounded-4 bg-opacity-10 bg-danger text-danger border border-danger border-opacity-25 shadow-glow">
                        <span class="material-symbols-outlined">security</span>
                    </div>
                </div>
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Flagged Content</p>
                <div class="d-flex align-items-baseline gap-2">
                    <h2 class="display-5 fw-bold text-white mb-0">@ViewBag.FlaggedContentCount</h2>
                    <span class="text-danger small fw-bold">AI Moderated</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Placeholder -->
    <div class="glass-card overflow-hidden border-glass-strong">
        <div class="p-4 border-bottom border-glass-strong d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.2);">
            <h5 class="fw-bold text-white mb-0">Pending Activity</h5>
            <a asp-action="Verifications" class="text-aurora fw-bold text-decoration-none small">Queue →</a>
        </div>
        <div class="p-5 text-center d-flex flex-column align-items-center gap-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-muted border border-glass" style="width: 80px; height: 80px; background: rgba(255,255,255,0.05);">
                <span class="material-symbols-outlined display-5">inbox</span>
            </div>
            <p class="text-muted mb-0 mx-auto" style="max-width: 300px;">Check the verification queue to process new student applications and maintain platform integrity.</p>
        </div>
    </div>
</div>
