@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h2 class="display-6 fw-bold text-white mb-2">Dashboard Overview</h2>
        </div>
    </div>

    <!-- Recent Activity Placeholder -->
    <div class="glass-card overflow-hidden border-glass-strong">
        <div class="p-4 border-bottom border-glass-strong d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.2);">
            <h5 class="fw-bold text-white mb-0">Pending Activity</h5>
            <a asp-action="Verifications" class="text-aurora fw-bold text-decoration-none small">Queue →</a>
        </div>
        <div class="p-5 text-center d-flex flex-column align-items-center gap-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-muted border border-glass" style="width: 80px; height: 80px; background: rgba(255,255,255,0.05);">
                <span class="material-symbols-outlined display-5">inbox</span>
            </div>
            <p class="text-muted mb-0 mx-auto" style="max-width: 300px;">Check the verification queue to process new student applications and maintain platform integrity.</p>
        </div>
    </div>
</div>
