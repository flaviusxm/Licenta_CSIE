@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-0 animate-entrance">
    <!-- Header -->
    <div class="mb-5">
        <h2 class="display-6 fw-bold text-white mb-2 tracking-tight">System Overview</h2>
        <p class="text-muted">Real-time platform health and security metrics.</p>
    </div>

    <!-- Stats Grid -->
    <div class="row g-4 mb-5">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="glass-card p-4 border-glass shadow-lg h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-aurora-soft text-aurora" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined">group</span>
                    </div>
                    <span class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Total Users</span>
                </div>
                <h3 class="display-6 fw-black text-white m-0">@ViewBag.TotalUsers.ToString("N0")</h3>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="glass-card p-4 border-glass shadow-lg h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-primary-soft text-primary" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined">verified_user</span>
                    </div>
                    <span class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">Pending ID</span>
                </div>
                <h3 class="display-6 fw-black text-white m-0">@ViewBag.PendingVerifications.ToString("N0")</h3>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="glass-card p-4 border-glass shadow-lg h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-danger-soft text-danger" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined">security</span>
                    </div>
                    <span class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">AI Flagged</span>
                </div>
                <h3 class="display-6 fw-black text-white m-0">@ViewBag.AiFlaggedCount.ToString("N0")</h3>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="glass-card p-4 border-glass shadow-lg h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-warning-soft text-warning" style="width: 48px; height: 48px;">
                        <span class="material-symbols-outlined">feedback</span>
                    </div>
                    <span class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.7rem;">User Reports</span>
                </div>
                <h3 class="display-6 fw-black text-white m-0">@ViewBag.PendingReportsCount.ToString("N0")</h3>
            </div>
        </div>
    </div>

    <!-- AI Insights Section -->
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="glass-card overflow-hidden border-glass-strong shadow-2xl h-100">
                <div class="p-4 border-bottom border-glass-strong d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.2);">
                    <div>
                        <h5 class="fw-bold text-white mb-1">AI Guardian Performance</h5>
                        <p class="text-muted small m-0">Automated content moderation summary.</p>
                    </div>
                    <span class="badge bg-aurora-soft text-aurora fw-bold">Live Tracking</span>
                </div>
                <div class="p-5">
                    <div class="row g-5">
                        <div class="col-12 col-sm-4 text-center">
                            <div class="mb-3 text-success opacity-75">
                                <span class="material-symbols-outlined display-4">check_circle</span>
                            </div>
                            <h4 class="text-white fw-black m-0">@ViewBag.AiApprovedCount.ToString("N0")</h4>
                            <p class="text-muted text-uppercase tracking-widest fw-bold mt-2" style="font-size: 0.6rem;">AI Auto-Resolved</p>
                        </div>
                        <div class="col-12 col-sm-4 text-center">
                            <div class="mb-3 text-danger opacity-75">
                                <span class="material-symbols-outlined display-4">report</span>
                            </div>
                            <h4 class="text-white fw-black m-0">@ViewBag.AiFlaggedCount.ToString("N0")</h4>
                            <p class="text-muted text-uppercase tracking-widest fw-bold mt-2" style="font-size: 0.6rem;">AI Blocked/Flagged</p>
                        </div>
                        <div class="col-12 col-sm-4 text-center">
                            <div class="mb-3 text-warning opacity-75">
                                <span class="material-symbols-outlined display-4">visibility</span>
                            </div>
                            <h4 class="text-white fw-black m-0">@ViewBag.AiSuspectCount.ToString("N0")</h4>
                            <p class="text-muted text-uppercase tracking-widest fw-bold mt-2" style="font-size: 0.6rem;">Requires Manual Review</p>
                        </div>
                    </div>
                    
                    <div class="mt-5 p-4 rounded-4 bg-black bg-opacity-30 border border-glass d-flex align-items-center justify-content-between">
                         <div class="d-flex align-items-center gap-3">
                            <span class="material-symbols-outlined text-aurora">info</span>
                            <span class="text-muted small">The AI has processed over <b>@((ViewBag.AiApprovedCount + ViewBag.AiFlaggedCount + ViewBag.AiSuspectCount).ToString("N0"))</b> items this session.</span>
                         </div>
                         <a asp-action="Moderation" class="btn btn-premium btn-sm px-4">Intervene Now</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
             <div class="glass-card p-5 border-glass shadow-lg h-100 d-flex flex-column align-items-center justify-content-center text-center gap-4">
                 <div class="rounded-circle d-flex align-items-center justify-content-center bg-universe border border-glass" style="width: 80px; height: 80px;">
                    <span class="material-symbols-outlined text-muted display-5">hub</span>
                 </div>
                 <div>
                    <h5 class="text-white fw-bold">Platform Status</h5>
                    <p class="text-muted small">All systems operational. Database connected to <b>@ViewBag.TotalCommunities communities</b>.</p>
                 </div>
                 <a asp-action="Verifications" class="btn btn-glass w-100 py-3 rounded-4 fw-bold">Open Verification Queue</a>
             </div>
        </div>
    </div>
</div>
