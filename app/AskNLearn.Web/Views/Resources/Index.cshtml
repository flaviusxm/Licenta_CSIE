@using AskNLearn.Domain.Entities.Core
@model List<StoredFile>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Academic Resources";
}

@section Sidebar {
    <div class="p-4 border-bottom border-glass animate-entrance">
        <h2 class="h5 fw-bold text-white mb-2 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-white">folder_open</span>
            Academic Resources
        </h2>
        <p class="text-muted small mb-4">Browse and share learning materials with your colleagues</p>

        <button class="btn btn-premium w-100 d-flex align-items-center justify-content-center gap-2 py-3 mb-2 shadow-lg" data-bs-toggle="modal" data-bs-target="#uploadModal">
            <span class="material-symbols-outlined fs-5">cloud_upload</span>
            Upload Material
        </button>
    </div>

    <div class="flex-grow-1 p-3 overflow-y-auto custom-scrollbar animate-entrance" style="animation-delay: 0.1s;">
        <div class="mb-4">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Search</label>
            <div class="position-relative">
                <span class="material-symbols-outlined position-absolute start-0 top-50 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                <input type="text" id="resource-search" class="form-control form-control-glass ps-5" placeholder="Search files real-time..." oninput="filterResources(this.value)" />
            </div>
        </div>

        <div class="mb-4">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Filter by type</label>
            <div class="d-flex flex-column gap-1">
                <a href="?type=" class="nav-link-flat @(string.IsNullOrEmpty(Context.Request.Query["type"]) ? "active" : "")">
                    <span class="material-symbols-outlined fs-6 me-2">all_inclusive</span> All Files
                </a>
                <a href="?type=pdf" class="nav-link-flat @(Context.Request.Query["type"] == "pdf" ? "active" : "")">
                    <span class="material-symbols-outlined fs-6 me-2">picture_as_pdf</span> PDF Documents
                </a>
                <a href="?type=image" class="nav-link-flat @(Context.Request.Query["type"] == "image" ? "active" : "")">
                    <span class="material-symbols-outlined fs-6 me-2">image</span> Images
                </a>
                <a href="?type=word" class="nav-link-flat @(Context.Request.Query["type"] == "word" ? "active" : "")">
                    <span class="material-symbols-outlined fs-6 me-2">description</span> Word Docs
                </a>
            </div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center justify-content-center gap-2 py-4 mt-auto text-muted hover-text-white transition-all text-decoration-none border-top border-glass">
        <span class="material-symbols-outlined fs-5">arrow_back</span>
        <span class="fw-bold text-uppercase tracking-widest fs-xs">Back</span>
    </a>
}

<div class="max-w-4xl mx-auto p-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5 opacity-50">
            <span class="material-symbols-outlined display-1 mb-3">draft_orders</span>
            <h3 class="h4">No resources found</h3>
            <p>Be the first to upload a study material!</p>
        </div>
    }
    else
    {
    <div id="resource-container" class="d-flex flex-column gap-1">
        <partial name="_ResourceList" model="Model" />
    </div>
    
    <div id="load-more-indicator" class="text-center py-4 d-none">
        <div class="spinner-border text-accent spinner-border-sm"></div>
    </div>

    }
</div>



@section Modals {
    <!-- Upload Modal -->
    <div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card border-glass shadow-2xl" style="background: rgba(15, 15, 17, 0.95); backdrop-filter: blur(40px);">
                <div class="modal-header border-glass">
                    <h5 class="modal-title text-white fw-bold">Upload New Material</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div class="modal-body p-4">
                        <div class="upload-drop-zone border-dashed rounded-xl p-5 text-center transition-all cursor-pointer hover-bg-glass" 
                             onclick="document.getElementById('modalFileUpload').click()">
                            <span class="material-symbols-outlined display-4 text-accent mb-3">cloud_upload</span>
                            <h4 class="h6 text-white fw-bold mb-1">Click to browse or drag and drop</h4>
                            <p class="text-muted small mb-0">PDF, Images, or Documents (Max 50MB)</p>
                            <input type="file" id="modalFileUpload" name="file" class="d-none" onchange="updateModalFileName(this)" />
                        </div>
                        <div id="modalFileName" class="mt-3 text-accent small fw-bold text-center d-none">
                            <!-- Selected file name will appear here -->
                        </div>
                    </div>
                    <div class="modal-footer border-glass">
                        <button type="button" class="btn btn-glass" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-premium px-4">Upload File</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Preview Modal -->
    <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content glass-card border-glass h-80vh shadow-2xl" style="background: rgba(10, 10, 12, 0.98); backdrop-filter: blur(40px);">
                <div class="modal-header border-glass py-2">
                    <div class="d-flex align-items-center gap-3">
                        <span id="previewIcon" class="material-symbols-outlined text-accent fs-4">description</span>
                        <h5 id="previewTitle" class="modal-title text-white fw-bold small mb-0">File Preview</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 overflow-hidden bg-black-alpha-40">
                    <div id="previewContainer" class="h-100 d-flex align-items-center justify-content-center">
                        <!-- Preview content injected by JS -->
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    let previewModalInstance = null;
    let skip = 15;
    const take = 15;
    let isLoading = false;
    let hasMore = true;

    document.addEventListener('DOMContentLoaded', () => {
        const main = document.querySelector('main');
        if (main) {
            main.addEventListener('scroll', () => {
                if (isLoading || !hasMore) return;
                
                const scrollPos = main.scrollTop + main.clientHeight;
                const threshold = main.scrollHeight - 100;
                
                if (scrollPos >= threshold) {
                    loadMoreResources();
                }
            });
        }
    });

    async function loadMoreResources() {
        if (isLoading || !hasMore) return;
        
        isLoading = true;
        document.getElementById('load-more-indicator').classList.remove('d-none');
        
        const type = new URLSearchParams(window.location.search).get('type') || '';
        const term = document.getElementById('resource-search').value;
        
        try {
            const response = await fetch(`/resources?type=${type}&searchTerm=${term}&skip=${skip}&take=${take}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            
            if (response.ok) {
                const html = await response.text();
                if (html.trim().length === 0) {
                    hasMore = false;
                } else {
                    document.getElementById('resource-container').insertAdjacentHTML('beforeend', html);
                    skip += take;
                }
            }
        } catch (err) {
            console.error("Error loading resources:", err);
        } finally {
            isLoading = false;
            document.getElementById('load-more-indicator').classList.add('d-none');
        }
    }

    let searchTimeout = null;
    async function filterResources(term) {
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(async () => {
            isLoading = true;
            skip = 0; // Reset pagination for new search
            hasMore = true;
            
            const type = new URLSearchParams(window.location.search).get('type') || '';
            const container = document.getElementById('resource-container');
            
            try {
                const response = await fetch(`/resources?type=${type}&searchTerm=${term}&skip=0&take=${take}`, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
                
                if (response.ok) {
                    const html = await response.text();
                    container.innerHTML = html;
                    skip = take;
                    
                    // Toggle "No results" message
                    let emptyMsg = document.getElementById('search-empty-msg');
                    if (html.trim().length === 0) {
                        if (!emptyMsg) {
                            container.insertAdjacentHTML('afterend', `
                                <div id="search-empty-msg" class="text-center py-5 opacity-50 animate-entrance">
                                    <span class="material-symbols-outlined display-1 mb-3">search_off</span>
                                    <h3 class="h4">No matching resources</h3>
                                    <p>Try a different search term.</p>
                                </div>
                            `);
                        }
                    } else {
                        emptyMsg?.remove();
                    }
                }
            } catch (err) {
                console.error("Error searching resources:", err);
            } finally {
                isLoading = false;
            }
        }, 300);
    }

    function updateModalFileName(input) {
        const nameDiv = document.getElementById('modalFileName');
        if (input.files && input.files[0]) {
            nameDiv.textContent = `Selected: ${input.files[0].name}`;
            nameDiv.classList.remove('d-none');
        } else {
            nameDiv.classList.add('d-none');
        }
    }

    function previewFile(id, name, path, type) {
        const title = document.getElementById('previewTitle');
        const container = document.getElementById('previewContainer');
        const icon = document.getElementById('previewIcon');
        
        title.textContent = name;
        container.innerHTML = '<div class="spinner-border text-accent"></div>';
        
        if (!previewModalInstance) {
            previewModalInstance = new bootstrap.Modal(document.getElementById('previewModal'));
        }
        previewModalInstance.show();

        setTimeout(() => {
            if (type.includes('image')) {
                icon.textContent = 'image';
                container.innerHTML = `<img src="${path}" class="img-fluid rounded shadow-lg animate-entrance" style="max-height: 90%; object-fit: contain;" />`;
            } else if (type.includes('pdf')) {
                icon.textContent = 'picture_as_pdf';
                container.innerHTML = `<iframe src="${path}" class="w-100 h-100 border-0" style="min-height: 70vh;"></iframe>`;
            } else {
                icon.textContent = 'draft';
                container.innerHTML = `
                    <div class="text-center p-5 animate-entrance">
                        <span class="material-symbols-outlined display-1 text-muted mb-3">quick_reference_all</span>
                        <h4 class="text-white">Preview not available</h4>
                        <p class="text-muted small mb-4">This file type (${type}) cannot be previewed directly.</p>
                        <a href="/resources/download/${id}" class="btn btn-premium px-4">Download to View</a>
                    </div>
                `;
            }
        }, 300);
    }
</script>
}

<style>
    .h-80vh { height: 85vh; }
    .bg-black-alpha-40 { background: rgba(0,0,0,0.4); }
    .border-dashed { border: 2px dashed rgba(255,255,255,0.1); }
    .upload-drop-zone:hover { border-color: var(--color-accent); background: rgba(255,255,255,0.05); }
    
    .resource-item {
        transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
        backface-visibility: hidden;
        transform: translateZ(0);
    }
    .resource-item:hover {
        background: rgba(255, 255, 255, 0.03);
    }
    .btn-icon-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: background 0.2s ease, color 0.2s ease;
    }
    .bg-black-alpha-20 { background: rgba(0,0,0,0.2); }
</style>
