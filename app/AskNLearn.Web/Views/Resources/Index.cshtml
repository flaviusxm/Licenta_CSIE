@using AskNLearn.Domain.Entities.Core
@model List<StoredFile>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Academic Resources";
}

<div class="d-flex h-100 flex-column overflow-hidden">
    <!-- Header Area (Discord-like) -->
    <div class="px-4 py-3 border-bottom border-glass d-flex align-items-center justify-content-between bg-black-alpha-20">
        <div>
            <h2 class="h5 fw-bold text-white mb-0 d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-accent">folder_open</span>
                Academic Resources
            </h2>
            <p class="text-muted small mb-0">Browse and share learning materials with your colleagues</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-premium btn-sm d-flex align-items-center gap-2 px-3" onclick="document.getElementById('fileUpload').click()">
                <span class="material-symbols-outlined fs-6">upload</span>
                Upload Material
            </button>
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="d-none">
                <input type="file" id="fileUpload" name="file" onchange="this.form.submit()" />
            </form>
        </div>
    </div>

    <div class="flex-grow-1 d-flex overflow-hidden">
        <!-- Sidebar Filters (Discord-like) -->
        <aside class="sidebar-filters border-right border-glass p-3 d-none d-lg-block" style="width: 240px;">
            <div class="mb-4">
                <label class="text-muted small fw-bold text-uppercase tracking-widest mb-2 d-block">Filter by type</label>
                <div class="d-flex flex-column gap-1">
                    <a href="?type=" class="nav-link-flat @(string.IsNullOrEmpty(Context.Request.Query["type"]) ? "active" : "")">All Files</a>
                    <a href="?type=pdf" class="nav-link-flat @(Context.Request.Query["type"] == "pdf" ? "active" : "")">PDF Documents</a>
                    <a href="?type=image" class="nav-link-flat @(Context.Request.Query["type"] == "image" ? "active" : "")">Images</a>
                    <a href="?type=word" class="nav-link-flat @(Context.Request.Query["type"] == "word" ? "active" : "")">Word Docs</a>
                </div>
            </div>
            
            <div class="mb-4">
                <label class="text-muted small fw-bold text-uppercase tracking-widest mb-2 d-block">Search</label>
                <form action="" method="get">
                    <input type="hidden" name="type" value="@Context.Request.Query["type"]" />
                    <input type="text" name="searchTerm" class="form-control form-control-glass sm" placeholder="Search files..." value="@Context.Request.Query["searchTerm"]" />
                </form>
            </div>
        </aside>

        <!-- Main Feed (Reddit/Flat style) -->
        <main class="flex-grow-1 overflow-y-auto custom-scrollbar p-4">
            <div class="max-w-4xl mx-auto">
                @if (!Model.Any())
                {
                    <div class="text-center py-5 opacity-50">
                        <span class="material-symbols-outlined display-1 mb-3">draft_orders</span>
                        <h3 class="h4">No resources found</h3>
                        <p>Be the first to upload a study material!</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-1">
                        @foreach (var file in Model)
                        {
                            <div class="resource-item d-flex align-items-center gap-3 p-3 rounded-lg hover-bg-glass transition-all border-bottom border-glass-soft">
                                <div class="file-icon rounded-lg d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass);">
                                    <span class="material-symbols-outlined fs-4 text-accent">
                                        @(file.FileType?.Contains("pdf") == true ? "picture_as_pdf" : 
                                          file.FileType?.Contains("image") == true ? "image" : 
                                          file.FileType?.Contains("word") == true ? "description" : "draft")
                                    </span>
                                </div>
                                
                                <div class="flex-grow-1 min-w-0">
                                    <h4 class="h6 fw-bold text-white mb-0 text-truncate">@file.FileName</h4>
                                    <div class="d-flex align-items-center gap-2 text-muted" style="font-size: 0.75rem;">
                                        <span>Uploaded by @(file.Uploader?.FullName ?? "Unknown")</span>
                                        <span>•</span>
                                        <span>@((file.FileSize ?? 0) / 1024) KB</span>
                                        <span>•</span>
                                        <span>@file.UploadedAt.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>

                                <div class="d-flex gap-1">
                                    <a asp-action="Download" asp-route-id="@file.Id" class="btn btn-glass btn-icon-sm" title="Download">
                                        <span class="material-symbols-outlined fs-5">download</span>
                                    </a>
                                    @if (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == file.UploaderId || User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@file.Id" method="post" onsubmit="return confirm('Delete this file?')" class="m-0">
                                            <button type="submit" class="btn btn-glass btn-icon-sm text-danger" title="Delete">
                                                <span class="material-symbols-outlined fs-5">delete</span>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </main>
    </div>
</div>

<style>
    .nav-link-flat {
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .nav-link-flat:hover {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-pure);
    }
    .nav-link-flat.active {
        background: var(--color-accent-soft);
        color: var(--text-pure);
    }
    .resource-item:hover {
        background: rgba(255, 255, 255, 0.03);
    }
    .btn-icon-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }
    .bg-black-alpha-20 { background: rgba(0,0,0,0.2); }
</style>
