@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Resources Hub";
}

<div class="p-8 flex flex-col gap-8 pb-20">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Resources Hub</h2>
            <p class="text-slate-500 dark:text-slate-400">Access and share study materials with your peers.</p>
        </div>
        <div class="flex gap-3">
            <button class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold transition-all text-slate-700 dark:text-white">
                <span class="material-symbols-outlined">upload</span>
                Upload
            </button>
        </div>
    </div>

    <!-- Search & Categories -->
    <div class="flex flex-col md:flex-row gap-4">

        <!-- Search -->
        <div class="flex-1 relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
                search
            </span>
            <input class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl py-3 pl-12 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400"
                   placeholder="Search for notes, PDFs, or exam papers..."
                   type="text" />
        </div>

        <!-- Filter Button -->
        <div class="relative">
            <button onclick="toggleFilter()"
                    class="flex items-center gap-2 bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl px-4 py-3 text-sm text-slate-700 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-700 transition">

                <span class="material-symbols-outlined text-slate-500 dark:text-slate-300">
                    filter_list
                </span>
                Filter
            </button>

            <!-- Dropdown -->
            <div id="filterDropdown"
                 class="hidden absolute right-0 mt-2 w-56 bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl shadow-lg p-4 z-50 space-y-3">

                <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-white">
                    <input type="checkbox" class="accent-primary">
                    Notes
                </label>

                <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-white">
                    <input type="checkbox" class="accent-primary">
                    PDFs
                </label>

                <label class="flex items-center gap-2 text-sm text-slate-700 dark:text-white">
                    <input type="checkbox" class="accent-primary">
                    Exam Papers
                </label>
            </div>
        </div>

    </div>
    <!-- Resource Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Resource Card 1 -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all group flex flex-col gap-4 shadow-sm">
            <div class="flex items-start justify-between">
                <div class="size-12 rounded-xl bg-red-500/10 text-red-500 flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">picture_as_pdf</span>
                </div>
                <button class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 transition-colors">
                    <span class="material-symbols-outlined">more_vert</span>
                </button>
            </div>
            <div>
                <h3 class="font-bold text-slate-900 dark:text-white mb-1 group-hover:text-primary transition-colors">Advanced Calculus Notes</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400">Shared by Alex Johnson • 2 days ago</p>
            </div>
            <div class="flex items-center justify-between mt-2 pt-4 border-t border-border-light dark:border-border-dark">
                <span class="text-xs font-medium text-slate-400 italic">2.4 MB • PDF</span>
                <button class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold text-sm transition-all text-slate-700 dark:text-white">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Download
                </button>
            </div>
        </div>

        <!-- Resource Card 2 -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all group flex flex-col gap-4 shadow-sm">
            <div class="flex items-start justify-between">
                <div class="size-12 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">description</span>
                </div>
                <button class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 transition-colors">
                    <span class="material-symbols-outlined">more_vert</span>
                </button>
            </div>
            <div>
                <h3 class="font-bold text-slate-900 dark:text-white mb-1 group-hover:text-primary transition-colors">Java Programming Lab Guide</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400">Shared by Sarah Smith • 5 days ago</p>
            </div>
            <div class="flex items-center justify-between mt-2 pt-4 border-t border-border-light dark:border-border-dark">
                <span class="text-xs font-medium text-slate-400 italic">1.1 MB • DOCX</span>
                <button class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold text-sm transition-all text-slate-700 dark:text-white">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Download
                </button>
            </div>
        </div>

        <!-- Resource Card 3 -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all group flex flex-col gap-4 shadow-sm">
            <div class="flex items-start justify-between">
                <div class="size-12 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">folder_zip</span>
                </div>
                <button class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-white/5 text-slate-400 transition-colors">
                    <span class="material-symbols-outlined">more_vert</span>
                </button>
            </div>
            <div>
                <h3 class="font-bold text-slate-900 dark:text-white mb-1 group-hover:text-primary transition-colors">Database Systems Lab Work</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400">Shared by Mike Ross • 1 week ago</p>
            </div>
            <div class="flex items-center justify-between mt-2 pt-4 border-t border-border-light dark:border-border-dark">
                <span class="text-xs font-medium text-slate-400 italic">15 MB • ZIP</span>
                <button class="inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold text-sm transition-all text-slate-700 dark:text-white">
                    <span class="material-symbols-outlined text-sm">download</span>
                    Download
                </button>
            </div>
        </div>
    </div>
</div>
<script>
        function toggleFilter() {
        const dropdown = document.getElementById("filterDropdown");
        dropdown.classList.toggle("hidden");
        }
    document.addEventListener("click", function(event) {
        const dropdown = document.getElementById("filterDropdown");
        const button = event.target.closest("button");
        if (!event.target.closest("#filterDropdown") && !button) {
            dropdown.classList.add("hidden");
        }
    });
</script>