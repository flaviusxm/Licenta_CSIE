<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - AskNLearn</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-mesh-bg d-flex flex-column vh-100 overflow-hidden">

    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>
    <div class="aurora-orb aurora-orb-blue position-fixed"></div>

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 80px; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 250px;">
            <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <h1 class="fs-4 fw-bold tracking-tight text-white mb-0">
                    Ask<span class="text-aurora">N</span>Learn
                </h1>
            </a>
        </div>

        <!-- Center Global Navigation -->
        <nav class="d-none d-lg-flex align-items-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="nav-link-premium justify-content-center @(ViewData["ActivePage"] as string == "Home" ? "active" : "") animate-entrance delay-100">
                Home
            </a>
            <a asp-controller="Explore" asp-action="Index" class="nav-link-premium justify-content-center @(ViewData["ActivePage"] as string == "Explore" ? "active" : "") animate-entrance delay-200">
                Explore
            </a>
            <a asp-controller="Resources" asp-action="Index" class="nav-link-premium justify-content-center @(ViewData["ActivePage"] as string == "Resources" ? "active" : "") animate-entrance delay-300">
                Resources
            </a>
            <a asp-controller="StudyGroups" asp-action="Index" class="nav-link-premium justify-content-center @(ViewData["ActivePage"] as string == "StudyGroups" ? "active" : "") animate-entrance delay-400">
                Groups
            </a>
            <a asp-controller="Leaderboard" asp-action="Index" class="nav-link-premium justify-content-center @(ViewData["ActivePage"] as string == "Leaderboard" ? "active" : "") animate-entrance delay-500">
                Leaderboard
            </a>
        </nav>
        
        <!-- Right Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3" style="width: 250px;">
            @if (User.Identity.IsAuthenticated)
            {
                <!-- Inbox -->
                <a asp-controller="Inbox" asp-action="Index" class="btn btn-link text-muted hover-text-white p-2 rounded-circle transition-all d-flex align-items-center justify-content-center text-decoration-none hover-bg-glass">
                    <span class="material-symbols-outlined fs-5">all_inbox</span>
                </a>

                <div class="mx-2" style="width: 1px; height: 24px; background: var(--border-glass-strong);"></div>
                
                <!-- Profile Link -->
                <a asp-controller="Profile" asp-action="Index" class="text-decoration-none">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-muted transition-colors hover-glow" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass-strong);">
                        <span class="material-symbols-outlined fs-5">person</span>
                    </div>
                </a>
            }
            else
            {
                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Auth" asp-action="SignIn" class="btn btn-link text-muted hover-text-white text-decoration-none fw-bold small text-uppercase tracking-widest px-3">Log In</a>
                    <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium d-flex align-items-center justify-content-center py-2 px-4 shadow-sm" style="font-size: 0.8rem;">Sign Up</a>
                </div>
            }
        </div>
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        @if (IsSectionDefined("Sidebar"))
        {
            <!-- Left Sidebar -->
            <aside id="leftSidebar" class="d-flex sidebar-transition flex-column h-100 flex-shrink-0 position-relative" style="width: 300px; border-right: 1px solid var(--border-glass); background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(20px); z-index: 2;">
                <div class="flex-grow-1 d-flex flex-column min-vh-0 overflow-hidden">
                    @RenderSection("Sidebar")
                </div>
            </aside>
            <button id="toggleLeftSidebar"
                    class="d-flex sidebar-transition align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 p-0 shadow-lg"
                    style="left: 300px; width: 28px; height: 64px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-left: none; backdrop-filter: blur(10px);">
                <span class="material-symbols-outlined text-muted m-0 p-0" style="margin-left: -2px !important;">chevron_left</span>
            </button>
        }

        <!-- Center Feed -->
        <main class="flex-grow-1 h-100 position-relative w-100 @(ViewData["AppLayout"] as bool? == true ? "d-flex flex-column overflow-hidden" : "overflow-y-auto custom-scrollbar")">
            @if (User.Identity.IsAuthenticated && ViewData["HideProfileCompletion"] as bool? != true)
            {
                <div class="p-4 p-md-5 pb-0">
                    @await Component.InvokeAsync("ProfileCompletion")
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const leftSidebar = document.getElementById("leftSidebar");
        const leftButton = document.getElementById("toggleLeftSidebar");
        const chevron = leftButton ? leftButton.querySelector('span') : null;

        if (leftSidebar && leftButton) {
            leftButton.addEventListener("click", () => {
                const isCollapsed = leftSidebar.classList.toggle("sidebar-collapsed");
                chevron.innerText = isCollapsed ? "chevron_right" : "chevron_left";
                leftButton.style.left = isCollapsed ? "0px" : "300px";
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
