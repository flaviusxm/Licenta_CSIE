<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - AskNLearn</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-mesh-bg d-flex flex-column vh-100 overflow-hidden" style="font-family: 'Inter', sans-serif;">

    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>
    <div class="aurora-orb aurora-orb-blue position-fixed"></div>

    <!-- Banner de avertizare pentru email neverificat -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        var userManager = Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser>>();
        var user = await userManager.GetUserAsync(User);
        if (user != null && !user.EmailConfirmed)
        {
            <div class="alert alert-warning rounded-0 mb-0 py-3 text-center fw-bold border-0 shadow-sm" style="background: rgba(245, 158, 11, 0.1); color: #fbbf24; border-bottom: 2px solid #f59e0b !important;">
                <span class="material-symbols-outlined align-middle me-2">warning</span>
                Your email is not verified. Please check your inbox or <a asp-controller="Auth" asp-action="VerifyEmailNotice" class="alert-link text-white fw-black text-decoration-underline">resend verification</a>.
                <span class="material-symbols-outlined align-middle ms-2">warning</span>
            </div>
        }
    }

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 80px; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 250px;">
            <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <h1 class="fs-4 fw-bold text-white mb-0">
                    Ask<span class="text-aurora">N</span>Learn
                </h1>
            </a>
        </div>

        <!-- Center Global Navigation -->
        <nav class="d-none d-lg-flex align-items-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                Home
            </a>
            <a asp-controller="Explore" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Explore" ? "active" : "")">
                Communities
            </a>
            <a asp-controller="Resources" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Resources" ? "active" : "")">
                Resources
            </a>
            <a asp-controller="StudyGroups" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudyGroups" ? "active" : "")">
                Groups
            </a>
            <a asp-controller="Leaderboard" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Leaderboard" ? "active" : "")">
                Leaderboard
            </a>
        </nav>
        
        <!-- Right Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3" style="width: 250px;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Inbox -->
                <a asp-controller="Inbox" asp-action="Index" class="nav-link-premium border-0 p-0 rounded-circle transition-all d-flex align-items-center justify-content-center text-decoration-none" style="width: 40px; height: 40px;">
                    <span class="material-symbols-outlined fs-5">all_inbox</span>
                </a>

                <div class="mx-1" style="width: 1px; height: 16px; background: var(--border-glass-strong);"></div>
                
                <!-- Profile Link -->
                <a asp-controller="Profile" asp-action="Index" class="nav-link-premium border-0 p-0 rounded-circle transition-all d-flex align-items-center justify-content-center text-decoration-none" style="width: 40px; height: 40px;">
                    <span class="material-symbols-outlined fs-5">person</span>
                </a>
            }
            else
            {
                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Auth" asp-action="SignIn" class="btn btn-link text-muted hover-text-white text-decoration-none fw-bold small text-uppercase tracking-widest px-3">Log In</a>
                    <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium d-flex align-items-center justify-content-center py-2 px-4 shadow-sm" style="font-size: 0.8rem;">Sign Up</a>
                </div>
            }
        </div>
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        @if (IsSectionDefined("Sidebar"))
        {
            <!-- Left Sidebar -->
            <aside id="leftSidebar" class="d-flex sidebar-transition flex-column h-100 flex-shrink-0 position-relative" style="width: 300px; border-right: 1px solid var(--border-glass); background: transparent; backdrop-filter: blur(20px); z-index: 2;">
                <div class="flex-grow-1 d-flex flex-column min-vh-0 overflow-hidden">
                    @RenderSection("Sidebar")
                </div>
            </aside>
            <button id="toggleLeftSidebar"
                    class="d-flex sidebar-transition align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 p-0 shadow-lg"
                    style="left: 300px; width: 28px; height: 64px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-left: none; backdrop-filter: blur(10px); transition: left 0.6s var(--ease-apple);">
                <span class="material-symbols-outlined text-muted m-0 p-0" style="margin-left: -2px !important;">chevron_left</span>
            </button>
        }

        <!-- Center Feed -->
        <main class="flex-grow-1 h-100 position-relative @(ViewData["AppLayout"] as bool? == true ? "d-flex flex-column overflow-hidden" : "overflow-y-auto custom-scrollbar")">
            @RenderBody()
        </main>
    </div>

    <!-- Apple-style Toast Container -->
    <div id="toast-container" class="position-fixed bottom-0 end-0 p-4 z-5 d-flex flex-column gap-3" style="pointer-events: none;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    
    <script>
        // --- SignalR Real-time Hub (Global, robust) ---
        window.connection = new signalR.HubConnectionBuilder()
            .withUrl("/communicationHub")
            .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
            .configureLogging(signalR.LogLevel.Information)
            .build();

        window.signalRReady = false;
        window.startSignalR = async function() {
            if (window.connection.state === signalR.HubConnectionState.Disconnected) {
                try {
                    await window.connection.start();
                    console.log("SignalR Connected.");
                    window.signalRReady = true;
                    if (window.onSignalRConnected) window.onSignalRConnected();
                } catch (err) {
                    console.error("SignalR Connection Error: ", err);
                    setTimeout(window.startSignalR, 5000);
                }
            }
        };

        // --- Global Notification & System Health Engine ---
        window.Notify = {
            container: document.getElementById('toast-container'),
            
            show: function(message, type = 'info', icon = 'info', duration = 5000) {
                if (!this.container) return;
                
                const toast = document.createElement('div');
                toast.className = 'glass-card p-3 shadow-lg d-flex align-items-center gap-3 animate-entrance system-toast';
                
                let color = 'var(--text-muted)';
                let defaultIcon = icon;
                
                switch(type) {
                    case 'success': 
                        color = 'var(--color-mint-bright)'; 
                        defaultIcon = icon || 'check_circle';
                        break;
                    case 'error': 
                        color = '#ff4b5c'; 
                        defaultIcon = icon || 'error';
                        break;
                    case 'warning': 
                        color = '#ffb300'; 
                        defaultIcon = icon || 'warning';
                        break;
                    case 'system': 
                        color = 'var(--color-teal)'; 
                        defaultIcon = icon || 'guardian';
                        break;
                }

                toast.style.cssText = `
                    width: 340px;
                    pointer-events: auto;
                    background: rgba(10, 24, 18, 0.95);
                    border-left: 4px solid ${color};
                    backdrop-filter: blur(25px);
                    margin-bottom: 12px;
                    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
                `;
                
                toast.innerHTML = `
                    <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05);">
                        <span class="material-symbols-outlined" style="color: ${color}; font-size: 22px;">${defaultIcon}</span>
                    </div>
                    <div class="flex-grow-1">
                        <p class="text-white fw-bold mb-0" style="font-size: 0.85rem; line-height: 1.3;">${message}</p>
                    </div>
                    <button onclick="this.closest('.system-toast').remove()" class="btn btn-link p-1 text-muted hover-text-white text-decoration-none shadow-none">
                        <span class="material-symbols-outlined fs-6">close</span>
                    </button>
                `;

                this.container.appendChild(toast);
                
                if (duration > 0) {
                    setTimeout(() => {
                        toast.style.opacity = '0';
                        toast.style.transform = 'translateY(20px) scale(0.95)';
                        setTimeout(() => toast.remove(), 600);
                    }, duration);
                }
                return toast;
            },
            success: (msg) => window.Notify.show(msg, 'success'),
            error: (msg) => window.Notify.show(msg, 'error'),
            warning: (msg) => window.Notify.show(msg, 'warning'),
            system: (msg) => window.Notify.show(msg, 'system')
        };

        // backward compatibility for old showToast calls
        window.showToast = (msg, icon, color) => window.Notify.show(msg, 'info', icon);

        // --- Network & Connectivity Monitoring ---
        window.addEventListener('online', () => {
            if (window.offlineToast) {
                window.offlineToast.remove();
                window.offlineToast = null;
            }
            window.Notify.success("Internet connection restored. Syncing...");
            window.startSignalR();
        });

        window.addEventListener('offline', () => {
            window.offlineToast = window.Notify.show(
                "Internet connection lost. Please check your network.", 
                'error', 
                'cloud_off', 
                0 // Persistent
            );
        });

        // --- SignalR Health Hooks ---
        window.connection.onreconnecting((err) => {
            console.warn("SignalR Reconnecting...");
            window.Notify.warning("Live connection interrupted. Reconnecting...");
        });

        window.connection.onreconnected(() => {
            window.Notify.success("Live connection restored.");
        });

        window.connection.onclose(() => {
            window.signalRReady = false;
            window.Notify.error("Live session disconnected. Checking server status...");
            setTimeout(window.startSignalR, 5000);
        });

        // Global Fetch Error Guard
        const originalFetch = window.fetch;
        window.fetch = async (...args) => {
            try {
                const response = await originalFetch(...args);
                if (!response.ok && response.status >= 500) {
                    window.Notify.error("Server is currently unavailable. Please try again later.");
                }
                return response;
            } catch (err) {
                if (!navigator.onLine) {
                    // Handled by offline listener
                } else if (err.message.includes("Failed to fetch") || err.name === "TypeError") {
                    window.Notify.error("Cannot reach servers. Please check your connection or wait for maintenance.");
                }
                throw err;
            }
        };

        // Listeners for predefined triggers
        window.connection.on("ReceiveConnectionRequest", (data) => {
            window.Notify.show(data.message, 'success', 'person_add');
        });

        window.connection.on("ReceiveConnectionAccepted", (data) => {
             window.Notify.show(data.message, 'success', 'check_circle');
        });

        // --- Layout Logic ---
        const leftSidebar = document.getElementById("leftSidebar");
        const leftButton = document.getElementById("toggleLeftSidebar");
        const chevron = leftButton ? leftButton.querySelector('span') : null;

        if (leftSidebar && leftButton) {
            leftButton.addEventListener("click", () => {
                const isCollapsed = leftSidebar.classList.toggle("sidebar-collapsed");
                chevron.innerText = isCollapsed ? "chevron_right" : "chevron_left";
                leftButton.style.left = isCollapsed ? "0px" : "300px";
            });
        }
    </script>
    <style>
        @@keyframes toast-in {
            from { opacity: 0; transform: translateX(100%) scale(0.9) blur(10px); }
            to { opacity: 1; transform: translateX(0) scale(1) blur(0); }
        }
    </style>
    @await Html.PartialAsync("_ReportModal")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>