<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - AskNLearn</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-mesh-bg d-flex flex-column vh-100 overflow-hidden" style="font-family: 'Inter', sans-serif;">

    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>
    <div class="aurora-orb aurora-orb-blue position-fixed"></div>

    <!-- Banner de avertizare pentru email neverificat -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        var userManager = Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser>>();
        var user = await userManager.GetUserAsync(User);
        if (user != null && !user.EmailConfirmed)
        {
            <div class="alert alert-warning rounded-0 mb-0 py-3 text-center fw-bold border-0 shadow-sm" style="background: rgba(245, 158, 11, 0.1); color: #fbbf24; border-bottom: 2px solid #f59e0b !important;">
                <span class="material-symbols-outlined align-middle me-2">warning</span>
                Your email is not verified. Please check your inbox or <a asp-controller="Auth" asp-action="VerifyEmailNotice" class="alert-link text-white fw-black text-decoration-underline">resend verification</a>.
                <span class="material-symbols-outlined align-middle ms-2">warning</span>
            </div>
        }
    }

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 4rem; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 15.625rem;">
            <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <h1 class="fs-4 fw-bold text-white mb-0">
                    Ask<span class="text-accent">N</span>Learn
                </h1>
            </a>
        </div>

        <!-- Center Global Navigation -->
        <nav class="d-none d-lg-flex align-items-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                Home
            </a>
            <a asp-controller="Explore" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Explore" ? "active" : "")">
                Communities
            </a>
            <a asp-controller="Resources" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Resources" ? "active" : "")">
                Resources
            </a>
            <a asp-controller="Leaderboard" asp-action="Index" class="nav-link-premium justify-content-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Leaderboard" ? "active" : "")">
                Leaderboard
            </a>
        </nav>
        
        <!-- Right Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3" style="width: 15.625rem;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Inbox -->
                <a asp-controller="Inbox" asp-action="Index" class="nav-link-premium border-0 p-0 rounded-circle transition-all d-flex align-items-center justify-content-center text-decoration-none position-relative" style="width: 2.5rem; height: 2.5rem; overflow: visible !important;">
                    <span class="material-symbols-outlined fs-5">all_inbox</span>
                    @{
                        var _context = Context.RequestServices.GetRequiredService<AskNLearn.Infrastructure.Persistance.ApplicationDbContext>();
                        var _userManager = Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser>>();
                        var _userId = _userManager.GetUserId(User);
                        int _totalCount = 0;
                        if (_userId != null)
                        {
                            var _unreadNotif = await _context.Notifications
                                .Where(n => n.UserId == _userId && !n.IsRead)
                                .CountAsync();
                                
                            var _pendingReq = await _context.Friendships
                                .Where(f => f.AddresseeId == _userId && f.Status == AskNLearn.Domain.Entities.Core.FriendshipStatus.Pending)
                                .CountAsync();
                            
                            var _unreadMsgs = 0;
                            var _participants = await _context.DirectConversationParticipants
                                .Where(p => p.UserId == _userId)
                                .ToListAsync();

                            foreach(var p in _participants)
                            {
                                var lastReadAt = DateTime.MinValue;
                                if (p.LastReadMessageId != null)
                                {
                                    lastReadAt = await _context.Messages
                                        .Where(m => m.Id == p.LastReadMessageId)
                                        .Select(m => m.CreatedAt)
                                        .FirstOrDefaultAsync();
                                }
                                
                                _unreadMsgs += await _context.Messages
                                    .CountAsync(m => m.ConversationId == p.ConversationId && m.AuthorId != _userId && m.CreatedAt > lastReadAt);
                            }

                            _totalCount = _unreadNotif + _pendingReq + _unreadMsgs;
                        }
                    }
                    @if (_totalCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-white d-flex align-items-center justify-content-center shadow-lg" 
                              style="font-size: 0.7rem; min-width: 1.4rem; height: 1.4rem; padding: 0 5px; margin-top: 0.35rem; margin-left: -0.35rem; z-index: 10; font-weight: 900; border: 2px solid var(--bg-universe); background: #FF3B30 !important; box-shadow: 0 0 12px rgba(255, 59, 48, 0.5);">
                            @(_totalCount > 99 ? "99+" : _totalCount.ToString())
                        </span>
                    }
                </a>

                <div class="mx-1" style="width: 0.0625rem; height: 1rem; background: var(--border-glass-strong);"></div>
                
                <!-- Profile Link -->
                <a asp-controller="Profile" asp-action="Index" class="nav-link-premium border-0 p-0 rounded-circle transition-all d-flex align-items-center justify-content-center text-decoration-none" style="width: 2.5rem; height: 2.5rem;">
                    <span class="material-symbols-outlined fs-5">person</span>
                </a>
            }
            else
            {
                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Auth" asp-action="SignIn" class="btn btn-ghost px-3">Log In</a>
                    <a asp-controller="Auth" asp-action="SignUp" class="btn btn-premium py-2 px-4 shadow-sm" style="font-size: 0.85rem;">Sign Up</a>
                </div>
            }
        </div>
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        @if (IsSectionDefined("Sidebar"))
        {
            <!-- Left Sidebar -->
            <aside id="leftSidebar" class="d-flex sidebar-transition flex-column h-100 flex-shrink-0 position-relative" style="width: 26rem; border-right: 1px solid var(--border-glass); background: transparent; backdrop-filter: blur(1.25rem); z-index: 2;">
                <div class="flex-grow-1 d-flex flex-column min-vh-0 overflow-hidden">
                    @RenderSection("Sidebar")
                </div>
            </aside>
            <button id="toggleLeftSidebar"
                    class="d-flex sidebar-transition align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 p-0 shadow-lg"
                    style="left: 26rem; width: 1.75rem; height: 4rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-left: none; backdrop-filter: blur(0.625rem); transition: left 0.6s var(--ease-apple);">
                <span class="material-symbols-outlined text-muted m-0 p-0" style="margin-left: -2px !important;">chevron_left</span>
            </button>
        }

        <!-- Center Feed -->
        <main class="flex-grow-1 h-100 position-relative @(ViewData["AppLayout"] as bool? == true ? "d-flex flex-column overflow-hidden" : "overflow-y-auto custom-scrollbar")">
            @RenderBody()
        </main>
    </div>

    <!-- Apple-style Toast Container -->
    <div id="toast-container" class="position-fixed bottom-0 end-0 p-4 z-5 d-flex flex-column gap-3" style="pointer-events: none;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script type="module" src="~/js/module.forum.js" asp-append-version="true"></script>
    
    <script>
        // --- SignalR Setup ---
        window.connection = new signalR.HubConnectionBuilder()
            .withUrl("/communicationHub")
            .withAutomaticReconnect()
            .build();

        window.startSignalR = async function() {
            if (window.connection.state === "Disconnected") {
                try { await window.connection.start(); } catch (err) { setTimeout(startSignalR, 5000); }
            }
        };

        // --- Connectivity & Global Events ---
        window.addEventListener('online', () => window.Notify?.success("Connection restored."));
        window.addEventListener('offline', () => window.Notify?.error("Connection lost.", 'error', 'cloud_off', 0));

        window.connection.on("ReceiveConnectionRequest", d => window.Notify?.show(d.message, 'success', 'person_add'));
        window.connection.on("ReceiveConnectionAccepted", d => window.Notify?.show(d.message, 'success', 'check_circle'));

        // Sidebar Toggle
        document.addEventListener('DOMContentLoaded', () => {
            window.startSignalR();
            const btn = document.getElementById("toggleLeftSidebar");
            const side = document.getElementById("leftSidebar");
            if (btn && side) {
                btn.addEventListener("click", () => {
                    const isCol = side.classList.toggle("sidebar-collapsed");
                    btn.querySelector('span').innerText = isCol ? "chevron_right" : "chevron_left";
                    btn.style.left = isCol ? "0rem" : "26rem";
                });
            }
        });
    </script>
    <style>
        @@keyframes toast-in {
            from { opacity: 0; transform: translateX(100%) scale(0.9) blur(10px); }
            to { opacity: 1; transform: translateX(0) scale(1) blur(0); }
        }
    </style>

    @await Html.PartialAsync("_ReportModal")
    @RenderSection("Modals", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>