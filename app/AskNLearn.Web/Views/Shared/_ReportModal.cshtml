@using AskNLearn.Domain.Entities.Core
<!-- Report Modal -->
<div class="modal fade" id="reportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-glass-strong shadow-lg">
            <div class="modal-header border-glass">
                <h5 class="modal-title fs-5 fw-bold text-white d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined text-danger">report</span>
                    Report Content
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="reportForm">
                    <input type="hidden" id="reportTargetId" name="id" />
                    <input type="hidden" id="reportTargetType" name="type" />
                    
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold mb-2">REASON FOR REPORTING</label>
                        <select class="form-select form-control-glass text-white" id="reportReason" name="reason" required>
                            @foreach (var reason in Enum.GetValues<ReportReason>())
                            {
                                <option value="@reason">@reason</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold mb-2">ADDITIONAL DETAILS (OPTIONAL)</label>
                        <textarea class="form-control form-control-glass text-white" id="reportDescription" name="description" rows="3" placeholder="Describe why you are reporting this..."></textarea>
                    </div>

                    <div class="alert alert-info bg-info-glass border-info-glass text-info small d-flex align-items-start gap-2 mb-0">
                        <span class="material-symbols-outlined fs-5">guardian</span>
                        <span>Our Guardian AI will immediately analyze this content once submitted.</span>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-glass">
                <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="submitGlobalReport()" class="btn btn-premium px-4 d-flex align-items-center gap-2" id="submitReportBtn">
                    Submit Report
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openReportModal(id, type) {
        document.getElementById('reportTargetId').value = id;
        document.getElementById('reportTargetType').value = type;
        document.getElementById('reportForm').reset();
        const modal = new bootstrap.Modal(document.getElementById('reportModal'));
        modal.show();
    }

    async function submitGlobalReport() {
        const btn = document.getElementById('submitReportBtn');
        const id = document.getElementById('reportTargetId').value;
        const type = document.getElementById('reportTargetType').value;
        const reason = document.getElementById('reportReason').value;
        const description = document.getElementById('reportDescription').value;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Submitting...';

        try {
            let url = '';
            if (type === 'POST') url = '/hubs/communities/v1/discussions/report';
            else if (type === 'COMMENT') url = '/hubs/communities/v1/comments/report';
            else if (type === 'MESSAGE') url = '/communication/messaging/messages/report';
            else if (type === 'RESOURCE') url = '/Resources/Report';

            const response = await fetch(url + `?id=${id}&reason=${reason}&description=${encodeURIComponent(description)}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            });

            if (response.ok) {
                const modalEl = document.getElementById('reportModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal.hide();
                
                window.Notify.success("Report submitted. Guardian AI is now analyzing the content.");
            } else {
                window.Notify.error("Failed to submit report. Please try again.");
            }
        } catch (error) {
            console.error("Report error:", error);
            window.Notify.error("An error occurred. Please try again.");
        } finally {
            btn.disabled = false;
            btn.innerHTML = 'Submit Report';
        }
    }
</script>
