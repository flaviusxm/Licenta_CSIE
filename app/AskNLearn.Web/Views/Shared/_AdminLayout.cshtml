<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
            extend: {
                colors: {
                "primary": "#13c8ec",
                "background-light": "#f6f8f8",
                "background-dark": "#101f22",
                "surface-dark": "#192f33",
                "surface-light": "#ffffff",
                "border-dark": "#234248",
                "border-light": "#e2e8f0",
                },
                fontFamily: {
                "display": ["Lexend", "sans-serif"]
                },
                borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px"},
            },
            },
        }
    </script>
    <style>
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #234248; border-radius: 3px; }
        body { background-color: #101f22; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display overflow-hidden h-screen flex flex-col transition-colors duration-200">
    <!-- Top Navigation Bar -->
    <header class="h-16 flex items-center justify-between px-6 border-b border-border-light dark:border-border-dark bg-surface-light dark:bg-background-dark z-50 shrink-0">
        <!-- Logo Area -->
        <div class="flex items-center gap-8 w-64 justify-center">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 text-slate-900 dark:text-white cursor-pointer hover:opacity-80 transition-opacity">
                <h1 class="text-xl font-bold tracking-tight flex items-center gap-2">
                    AskNLearn <span class="text-[10px] bg-primary/20 text-primary px-1.5 py-0.5 rounded border border-primary/30 font-bold uppercase tracking-wider">Admin</span>
                </h1>
            </a>
        </div>
        
        

        <!-- Right Actions -->
        <div class="flex items-center justify-end gap-4 w-64">
             <div class="flex items-center gap-3">
                <div class="text-right hidden sm:block">
                    <p class="text-xs font-bold text-slate-900 dark:text-white">System Admin</p>
                    <p class="text-[10px] text-slate-500 uppercase font-medium">Verification Root</p>
                </div>
                <div class="size-10 rounded-xl bg-slate-100 dark:bg-surface-dark border border-border-light dark:border-border-dark flex items-center justify-center text-primary font-bold">
                    SA
                </div>
            </div>
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <!-- Left Sidebar (Navigation) -->
        <aside id="leftSidebar" class="relative w-64 hidden lg:flex flex-col border-r border-border-light dark:border-border-dark bg-surface-light dark:bg-background-dark overflow-y-auto p-4 gap-8 shrink-0">
            <div>
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-[2px] mb-4 px-4">Management</p>
                <nav class="flex flex-col gap-1">
                    <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-surface-dark transition-colors group">
                        <span class="material-symbols-outlined text-slate-500 group-hover:text-primary">dashboard</span>
                        <span class="font-bold text-sm">Dashboard Overview</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Verifications" class="flex items-center justify-between px-4 py-3 rounded-xl bg-primary/10 text-primary border border-primary/20 transition-colors group">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-outlined">verified_user</span>
                            <span class="font-bold text-sm">Verification Requests</span>
                        </div>
                        <span class="size-5 rounded bg-primary text-[10px] flex items-center justify-center text-background-dark font-bold">12</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-surface-dark transition-colors group opacity-50 cursor-not-allowed">
                        <span class="material-symbols-outlined text-slate-500">person_search</span>
                        <span class="font-bold text-sm">Student Directory</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-surface-dark transition-colors group opacity-50 cursor-not-allowed">
                        <span class="material-symbols-outlined text-slate-500">forum</span>
                        <span class="font-bold text-sm">Study Communities</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 dark:hover:bg-surface-dark transition-colors group opacity-50 cursor-not-allowed">
                        <span class="material-symbols-outlined text-slate-500">flag</span>
                        <span class="font-bold text-sm">Reported Content</span>
                    </a>
                </nav>
            </div>

            <!-- System Status -->
            <div class="mt-auto p-4 rounded-2xl bg-surface-dark border border-border-dark">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">System Status</p>
                <div class="flex items-center gap-2">
                    <div class="size-2 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span class="text-xs text-white">Cloud Nodes Active</span>
                </div>
            </div>
        </aside>

        <button id="toggleLeftSidebar"
                class="hidden lg:flex items-center justify-center
                absolute top-1/2 -translate-y-1/2
                left-64
                bg-primary text-white
                z-50
                w-8 h-12 rounded-r-lg shadow-md
                hover:bg-primary/80 transition-all">
            ❮
        </button>

        <!-- Main Content -->
        <main class="flex-1 overflow-y-auto relative bg-background-light dark:bg-background-dark p-8">
            @RenderBody()
        </main>
    </div>
    <script>
        const leftSidebar = document.getElementById("leftSidebar");
        const leftButton = document.getElementById("toggleLeftSidebar");

        leftButton.addEventListener("click", () => {
            leftSidebar.classList.toggle("lg:flex");

            if (!leftSidebar.classList.contains("lg:flex")) {
                leftButton.innerHTML = "❯";
                leftButton.classList.remove("left-64");
                leftButton.classList.add("left-0");
            } else {
                leftButton.innerHTML = "❮";
                leftButton.classList.remove("left-0");
                leftButton.classList.add("left-64");
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
