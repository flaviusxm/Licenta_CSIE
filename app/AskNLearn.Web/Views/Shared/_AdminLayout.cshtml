<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Admin Portal</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/AskNLearn.styles.css" asp-append-version="true" />
    <style>
        .table, .table th, .table td, .table tr { 
            --bs-table-bg: transparent !important;
            --bs-table-color: #e5e7eb !important;
            --bs-table-hover-bg: rgba(255,255,255,0.05) !important;
            background-color: transparent !important;
            color: #e5e7eb !important;
        }
        .table-responsive { background-color: transparent !important; }
    </style>
</head>
<body class="dark-mesh-bg d-flex flex-column vh-100 overflow-hidden">
    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 80px; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 250px;">
            <a asp-controller="Admin" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                <div class="p-2 rounded-3 bg-aurora-glass d-flex align-items-center justify-content-center shadow-glow me-2" style="background: rgba(52, 211, 153, 0.15) !important; border: 1px solid rgba(52, 211, 153, 0.3) !important;">
                    <span class="material-symbols-outlined text-white fs-4" style="display: block !important;">school</span>
                </div>
                <h1 class="fs-4 fw-bold tracking-tight text-white mb-0">
                    Ask<span class="text-aurora">N</span>Learn <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 small ms-2" style="font-size: 0.6rem; vertical-align: middle;">ADMIN</span>
                </h1>
            </a>
        </div>

        <!-- Center Navigation -->
        <nav class="d-none d-lg-flex align-items-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="nav-link-premium gap-2 animate-entrance delay-100">
                <span class="material-symbols-outlined fs-5">exit_to_app</span>
                <span>Exit to Site</span>
            </a>
        </nav>
        
        <!-- Right Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3" style="width: 250px;">
            <div class="d-flex align-items-center gap-3">
                <div class="text-end d-none d-sm-block">
                    <p class="small fw-bold text-white mb-0">System Admin</p>
                    <p class="text-muted mb-0" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em;">Root Access</p>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-aurora fw-bold border border-glass-strong" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05);">
                    SA
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        <!-- Left Sidebar -->
        <aside id="leftSidebar" class="d-flex sidebar-transition flex-column h-100 flex-shrink-0 position-relative" style="width: 300px; border-right: 1px solid var(--border-glass); background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(20px); overflow-x: hidden; z-index: 2;">
            <div class="flex-grow-1 d-flex flex-column min-vh-0 overflow-hidden">
                <div class="p-4 flex-grow-1 overflow-y-auto custom-scrollbar">
                    <p class="text-muted fw-bold text-uppercase tracking-widest mb-4 px-2" style="font-size: 0.65rem;">Management</p>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Admin" asp-action="Index" class="nav-link-premium justify-content-start w-100 gap-3 sidebar-transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                            <span class="material-symbols-outlined fs-5">dashboard</span>
                            <span>Dashboard Overview</span>
                        </a>
                        <a asp-controller="Admin" asp-action="Verifications" class="nav-link-premium justify-content-start w-100 gap-3 sidebar-transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Verifications" ? "active" : "")">
                            <span class="material-symbols-outlined fs-5">verified_user</span>
                            <div class="d-flex align-items-center justify-content-between flex-grow-1">
                                <span>Pending Requests</span>
                                <span class="badge rounded-pill bg-aurora text-dark fw-bold" style="font-size: 0.6rem;">@ViewBag.PendingVerifications</span>
                            </div>
                        </a>
                        <a asp-controller="Admin" asp-action="Moderation" class="nav-link-premium justify-content-start w-100 gap-3 sidebar-transition @(ViewContext.RouteData.Values["action"]?.ToString() == "Moderation" ? "active" : "")">
                            <span class="material-symbols-outlined fs-5">security</span>
                            <div class="d-flex align-items-center justify-content-between flex-grow-1">
                                <span>AI Moderation</span>
                                <span class="badge rounded-pill bg-danger text-white fw-bold" style="font-size: 0.6rem;">@ViewBag.FlaggedContentCount</span>
                            </div>
                        </a>
                        <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 opacity-50">
                            <span class="material-symbols-outlined fs-5">person_search</span>
                            <span>Student Directory</span>
                        </a>
                        <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 opacity-50">
                            <span class="material-symbols-outlined fs-5">forum</span>
                            <span>Study Communities</span>
                        </a>
                        <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 sidebar-transition opacity-50">
                            <span class="material-symbols-outlined fs-5">flag</span>
                            <span>User Reports</span>
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <button id="toggleLeftSidebar"
                class="d-flex sidebar-transition align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 p-0 shadow-lg border-0"
                style="left: 300px; width: 28px; height: 64px; background: rgba(52, 211, 153, 0.1); backdrop-filter: blur(20px); border: 1px solid var(--border-glass-strong) !important; border-left: none !important;">
            <span class="material-symbols-outlined m-0 p-0" style="color: var(--color-mint-bright); margin-left: -2px !important;">chevron_left</span>
        </button>

        <!-- Main Content -->
        <main class="flex-grow-1 h-100 overflow-y-auto position-relative custom-scrollbar p-4 p-md-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const leftSidebar = document.getElementById("leftSidebar");
        const leftButton = document.getElementById("toggleLeftSidebar");
        const chevron = leftButton ? leftButton.querySelector('span') : null;

        if (leftSidebar && leftButton) {
            leftButton.addEventListener("click", () => {
                const isCollapsed = leftSidebar.classList.toggle("sidebar-collapsed");
                chevron.innerText = isCollapsed ? "chevron_right" : "chevron_left";
                leftButton.style.left = isCollapsed ? "0px" : "300px";
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
