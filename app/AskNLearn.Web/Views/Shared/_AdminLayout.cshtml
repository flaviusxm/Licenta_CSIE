<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Admin Portal</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-mesh-bg d-flex flex-column min-vh-100 overflow-hidden">

    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 80px; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 250px;">
            <a asp-controller="Admin" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <h1 class="fs-4 fw-bold tracking-tight text-white mb-0">
                    Ask<span class="text-aurora">N</span>Learn <span class="badge bg-opacity-10 bg-info text-info border border-info border-opacity-25 small ms-2" style="font-size: 0.6rem; vertical-align: middle;">ADMIN</span>
                </h1>
            </a>
        </div>

        <!-- Center Navigation -->
        <nav class="d-none d-lg-flex align-items-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="nav-link-premium animate-entrance delay-100">
                Exit to Site
            </a>
        </nav>
        
        <!-- Right Actions -->
        <div class="d-flex align-items-center justify-content-end gap-3" style="width: 250px;">
            <div class="d-flex align-items-center gap-3">
                <div class="text-end d-none d-sm-block">
                    <p class="small fw-bold text-white mb-0">System Admin</p>
                    <p class="text-muted mb-0" style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em;">Root Access</p>
                </div>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-aurora fw-bold border border-glass-strong" style="width: 40px; height: 40px; background: rgba(255,255,255,0.05);">
                    SA
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        <!-- Left Sidebar -->
        <aside id="leftSidebar" class="d-none d-lg-flex flex-column h-100 flex-shrink-0 transition-all" style="width: 300px; border-right: 1px solid var(--border-glass); background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(20px);">
            <div class="p-4">
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-4 px-2" style="font-size: 0.65rem;">Management</p>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="Admin" asp-action="Index" class="nav-link-premium justify-content-start w-100 gap-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <span class="material-symbols-outlined fs-5">dashboard</span>
                        <span>Dashboard Overview</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Verifications" class="nav-link-premium justify-content-start w-100 gap-3 @(ViewContext.RouteData.Values["action"]?.ToString() == "Verifications" ? "active" : "")">
                        <span class="material-symbols-outlined fs-5">verified_user</span>
                        <div class="d-flex align-items-center justify-content-between flex-grow-1">
                            <span>Verification Requests</span>
                            <span class="badge rounded-pill bg-aurora text-dark fw-bold" style="font-size: 0.6rem;">12</span>
                        </div>
                    </a>
                    <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 opacity-50">
                        <span class="material-symbols-outlined fs-5">person_search</span>
                        <span>Student Directory</span>
                    </a>
                    <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 opacity-50">
                        <span class="material-symbols-outlined fs-5">forum</span>
                        <span>Study Communities</span>
                    </a>
                    <a href="#" class="nav-link-premium justify-content-start w-100 gap-3 opacity-50">
                        <span class="material-symbols-outlined fs-5">flag</span>
                        <span>Reported Content</span>
                    </a>
                </div>

                <div class="mt-5 p-4 rounded-4 border border-glass-strong" style="background: rgba(52, 211, 153, 0.05);">
                    <p class="text-muted fw-bold text-uppercase tracking-widest mb-2" style="font-size: 0.6rem;">System Status</p>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-success" style="width: 8px; height: 8px; box-shadow: 0 0 10px var(--color-mint-bright);"></div>
                        <span class="small text-white">Cloud Nodes Online</span>
                    </div>
                </div>
            </div>
        </aside>

        <button id="toggleLeftSidebar"
                class="d-none d-lg-flex align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 transition-all p-0 shadow-lg"
                style="left: 300px; width: 28px; height: 64px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-left: none; backdrop-filter: blur(10px);">
            <span class="material-symbols-outlined text-muted m-0 p-0" style="margin-left: -2px !important;">chevron_left</span>
        </button>

        <!-- Main Content -->
        <main class="flex-grow-1 h-100 overflow-y-auto position-relative custom-scrollbar p-4 p-md-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const leftSidebar = document.getElementById("leftSidebar");
        const leftButton = document.getElementById("toggleLeftSidebar");
        const chevron = leftButton ? leftButton.querySelector('span') : null;

        if (leftSidebar && leftButton) {
            leftButton.addEventListener("click", () => {
                leftSidebar.classList.toggle("d-lg-flex");

                if (!leftSidebar.classList.contains("d-lg-flex")) {
                    chevron.innerText = "chevron_right";
                    leftButton.style.left = "0px";
                } else {
                    chevron.innerText = "chevron_left";
                    leftButton.style.left = "300px";
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
