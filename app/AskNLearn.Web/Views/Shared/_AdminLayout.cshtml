<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Admin Portal</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="~/css/theme.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/AskNLearn.styles.css" asp-append-version="true" />
    <style>
        .table, .table th, .table td, .table tr { 
            --bs-table-bg: transparent !important;
            --bs-table-color: #e5e7eb !important;
            --bs-table-hover-bg: rgba(255,255,255,0.05) !important;
            background-color: transparent !important;
            color: #e5e7eb !important;
        }
        .table-responsive { background-color: transparent !important; }

        /* Custom Premium Sidebar Badges */
        .glass-badge {
            font-size: 0.65rem;
            padding: 0.2rem 0.6rem;
            border-radius: 2rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
        }
        .glass-badge-aurora { background: rgba(0, 122, 255, 0.15); color: #007AFF; border-color: rgba(0, 122, 255, 0.3); }

        .nav-link-premium {
            padding: 0.65rem 1rem;
            margin: 0.1rem 0.5rem;
            border-radius: 12px;
            border-left: 3px solid transparent;
        }

        .nav-link-premium.active {
            background: rgba(255, 255, 255, 0.08) !important;
            color: #fff !important;
        }

        .nav-link-premium:hover:not(.active) {
            background: rgba(255, 255, 255, 0.05);
            color: #fff !important;
        }

        .text-aurora { color: #007AFF !important; }
        .bg-aurora { background-color: #007AFF !important; }
        .bg-aurora-soft { background-color: rgba(0, 122, 255, 0.1) !important; }
        .text-accent { color: #007AFF !important; }
        .text-accent { color: #007AFF !important; }
    </style>
</head>
<body class="dark-mesh-bg d-flex flex-column vh-100 overflow-hidden">
    <!-- Ambient Aurora Orbs -->
    <div class="aurora-orb aurora-orb-cyan position-fixed"></div>
    <div class="aurora-orb aurora-orb-purple position-fixed"></div>
    <div class="aurora-orb aurora-orb-blue position-fixed"></div>

    <!-- Top Navigation Bar -->
    <header class="glass-nav position-relative z-3 w-100 px-4 d-flex align-items-center justify-content-between" style="height: 4rem; flex-shrink: 0;">
        <!-- Logo Area -->
        <div class="d-flex align-items-center" style="width: 15.625rem;">
            <a asp-controller="Admin" asp-action="Index" class="d-flex align-items-center text-decoration-none transition-all hover-translate-y">
                <h1 class="fs-4 fw-bold tracking-tight text-white mb-0">
                    Ask<span class="text-accent">N</span>Learn <span class="text-muted fw-normal opacity-50 ms-1 small" style="font-size: 0.8rem;">Admin</span>
                </h1>
            </a>
        </div>


        
       
    </header>

    <!-- Main Content Area -->
    <div class="d-flex flex-grow-1 overflow-hidden position-relative z-1">
        <!-- Left Sidebar -->
        <aside id="leftSidebar" class="d-flex sidebar-transition flex-column h-100 flex-shrink-0 position-relative" style="width: 400px; border-right: 1px solid var(--border-glass); background: rgba(5, 5, 5, 0.85); backdrop-filter: blur(40px); overflow-x: hidden; z-index: 2;">
            <div class="flex-grow-1 d-flex flex-column min-vh-0 overflow-hidden" style="background: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.02) 0%, transparent 50%);">
                @await Component.InvokeAsync("AdminSidebar")
                @if (IsSectionDefined("Sidebar"))
                {
                    <div class="mt-2 border-top border-glass pt-4 px-4">
                        @RenderSection("Sidebar")
                    </div>
                }
            </div>
        </aside>

        <button id="toggleLeftSidebar"
                class="d-flex sidebar-transition align-items-center justify-content-center position-absolute top-50 translate-middle-y rounded-end cursor-pointer z-3 p-0 shadow-lg"
                style="left: 400px; width: 1.75rem; height: 4rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); border-left: none; backdrop-filter: blur(10px); transition: left 0.6s var(--ease-apple);">
            <span class="material-symbols-outlined text-muted m-0 p-0" style="margin-left: -2px !important;">chevron_left</span>
        </button>

        <!-- Main Content -->
        <main class="flex-grow-1 h-100 overflow-y-auto position-relative custom-scrollbar p-4 p-xl-5">
            @RenderBody()
        </main>
    </div>

    <!-- Apple-style Toast Container -->
    <div id="toast-container" class="position-fixed bottom-0 end-0 p-4 z-5 d-flex flex-column gap-3" style="pointer-events: none;"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById("toggleLeftSidebar");
            const side = document.getElementById("leftSidebar");
            if (btn && side) {
                btn.addEventListener("click", () => {
                    const isCol = side.classList.toggle("sidebar-collapsed");
                    btn.querySelector('span').innerText = isCol ? "chevron_right" : "chevron_left";
                    btn.style.left = isCol ? "0px" : "400px";
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
