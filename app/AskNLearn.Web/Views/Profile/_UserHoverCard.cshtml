@using AskNLearn.Application.Features.Users.Queries.GetUserProfile
@model UserProfileDto

<div class="hover-card-inner p-3">
    <div class="d-flex align-items-center gap-3 mb-3">
        <div class="avatar-lg rounded-xl overflow-hidden shadow-lg border border-glass" style="width: 56px; height: 56px;">
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl" class="w-100 h-100 object-cover" />
            }
            else
            {
                <div class="w-100 h-100 d-flex flex-center bg-aurora-glass text-aurora">
                    <span class="material-symbols-outlined fs-2">account_circle</span>
                </div>
            }
        </div>
        <div class="flex-grow-1 min-w-0">
            <h4 class="fw-black text-white mb-0 text-truncate" style="font-size: 1rem;">@Model.FullName</h4>
            <div class="d-flex align-items-center gap-1.5 mt-0.5">
                <span class="badge bg-aurora-glass text-aurora px-1.5 py-0.5 rounded fw-black text-uppercase" style="font-size: 0.55rem;">Lv.@Model.Level Student</span>
                @if (Model.IsVerified)
                {
                    <span class="material-symbols-outlined text-mint fs-6" style="font-variation-settings: 'FILL' 1;">verified</span>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Bio))
    {
        <p class="text-muted mb-3" style="font-size: 0.8rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            @Model.Bio
        </p>
    }

    <div class="d-grid grid-cols-2 gap-2 pb-3 border-bottom border-glass">
        <div class="glass-panel p-2 rounded-lg text-center" style="background: rgba(255,255,255,0.03);">
            <p class="text-muted fw-bold mb-0" style="font-size: 0.55rem; letter-spacing: 0.5px;">REPUTATION</p>
            <p class="text-white fw-black m-0" style="font-size: 0.9rem;">@Model.ReputationPoints</p>
        </div>
        <div class="glass-panel p-2 rounded-lg text-center" style="background: rgba(255,255,255,0.03);">
            <p class="text-muted fw-bold mb-0" style="font-size: 0.55rem; letter-spacing: 0.5px;">STREAK</p>
            <p class="text-white fw-black m-0" style="font-size: 0.9rem;">5 Days</p>
        </div>
    </div>

    <div class="mt-3">
        <a href="/Profile?id=@Model.Id" class="btn btn-premium-sm w-100 py-2 fw-black text-uppercase tracking-widest d-flex flex-center gap-2" style="font-size: 0.65rem;">
            View Full Profile
            <span class="material-symbols-outlined" style="font-size: 12px;">arrow_forward</span>
        </a>
    </div>
</div>
