@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Verification Path";
    ViewData["IsVerificationPage"] = true;
}

<div class="container py-5" style="max-width: 1000px;">
    
    <!-- Profile Header Section -->
    <div class="d-flex flex-column gap-5 mb-5">
        <partial name="_ProfileHeader" model="Model" />
    </div>

    <!-- Verification Path Section -->
    <div class="px-3 px-md-5 d-flex flex-column gap-5 mt-4">
        <div class="d-flex flex-column gap-2 mb-3">
            <h2 class="display-6 fw-bold text-white tracking-tight text-uppercase m-0">Verification Path</h2>
            <p class="text-muted fw-bold">Complete the milestones below to unlock the "Verified Student" status and exclusive community features.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 p-3 p-md-4 shadow-sm" style="border-radius: 1.5rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;" role="alert">
                <span class="material-symbols-outlined fs-5">error</span>
                <span class="fw-bold tracking-widest text-uppercase" style="font-size: 0.75rem;">@TempData["Error"]</span>
            </div>
        }
        @if (TempData["Success"] != null)
        {
             <div class="alert alert-success d-flex align-items-center gap-2 p-3 p-md-4 shadow-sm" style="border-radius: 1.5rem; background: rgba(52, 211, 153, 0.1); border: 1px solid rgba(52, 211, 153, 0.2); color: var(--color-mint-bright);" role="alert">
                <span class="material-symbols-outlined fs-5">check_circle</span>
                <span class="fw-bold tracking-widest text-uppercase" style="font-size: 0.75rem;">@TempData["Success"]</span>
            </div>
        }

        <!-- The Journey Stepper -->
        <div class="position-relative d-flex flex-column gap-5">
            <!-- Central Line -->
            <div class="position-absolute h-100" style="left: 2rem; top: 0; width: 4px; background: linear-gradient(to bottom, var(--color-mint-bright), rgba(255,255,255,0.05)); transform: translateX(-50%); border-radius: 2px;"></div>

            <!-- Milestone 1: Initiation -->
            <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group">
                <div class="position-relative z-1 d-flex align-items-center justify-content-center bg-primary text-dark shadow-lg transition-transform hover-scale flex-shrink-0" style="width: 4rem; height: 4rem; border-radius: 1rem; box-shadow: 0 0 20px rgba(52, 211, 153, 0.3) !important;">
                    <span class="material-symbols-outlined fs-1">rocket_launch</span>
                </div>
                <div class="flex-grow-1 pt-2">
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0">Step 1: Initiation</h3>
                        <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2); font-size: 0.65rem;">Completed</span>
                    </div>
                    <p class="text-muted fw-bold lh-base small m-0" style="max-width: 600px;">
                        Your journey began on <span class="text-white">@Model.CreatedAt.ToString("MMMM dd, yyyy")</span>. You took the first step by joining the AskNLearn community.
                    </p>
                </div>
            </div>

            <!-- Milestone 2: Profile Maturity -->
            <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group">
                <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 transition-transform hover-scale flex-shrink-0 shadow-sm" style="width: 4rem; height: 4rem; border-radius: 1rem; @(Model.ProfileCompletionPercentage >= 100 ? "background: var(--color-mint-bright); color: var(--bg-universe); border-color: var(--color-mint-bright); box-shadow: 0 0 20px rgba(52, 211, 153, 0.3) !important;" : "background: rgba(0,0,0,0.5); color: #94a3b8; border-color: rgba(255,255,255,0.1);")">
                    <span class="material-symbols-outlined fs-1">person_edit</span>
                </div>
                <div class="flex-grow-1 pt-2">
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0">Step 2: Profile Maturity</h3>
                        @if (Model.ProfileCompletionPercentage >= 100)
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2); font-size: 0.65rem;">Completed</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); font-size: 0.65rem;">In Progress</span>
                        }
                    </div>
                    <p class="text-muted fw-bold lh-base small mb-3" style="max-width: 600px;">
                        A complete profile helps us verify your identity. Add your bio, occupation, institution, and interests.
                    </p>
                    <div class="rounded-pill p-1 overflow-hidden w-100" style="max-width: 300px; background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass);">
                        <div class="rounded-pill transition-all shadow-sm bg-primary" style="height: 0.5rem; width: @Model.ProfileCompletionPercentage%; transition-duration: 0.5s;"></div>
                    </div>
                    <p class="mt-2 text-uppercase tracking-widest fw-bold text-aurora" style="font-size: 0.65rem;">
                        @Model.ProfileCompletionPercentage% Completion
                    </p>
                </div>
            </div>

            <!-- Milestone 3: Verification Request -->
            <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group">
                <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 transition-transform hover-scale flex-shrink-0 shadow-sm" style="width: 4rem; height: 4rem; border-radius: 1rem; @(Model.IsVerified || Model.HasPendingVerification ? "background: var(--color-mint-bright); color: var(--bg-universe); border-color: var(--color-mint-bright); box-shadow: 0 0 20px rgba(52, 211, 153, 0.3) !important;" : "background: rgba(0,0,0,0.5); color: #94a3b8; border-color: rgba(255,255,255,0.1);")">
                    <span class="material-symbols-outlined fs-1">upload_file</span>
                </div>
                <div class="flex-grow-1 pt-2">
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0">Step 3: Identity Verification</h3>
                         @if (Model.IsVerified)
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2); font-size: 0.65rem;">Approved</span>
                        }
                        else if (Model.HasPendingVerification)
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); font-size: 0.65rem;">Pending Review</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm text-muted" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); font-size: 0.65rem;">Action Required</span>
                        }
                    </div>
                    
                    @if (!Model.IsVerified && !Model.HasPendingVerification)
                    {
                        <p class="text-muted fw-bold lh-base small mb-4" style="max-width: 600px;">
                            Upload your Student ID and your university Carnet/Booklet to confirm you are a real student.
                        </p>
                        
                        <!-- Upload Form -->
                        <div class="glass-card p-4 p-md-5 shadow-lg border-glass-strong" style="max-width: 600px; border-radius: 2rem;">
                            <form asp-action="SubmitVerification" method="post" enctype="multipart/form-data" class="d-flex flex-column gap-4">
                                @Html.AntiForgeryToken()
                                <div class="d-flex flex-column gap-2">
                                    <label class="text-white text-uppercase tracking-widest fw-bold" style="font-size: 0.7rem;">Student ID (Badge)</label>
                                    <div class="position-relative group">
                                        <input type="file" name="studentId" class="form-control form-control-glass text-muted w-100 shadow-sm" style="padding: 0.75rem 1rem; border-radius: 1rem;" accept="image/*,.pdf" required />
                                    </div>
                                </div>
                                <div class="d-flex flex-column gap-2 mb-2">
                                    <label class="text-white text-uppercase tracking-widest fw-bold" style="font-size: 0.7rem;">Carnet (Student Booklet)</label>
                                    <div class="position-relative group">
                                        <input type="file" name="carnet" class="form-control form-control-glass text-muted w-100 shadow-sm" style="padding: 0.75rem 1rem; border-radius: 1rem;" accept="image/*,.pdf" required />
                                    </div>
                                </div>
                                
                                <button type="submit" class="btn btn-premium w-100 d-flex align-items-center justify-content-center gap-2 text-uppercase tracking-wider fw-bold shadow-lg py-3" style="border-radius: 1rem;">
                                    <span class="material-symbols-outlined fs-5">cloud_upload</span>
                                    Submit Documents
                                </button>
                            </form>
                        </div>
                    }
                    else if (Model.HasPendingVerification && !Model.IsVerified)
                    {
                        <p class="text-muted fw-bold lh-base small m-0" style="max-width: 600px;">
                            The administrators are currently reviewing your documents. Please wait up to 48 hours.
                        </p>
                    }
                    else
                    {
                        <p class="text-muted fw-bold lh-base small m-0" style="max-width: 600px;">
                            Your identity has been verified by the community administration.
                        </p>
                    }
                </div>
            </div>

            <!-- Milestone 4: Community Influence -->
            <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group">
                <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 transition-transform hover-scale flex-shrink-0 shadow-sm" style="width: 4rem; height: 4rem; border-radius: 1rem; @(Model.Role == "Admin" || Model.Level >= 5 ? "background: var(--color-mint-bright); color: var(--bg-universe); border-color: var(--color-mint-bright); box-shadow: 0 0 20px rgba(52, 211, 153, 0.3) !important;" : "background: rgba(0,0,0,0.5); color: #94a3b8; border-color: rgba(255,255,255,0.1);")">
                    <span class="material-symbols-outlined fs-1">@(Model.Role == "Admin" ? "shield_person" : "military_tech")</span>
                </div>
                <div class="flex-grow-1 pt-2">
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0">Step 4: Community Level</h3>
                        @if (Model.Role == "Admin")
                        {
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); font-size: 0.65rem;">Admin Bypass</span>
                        }
                        else 
                        {
                            <span class="text-muted text-uppercase tracking-widest fw-bold" style="font-size: 0.7rem;">Target: Level 5</span>
                        }
                    </div>
                    @if (Model.Role == "Admin")
                    {
                        <p class="text-muted fw-bold lh-base small mb-3" style="max-width: 600px;">
                            As a System Administrator, you are exempt from community level requirements.
                        </p>
                    }
                    else
                    {
                        <p class="text-muted fw-bold lh-base small mb-3" style="max-width: 600px;">
                            Interact with others and share knowledge to reach level 5. You are currently at <strong class="text-white">Level @Model.Level</strong>.
                        </p>
                        <div class="d-flex align-items-center gap-3 mt-2" style="max-width: 300px;">
                            <div class="d-flex align-items-center justify-content-center fw-bold flex-shrink-0 text-aurora shadow-sm" style="width: 40px; height: 40px; border-radius: 1rem; background: rgba(52, 211, 153, 0.1);">
                                @Model.Level
                            </div>
                            <div class="rounded-pill p-1 overflow-hidden flex-grow-1" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass);">
                                <div class="rounded-pill transition-all shadow-sm bg-primary" style="height: 0.5rem; width: @(Math.Min(Model.Level * 20, 100))%; transition-duration: 0.5s;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- The Goal -->
            <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group mt-3">
                <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 transition-transform hover-scale flex-shrink-0 shadow-sm" style="width: 4rem; height: 4rem; border-radius: 1rem; @(Model.IsVerified ? "border-color: #3b82f6; background: #2563eb; color: white; box-shadow: 0 0 20px rgba(59, 130, 246, 0.3) !important;" : "border-color: rgba(255,255,255,0.05); background: rgba(0,0,0,0.2); color: #475569;")">
                    <span class="material-symbols-outlined fs-1">verified</span>
                </div>
                <div class="flex-grow-1 pt-2">
                    <h3 class="fs-3 fw-bold text-uppercase tracking-tight m-0 @(Model.IsVerified ? "text-primary text-opacity-75" : "text-muted")" style="@(Model.IsVerified ? "color: #3b82f6 !important;" : "")">
                        Verified Student Status
                    </h3>
                    <p class="fw-bold lh-base mt-2 small m-0 @(Model.IsVerified ? "text-white" : "text-muted")" style="max-width: 600px;">
                        Unlock the full potential: Verified Badge, priority in discussions, and exclusive Study Groups access.
                    </p>
                </div>
            </div>

            <!-- Moderator Application (Optional Path) -->
            @if (Model.IsVerified && Model.Role == "Member" && Model.Level >= 5)
            {
                <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group mt-5 pt-5 border-top border-glass">
                    <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 border-aurora bg-aurora-soft text-aurora transition-transform hover-scale flex-shrink-0 shadow-lg" style="width: 4rem; height: 4rem; border-radius: 1rem;">
                        <span class="material-symbols-outlined fs-1">gavel</span>
                    </div>
                    <div class="flex-grow-1 pt-2">
                        <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                            <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0">Apply for Moderator</h3>
                            <span class="badge rounded-pill fw-bold text-uppercase tracking-widest px-3 py-2 shadow-sm" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2); font-size: 0.65rem;">Unlocked</span>
                        </div>
                        <p class="text-muted fw-bold lh-base small mb-4" style="max-width: 600px;">
                            Your contributions have been recognized. You are now eligible to join the moderation team and help guide the community.
                        </p>
                        <form asp-controller="Admin" asp-action="ApplyForModerator" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-premium d-inline-flex align-items-center gap-2 text-uppercase tracking-wider fw-bold shadow-lg py-3 px-5" style="border-radius: 1rem;">
                                <span class="material-symbols-outlined fs-5">send</span>
                                Submit Moderator Application
                            </button>
                        </form>
                    </div>
                </div>
            }
            else if (Model.Role == "Moderator")
            {
                 <div class="position-relative d-flex align-items-start gap-4 gap-md-5 group mt-5 pt-5 border-top border-glass">
                    <div class="position-relative z-1 d-flex align-items-center justify-content-center border border-2 border-aurora bg-aurora text-dark transition-transform hover-scale flex-shrink-0 shadow-lg" style="width: 4rem; height: 4rem; border-radius: 1rem;">
                        <span class="material-symbols-outlined fs-1">verified_user</span>
                    </div>
                    <div class="flex-grow-1 pt-2">
                        <h3 class="fs-4 fw-bold text-white text-uppercase tracking-tight m-0 mb-2">Active Moderator</h3>
                        <p class="text-muted fw-bold lh-base small m-0" style="max-width: 600px;">
                            You are already part of the community moderation team. Thank you for your service!
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
