@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Profile";
}

<div class="max-w-4xl mx-auto p-6 md:p-10 flex flex-col gap-10 animate-fade-in pb-20">
    
    <!-- Profile Header & Identity -->
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12 relative">
        <div class="group relative">
            <div class="size-32 md:size-40 rounded-full bg-cover bg-center border-4 border-surface-light dark:border-surface-dark shadow-2xl shrink-0" 
                 style="background-image: url('@Model.AvatarUrl');"></div>
            <button onclick="openEditModal()" class="absolute bottom-2 right-2 bg-primary text-background-dark p-2 rounded-full shadow-lg hover:bg-opacity-90 transition-all" title="Edit Profile">
                 <span class="material-symbols-outlined text-[20px]">edit</span>
            </button>
        </div>

        <div class="text-center md:text-left flex flex-col gap-2">
            <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white">@Model.FullName</h1>
            <p class="text-slate-500 dark:text-[#92c0c9] font-medium text-lg">@Model.Email</p>
            <div class="flex items-center justify-center md:justify-start gap-3 mt-2">
                 <span class="px-3 py-1 rounded-full bg-slate-100 dark:bg-surface-dark text-slate-600 dark:text-slate-300 text-xs font-bold uppercase tracking-wider border border-border-light dark:border-border-dark">
                    Joined @Model.CreatedAt.ToString("MMM yyyy")
                </span>
                <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider border border-primary/20">
                    Student
                </span>
            </div>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-surface-light dark:bg-surface-dark p-5 rounded-2xl border border-border-light dark:border-border-dark flex flex-col items-center justify-center gap-1 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-yellow-500 group-hover:scale-110 transition-transform">star</span>
            <span class="text-2xl font-bold text-slate-900 dark:text-white">@Model.ReputationPoints</span>
            <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-bold tracking-wider">Reputation</span>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark p-5 rounded-2xl border border-border-light dark:border-border-dark flex flex-col items-center justify-center gap-1 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-blue-500 group-hover:scale-110 transition-transform">forum</span>
            <span class="text-2xl font-bold text-slate-900 dark:text-white">12</span>
            <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-bold tracking-wider">Posts</span>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark p-5 rounded-2xl border border-border-light dark:border-border-dark flex flex-col items-center justify-center gap-1 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-green-500 group-hover:scale-110 transition-transform">check_circle</span>
            <span class="text-2xl font-bold text-slate-900 dark:text-white">45</span>
            <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-bold tracking-wider">Answers</span>
        </div>
         <div class="bg-surface-light dark:bg-surface-dark p-5 rounded-2xl border border-border-light dark:border-border-dark flex flex-col items-center justify-center gap-1 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-pink-500 group-hover:scale-110 transition-transform">groups</span>
            <span class="text-2xl font-bold text-slate-900 dark:text-white">3</span>
            <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-bold tracking-wider">Groups</span>
        </div>
    </div>

    <div class="h-[1px] bg-border-light dark:bg-border-dark w-full"></div>

  
     <!-- Settings Section -->
    <section class="flex flex-col gap-4">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white uppercase tracking-wider flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">settings</span> Settings
        </h3>
        
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl border border-border-light dark:border-border-dark overflow-hidden divide-y divide-border-light dark:divide-border-dark">
            
            <!-- Dark Mode Toggle -->
            <div class="p-6 flex items-center justify-between">
                <div>
                     <h4 class="font-bold text-slate-900 dark:text-white">Appearance</h4>
                     <p class="text-sm text-slate-500">Switch between light and dark themes.</p>
                </div>
                 <button id="themeToggle" onclick="toggleTheme()" class="relative w-14 h-8 rounded-full bg-slate-200 dark:bg-slate-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-background-dark">
                    <span id="themeToggleKnob" class="absolute left-1 top-1 w-6 h-6 rounded-full bg-white shadow-md transform transition-transform duration-200 flex items-center justify-center">
                        <span id="themeIcon" class="material-symbols-outlined text-[16px] text-yellow-500">light_mode</span>
                    </span>
                </button>
            </div>

             <!-- Security -->
            <div class="p-6 flex items-center justify-between">
                <div>
                     <h4 class="font-bold text-slate-900 dark:text-white">Password</h4>
                     <p class="text-sm text-slate-500">Regularly updating your password improves security.</p>
                </div>
                 <a href="/Identity/Account/Manage/ChangePassword" class="px-4 py-2 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-slate-800 transition font-bold text-sm text-slate-600 dark:text-slate-300">
                    Change
                </a>
            </div>

             <!-- Danger Zone -->
            <div class="p-6 flex items-center justify-between bg-red-50/50 dark:bg-red-900/10">
                <div>
                     <h4 class="font-bold text-red-600 dark:text-red-400">Delete Account</h4>
                     <p class="text-sm text-red-400/80">Permanently remove your account and data.</p>
                </div>
                 <button onclick="confirmDelete()" class="px-4 py-2 rounded-xl bg-red-500 text-white font-bold text-sm hover:bg-red-600 transition shadow-lg shadow-red-500/20">
                    Delete
                </button>
            </div>
        </div>
    </section>

    <div class="p-6 flex items-center justify-between bg-red-50/50 dark:bg-red-900/10">
        <form asp-controller="Auth" asp-action="SignOut" method="post">
            <button type="submit" class="text-slate-400 hover:text-red-500 font-bold transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined">logout</span> Log Out
            </button>
        </form>
    </div>

</div>

<!-- Edit Profile Modal -->
<div id="editModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="closeEditModal()"></div>
    
    <!-- Modal Content -->
    <div class="relative bg-surface-light dark:bg-background-dark w-full max-w-lg rounded-3xl border border-border-light dark:border-border-dark shadow-2xl overflow-hidden animate-scale-in">
        <div class="p-6 border-b border-border-light dark:border-border-dark flex justify-between items-center bg-slate-50 dark:bg-surface-dark">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">Edit Profile</h3>
            <button onclick="closeEditModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <form asp-action="Update" method="post" class="p-6 md:p-8 flex flex-col gap-6">
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Full Name</label>
                <input type="text" name="FullName" value="@Model.FullName" class="px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400" placeholder="e.g. John Doe" />
            </div>

             <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Bio</label>
                <textarea name="Bio" rows="4" class="px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400 resize-none" placeholder="Tell us about yourself...">@Model.Bio</textarea>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700 dark:text-slate-300 ml-1">Avatar URL</label>
                 <div class="flex gap-2">
                    <input type="text" name="AvatarUrl" value="@Model.AvatarUrl" class="flex-1 px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-white dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400" placeholder="https://..." />
                </div>
                <p class="text-xs text-slate-500 ml-1">Paste a direct link to an image.</p>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-border-light dark:border-border-dark mt-2">
                <button type="button" onclick="closeEditModal()" class="px-6 py-2.5 rounded-xl font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-surface-dark transition-colors">Cancel</button>
                <button type="submit" class="px-8 py-2.5 rounded-xl bg-primary text-background-dark font-bold hover:bg-opacity-90 transition-all shadow-lg shadow-primary/20">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
   

</script>
