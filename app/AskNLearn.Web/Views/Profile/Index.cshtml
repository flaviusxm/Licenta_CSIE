@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.FullName;
}

<div class="h-100 overflow-y-auto custom-scrollbar pt-4">
    <div class="container-fluid max-w-7xl px-4 pb-5 animate-entrance">
        
        <!-- Header Section -->
        <div class="glass-card overflow-hidden mb-5 border-glass shadow-2xl">
            <div class="position-relative" style="height: 280px;">
                <div class="w-100 h-100" style="background: url('@(Model.BannerUrl ?? "https://images.unsplash.com/photo-1557683316-973673baf926")') center/cover no-repeat;">
                    <div class="position-absolute inset-0 bg-gradient-to-t from-universe via-transparent to-transparent opacity-80"></div>
                </div>
                
                @if (Model.IsOwnProfile) {
                    <div class="position-absolute top-0 end-0 p-4">
                        <button type="button" class="btn btn-glass btn-sm rounded-pill px-3" onclick="document.getElementById('bannerUpload').click()">
                            <span class="material-symbols-outlined fs-6 me-1">edit</span> Change Cover
                        </button>
                    </div>
                }
            </div>

            <div class="px-5 pb-5 position-relative">
                <div class="d-flex align-items-end gap-4" style="margin-top: -80px;">
                    <div class="position-relative">
                        <div class="avatar-lg rounded-4 overflow-hidden border border-4 border-universe shadow-2xl" style="width: 160px; height: 160px;">
                            <img src="@(Model.AvatarUrl ?? "https://api.dicebear.com/7.x/avataaars/svg?seed=" + Model.FullName)" class="w-100 h-100 object-cover" id="avatarPreview" />
                        </div>
                        @if (Model.IsOwnProfile) {
                            <button type="button" class="btn btn-premium p-0 d-flex align-items-center justify-content-center position-absolute bottom-0 end-0 m-2 rounded-3 shadow-lg" style="width: 32px; height: 32px;" onclick="document.getElementById('avatarUpload').click()">
                                <span class="material-symbols-outlined fs-6">camera_alt</span>
                            </button>
                        }
                    </div>
                    
                    <div class="flex-grow-1 pb-2">
                        <div class="d-flex align-items-center gap-3 mb-1 profile-name-container">
                            <input type="text" form="profileUpdateForm" name="FullName" 
                                   class="h2 fw-black text-white m-0 bg-transparent border-0 p-0 w-100 profile-name-input" 
                                   value="@Model.FullName" placeholder="Enter your name..."
                                   @(Model.IsOwnProfile ? "" : "readonly") />
                            <span class="material-symbols-outlined fs-5 text-muted edit-icon-hint">edit</span>
                            @if (Model.IsVerified) {
                                <span class="material-symbols-outlined text-accent fill-1" title="Verified Professional">verified</span>
                            }
                        </div>
                        <p class="text-muted mb-0 d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6">school</span>
                            Student @@ @(Model.Role == "Admin" ? "Administration" : "Community")
                        </p>
                    </div>

                    <div class="d-flex gap-4 pb-2">
                        <div class="text-center">
                            <div class="h5 fw-black text-white mb-0">@Model.PostsCount</div>
                            <div class="text-muted tiny fw-bold text-uppercase tracking-widest">Posts</div>
                        </div>
                        <div class="text-center">
                            <div class="h5 fw-black text-white mb-0">@Model.AnswersCount</div>
                            <div class="text-muted tiny fw-bold text-uppercase tracking-widest">Answers</div>
                        </div>
                        <div class="vr opacity-20 mx-1"></div>
                        <div class="text-center">
                            <div class="h5 fw-black text-white mb-0">@Model.ReputationPoints</div>
                            <div class="text-muted tiny fw-bold text-uppercase tracking-widest">Reputation</div>
                        </div>
                        <div class="text-center">
                            <div class="h5 fw-black text-white mb-0">@Model.Level</div>
                            <div class="text-muted tiny fw-bold text-uppercase tracking-widest">Level</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications / Alerts -->
        @if (TempData["Success"] != null) {
            <div class="alert alert-success border-0 bg-success-soft text-success rounded-4 mb-4 animate-slide-in">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined">check_circle</span>
                    <span class="fw-bold">@TempData["Success"]</span>
                </div>
            </div>
        }
        @if (TempData["Error"] != null) {
            <div class="alert alert-danger border-0 bg-danger-soft text-danger rounded-4 mb-4 animate-slide-in">
                <div class="d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined">error</span>
                    <span class="fw-bold">@TempData["Error"]</span>
                </div>
            </div>
        }

        <div class="row g-4">
            <!-- Sidebar (Left) - Core Info & Management -->
            <div class="col-xl-4">
                <div class="d-flex flex-column gap-4">
                    
                    <!-- Management Card -->
                    <div class="glass-card p-4 border-glass shadow-sm">
                        <h3 class="text-white fw-bold fs-xs text-uppercase tracking-widest mb-4 d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-accent">settings</span>
                            Account Management
                        </h3>
                        
                        <div class="d-flex flex-column gap-3">
                            <div class="p-3 rounded-4 bg-glass-soft border border-glass">
                                <div class="text-muted tiny fw-bold text-uppercase mb-1">Account Status</div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle @(Model.EmailConfirmed ? "bg-success" : "bg-warning")" style="width: 8px; height: 8px;"></div>
                                    <span class="text-white small fw-bold">@(Model.EmailConfirmed ? "Active Account" : "Awaiting Activation")</span>
                                </div>
                            </div>

                            @if (Model.IsOwnProfile) {
                                <div class="d-grid gap-2 mt-2">
                                @if (User.IsInRole("Admin")) {
                                    <a asp-controller="Admin" asp-action="Index" class="btn btn-premium btn-sm py-2 fw-bold text-uppercase fs-xs d-flex align-items-center justify-content-center mb-1">
                                        <span class="material-symbols-outlined fs-6 me-2">admin_panel_settings</span> Admin Portal
                                    </a>
                                }
                                <button type="button" onclick="ProfileManager.showResetModal()" class="btn btn-glass btn-sm py-2 fw-bold text-uppercase fs-xs">
                                        <span class="material-symbols-outlined fs-6 me-2">lock</span> Change Password
                                    </button>
                                    <button type="button" onclick="document.getElementById('logoutForm').submit()" class="btn btn-link text-danger text-decoration-none fw-black text-uppercase fs-xs">
                                        Sign Out
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>

            <!-- Content Area (Right) -->
            <div class="col-xl-8">
                <div class="d-flex flex-column gap-4">
                    
                    <!-- About Me & Profile Data -->
                    <form asp-action="Update" method="post" id="profileUpdateForm" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="file" name="BannerFile" id="bannerUpload" class="d-none" onchange="this.form.submit()" />
                        <input type="file" name="AvatarFile" id="avatarUpload" class="d-none" onchange="this.form.submit()" />
                        <input type="hidden" name="Occupation" value="@Model.Occupation" />
                        <input type="hidden" name="Institution" value="@Model.Institution" />
                        <input type="hidden" name="SocialLinks" id="socialLinksHidden" value="@Model.SocialLinks" />
                        <input type="hidden" name="Interests" id="interestsHidden" value="@Model.Interests" />

                        <div class="glass-card p-4 border-glass shadow-sm">
                            <div class="d-flex align-items-center justify-content-between mb-4">
                                <h3 class="text-white fw-bold fs-xs text-uppercase tracking-widest m-0 d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 text-accent">person</span>
                                    Professional Summary
                                </h3>
                                @if (Model.IsOwnProfile) {
                                    <button type="submit" class="btn btn-premium btn-sm px-4 py-1 fw-bold text-uppercase fs-xs">
                                        Save Changes
                                    </button>
                                }
                            </div>
                            <textarea name="Bio" class="form-control form-control-glass w-100 border-0 p-0 fs-5 text-white" rows="3" 
                                      placeholder="Write something about your academic interests..." 
                                      style="background: transparent; resize: none; line-height: 1.6;"
                                      @(Model.IsOwnProfile ? "" : "readonly")>@Model.Bio</textarea>
                        </div>
                    </form>

                    <!-- Identity Verification Console -->
                    <div class="glass-card border-glass shadow-2xl overflow-hidden">
                        <div class="px-4 py-3 border-bottom border-glass d-flex align-items-center justify-content-between bg-glass-soft">
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined text-accent">verified_user</span>
                                <h3 class="text-white fw-bold fs-xs text-uppercase tracking-widest mb-0">Identity & Institution Verification</h3>
                            </div>
                            @if (Model.IsVerified) {
                                <span class="badge bg-success-soft text-success rounded-pill px-3 py-1 fw-black text-uppercase fs-xs">Verified</span>
                            } else if (Model.HasPendingVerification) {
                                <span class="badge bg-warning-soft text-warning rounded-pill px-3 py-1 fw-black text-uppercase fs-xs animate-pulse">In Review</span>
                            }
                        </div>

                        <div class="p-4">
                            @if (!Model.IsVerified && !Model.HasPendingVerification && Model.IsOwnProfile) {
                                <p class="text-muted small mb-4">Validate your account to unlock premium features. Upload your Personal ID, Passport, or University Card.</p>
                                <form asp-action="SubmitVerification" asp-controller="Profile" method="post" enctype="multipart/form-data">
                                    <div class="premium-upload-zone rounded-4 p-5 text-center position-relative mb-4">
                                        <div class="upload-content py-3">
                                            <span class="material-symbols-outlined fs-display text-accent mb-3 animate-bounce-slow">upload_file</span>
                                            <h4 class="text-white fw-bold mb-2">Upload Identity Document</h4>
                                            <p class="text-muted tiny mb-0 file-name-display">Drag & drop or click (Only PNG, JPG images supported)</p>
                                        </div>
                                        <input type="file" name="verificationDoc" class="position-absolute inset-0 opacity-0 cursor-pointer w-100 h-100" accept="image/png, image/jpeg, image/jpg" required onchange="ProfileManager.handleFileSelect(this)" />
                                    </div>
                                    <button type="submit" class="btn btn-premium w-100 py-3 fw-black text-uppercase tracking-widest fs-xs shadow-lg">
                                        Start AI Verification
                                    </button>
                                </form>
                            } else if (Model.HasPendingVerification) {
                                <div class="guardian-console rounded-4 overflow-hidden border border-glass bg-black-alpha-40">
                                    <div class="console-header px-3 py-2 border-bottom border-glass d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="spinner-grow text-accent" style="width: 8px; height: 8px;"></div>
                                            <span class="text-white tiny fw-black text-uppercase tracking-widest">Guardian AI Monitoring</span>
                                        </div>
                                        <span class="text-muted tiny font-monospace">@Model.Id.Substring(0, 8).ToUpper()</span>
                                    </div>
                                    <div class="console-body p-3 font-monospace small" style="min-height: 140px; background: rgba(0,0,0,0.2);">
                                        <div class="d-flex align-items-start gap-2 mb-3">
                                            <span class="text-accent">>></span>
                                            <div id="guardian-current-notes" class="text-white">
                                                @(string.IsNullOrEmpty(Model.AdminNotes) ? "[Guardian AI]: Inițializare scanare biometrică și OCR..." : Model.AdminNotes)
                                            </div>
                                        </div>
                                        
                                        <div id="guardian-logs" class="mt-3 pt-3 border-top border-glass-thin overflow-auto" style="max-height: 80px;">
                                            <div class="text-muted tiny">>> System handshake... OK</div>
                                            <div class="text-muted tiny">>> Fetching document from secure storage... OK</div>
                                            <div class="text-muted tiny animate-pulse">>> Waiting for AI model (moondream) inference...</div>
                                        </div>
                                    </div>
                                </div>
                                @if (Model.IsOwnProfile) {
                                    <form asp-action="CancelVerification" method="post" class="mt-3">
                                        <button type="submit" class="btn btn-link text-danger text-decoration-none tiny fw-black text-uppercase">Cancel Request</button>
                                    </form>
                                }
                            } else if (Model.IsVerified) {
                                <div class="d-flex align-items-center gap-3 p-4 rounded-4 bg-success-soft border border-success-thin">
                                    <div class="rounded-circle bg-success text-white p-2">
                                        <span class="material-symbols-outlined">check</span>
                                    </div>
                                    <div>
                                        <h4 class="h6 fw-bold text-white mb-1">Account fully verified</h4>
                                        <p class="text-muted small mb-0">Identity and institution verified.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>    </div>
</div>

<style>
    .max-w-7xl { max-width: 1280px; margin: 0 auto; }
    .bg-universe { background: var(--bg-universe); }
    .inset-0 { top: 0; left: 0; bottom: 0; right: 0; }
    .bg-gradient-to-t { background: linear-gradient(to top, var(--bg-universe), transparent); }
    .avatar-lg { aspect-ratio: 1; }
    .shadow-accent { box-shadow: 0 0 15px var(--color-accent); }
    .shadow-success { box-shadow: 0 0 15px var(--color-success); }
    
    .premium-upload-zone {
        background: rgba(255, 255, 255, 0.02);
        border: 2px dashed var(--border-glass);
        transition: all 0.3s var(--ease-apple);
    }
    .premium-upload-zone:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--color-accent);
    }
    .premium-upload-zone.active {
        background: var(--color-accent-soft);
        border-color: var(--color-accent);
        border-style: solid;
    }

    .guardian-console {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }
    .bg-black-alpha-40 { background: rgba(0, 0, 0, 0.4); }
    
    .timeline-unified { border-left: 2px solid var(--border-glass); }
    .timeline-item { position: relative; }
    .timeline-dot {
        position: absolute;
        left: -25px;
        top: 0;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--border-glass);
    }
    .fs-display { font-size: 4rem; }
    .profile-name-container { transition: all 0.2s ease; border-radius: 8px; padding: 4px; margin: -4px; cursor: text; }
    .profile-name-container:hover { background: rgba(255, 255, 255, 0.05); }
    .edit-icon-hint { opacity: 0; transition: opacity 0.2s ease; }
    .profile-name-container:hover .edit-icon-hint { opacity: 1; }
    .profile-name-input:focus { outline: none; background: rgba(255, 255, 255, 0.1) !important; border-radius: 4px; padding-left: 8px !important; }

    .max-w-7xl { max-width: 1280px; margin: 0 auto; }
</style>

<!-- Standard Forms for Logout & Resets -->
<form asp-controller="Auth" asp-action="SignOut" method="post" id="logoutForm" class="d-none"></form>

@section Modals {
    <div class="modal fade" id="resetModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card border-glass shadow-2xl overflow-hidden">
                <div class="modal-body p-5 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 bg-accent-soft text-accent" style="width: 80px; height: 80px;">
                        <span class="material-symbols-outlined fs-1">lock_reset</span>
                    </div>
                    <h3 class="h4 text-white fw-black text-uppercase tracking-tight mb-3">Security Update</h3>
                    <p class="text-muted small mb-4">A password reset link will be sent to your registered email address.</p>
                    <div id="resetFeedback" class="mb-4 d-none">
                        <div class="alert alert-success border-0 bg-success-soft text-success small py-2 px-3 rounded-4">
                            Check your email for the reset link!
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="button" id="btnRequestReset" class="btn btn-accent py-3 fw-bold text-uppercase tracking-widest shadow-lg" style="border-radius: 1rem;">
                            Send Reset Link
                        </button>
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold fs-xs text-uppercase tracking-widest" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script type="module" src="~/js/module.profile.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const initialTags = "@Model.Interests".split(',').filter(x => x.trim() !== '');
        const initialLinks = "@Model.SocialLinks".split(';').filter(x => x.trim() !== '');
        ProfileManager.init(@Model.IsOwnProfile.ToString().ToLower(), initialTags, initialLinks, "@Model.Id", @Model.HasPendingVerification.ToString().ToLower());

        // Handle File Input Highlights
        document.querySelectorAll('.premium-upload-zone input').forEach(input => {
            input.addEventListener('change', () => {
                if (input.files.length > 0) {
                    input.parentElement.classList.add('active');
                    input.parentElement.querySelector('.text-muted').innerText = input.files[0].name;
                }
            });
        });

        // Request Password Reset Logic
        const btnReset = document.getElementById('btnRequestReset');
        if (btnReset) {
            btnReset.addEventListener('click', async () => {
                btnReset.disabled = true;
                btnReset.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Sending...';
                try {
                    const response = await fetch('/identity/auth/request-password-reset', { method: 'POST' });
                    if (response.ok) {
                        document.getElementById('resetFeedback').classList.remove('d-none');
                        setTimeout(() => bootstrap.Modal.getInstance(document.getElementById('resetModal')).hide(), 3000);
                    }
                } catch (e) { console.error(e); }
                finally { 
                    btnReset.disabled = false; 
                    btnReset.innerText = 'Send Reset Link';
                }
            });
        }
        // Profile Manager Extension
        window.ProfileManager = window.ProfileManager || {};
        window.ProfileManager.handleFileSelect = function(input) {
            const display = input.parentElement.querySelector('.file-name-display');
            if (input.files && input.files[0]) {
                display.innerText = input.files[0].name;
                display.classList.add('text-accent');
                input.parentElement.style.borderColor = 'var(--color-accent)';
            }
        };
    });

    window.ProfileManager = window.ProfileManager || {
        showResetModal: () => {
            new bootstrap.Modal(document.getElementById('resetModal')).show();
        }
    };
</script>
}
