@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Profile";
}

<div class="max-w-5xl mx-auto p-4 md:p-8 flex flex-col gap-8 min-h-full animate-fade-in">
    <!-- Header Section -->
    <div class="flex items-center justify-between border-b border-border-light dark:border-border-dark pb-4">
        <div>
             <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Profile</h2>
             <p class="text-slate-500 dark:text-[#92c0c9]">Manage your account settings and preferences.</p>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <div class="flex gap-4 border-b border-border-light dark:border-border-dark">
        <button onclick="switchTab('overview')" id="tab-overview" class="tab-btn px-4 py-2 text-sm font-medium text-primary border-b-2 border-primary transition-colors">
            Overview
        </button>
        <button onclick="switchTab('edit')" id="tab-edit" class="tab-btn px-4 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors border-b-2 border-transparent">
            Edit Profile
        </button>
        <button onclick="switchTab('settings')" id="tab-settings" class="tab-btn px-4 py-2 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 transition-colors border-b-2 border-transparent">
            Settings
        </button>
    </div>

    <!-- Tab Contents -->
    <div class="mt-4">
        <!-- Overview Tab -->
        <div id="content-overview" class="tab-content flex flex-col gap-6 animate-fade-in">
             @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 text-red-500 p-4 rounded-lg">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark overflow-hidden p-8 flex flex-col md:flex-row gap-8 items-center md:items-start text-center md:text-left shadow-sm">
                
                <div class="size-32 rounded-full bg-cover bg-center border-4 border-slate-100 dark:border-border-dark shadow-xl" style="background-image: url('@Model.AvatarUrl');"></div>
                
                <div class="flex flex-col gap-3 flex-grow">
                     <h1 class="text-4xl font-bold text-slate-900 dark:text-white">@Model.FullName</h1>
                     <p class="text-slate-500 dark:text-slate-400 font-medium">@Model.Email</p>
                     
                     @if(!string.IsNullOrEmpty(Model.Bio))
                     {
                        <p class="text-slate-600 dark:text-slate-300 mt-2 italic text-lg">"@Model.Bio"</p>
                     }
                     else
                     {
                         <p class="text-slate-400 dark:text-slate-500 mt-2 italic">No bio set.</p>
                     }

                    <div class="flex gap-4 mt-6 justify-center md:justify-start">
                         <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-yellow-500/10 text-yellow-600 dark:text-yellow-400 border border-yellow-500/20">
                            <span class="material-symbols-outlined text-lg">star</span>
                            <span class="font-bold">@Model.ReputationPoints Reputation</span>
                        </div>
                        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-500/10 text-slate-600 dark:text-slate-400 border border-slate-500/20">
                            <span class="material-symbols-outlined text-lg">calendar_month</span>
                            <span class="font-bold">Joined @Model.CreatedAt.ToString("MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            </div>

             <section class="flex flex-col gap-4">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">Recent Activity</h3>
                <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark p-6">
                    <div class="flex flex-col gap-3">
                        <div class="flex gap-3 items-start p-3 hover:bg-slate-50 dark:hover:bg-slate-800/50 rounded-lg transition-colors">
                            <span class="material-symbols-outlined text-green-500 mt-1">check_circle</span>
                            <div>
                                <p class="text-sm font-medium text-slate-800 dark:text-slate-200">Answered a question in Physics</p>
                                <p class="text-xs text-slate-400">2 hours ago</p>
                            </div>
                        </div>
                         <!-- Placeholder for more activity -->
                         <div class="text-center text-slate-400 text-sm mt-2">No more recent activity.</div>
                    </div>
                </div>
            </section>
        </div>

        <!-- Edit Profile Tab -->
        <div id="content-edit" class="tab-content hidden flex flex-col gap-6 animate-fade-in">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">Edit Profile Details</h3>
            <form asp-action="Update" method="post" class="flex flex-col gap-6 w-full max-w-2xl">
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-slate-700 dark:text-white">Full Name</label>
                    <input type="text" name="FullName" value="@Model.FullName" class="px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-slate-50 dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" />
                </div>

                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-slate-700 dark:text-white">Bio</label>
                    <textarea name="Bio" rows="4" class="px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-slate-50 dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all">@Model.Bio</textarea>
                    <p class="text-xs text-slate-500">Tell us a little about yourself.</p>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-slate-700 dark:text-white">Avatar URL</label>
                    <input type="text" name="AvatarUrl" value="@Model.AvatarUrl" class="px-4 py-3 rounded-xl border border-border-light dark:border-border-dark bg-slate-50 dark:bg-surface-dark text-slate-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" />
                    <p class="text-xs text-slate-500">Paste an image URL for your profile picture.</p>
                </div>

                <button type="submit" class="self-start px-8 py-3 bg-primary text-[#111f22] font-bold rounded-xl hover:bg-opacity-90 transition-all shadow-lg shadow-primary/20">
                    Save Changes
                </button>
            </form>
        </div>

        <!-- Settings Tab -->
        <div id="content-settings" class="tab-content hidden flex flex-col gap-8 animate-fade-in">
            
            <!-- Appearance -->
            <section class="flex flex-col gap-4">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white">Appearance</h3>
                <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark p-6 flex flex-col gap-4">
                    <label class="text-sm font-semibold text-slate-700 dark:text-white">Theme</label>
                     <div class="flex gap-4">
                        <button type="button" class="px-4 py-2 rounded-lg border border-border-light dark:border-border-dark hover:bg-slate-100 dark:hover:bg-[#234248] transition flex items-center gap-2">
                            <span>☀️</span> Light
                        </button>
                        <button type="button" class="px-4 py-2 rounded-lg border border-border-light dark:border-border-dark hover:bg-slate-100 dark:hover:bg-[#234248] transition flex items-center gap-2">
                            <span>🌙</span> Dark
                        </button>
                        <button type="button" class="px-4 py-2 rounded-lg border border-border-light dark:border-border-dark hover:bg-slate-100 dark:hover:bg-[#234248] transition flex items-center gap-2">
                            <span>💻</span> System
                        </button>
                    </div>
                </div>
            </section>

             <!-- Security -->
            <section class="flex flex-col gap-4">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white">Security</h3>
                <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark p-6 flex flex-col gap-6">
                    
                    <div class="flex items-center justify-between">
                         <div>
                            <h4 class="font-semibold text-slate-900 dark:text-white">Change Password</h4>
                            <p class="text-sm text-slate-500">Update your password to keep your account secure.</p>
                        </div>
                        <a href="/Identity/Account/Manage/ChangePassword" class="px-4 py-2 rounded-lg border border-border-light dark:border-border-dark hover:bg-slate-100 dark:hover:bg-[#234248] transition text-sm font-medium">
                            Update
                        </a>
                    </div>
                    
                    <div class="h-[1px] bg-border-light dark:bg-border-dark w-full"></div>

                    <div class="flex items-center justify-between">
                         <div>
                            <h4 class="font-semibold text-red-500">Delete Account</h4>
                            <p class="text-sm text-slate-500">Permanently delete your account and all data.</p>
                        </div>
                         <button type="button" onclick="openDeleteModal()" class="px-4 py-2 rounded-lg border border-red-500/30 bg-red-500/5 text-red-600 hover:bg-red-500/10 transition text-sm font-semibold">
                            Delete Account
                        </button>
                    </div>

                </div>
            </section>

            <!-- Sign Out -->
             <div class="flex justify-end">
                <form asp-controller="Auth" asp-action="SignOut" method="post">
                    <button type="submit" class="px-6 py-3 rounded-xl border border-red-500/20 bg-red-500/5 text-red-500 font-bold hover:bg-red-500/10 transition-colors flex items-center gap-2 group">
                        <span>Log Out</span>
                        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">logout</span>
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    function switchTab(tabName) {
        // Update Buttons
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('text-primary', 'border-primary');
            btn.classList.add('text-slate-500', 'dark:text-slate-400', 'border-transparent');
        });
        const activeBtn = document.getElementById('tab-' + tabName);
        activeBtn.classList.remove('text-slate-500', 'dark:text-slate-400', 'border-transparent');
        activeBtn.classList.add('text-primary', 'border-primary');

        // Update Content
        document.querySelectorAll('.tab-content').forEach(content => {
           content.classList.add('hidden');
        });
        document.getElementById('content-' + tabName).classList.remove('hidden');
    }

    function openDeleteModal() {
        if(confirm("Are you sure you want to delete your account? This action cannot be undone.")) {
            // Implement delete logic here
            alert("Delete functionality not fully implemented yet.");
        }
    }
</script>
