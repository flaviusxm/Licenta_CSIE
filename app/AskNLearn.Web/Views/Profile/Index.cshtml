@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Profile";
}

<div class="max-w-4xl mx-auto p-6 md:p-10 flex flex-col gap-12 animate-fade-in pb-20">
    
    <form asp-action="Update" method="post" id="profileForm">
        <input type="hidden" name="FullName" value="@Model.FullName" />
        <input type="hidden" name="AvatarUrl" value="@Model.AvatarUrl" />

        <!-- Merged Header Layout -->
        <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12 relative">
            <!-- Avatar -->
            <div class="group relative shrink-0">
                <div class="size-32 md:size-40 rounded-full bg-cover bg-center border-4 border-surface-light dark:border-surface-dark shadow-2xl transition-transform group-hover:scale-[1.02]" 
                     style="background-image: url('@(Model.AvatarUrl ?? "https://api.dicebear.com/7.x/avataaars/svg?seed=" + Model.FullName)');"></div>
            </div>

            <!-- Identity & In-place Inputs -->
            <div class="text-center md:text-left flex flex-col gap-4 flex-1 w-full">
                <div class="flex flex-col md:flex-row justify-between items-start gap-4">
                    <div>
                        <h1 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white tracking-tight">@Model.FullName</h1>
                        <p class="text-primary font-bold text-sm tracking-wide">@Model.Email</p>
                    </div>
                    <button type="submit" class="w-full md:w-auto px-8 py-3 rounded-2xl bg-primary text-white font-black shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-xl">save</span> Save Changes
                    </button>
                </div>

                <!-- Status Row -->
                <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
                    <span class="px-3 py-1.5 rounded-full bg-slate-100 dark:bg-surface-dark text-slate-600 dark:text-slate-300 text-[10px] font-black uppercase tracking-widest border border-border-light dark:border-border-dark flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-sm">calendar_today</span> Joined @Model.CreatedAt.ToString("MMM yyyy")
                    </span>
                    <span class="px-3 py-1.5 rounded-full bg-primary/10 text-primary text-[10px] font-black uppercase tracking-widest border border-primary/20 flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-sm">military_tech</span> Level @Model.Level
                    </span>
                    @if (!string.IsNullOrEmpty(Model.RankName))
                    {
                        <span class="px-3 py-1.5 rounded-full bg-yellow-500/10 text-yellow-500 text-[10px] font-black uppercase tracking-widest border border-yellow-500/20 flex items-center gap-1.5">
                            @if (!string.IsNullOrEmpty(Model.RankIconUrl))
                            {
                                <img src="@Model.RankIconUrl" class="size-3 object-contain" alt="" />
                            }
                            @Model.RankName
                        </span>
                    }
                </div>

                <!-- Bio: Right under Joined/Level -->
                <div class="flex flex-col gap-2 pt-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 ml-1">About Me</label>
                    <textarea name="Bio" rows="3" placeholder="Tell us about yourself..." 
                              class="w-full px-5 py-4 rounded-2xl border border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-surface-dark/30 text-slate-700 dark:text-slate-200 font-medium italic leading-relaxed placeholder:text-slate-400 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all resize-none shadow-inner">@Model.Bio</textarea>
                </div>

                <!-- Occupation & Institution Row -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 ml-1">Occupation</label>
                        <select name="Occupation" class="w-full px-4 py-3 rounded-2xl border border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-surface-dark/30 text-slate-900 dark:text-white font-bold focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all cursor-pointer shadow-inner">
                            <option value="">Choose Occupation</option>
                            <option value="Pupil" selected='@(Model.Occupation == "Pupil")'>Pupil</option>
                            <option value="Student" selected='@(Model.Occupation == "Student")'>Student</option>
                            <option value="Teacher" selected='@(Model.Occupation == "Teacher")'>Teacher</option>
                            <option value="Researcher" selected='@(Model.Occupation == "Researcher")'>Researcher</option>
                            <option value="Professional" selected='@(Model.Occupation == "Professional")'>Professional</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500 ml-1">Institution</label>
                        <input type="text" name="Institution" value="@Model.Institution" placeholder="School/University..." 
                               class="w-full px-5 py-3 rounded-2xl border border-border-light dark:border-border-dark bg-slate-50/50 dark:bg-surface-dark/30 text-slate-900 dark:text-white font-bold placeholder:text-slate-400 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all shadow-inner" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Academic Interests Section -->
        <div class="mt-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined">psychology</span>
                </div>
                <h3 class="text-xl font-black text-slate-900 dark:text-white tracking-tight uppercase">Academic Interests</h3>
            </div>

            <div class="flex flex-col gap-6 p-8 bg-surface-light/50 dark:bg-surface-dark/20 rounded-[2.5rem] border border-border-light dark:border-border-dark border-dashed">
                <!-- Tag Wrapper -->
                <div id="interestsContainer" class="flex flex-wrap gap-2 min-h-[56px] p-2">
                    <!-- Initial Tags -->
                    @if (!string.IsNullOrEmpty(Model.Interests))
                    {
                        @foreach (var interest in Model.Interests.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="group flex items-center gap-2 px-4 py-2 bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl shadow-sm animate-scale-in">
                                <span class="text-sm font-bold text-slate-700 dark:text-slate-200">#@interest.Trim()</span>
                                <button type="button" onclick="removeTag(this, '@interest.Trim()')" class="text-slate-400 hover:text-red-500 transition-colors">
                                    <span class="material-symbols-outlined text-lg">close</span>
                                </button>
                            </div>
                        }
                    }
                    <input type="text" id="interestInput" placeholder="+ Add custom interest and press Enter..." 
                           class="flex-1 min-w-[200px] bg-transparent border-none focus:ring-0 text-sm font-bold text-slate-600 dark:text-slate-400 placeholder:text-slate-400" />
                </div>
                
                <input type="hidden" name="Interests" id="interestsHidden" value="@Model.Interests" />

                <!-- Predefined Suggestions -->
                <div class="flex flex-col gap-3">
                    <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Quick Add Recommendations</label>
                    <div class="flex flex-wrap gap-2">
                        @{
                            var suggestions = new[] { "Computer Science", "Mathematics", "Physics", "Chemistry", "Biology", "Economics", "Literature", "History", "Engineering", "Design" };
                        }
                        @foreach (var suggestion in suggestions)
                        {
                            <button type="button" onclick="addTagValue('@suggestion')" class="px-4 py-2 rounded-xl border border-border-light dark:border-border-dark text-xs font-bold text-slate-600 dark:text-slate-400 hover:bg-white dark:hover:bg-surface-dark hover:border-primary/50 hover:text-primary transition-all shadow-sm">
                                + @suggestion
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>

    <!-- Stats Hub (Boxed layout from "Old Layout") -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-4">
        <div class="bg-surface-light dark:bg-surface-dark/50 p-6 rounded-3xl border border-border-light dark:border-border-dark flex flex-col items-center gap-2 group hover:border-primary/30 transition-all">
             <span class="material-symbols-outlined text-3xl text-yellow-500 group-hover:scale-110 transition-transform">star</span>
            <span class="text-3xl font-black text-slate-900 dark:text-white">@Model.ReputationPoints</span>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Reputation</span>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark/50 p-6 rounded-3xl border border-border-light dark:border-border-dark flex flex-col items-center gap-2 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-blue-500 group-hover:scale-110 transition-transform">forum</span>
            <span class="text-3xl font-black text-slate-900 dark:text-white">@Model.PostsCount</span>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Resources</span>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark/50 p-6 rounded-3xl border border-border-light dark:border-border-dark flex flex-col items-center gap-2 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-green-500 group-hover:scale-110 transition-transform">check_circle</span>
            <span class="text-3xl font-black text-slate-900 dark:text-white">@Model.AnswersCount</span>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Answers</span>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark/50 p-6 rounded-3xl border border-border-light dark:border-border-dark flex flex-col items-center gap-2 group hover:border-primary/30 transition-all">
            <span class="material-symbols-outlined text-3xl text-pink-500 group-hover:scale-110 transition-transform">groups</span>
            <span class="text-3xl font-black text-slate-900 dark:text-white">@Model.GroupsCount</span>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Groups</span>
        </div>
    </div>

    <!-- Settings (Merged Design) -->
    <div class="bg-surface-light dark:bg-surface-dark/30 rounded-[2.5rem] border border-border-light dark:border-border-dark overflow-hidden divide-y divide-border-light dark:divide-border-dark mt-4">
        <div class="p-8 flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
                 <h4 class="text-lg font-black text-slate-900 dark:text-white uppercase tracking-tight">Account Security</h4>
                 <p class="text-sm text-slate-500">Update your password or manage linked accounts.</p>
            </div>
             <a href="/Identity/Account/Manage/ChangePassword" class="w-full md:w-auto px-6 py-3 rounded-xl border border-border-light dark:border-border-dark hover:bg-white dark:hover:bg-slate-800 transition font-bold text-sm text-slate-600 dark:text-slate-300 text-center">
                Change Password
            </a>
        </div>
        <div class="p-8 flex flex-col md:flex-row items-center justify-between gap-6 bg-red-50/50 dark:bg-red-900/10">
            <div>
                 <h4 class="text-lg font-black text-red-600 dark:text-red-400 uppercase tracking-tight">Danger Zone</h4>
                 <p class="text-sm text-red-400/80">Permanently delete your profile and all contributions.</p>
            </div>
             <button onclick="return confirm('Are you sure? This cannot be undone!')" class="w-full md:w-auto px-6 py-3 rounded-xl border border-red-500/50 text-red-500 font-bold text-sm hover:bg-red-500 hover:text-white transition shadow-lg shadow-red-500/10">
                Delete Account
            </button>
        </div>
    </div>

    <div class="p-8 flex items-center justify-center">
        <form asp-controller="Auth" asp-action="SignOut" method="post">
            <button type="submit" class="text-slate-400 hover:text-red-500 font-bold transition-colors flex items-center gap-2 group">
                <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">logout</span> Sign Out
            </button>
        </form>
    </div>

</div>

<script>
    const interestsHidden = document.getElementById('interestsHidden');
    const interestsContainer = document.getElementById('interestsContainer');
    const interestInput = document.getElementById('interestInput');

    let interests = interestsHidden.value ? interestsHidden.value.split(',').filter(x => x.trim() !== '') : [];

    function updateHiddenInput() {
        interestsHidden.value = interests.join(',');
    }

    function addTagValue(value) {
        value = value.trim();
        if (value === '' || interests.includes(value)) return;
        
        interests.push(value);
        updateHiddenInput();

        const tag = document.createElement('div');
        tag.className = 'group flex items-center gap-2 px-4 py-2 bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl shadow-sm animate-scale-in';
        tag.innerHTML = `
            <span class="text-sm font-bold text-slate-700 dark:text-slate-200">#${value}</span>
            <button type="button" onclick="removeTag(this, '${value}')" class="text-slate-400 hover:text-red-500 transition-colors">
                <span class="material-symbols-outlined text-lg">close</span>
            </button>
        `;
        interestsContainer.insertBefore(tag, interestInput);
        interestInput.value = '';
    }

    function removeTag(button, value) {
        interests = interests.filter(i => i !== value);
        updateHiddenInput();
        button.parentElement.remove();
    }

    interestInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            addTagValue(interestInput.value);
        }
    });

    interestInput.addEventListener('blur', () => {
        if (interestInput.value) {
            addTagValue(interestInput.value);
        }
    });

    // Handle clicks on "+ Add" prompts from dashboard or completion bar
    document.addEventListener('click', function(e) {
        if (e.target && e.target.innerText && e.target.innerText.includes('+ Add')) {
            const text = e.target.innerText;
            if (text.includes('Bio')) document.querySelector('textarea[name="Bio"]')?.focus();
            if (text.includes('Occupation')) document.querySelector('select[name="Occupation"]')?.focus();
            if (text.includes('Institution')) document.querySelector('input[name="Institution"]')?.focus();
            if (text.includes('Interests')) document.querySelector('#interestInput')?.focus();
        }
    });
</script>
