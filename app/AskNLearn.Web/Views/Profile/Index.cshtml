@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.FullName;
}

<div class="profile-container py-4 px-4 px-lg-5">
    <!-- Header Hero Section -->
    <div class="profile-hero glass-card border-0 mb-5 overflow-hidden position-relative">
        <!-- Banner -->
        <div class="profile-banner" style="height: 160px; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);">
            @if (!string.IsNullOrEmpty(Model.BannerUrl))
            {
                <img src="@Model.BannerUrl" class="w-100 h-100 object-cover" />
            }
            <div class="position-absolute inset-0 bg-gradient-to-t from-[#0f172a] via-transparent to-transparent"></div>
            @if (Model.IsOwnProfile)
            {
                <button class="btn btn-glass btn-sm position-absolute bottom-2 end-3 rounded-pill px-3 py-1" onclick="document.getElementById('bannerUpload').click()">
                    <span class="material-symbols-outlined fs-6 me-1">edit</span> Change Cover
                </button>
            }
        </div>

        <!-- Avatar & Basic Info -->
        <div class="profile-avatar-section px-4 pb-3 position-relative" style="margin-top: -50px;">
            <div class="d-flex flex-column flex-md-row align-items-md-end gap-4">
                <div class="position-relative">
                    <div class="avatar-frame rounded-3 overflow-hidden border border-4 border-[#0f172a] shadow-xl" style="width: 100px; height: 100px;">
                        <img src="@(Model.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={Model.FullName}")"
                             class="w-100 h-100 object-cover" id="avatarPreview" />
                    </div>
                    @if (Model.IsOwnProfile)
                    {
                        <button class="btn btn-dark btn-sm p-1 rounded-circle position-absolute bottom-0 end-0 mb-1 me-1 shadow"
                                style="width: 28px; height: 28px;" onclick="document.getElementById('avatarUpload').click()">
                            <span class="material-symbols-outlined fs-6">camera_alt</span>
                        </button>
                    }
                </div>

                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @if (Model.IsOwnProfile)
                        {
                            <input type="text" id="fullNameInput" value="@Model.FullName"
                                   class="profile-name-input fs-2 fw-bold bg-transparent border-0 p-0"
                                   placeholder="Your name" />
                            <span class="material-symbols-outlined text-muted fs-5 edit-hint">edit</span>
                        }
                        else
                        {
                            <h1 class="fs-2 fw-bold text-white mb-0">@Model.FullName</h1>
                        }
                        @if (Model.IsVerified)
                        {
                            <span class="material-symbols-outlined text-primary fs-4" title="Verified Student">verified</span>
                        }
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <div class="d-flex align-items-center gap-1">
                            <span class="material-symbols-outlined fs-6 text-muted">school</span>
                            <span class="text-muted small">@(Model.Role == "Admin" ? "Administrator" : "Student")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.RankName))
                        {
                            <div class="badge bg-primary-soft text-primary rounded-pill px-3 py-1">
                                <span class="material-symbols-outlined fs-6 me-1">military_tech</span>
                                @Model.RankName
                            </div>
                        }
                    </div>

                    <!-- Linia de jos cu Posts, Answers, Joined, Points -->
                    <div class="d-flex flex-wrap align-items-center gap-4 gap-md-5">
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-primary">article</span>
                            <div>
                                <div class="fw-bold text-white">@Model.PostsCount</div>
                                <div class="text-muted small">Posts</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-primary">chat</span>
                            <div>
                                <div class="fw-bold text-white">@Model.AnswersCount</div>
                                <div class="text-muted small">Answers</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-primary">calendar_month</span>
                            <div>
                                <div class="fw-bold text-white">@Model.CreatedAt.ToString("MMM yyyy")</div>
                                <div class="text-muted small">Joined</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-warning">stars</span>
                            <div>
                                <div class="fw-bold text-primary" id="userReputationPoints">@Model.ReputationPoints</div>
                                <div class="text-muted small">Points</div>
                            </div>
                        </div>
                    </div>

                    @if (Model.IsOwnProfile)
                    {
                        <div id="saveChangesBanner" class="d-none mt-3">
                            <div class="alert alert-primary-soft d-flex align-items-center justify-content-between p-2 rounded-3" style="background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.2);">
                                <span class="small">You have unsaved changes</span>
                                <div class="d-flex gap-2">
                                    <button onclick="ProfileManager.discardChanges()" class="btn btn-sm btn-glass px-3">Discard</button>
                                    <button onclick="ProfileManager.saveChanges()" class="btn btn-sm btn-primary px-3">Save Changes</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!Model.IsOwnProfile)
                {
                    <div class="d-flex gap-2">
                        @switch (Model.ConnectionStatus)
                        {
                            case AskNLearn.Application.Common.Models.ConnectionStatus.None:
                                <form asp-action="SendConnection" asp-route-userId="@Model.Id" method="post">
                                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                                        <span class="material-symbols-outlined fs-6 me-1">person_add</span> Connect
                                    </button>
                                </form>
                                break;
                            case AskNLearn.Application.Common.Models.ConnectionStatus.PendingSent:
                                <button class="btn btn-secondary rounded-pill px-4" disabled>
                                    <span class="material-symbols-outlined fs-6 me-1">hourglass_empty</span> Pending
                                </button>
                                break;
                            case AskNLearn.Application.Common.Models.ConnectionStatus.PendingReceived:
                                <div class="d-flex gap-2">
                                    <form asp-action="AcceptConnection" asp-route-userId="@Model.Id" method="post">
                                        <button type="submit" class="btn btn-success rounded-pill px-3">Accept</button>
                                    </form>
                                    <form asp-action="RejectConnection" asp-route-userId="@Model.Id" method="post">
                                        <button type="submit" class="btn btn-outline-danger rounded-pill px-3">Decline</button>
                                    </form>
                                </div>
                                break;
                            case AskNLearn.Application.Common.Models.ConnectionStatus.Accepted:
                                <div class="dropdown">
                                    <button class="btn btn-outline-primary rounded-pill px-4 dropdown-toggle" data-bs-toggle="dropdown">
                                        Connected
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-dark">
                                        <li>
                                            <form asp-action="RemoveConnection" asp-route-userId="@Model.Id" method="post">
                                                <button type="submit" class="dropdown-item text-danger">Remove Connection</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                                break;
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    
    <!-- Main Content Row -->
    <div class="row g-4">
        <!-- Left Column - Account Settings -->
        <div class="col-lg-4">
            <div class="glass-card p-4 border-0">
                <div class="d-flex align-items-center gap-2 mb-3 pb-2 border-bottom border-glass">
                    <span class="material-symbols-outlined text-primary fs-5">settings</span>
                    <h3 class="fs-6 fw-bold text-white mb-0">Account</h3>
                </div>

                @if (Model.IsOwnProfile)
                {
                    <div class="d-grid gap-2">
                        <button onclick="ProfileManager.showResetModal()" class="btn btn-glass d-flex align-items-center justify-content-between w-100">
                            <span><span class="material-symbols-outlined fs-5 me-2">lock</span> Change Password</span>
                            <span class="material-symbols-outlined fs-5">chevron_right</span>
                        </button>
                        <form asp-controller="Auth" asp-action="SignOut" method="post" id="logoutForm">
                            <button type="submit" class="btn btn-glass text-danger d-flex align-items-center justify-content-between w-100">
                                <span><span class="material-symbols-outlined fs-5 me-2">logout</span> Sign Out</span>
                                <span class="material-symbols-outlined fs-5">chevron_right</span>
                            </button>
                        </form>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-premium d-flex align-items-center justify-content-between w-100 mt-2">
                                <span><span class="material-symbols-outlined fs-5 me-2">admin_panel_settings</span> Admin Portal</span>
                                <span class="material-symbols-outlined fs-5">chevron_right</span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small text-center py-3">Account settings are only visible to you</p>
                }
            </div>
        </div>

        <!-- Right Column - Main Content -->
        <div class="col-lg-8">
            <!-- About Me -->
            <div class="glass-card p-4 border-0 mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary fs-5">description</span>
                        <h3 class="fs-6 fw-bold text-white mb-0">About Me</h3>
                    </div>
                    @if (Model.IsOwnProfile)
                    {
                        <span id="bioEditHint" class="text-muted small" style="cursor: pointer;" onclick="ProfileManager.editBio()">
                            <span class="material-symbols-outlined fs-6">edit</span> Edit
                        </span>
                    }
                </div>

                <div id="bioDisplay" class="text-muted" style="line-height: 1.6;">
                    @if (string.IsNullOrEmpty(Model.Bio))
                    {
                        <em class="text-muted">No bio yet. Click edit to add one.</em>
                    }
                    else
                    {
                        @Model.Bio
                    }
                </div>

                @if (Model.IsOwnProfile)
                {
                    <div id="bioEdit" class="d-none">
                        <textarea id="bioTextarea" class="form-control form-control-glass mb-3" rows="4" placeholder="Tell us about yourself...">@Model.Bio</textarea>
                        <div class="d-flex gap-2 justify-content-end">
                            <button onclick="ProfileManager.cancelBioEdit()" class="btn btn-sm btn-glass">Cancel</button>
                            <button onclick="ProfileManager.saveBio()" class="btn btn-sm btn-primary">Save</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Rank Progress -->
            <div class="glass-card p-4 border-0 mb-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-primary fs-5">trending_up</span>
                    <h3 class="fs-6 fw-bold text-white mb-0">Rank Progress</h3>
                </div>

                <div class="row align-items-center g-3">
                    <div class="col-5">
                        <div class="text-center p-2 rounded-3" style="background: rgba(255,255,255,0.03);">
                            <span class="text-muted small d-block">Current</span>
                            <span class="fw-bold text-primary fs-5" id="currentRankName">@(Model.RankName ?? "Newcomer")</span>
                        </div>
                    </div>
                    <div class="col-2 text-center">
                        <span class="material-symbols-outlined text-muted">arrow_forward</span>
                    </div>
                    <div class="col-5">
                        <div class="text-center p-2 rounded-3" style="background: rgba(255,255,255,0.03);">
                            <span class="text-muted small d-block">Next</span>
                            <span class="fw-bold text-white fs-5" id="nextRankName">Loading...</span>
                        </div>
                    </div>
                </div>

                <!-- Progress Bar -->
                <div class="mt-3">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span id="currentRankPoints">@Model.ReputationPoints pts</span>
                        <span id="nextRankThreshold">-</span>
                    </div>
                    <div class="progress" style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                        <div id="rankProgressBar" class="progress-bar bg-primary" role="progressbar"
                             style="width: 0%; transition: width 0.5s ease;"></div>
                    </div>
                </div>
            </div>

            <!-- Verification -->
            <div class="glass-card p-4 border-0 mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary fs-5">verified_user</span>
                        <h3 class="fs-6 fw-bold text-white mb-0">Verification</h3>
                    </div>
                    <div id="verification-status-badge">
                        @if (Model.IsVerified)
                        {
                            <span class="badge bg-success-soft text-success rounded-pill px-3 py-1">Verified</span>
                        }
                        else if (Model.HasPendingVerification)
                        {
                            <span class="badge bg-warning-soft text-warning rounded-pill px-3 py-1">Pending</span>
                        }
                    </div>
                </div>

                <div class="verification-content">
                    @if (!Model.IsVerified && !Model.HasPendingVerification && Model.IsOwnProfile)
                    {
                        <p class="text-muted small mb-3">Get verified to unlock all features and build trust in the community.</p>
                        <form asp-action="SubmitVerification" method="post" enctype="multipart/form-data">
                            <div class="upload-zone rounded-3 p-3 text-center position-relative mb-2"
                                 style="border: 1px dashed rgba(255,255,255,0.2); background: rgba(255,255,255,0.02);">
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <span class="material-symbols-outlined text-primary">upload_file</span>
                                    <span class="text-muted small file-name-display">Click to upload ID document</span>
                                </div>
                                <input type="file" name="verificationDoc" class="position-absolute inset-0 opacity-0 cursor-pointer w-100 h-100"
                                       accept="image/png, image/jpeg, image/jpg" required
                                       onchange="ProfileManager.handleFileSelect(this)" />
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">Submit Verification</button>
                        </form>
                    }
                    else if (Model.HasPendingVerification)
                    {
                        <div class="text-center py-2">
                            @if (Model.AdminNotes?.Contains("failed") == true)
                            {
                                <div class="text-danger mb-2">
                                    <span class="material-symbols-outlined fs-3">error_outline</span>
                                    <p class="small mb-0 mt-1">Manual review required</p>
                                </div>
                            }
                            else
                            {
                                <div class="text-primary mb-2">
                                    <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                    <p class="small mb-0">Analyzing your documents...</p>
                                </div>
                            }
                            @if (Model.IsOwnProfile)
                            {
                                <form asp-action="CancelVerification" method="post" class="mt-2">
                                    <button type="submit" class="btn btn-link text-muted small p-0">Cancel request</button>
                                </form>
                            }
                        </div>
                    }
                    else if (Model.IsVerified)
                    {
                        <div class="text-center py-2">
                            <div class="text-success mb-2">
                                <span class="material-symbols-outlined fs-3">verified</span>
                                <p class="small mb-0 mt-1">Identity verified ✓</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="glass-card p-4 border-0">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-primary fs-5">history</span>
                        <h3 class="fs-6 fw-bold text-white mb-0">Recent Activity</h3>
                    </div>
                    <span class="text-primary small fw-semibold" id="recentPointsEarned">+0 pts</span>
                </div>

                <div id="recentActivityList" class="d-flex flex-column gap-2">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <p class="text-muted small mt-2">Loading activities...</p>
                    </div>
                </div>
            </div>

            
        </div>
    </div>
</div>

<!-- Hidden Forms -->
<form asp-action="Update" method="post" id="profileUpdateForm" enctype="multipart/form-data" class="d-none">
    @Html.AntiForgeryToken()
    <input type="file" name="BannerFile" id="bannerUpload" onchange="this.form.submit()" />
    <input type="file" name="AvatarFile" id="avatarUpload" onchange="this.form.submit()" />
    <input type="hidden" name="FullName" id="fullNameHidden" />
    <input type="hidden" name="Bio" id="bioHidden" />
</form>

@section Modals {
    <div class="modal fade" id="resetModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card border-0">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3">
                        <span class="material-symbols-outlined text-primary fs-1">lock_reset</span>
                    </div>
                    <h3 class="h6 text-white fw-bold mb-2">Reset Password</h3>
                    <p class="text-muted small mb-3">A reset link will be sent to your email.</p>
                    <div class="d-grid gap-2">
                        <button type="button" id="btnRequestReset" class="btn btn-primary py-2">Send Reset Link</button>
                        <button type="button" class="btn btn-link text-muted small" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script type="module" src="~/js/module.profile.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
        ProfileManager.init(@Model.IsOwnProfile.ToString().ToLower(), "@Model.Id", @Model.HasPendingVerification.ToString().ToLower(), @Model.ReputationPoints);
        });
    </script>
}

<style>
    .profile-container {
    max-width: 1200px;
    margin: 0 auto;
    }

    .profile-hero {
    background: rgba(30, 41, 59, 0.5);
    backdrop-filter: blur(12px);
    }

    .profile-banner {
    position: relative;
    overflow: hidden;
    }

    .bg-gradient-to-t {
    background: linear-gradient(to top, #0f172a, transparent);
    }

    .avatar-frame {
    background: #0f172a;
    }

    .profile-name-input:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding-left: 8px;
    }

    .edit-hint {
    opacity: 0;
    transition: opacity 0.2s;
    cursor: pointer;
    }

    .profile-name-input:hover + .edit-hint,
    .profile-name-input:focus + .edit-hint {
    opacity: 1;
    }

    .bg-primary-soft {
    background: rgba(59, 130, 246, 0.1);
    }

    .bg-success-soft {
    background: rgba(16, 185, 129, 0.1);
    }

    .bg-warning-soft {
    background: rgba(245, 158, 11, 0.1);
    }

    .upload-zone {
    transition: all 0.2s ease;
    cursor: pointer;
    }

    .upload-zone:hover {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.05);
    }

    .inset-0 {
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    }

    .bottom-2 {
    bottom: 0.5rem;
    }

    .end-3 {
    right: 1rem;
    }

    .progress-bar {
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>