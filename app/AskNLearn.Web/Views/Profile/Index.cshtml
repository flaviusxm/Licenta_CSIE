@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.FullName;
    ViewData["HideProfileCompletion"] = true;
}

<div class="h-100 overflow-y-auto custom-scrollbar pt-4">
    <div class="container pb-5 animate-entrance" style="max-width: 1100px;">
        
        <form asp-action="Update" method="post" id="linkedInForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SocialLinks" id="socialLinksHidden" value="@Model.SocialLinks" />
            <input type="hidden" name="Interests" id="interestsHidden" value="@Model.Interests" />
            <!-- NEW UNIFIED HERO STAGE -->
            <div class="profile-hero-stage mb-5">
                <div class="profile-banner-stage" style="background-image: url(&quot;@(Model.BannerUrl ?? "https://images.unsplash.com/photo-1557683316-973673baf926")&quot;);">
                    <div class="banner-overlay"></div>
                    @if (Model.IsOwnProfile) {
                        <input type="file" name="BannerFile" id="bannerUpload" class="d-none" onchange="ProfileManager.syncChanges()" />
                        <button type="button" class="btn btn-glass btn-sm position-absolute top-0 end-0 m-4 rounded-pill shadow-lg" onclick="document.getElementById('bannerUpload').click()">
                            <span class="material-symbols-outlined fs-6 me-1">landscape</span> Change Cover
                        </button>
                    }
                </div>
                
                <div class="profile-info-stage container px-5">
                    <div class="d-flex align-items-end gap-5">
                        <div class="profile-avatar-stage shadow-2xl">
                            <img src="@(Model.AvatarUrl ?? "https://api.dicebear.com/7.x/avataaars/svg?seed=" + Model.FullName)" id="avatarPreview" />
                            @if (Model.IsOwnProfile) {
                                <input type="file" name="AvatarFile" id="avatarUpload" class="d-none" onchange="ProfileManager.syncChanges()" />
                                <button type="button" class="avatar-edit-btn" onclick="document.getElementById('avatarUpload').click()">
                                    <span class="material-symbols-outlined">camera_enhance</span>
                                </button>
                            }
                        </div>
                        <div class="flex-grow-1 pb-3">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <h1 class="display-4 fw-black text-white m-0 tracking-tighter">@Model.FullName</h1>
                            </div>
                            <div class="d-flex flex-wrap align-items-center gap-x-4 gap-y-2 text-muted fw-bold text-uppercase tracking-widest fs-xs">
                                @if (Model.IsVerified) {
                                    <div class="d-flex align-items-center gap-2 text-accent" title="ID Verified">
                                        <span class="material-symbols-outlined fs-6">how_to_reg</span>
                                        <span>Verified</span>
                                    </div>
                                    <span class="opacity-20">|</span>
                                }
                                <div class="d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 opacity-50">work</span>
                                    <input type="text" name="Occupation" value="@Model.Occupation" class="inline-edit-input" placeholder="@(Model.IsOwnProfile ? "Add Occupation..." : "")" @(Model.IsOwnProfile ? "" : "readonly") />
                                </div>
                                <span class="opacity-20">|</span>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="material-symbols-outlined fs-6 opacity-50">school</span>
                                    <input type="text" name="Institution" value="@Model.Institution" class="inline-edit-input" placeholder="@(Model.IsOwnProfile ? "Add Institution..." : "")" @(Model.IsOwnProfile ? "" : "readonly") />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container px-5 mb-5">
                <div class="d-flex justify-content-center gap-5 py-4">
                    <div class="quick-stat-item">
                        <span class="val">@Model.PostsCount</span>
                        <span class="lbl">Posts Published</span>
                    </div>
                    <div class="quick-stat-item">
                        <span class="val">@Model.AnswersCount</span>
                        <span class="lbl">Solutions Provided</span>
                    </div>
                    <div class="quick-stat-item">
                        <span class="val">@Model.Level</span>
                        <span class="lbl">Community Level</span>
                    </div>
                    <div class="quick-stat-item">
                        <span class="val">@Model.ReputationPoints</span>
                        <span class="lbl">Reputation</span>
                    </div>
                </div>
            </div>

            <!-- MAIN CONTENT GRID -->
            <div class="row g-4">
                <div class="col-12 col-lg-8">
                    <div class="d-flex flex-column gap-4">
                        <!-- About Section -->
                        <div class="profile-sidebar-card">
                            <h3 class="profile-section-title">
                                <span class="material-symbols-outlined">person_search</span>
                                Professional Summary
                            </h3>
                            <textarea name="Bio" rows="5" class="form-control premium-textarea w-100" 
                                      placeholder="What defines you in the academic world?..." 
                                      @(Model.IsOwnProfile ? "" : "readonly")>@Model.Bio</textarea>
                        </div>

                        <!-- Roadmap Section -->
                        <div class="profile-sidebar-card">
                            <h3 class="profile-section-title">
                                <span class="material-symbols-outlined">timeline</span>
                                Academic Journey
                            </h3>
                            
                            <div class="d-flex flex-column gap-5 mt-4 position-relative">
                                <div class="position-absolute h-100" style="left: 17px; top: 0; width: 2px; background: rgba(255,255,255,0.05);"></div>

                                <!-- Step 1 -->
                                <div class="d-flex gap-4 position-relative z-1">
                                    <div class="step-circle @(Model.EmailConfirmed ? "done" : "current")">
                                        <span class="material-symbols-outlined fs-6">@(Model.EmailConfirmed ? "check" : "mail")</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="text-white fw-black mb-1 fs-6 text-uppercase tracking-wider">Identity Activation</h5>
                                        <p class="text-muted small m-0 italic">Secure your account by verifying your email address.</p>
                                    </div>
                                </div>
                                
                                <!-- Step 2 -->
                                <div class="d-flex gap-4 position-relative z-1">
                                    <div class="step-circle @(Model.IsVerified ? "done" : (Model.HasPendingVerification ? "current" : "todo"))">
                                        <span class="material-symbols-outlined fs-6">@(Model.IsVerified ? "verified_user" : "id_card")</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <h5 class="text-white fw-black m-0 fs-6 text-uppercase tracking-wider">Institution Validation</h5>
                                            @if(Model.IsVerified) {
                                                <span class="badge bg-success-soft text-success rounded-pill px-3 py-1 fw-black text-uppercase" style="font-size: 0.5rem;">Verified</span>
                                            }
                                        </div>
                                        
                                        @if (!Model.IsVerified && !Model.HasPendingVerification && Model.IsOwnProfile) {
                                            <div class="p-0 mt-3">
                                                <div class="row g-2">
                                                    <div class="col-6">
                                                        <label class="premium-file-label p-3 py-4">
                                                            <span class="material-symbols-outlined mb-1">badge</span>
                                                            ID CARD
                                                            <input type="file" name="studentId" />
                                                        </label>
                                                    </div>
                                                    <div class="col-6">
                                                        <label class="premium-file-label p-3 py-4">
                                                            <span class="material-symbols-outlined mb-1">menu_book</span>
                                                            BOOKLET
                                                            <input type="file" name="carnet" />
                                                        </label>
                                                    </div>
                                                </div>
                                                <button type="submit" formaction="/Profile/SubmitVerification" class="btn btn-premium w-100 mt-3 py-2 fw-black text-uppercase tracking-widest fs-xs">
                                                    Sync Validation
                                                </button>
                                            </div>
                                        } else if (Model.HasPendingVerification && !Model.IsVerified) {
                                             <div class="p-3 rounded-4 mt-2 bg-black bg-opacity-20 border border-glass d-flex align-items-center justify-content-between">
                                                <p class="text-aurora small m-0 fw-bold italic">Verification in progress...</p>
                                                <div class="spinner-grow text-aurora spinner-grow-sm" role="status"></div>
                                             </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SIDEBAR -->
                <div class="col-12 col-lg-4 ps-lg-5">
                    <div class="d-flex flex-column gap-5">
                        

                        <!-- Socials -->
                        <div class="profile-sidebar-card">
                            <h3 class="profile-section-title">
                                <span class="material-symbols-outlined">share</span>
                                Connections
                            </h3>
                            <div id="socialListArea" class="d-flex flex-column gap-2 mb-3"></div>
                            @if (Model.IsOwnProfile) {
                                <div class="d-flex gap-2">
                                    <input type="text" id="socialInputBox" class="form-control premium-input-sm flex-grow-1" placeholder="Add link..." />
                                    <button type="button" onclick="ProfileManager.addSocialLink()" class="btn btn-premium rounded-3 px-3">
                                        <span class="material-symbols-outlined fs-5">add</span>
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- Security -->
                        @if (Model.IsOwnProfile) {
                            <div class="profile-sidebar-card">
                                 <h3 class="profile-section-title">
                                     <span class="material-symbols-outlined">security</span>
                                     Security
                                 </h3>
                                 <div class="d-grid gap-2">
                                     <button type="button" onclick="ProfileManager.showResetModal()" class="btn btn-glass py-2 fw-bold text-uppercase fs-xs">
                                         Change Password
                                     </button>
                                     <button type="button" onclick="document.getElementById('logoutForm').submit()" class="btn btn-link text-muted text-hover-danger text-uppercase tracking-widest fw-black fs-xs text-decoration-none">
                                         Sign Out
                                     </button>
                                 </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- Background Sync HUD -->
    <div id="syncBadge" class="position-fixed bottom-0 start-50 translate-middle-x mb-5 z-5 pointer-events-none transition-all" style="transform: translateY(100%) translateX(-50%); opacity: 0;">
        <div class="glass-card px-4 py-3 d-flex align-items-center gap-3 border shadow-lg" style="border-radius: 2rem; border-color: rgba(0, 122, 255, 0.4);">
             <div class="spinner-border text-accent" style="width: 1rem; height: 1rem; border-width: 2px;"></div>
             <span id="syncStatus" class="text-white fw-black text-uppercase fs-xs tracking-widest">Changes saved</span>
        </div>
    </div>

    <form asp-controller="Auth" asp-action="SignOut" method="post" id="logoutForm" class="d-none"></form>

</div>

<style>
    .profile-hero-stage { position: relative; border-radius: 0 0 3rem 3rem; overflow: hidden; background: var(--bg-universe); }
    .profile-banner-stage { height: 320px; background-size: cover; background-position: center; position: relative; }
    .banner-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, transparent 70%, var(--bg-universe)); }
    .profile-info-stage { margin-top: -120px; position: relative; z-index: 10; }
    .profile-avatar-stage { width: 200px; height: 200px; border-radius: 2.5rem; overflow: hidden; border: 8px solid var(--bg-universe); background: var(--bg-universe); position: relative; }
    .profile-avatar-stage img { width: 100%; height: 100%; object-cover: cover; }
    .avatar-edit-btn { position: absolute; bottom: 15px; right: 15px; background: var(--color-accent); color: white; border: none; width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 20px rgba(0,0,0,0.3); }

    .inline-edit-input { background: transparent; border: none; color: inherit; width: auto; min-width: 100px; padding: 0; }
    .inline-edit-input:focus { outline: none; border-bottom: 1px solid var(--color-accent); }

    .reputation-badge { background: rgba(0, 122, 255, 0.1); border: 1px solid rgba(0, 122, 255, 0.2); padding: 1.5rem 2.5rem; border-radius: 2rem; text-align: center; }
    .reputation-badge .val { display: block; font-size: 2rem; font-weight: 900; color: var(--color-accent); line-height: 1; }
    .reputation-badge .lbl { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; color: var(--color-accent-soft); letter-spacing: 2px; }

    .quick-stat-item { display: flex; flex-direction: column; text-align: center; }
    .quick-stat-item .val { font-size: 1.5rem; font-weight: 900; color: white; line-height: 1; }
    .quick-stat-item .lbl { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px; margin-top: 5px; }

    .border-glass-soft { border-color: rgba(255,255,255,0.03) !important; }
    
    .premium-textarea { background: transparent; border: none; border-radius: 0; color: white; padding: 0 1.5rem; font-size: 1.1rem; line-height: 1.8; transition: all 0.3s ease; }
    .premium-textarea:focus { outline: none; }
</style>

@section Modals {
    <!-- Password Reset Modal -->
    <style>
        #resetModal { z-index: 99999 !important; }
        #resetModal .modal-content { z-index: 100000 !important; }
        .modal-backdrop { z-index: 99998 !important; opacity: 0.4 !important; backdrop-filter: blur(4px); }
    </style>
    <div class="modal" id="resetModal" tabindex="-1" aria-labelledby="resetModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-2xl" style="border-radius: 2rem; background: #0a0a0b; border: 1px solid rgba(255,255,255,0.1); overflow: hidden;">
                <div class="modal-body p-5 text-center">
                    <div class="avatar-lg bg-accent-soft text-accent rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" style="width: 80px; height: 80px;">
                        <span class="material-symbols-outlined fs-1">lock_reset</span>
                    </div>
                    <h3 class="text-white fw-black text-uppercase tracking-tight mb-3">Security Update</h3>
                    <p class="text-muted small mb-4">For your security, we will send a password reset link to your registered email address.</p>
                    <div id="resetFeedback" class="mb-4 d-none">
                        <div class="alert alert-success border-0 bg-success-soft text-success small py-2 px-3 rounded-4">
                            Check your email for the reset link!
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="button" id="btnRequestReset" class="btn btn-accent py-3 fw-bold text-uppercase tracking-widest shadow-lg" style="border-radius: 1rem;">
                            Send Reset Link
                        </button>
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold fs-xs text-uppercase tracking-widest" data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script type="module" src="~/js/module.profile.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const initialTags = "@Model.Interests".split(',').filter(x => x.trim() !== '');
        const initialLinks = "@Model.SocialLinks".split(';').filter(x => x.trim() !== '');
        ProfileManager.init(@Model.IsOwnProfile.ToString().ToLower(), initialTags, initialLinks);
    });
</script>
}
