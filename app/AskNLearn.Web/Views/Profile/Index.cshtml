@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Profile Settings";
}

<div class="max-w-5xl mx-auto p-6 md:p-12 flex flex-col gap-12 pb-24 max-w-[1200px] mx-auto overflow-hidden">
    
    <form asp-action="Update" method="post" id="profileForm" class="flex flex-col gap-12">
        <input type="hidden" name="FullName" value="@Model.FullName" />
        <input type="hidden" name="AvatarUrl" value="@Model.AvatarUrl" />
        <input type="hidden" name="SocialLinks" id="socialLinksHidden" value="@Model.SocialLinks" />

        <partial name="_ProfileHeader" model="Model" />

        <div class="px-6 md:px-12 flex flex-col gap-10">
            <!-- Bio Section -->
            <div class="flex flex-col gap-4 group">
                <div class="flex items-center gap-3 ml-2">
                    <span class="material-symbols-outlined text-primary text-sm font-bold">edit_note</span>
                    <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Biography</label>
                </div>
                <div class="relative">
                    <div class="absolute inset-0 bg-primary/5 rounded-3xl blur-xl opacity-0 group-focus-within:opacity-100 transition-opacity"></div>
                    <textarea name="Bio" rows="4" placeholder="Tell us about your academic background and interests..." 
                              class="w-full glass bg-white/50 dark:bg-white/5 px-8 py-6 rounded-3xl border border-border-light dark:border-border-dark/30 text-slate-700 dark:text-slate-200 font-medium leading-relaxed placeholder:text-slate-400/50 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all resize-none shadow-xl relative z-10">@Model.Bio</textarea>
                </div>
            </div>

            <!-- Occupation & Institution Row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="flex flex-col gap-4 group">
                    <div class="flex items-center gap-3 ml-2">
                        <span class="material-symbols-outlined text-primary text-sm font-bold">work</span>
                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Current Occupation</label>
                    </div>
                    <div class="relative">
                        <select name="Occupation" class="w-full glass bg-white/50 dark:bg-white/5 px-6 py-5 rounded-2xl border border-border-light dark:border-border-dark/30 text-slate-900 dark:text-white font-bold text-xs uppercase tracking-widest focus:ring-2 focus:ring-primary outline-none transition-all cursor-pointer shadow-lg relative z-10">
                            <option value="">Select Occupation</option>
                            <option value="Pupil" selected='@(Model.Occupation == "Pupil")'>Student (Pupil)</option>
                            <option value="Student" selected='@(Model.Occupation == "Student")'>University Student</option>
                            <option value="Teacher" selected='@(Model.Occupation == "Teacher")'>Teacher</option>
                            <option value="Researcher" selected='@(Model.Occupation == "Researcher")'>Researcher</option>
                        </select>
                    </div>
                </div>
                <div class="flex flex-col gap-4 group">
                    <div class="flex items-center gap-3 ml-2">
                        <span class="material-symbols-outlined text-primary text-sm font-bold">account_balance</span>
                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500">Institution</label>
                    </div>
                    <div class="relative">
                        <input type="text" name="Institution" value="@Model.Institution" placeholder="Enter institution name..." 
                               class="w-full glass bg-white/50 dark:bg-white/5 px-6 py-5 rounded-2xl border border-border-light dark:border-border-dark/30 text-slate-900 dark:text-white font-bold text-xs uppercase tracking-widest placeholder:text-slate-400/50 focus:ring-2 focus:ring-primary outline-none transition-all shadow-lg relative z-10" />
                    </div>
                </div>
            </div>

            <!-- Academic Interests & External Links Section -->
            <div class="flex flex-col gap-10">
                <!-- Saving Indicator (Hidden by default) -->
                <div id="saveIndicator" class="fixed bottom-12 right-12 z-[100] translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
                    <div class="glass bg-white/10 dark:bg-black/40 backdrop-blur-2xl px-6 py-4 rounded-[2rem] border border-white/20 shadow-2xl flex items-center gap-4">
                        <div class="size-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        <span id="saveText" class="text-[10px] font-black text-slate-900 dark:text-white uppercase tracking-widest">Saving changes...</span>
                    </div>
                </div>
                <!-- Interests -->
                <div class="flex flex-col gap-6">
                    <div class="flex items-center gap-4 ml-2">
                        <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary shadow-lg shadow-primary/5">
                            <span class="material-symbols-outlined text-xl font-bold">psychology</span>
                        </div>
                        <h3 class="text-[10px] font-bold text-slate-900 dark:text-white tracking-widest uppercase">Academic Interests</h3>
                    </div>
                    <div class="p-8 glass bg-white/30 dark:bg-white/5 rounded-[3rem] border border-border-light dark:border-border-dark/30 border-dashed flex flex-col gap-6 h-full min-h-[220px] shadow-2xl relative group">
                        <div class="absolute inset-0 bg-primary/2 rounded-[3rem] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div id="interestsContainer" class="flex flex-wrap gap-3 relative z-10">
                            @if (!string.IsNullOrEmpty(Model.Interests))
                            {
                                @foreach (var interest in Model.Interests.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <div class="group/tag flex items-center gap-2 px-5 py-2.5 glass bg-white dark:bg-white/10 border border-border-light dark:border-border-dark/30 rounded-xl shadow-lg hover:border-primary/50 transition-all">
                                        <span class="text-[10px] font-bold text-slate-700 dark:text-slate-200 uppercase tracking-widest">#@interest.Trim()</span>
                                        <button type="button" onclick="removeTag(this, '@interest.Trim()')" class="text-slate-400 hover:text-red-500 transition-colors">
                                            <span class="material-symbols-outlined text-lg font-bold">close</span>
                                        </button>
                                    </div>
                                }
                            }
                            <input type="text" id="interestInput" placeholder="+ Add Interest..." 
                                   class="flex-1 min-w-[140px] bg-transparent border-none focus:ring-0 text-[10px] font-bold uppercase tracking-widest placeholder:text-slate-400 group-hover:placeholder:text-primary transition-colors" />
                        </div>
                        <input type="hidden" name="Interests" id="interestsHidden" value="@Model.Interests" />
                    </div>
                </div>

                <!-- External Links Manager -->
                <div class="flex flex-col gap-6">
                    <div class="flex items-center gap-4 ml-2">
                        <div class="size-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 shadow-lg">
                            <span class="material-symbols-outlined text-xl font-bold">link</span>
                        </div>
                        <h3 class="text-[10px] font-bold text-slate-900 dark:text-white tracking-widest uppercase">Social Links</h3>
                    </div>
                    <div class="p-8 glass bg-white/30 dark:bg-white/5 rounded-[3rem] border border-border-light dark:border-border-dark/30 border-dashed flex flex-col gap-6 h-full min-h-[220px] shadow-2xl relative group">
                         <div class="absolute inset-0 bg-primary/2 rounded-[3rem] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div id="socialLinksContainer" class="flex flex-col gap-3 relative z-10">
                            <!-- Links injected by JS -->
                        </div>
                        <div class="flex gap-3 relative z-10">
                            <input type="text" id="socialInput" placeholder="Add Content Link (URL)..." 
                                   class="flex-1 glass bg-white/50 dark:bg-white/10 px-5 py-3 text-[10px] font-bold uppercase tracking-widest rounded-xl border border-border-light dark:border-border-dark/30 outline-none focus:ring-2 focus:ring-primary/50" />
                            <button type="button" onclick="addSocialLink()" class="size-11 rounded-xl glass flex items-center justify-center text-slate-600 hover:bg-primary hover:text-background-dark transition-all shadow-lg active:scale-95">
                                <span class="material-symbols-outlined font-black">add_link</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <!-- Stats Hub -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 px-6 md:px-12">
        <div class="glass p-8 rounded-[2.5rem] border border-border-light dark:border-border-dark/30 flex flex-col items-center gap-4 group hover:translate-y-[-4px] transition-all duration-300 shadow-2xl relative overflow-hidden">
             <div class="absolute -top-8 -right-8 size-24 bg-yellow-500/5 rounded-full blur-2xl group-hover:bg-yellow-500/10 transition-all"></div>
             <div class="size-12 rounded-xl bg-yellow-500/10 text-yellow-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-2xl font-black">star</span>
             </div>
            <div class="text-center">
                <span class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">@Model.ReputationPoints</span>
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-1">Reputation Score</p>
            </div>
        </div>
        <div class="glass p-8 rounded-[2.5rem] border border-border-light dark:border-border-dark/30 flex flex-col items-center gap-4 group hover:translate-y-[-4px] transition-all duration-300 shadow-2xl relative overflow-hidden">
             <div class="absolute -top-8 -right-8 size-24 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-all"></div>
             <div class="size-12 rounded-xl bg-blue-500/10 text-blue-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-2xl font-black">folder</span>
             </div>
            <div class="text-center">
                <span class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">@Model.PostsCount</span>
                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1">Total Posts</p>
            </div>
        </div>
        <div class="glass p-8 rounded-[2.5rem] border border-border-light dark:border-border-dark/30 flex flex-col items-center gap-4 group hover:translate-y-[-4px] transition-all duration-300 shadow-2xl relative overflow-hidden">
             <div class="absolute -top-8 -right-8 size-24 bg-emerald-500/5 rounded-full blur-2xl group-hover:bg-emerald-500/10 transition-all"></div>
             <div class="size-12 rounded-xl bg-emerald-500/10 text-emerald-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-2xl font-black">terminal</span>
             </div>
            <div class="text-center">
                <span class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">@Model.AnswersCount</span>
                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1">Total Answers</p>
            </div>
        </div>
        <div class="glass p-8 rounded-[2.5rem] border border-border-light dark:border-border-dark/30 flex flex-col items-center gap-4 group hover:translate-y-[-4px] transition-all duration-300 shadow-2xl relative overflow-hidden">
             <div class="absolute -top-8 -right-8 size-24 bg-pink-500/5 rounded-full blur-2xl group-hover:bg-pink-500/10 transition-all"></div>
             <div class="size-12 rounded-xl bg-pink-500/10 text-pink-500 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-2xl font-black">groups</span>
             </div>
            <div class="text-center">
                <span class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">@Model.GroupsCount</span>
                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1"> Groups</p>
            </div>
        </div>
    </div>

    <!-- Security & Danger Zone -->
    <div class="glass bg-surface-light/30 dark:bg-surface-dark/30 rounded-[3rem] border border-border-light dark:border-border-dark/30 overflow-hidden divide-y divide-border-light dark:divide-border-dark/30 mx-6 md:mx-12 shadow-2xl">
        <div class="p-10 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="space-y-1">
                 <h4 class="text-xl font-black text-slate-900 dark:text-white uppercase tracking-tighter">Change your password</h4>
                 <p class="text-sm text-slate-500 font-medium tracking-tight">Standard security procedures including password rotation and auth sync.</p>
            </div>
             <a href="/Identity/Account/Manage/ChangePassword" class="w-full md:w-auto px-8 py-4 rounded-2xl glass text-slate-900 dark:text-white font-black text-xs uppercase tracking-widest hover:bg-white/10 transition-all border border-border-light dark:border-border-dark/30 text-center">
                Update Password
            </a>
        </div>
        <div class="p-10 flex flex-col md:flex-row items-center justify-between gap-8 bg-red-500/[0.03] dark:bg-red-500/[0.02]">
            <div class="space-y-1">
                 <h4 class="text-xl font-black text-red-500 dark:text-red-400 uppercase tracking-tighter">Delete your account</h4>
                 <p class="text-sm text-red-400/60 font-medium tracking-tight">Permanently delete your account and all contribution history from the community.</p>
            </div>
             <button onclick="return confirm('Initiate Account Termination Protocol?')" class="w-full md:w-auto px-8 py-4 rounded-2xl border border-red-500/50 text-red-500 font-black text-xs uppercase tracking-widest hover:bg-red-500 hover:text-background-dark transition-all shadow-lg shadow-red-500/10">
                Delete Account
            </button>
        </div>
    </div>

    <div class="p-12 flex items-center justify-center">
        <form asp-controller="Auth" asp-action="SignOut" method="post">
            <button type="submit" class="text-slate-500 hover:text-red-500 font-bold uppercase tracking-widest text-[10px] transition-all flex items-center gap-3 group active:scale-95">
                <span class="material-symbols-outlined group-hover:rotate-180 transition-transform duration-700">power_settings_new</span> 
                Sign Out
            </button>
        </form>
    </div>

</div>

<script>
    // --- Interests Logic ---
    const interestsHidden = document.getElementById('interestsHidden');
    const interestsContainer = document.getElementById('interestsContainer');
    const interestInput = document.getElementById('interestInput');
    let interests = interestsHidden.value ? interestsHidden.value.split(',').filter(x => x.trim() !== '') : [];

    function updateInterests() { interestsHidden.value = interests.join(','); }

    function addInterest(value) {
        value = value.trim();
        if (!value || interests.includes(value)) return;
        if (interests.length >= 15) {
            alert('Maximum 15 interests allowed.');
            return;
        }
        interests.push(value);
        updateInterests();
        const tag = document.createElement('div');
        tag.className = 'group/tag flex items-center gap-2 px-5 py-2.5 glass bg-white dark:bg-white/10 border border-border-light dark:border-border-dark/30 rounded-xl shadow-lg hover:border-primary/50 transition-all animate-scale-in';
        tag.innerHTML = `<span class="text-[10px] font-bold text-slate-700 dark:text-slate-200 uppercase tracking-widest">#${value}</span>
                         <button type="button" onclick="removeTag(this, '${value}')" class="text-slate-400 hover:text-red-500 transition-colors"><span class="material-symbols-outlined text-lg font-bold">close</span></button>`;
        interestsContainer.insertBefore(tag, interestInput);
        interestInput.value = '';
    }

    function removeTag(button, value) {
        interests = interests.filter(i => i !== value);
        updateInterests();
        button.parentElement.remove();
    }

    interestInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); addInterest(interestInput.value); } });

    // --- Social Links Logic ---
    const socialLinksHidden = document.getElementById('socialLinksHidden');
    const socialLinksContainer = document.getElementById('socialLinksContainer');
    const socialDisplay = document.getElementById('socialDisplay');
    const socialInput = document.getElementById('socialInput');
    let links = socialLinksHidden.value ? socialLinksHidden.value.split(';').filter(x => x.trim() !== '') : [];

    function updateLinks() {
        socialLinksHidden.value = links.join(';');
        renderSocialUI();
    }

    function getIconForUrl(url) {
        if (url.includes('github.com')) return 'code';
        if (url.includes('linkedin.com')) return 'link_node';
        if (url.includes('discord')) return 'forum';
        return 'language';
    }

    function renderSocialUI() {
        socialLinksContainer.innerHTML = '';
        socialDisplay.innerHTML = '';
        links.forEach(url => {
            const item = document.createElement('div');
            item.className = 'flex items-center justify-between px-5 py-3 glass bg-white/50 dark:bg-white/10 rounded-xl border border-border-light dark:border-border-dark/30 text-[10px] font-bold uppercase tracking-widest shadow-lg animate-fade-in group';
            item.innerHTML = `<span class="truncate max-w-[180px] text-slate-500/80 group-hover:text-primary transition-colors">${url}</span>
                            <button type="button" onclick="removeLink('${url}')" class="text-red-400/50 px-2 hover:text-red-500 transition-all uppercase text-[9px]">Remove</button>`;
            socialLinksContainer.appendChild(item);

            const badge = document.createElement('a');
            badge.href = url.startsWith('http') ? url : 'https://' + url;
            badge.target = '_blank';
            badge.className = 'size-9 rounded-xl glass bg-white/50 dark:bg-white/10 text-slate-500 hover:text-primary hover:border-primary/50 transition-all flex items-center justify-center shadow-lg hover:translate-y-[-2px]';
            badge.innerHTML = `<span class="material-symbols-outlined text-sm font-bold">${getIconForUrl(url)}</span>`;
            socialDisplay.appendChild(badge);
        });
    }

    function addSocialLink() {
        const url = socialInput.value.trim();
        if (!url) return;
        
        // Simple URL regex
        const urlPattern = /^(https?:\/\/)?([\da-z.-]+)\.([a-z.]{2,6})([\/\w .-]*)*\/?$/;
        if (!urlPattern.test(url)) {
            alert('Please enter a valid URL.');
            return;
        }

        if (!links.includes(url)) { links.push(url); updateLinks(); socialInput.value = ''; }
    }

    function removeLink(url) { links = links.filter(l => l !== url); updateLinks(); }

    renderSocialUI();

    // --- Auto-save Logic ---
    let autoSaveTimeout;
    const form = document.getElementById('profileForm');
    const indicator = document.getElementById('saveIndicator');
    const saveText = document.getElementById('saveText');

    function showIndicator(message, isSuccess = false) {
        saveText.innerText = message;
        indicator.classList.remove('translate-y-20', 'opacity-0');
        if (isSuccess) {
            setTimeout(() => {
                indicator.classList.add('translate-y-20', 'opacity-0');
            }, 2000);
        }
    }

    async function performSave() {
        showIndicator('Saving changes...');
        const formData = new FormData(form);
        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                showIndicator('Changes saved', true);
            } else {
                showIndicator('Error saving', true);
            }
        } catch (err) {
            showIndicator('Network error', true);
        }
    }

    form.addEventListener('input', () => {
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(performSave, 1500);
    });

    // Special handlers for dynamic lists
    const originalUpdateInterests = updateInterests;
    updateInterests = function() {
        originalUpdateInterests();
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(performSave, 500);
    };

    const originalUpdateLinks = updateLinks;
    updateLinks = function() {
        originalUpdateLinks();
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(performSave, 500);
    };
</script>
