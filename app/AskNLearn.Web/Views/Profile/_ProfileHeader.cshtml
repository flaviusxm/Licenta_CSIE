@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

<!-- Custom Banner (Discord Style) -->
<div class="relative w-full h-48 md:h-64 overflow-hidden rounded-[3rem] shadow-2xl group border border-border-light dark:border-border-dark/30">
    <div id="profileBanner" class="w-full h-full bg-slate-200 dark:bg-slate-800 bg-cover bg-center transition-transform duration-1000 group-hover:scale-110" 
         style="background-image: url('@(Model.BannerUrl ?? "https://images.unsplash.com/photo-1557683316-973673baf926?q=80&w=2029&auto=format&fit=crop")');">
        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 via-transparent to-transparent"></div>
    </div>
    <div class="absolute bottom-6 right-6 opacity-0 group-hover:opacity-100 transition-all translate-y-2 group-hover:translate-y-0 duration-300">
        <div class="glass p-1.5 rounded-2xl border border-white/20 shadow-2xl flex items-center gap-2">
            <span class="material-symbols-outlined text-white/50 text-sm ml-2">link</span>
            <input type="text" name="BannerUrl" value="@Model.BannerUrl" placeholder="Banner URL..." 
                   class="bg-transparent border-none text-white text-[10px] font-bold placeholder:text-white/40 focus:ring-0 w-48 transition-all" />
        </div>
    </div>
</div>

<!-- Identity & Metrics Layout -->
<div class="flex flex-col md:flex-row items-end md:items-start gap-8 md:gap-12 relative px-6 md:px-12">
    <!-- Overlapping Avatar with Glow -->
    <div class="group relative shrink-0 mt-[-64px] md:mt-[-80px]">
        <div class="absolute inset-0 bg-primary/20 rounded-full blur-2xl group-hover:bg-primary/40 transition-all duration-500"></div>
        <div class="size-40 md:size-52 rounded-full bg-cover bg-center border-[8px] border-background-light dark:border-background-dark shadow-2xl transition-transform group-hover:scale-[1.05] relative z-10" 
             style="background-image: url('@(Model.AvatarUrl ?? "https://api.dicebear.com/7.x/avataaars/svg?seed=" + Model.FullName)');">
            <div class="absolute inset-0 rounded-full border border-white/10 group-hover:border-primary/50 transition-colors"></div>
        </div>
        <div class="absolute bottom-4 right-4 size-10 rounded-full bg-emerald-500 border-4 border-background-light dark:border-background-dark shadow-xl z-20 animate-pulse"></div>
    </div>
    <!-- Identity & Actions -->
    <div class="text-left flex flex-col gap-6 flex-1 w-full pt-6 md:pt-8 bg-surface-light/30 dark:bg-surface-dark/30 backdrop-blur-xl p-8 rounded-[2.5rem] mt-[-10px] border border-border-light dark:border-border-dark shadow-xl">
        <div class="flex flex-col xl:flex-row justify-between items-start gap-6">
            <div class="space-y-1">
                <div class="flex items-center gap-3">
                    <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white tracking-tighter">@Model.FullName</h1>
        
                </div>
                <p class="text-slate-500 dark:text-slate-400 font-bold text-[11px] uppercase tracking-[0.2em] flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">alternate_email</span>
                    @(Model.FullName.ToLower().Replace(" ", "-"))#@((Math.Abs(Model.FullName.GetHashCode()) % 10000).ToString("D4"))
                </p>
            </div>
            <div class="flex items-center gap-4">
                @if (ViewData["IsVerificationPage"] as bool? != true)
                {
                   
                }
                else
                {
                    <a asp-action="Index" class="px-8 py-4 rounded-2xl glass text-slate-900 dark:text-white font-bold text-xs uppercase tracking-widest hover:bg-white/10 transition-all border border-border-light dark:border-border-dark/30 flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">arrow_back_ios</span>
                        View Profile
                    </a>
                }
            </div>
        </div>

        <!-- Role & Verification Badges -->
        <div class="flex flex-wrap items-center justify-start gap-4">
            @if (Model.Role == "Admin")
            {
                <div class="px-4 py-2 rounded-xl bg-red-500/10 text-red-500 text-[10px] font-bold uppercase tracking-widest border border-red-500/20 flex items-center gap-2 shadow-lg shadow-red-500/5">
                    <span class="material-symbols-outlined text-sm font-bold">shield_person</span> System Admin
                </div>
            }
            else if (Model.Role == "Moderator")
            { 
                <div class="px-4 py-2 rounded-xl bg-purple-500/10 text-purple-500 text-[10px] font-bold uppercase tracking-widest border border-purple-500/20 flex items-center gap-2 shadow-lg shadow-purple-500/5">
                    <span class="material-symbols-outlined text-sm font-bold">verified_user</span> Moderator
                </div>
            }
            else if (Model.IsVerified)
            {
                <div class="px-4 py-2 rounded-xl bg-emerald-500/10 text-emerald-500 text-[10px] font-bold uppercase tracking-widest border border-emerald-500/20 flex items-center gap-2 shadow-lg shadow-emerald-500/5">
                    <span class="material-symbols-outlined text-sm font-bold">check_decagram</span> Verified Student
                </div>
            }
            else
            {
                 <a asp-action="Verification" class="px-4 py-2 rounded-xl glass text-slate-400 text-[10px] font-bold uppercase tracking-widest border border-border-light dark:border-border-dark flex items-center gap-2 hover:text-primary hover:border-primary/50 transition-all group">
                    
                    Verify Identity
                </a>
            }

            <div class="px-4 py-2 rounded-xl bg-white/5 dark:bg-white/5 text-slate-400 text-[10px] font-bold uppercase tracking-widest border border-border-light dark:border-border-dark/30 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">schedule</span>
                Joined: @Model.CreatedAt.ToString("MMM yyyy")
            </div>

            <div id="socialDisplay" class="flex items-center gap-2 ml-auto">
                <!-- Links injected by JS -->
            </div>
        </div>
    </div>
</div>
