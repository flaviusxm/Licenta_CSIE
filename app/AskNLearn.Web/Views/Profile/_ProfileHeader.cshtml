@model AskNLearn.Application.Features.Users.Queries.GetUserProfile.UserProfileDto

<!-- Custom Banner (Discord Style) -->
<div class="position-relative w-100 overflow-hidden shadow-lg group border-glass-strong" style="border-radius: 2.5rem; height: 16rem;">
    <div id="profileBanner" class="w-100 h-100 bg-cover bg-center transition-transform hover-scale" 
         style="background-image: url('@(Model.BannerUrl ?? "https://images.unsplash.com/photo-1557683316-973673baf926?q=80&w=2029&auto=format&fit=crop")'); transition-duration: 1s;">
        <div class="position-absolute inset-0" style="background: linear-gradient(to top, var(--bg-universe), transparent);"></div>
    </div>
    <div class="position-absolute bottom-0 end-0 p-4 z-3">
        <div class="glass-card px-3 py-2 d-flex align-items-center gap-2 hover-bg-glass transition-colors border-glass shadow-sm" style="border-radius: 1rem;">
            <span class="material-symbols-outlined text-muted fs-6">link</span>
            <input type="text" name="BannerUrl" value="@Model.BannerUrl" placeholder="Banner URL..." 
                   class="bg-transparent border-0 text-white text-uppercase tracking-widest fw-bold p-0 shadow-none" style="font-size: 0.65rem; width: 150px; outline: none; box-shadow: none !important;" />
        </div>
    </div>
</div>

<!-- Identity & Metrics Layout -->
<div class="d-flex flex-column flex-md-row align-items-md-start gap-4 gap-md-5 position-relative px-4 px-md-5 z-3" style="margin-top: -5rem;">
    <!-- Overlapping Avatar with Glow -->
    <div class="group position-relative flex-shrink-0 mx-auto mx-md-0">
        <div class="position-absolute end-0 start-0 top-0 bottom-0 rounded-circle" style="background: rgba(52, 211, 153, 0.2); filter: blur(30px);"></div>
        <div class="rounded-circle shadow-lg position-relative z-1" 
             style="width: 13rem; height: 13rem; border: 6px solid var(--bg-universe); background: url('@(Model.AvatarUrl ?? "https://api.dicebear.com/7.x/avataaars/svg?seed=" + Model.FullName)') center/cover;">
        </div>
    </div>
    
    <!-- Identity & Actions -->
    <div class="flex-grow-1 w-100 glass-card p-4 p-md-5 shadow-lg border-glass-strong" style="border-radius: 2.5rem; margin-top: 2rem;">
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-start gap-4">
            <div class="text-center text-md-start w-100">
                <h1 class="display-6 fw-bold text-white tracking-tight mb-2">@Model.FullName</h1>
                <p class="text-muted fw-bold text-uppercase tracking-widest d-inline-flex align-items-center gap-2 mb-4 mx-auto mx-md-0 px-2 py-1 rounded" style="font-size: 0.7rem; background: rgba(0,0,0,0.2);">
                    <span class="material-symbols-outlined small">alternate_email</span>
                    @(Model.FullName.ToLower().Replace(" ", "-"))#@((Math.Abs(Model.FullName.GetHashCode()) % 10000).ToString("D4"))
                </p>
                
                <!-- Role & Verification Badges -->
                <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-start gap-3 w-100">
                    @if (Model.Role == "Admin")
                    {
                        <div class="badge rounded-pill d-flex align-items-center gap-2 fw-bold tracking-widest text-uppercase px-3 py-2 shadow-sm" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                            <span class="material-symbols-outlined fs-6">shield_person</span> System Admin
                        </div>
                    }
                    else if (Model.Role == "Moderator")
                    { 
                        <div class="badge rounded-pill d-flex align-items-center gap-2 fw-bold tracking-widest text-uppercase px-3 py-2 shadow-sm" style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2);">
                            <span class="material-symbols-outlined fs-6">verified_user</span> Moderator
                        </div>
                    }
                    else if (Model.IsVerified)
                    {
                        <div class="badge rounded-pill d-flex align-items-center gap-2 fw-bold tracking-widest text-uppercase px-3 py-2 shadow-sm" style="background: rgba(52, 211, 153, 0.1); color: var(--color-mint-bright); border: 1px solid rgba(52, 211, 153, 0.2);">
                            <span class="material-symbols-outlined fs-6">check_decagram</span> Verified Student
                        </div>
                    }
                    else
                    {
                         <a asp-action="Verification" class="btn btn-glass rounded-pill d-flex align-items-center gap-2 fw-bold tracking-widest text-uppercase px-3 py-2 text-decoration-none shadow-sm" style="font-size: 0.75rem;">
                            Verify Identity
                        </a>
                    }

                    <div class="badge rounded-pill d-flex align-items-center gap-2 fw-bold tracking-widest text-uppercase px-3 py-2 shadow-sm text-muted" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass);">
                        <span class="material-symbols-outlined fs-6">schedule</span>
                        Joined: @Model.CreatedAt.ToString("MMM yyyy")
                    </div>
                </div>
            </div>
            
            <div class="d-flex flex-column align-items-center align-items-xl-end gap-3 w-100 w-xl-auto mt-3 mt-xl-0 flex-shrink-0">
                @if (ViewData["IsVerificationPage"] as bool? == true)
                {
                    <a asp-action="Index" class="btn btn-glass d-flex align-items-center gap-2 px-4 py-2 text-white text-uppercase tracking-widest fw-bold shadow-sm" style="font-size: 0.75rem; border-radius: 1rem;">
                        <span class="material-symbols-outlined small">arrow_back_ios</span>
                        View Profile
                    </a>
                }
                
                <!-- Social Links Display -->
                <div class="d-flex align-items-center justify-content-center justify-content-xl-end gap-2 flex-wrap" id="socialDisplay">
                    <!-- Links injected by JS -->
                </div>
            </div>
        </div>
    </div>
</div>
