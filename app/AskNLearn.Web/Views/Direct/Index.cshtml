@using AskNLearn.Domain.Entities.Messaging
@using AskNLearn.Web.Models
@model DirectConversation
@inject Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser> UserManager

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Direct Messages";
    ViewData["HideProfileCompletion"] = true;
    ViewData["AppLayout"] = true;
    var conversations = ViewBag.Conversations as List<ConversationPreviewViewModel> ?? new List<ConversationPreviewViewModel>();
    var currentUserId = (await UserManager.GetUserAsync(User))?.Id;
}

@section Sidebar {
    <div class="d-flex flex-column h-100 w-100 bg-transparent animate-entrance">
        <div class="px-4 py-3 border-bottom d-flex align-items-center justify-content-center" style="border-color: var(--border-glass) !important; min-height: 80px;">
            <div class="position-relative w-100">
                <span class="material-symbols-outlined position-absolute start-0 top-50 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                <input type="text" placeholder="Search direct messages..." class="form-control form-control-glass ps-5 py-2" style="font-size: 0.85rem; border-radius: 1rem;" />
            </div>
        </div>

        <div class="flex-grow-1 overflow-y-auto custom-scrollbar">
            @if (conversations.Any())
            {
                foreach (var conv in conversations)
                {
                    bool isActive = Model?.Id == conv.ConversationId;
                    <a asp-action="Index" asp-route-id="@conv.ConversationId" class="d-flex align-items-center gap-3 p-3 transition-all text-decoration-none border-bottom position-relative @(isActive ? "active-chat" : "chat-item-hover")" style="border-color: rgba(255,255,255,0.03) !important;">
                        @if (isActive)
                        {
                            <div class="position-absolute start-0 top-0 bottom-0 bg-aurora" style="width: 3px;"></div>
                        }
                        <div class="flex-shrink-0 position-relative">
                            <div class="avatar-md rounded-xl overflow-hidden border @(isActive ? "border-aurora" : "border-glass") shadow-sm">
                                <img src="@(string.IsNullOrEmpty(conv.OtherUserAvatar) ? $"https://api.dicebear.com/7.x/avataaars/svg?seed={conv.OtherUserName}" : conv.OtherUserAvatar)" class="w-100 h-100 object-cover" alt="@conv.OtherUserName" />
                            </div>
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <span class="fw-bold text-white text-truncate" style="font-size: 0.9rem;">@conv.OtherUserName</span>
                                <span class="text-muted" style="font-size: 0.65rem;">@conv.LastMessageAt.ToString("HH:mm")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <p class="text-muted text-truncate mb-0 @(conv.UnreadCount > 0 ? "fw-bold text-light italic" : "")" 
                                   id="last-msg-@conv.ConversationId"
                                   style="font-size: 0.75rem;">
                                    @conv.LastMessageContent
                                </p>
                                @if (conv.UnreadCount > 0)
                                {
                                    <span id="unread-badge-@conv.ConversationId" class="badge bg-aurora-glass text-aurora rounded-pill px-2 py-1 fw-bold flex-shrink-0" style="font-size: 0.65rem;">
                                        + @conv.UnreadCount new messages
                                    </span>
                                }
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="p-5 text-center opacity-50">
                    <span class="material-symbols-outlined display-4 mb-3 text-muted">chat_bubble</span>
                    <p class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.65rem;">No conversations</p>
                </div>
            }
        </div>

    </div>
}

<div class="d-flex flex-column h-100 flex-grow-1 bg-transparent w-100">
    <!-- Chat Area -->
    <main class="flex-grow-1 d-flex flex-column h-100 bg-transparent">
        @if (Model != null)
        {
            var otherParticipant = Model.Participants.FirstOrDefault(p => p.UserId != currentUserId);

            <!-- Chat Header (Fixed Transparency) -->
            <header class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom position-relative z-index-3" style="min-height: 80px; border-color: var(--border-glass) !important; background: rgba(15, 23, 42, 0.05); backdrop-filter: blur(10px);">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-md rounded-xl overflow-hidden border border-aurora shadow-lg">
                        <img src="@(otherParticipant?.User?.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={otherParticipant?.User?.UserName}")" class="w-100 h-100 object-cover" alt="User Avatar" />
                    </div>
                    <div>
                        <h4 class="h5 fw-bold text-white mb-0 tracking-tight">@(otherParticipant?.User?.FullName ?? otherParticipant?.User?.UserName)</h4>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span class="rounded-circle bg-success" style="width: 6px; height: 6px;"></span>
                            <span class="text-muted small fw-bold" style="font-size: 0.7rem;">Online</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button onclick="startCall(false)" class="btn btn-glass px-3 py-2 d-flex align-items-center justify-content-center" title="Voice Call">
                        <span class="material-symbols-outlined">call</span>
                    </button>
                    <button onclick="startCall(true)" class="btn btn-glass px-3 py-2 d-flex align-items-center justify-content-center" title="Video Call">
                        <span class="material-symbols-outlined">videocam</span>
                    </button>
                    <div id="call-controls" class="d-none d-flex align-items-center gap-2 ms-2">
                        <button onclick="endCall()" class="btn btn-danger btn-glass px-3 py-2 d-flex align-items-center justify-content-center" title="End Call">
                            <span class="material-symbols-outlined">call_end</span>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Video Grid -->
            <div id="videoGrid" class="d-none d-flex flex-wrap gap-3 p-3 border-bottom custom-scrollbar" style="background: rgba(0,0,0,0.2); border-color: var(--border-glass) !important; max-height: 200px; overflow-x: auto;">
                <div id="localVideoContainer" class="d-none position-relative bg-black rounded-xl overflow-hidden border border-aurora shadow-lg flex-shrink-0" style="width: 200px; height: 150px;">
                    <video id="localVideo" autoplay muted playsinline class="w-100 h-100 object-cover"></video>
                    <div class="position-absolute bottom-0 start-0 m-2 px-2 py-0.5 glass-card rounded-lg" style="background: rgba(0,0,0,0.5);">
                        <span class="fw-bold text-white" style="font-size: 0.65rem;">You</span>
                    </div>
                </div>
            </div>

            <!-- Messages List -->
            <div id="messages-container" class="flex-grow-1 overflow-y-auto p-4 p-md-5 d-flex flex-column gap-4 custom-scrollbar">
                @foreach (var message in Model.Messages.OrderBy(m => m.CreatedAt))
                {
                    bool isMine = message.AuthorId == currentUserId;
                    var authorName = message.Author?.FullName ?? message.Author?.UserName ?? "User";
                    var authorAvatar = message.Author?.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={message.Author?.UserName}";
                    
                    <div class="d-flex w-100 @(isMine ? "justify-content-end" : "justify-content-start") animate-slide-up group">
                        <div class="d-flex @(isMine ? "flex-row-reverse" : "") gap-3 align-items-end" style="max-width: 85%;">
                            @if (!isMine) {
                                <img src="@authorAvatar" class="avatar-sm rounded-lg shadow-sm border" style="border-color: var(--border-glass) !important;"/>
                            }
                            <div class="d-flex flex-column gap-1 @(isMine ? "align-items-end" : "align-items-start")">
                                <div class="d-flex align-items-center gap-2 px-1">
                                    <span class="fw-bold text-muted" style="font-size: 0.65rem;">@authorName</span>
                                    <span class="fw-bold text-muted" style="font-size: 0.6rem;">@message.CreatedAt.ToString("HH:mm")</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="p-3 shadow-lg" style="border-radius: 1.5rem; @(isMine ? "background: var(--gradient-aurora); color: var(--bg-universe); border-top-right-radius: 0.25rem;" : "background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white; border-top-left-radius: 0.25rem; backdrop-filter: blur(10px);")">
                                        @if (message.Content.StartsWith("http") && (message.Content.Contains("giphy.com") || message.Content.Contains("tenor.com"))) {
                                            <img src="@message.Content" class="img-fluid rounded-3" style="max-width: 250px;" />
                                        } else {
                                            <p class="mb-0 fw-medium" style="font-size: 0.9rem; line-height: 1.5;">@message.Content</p>
                                        }
                                    </div>
                                    @if (!isMine) {
                                        <button onclick="openReportModal('@message.Id', 'MESSAGE')" 
                                                class="btn btn-link p-1 text-muted hover-text-danger text-decoration-none transition-all opacity-0 group-hover-opacity-100" 
                                                title="Report message"
                                                style="font-size: 0.6rem;">
                                            <span class="material-symbols-outlined fs-6">report</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Chat Input (Standardized with Study Groups - Centered & Glassy) -->
            <footer class="p-4 bg-transparent border-0">
                <div class="mx-auto w-100 position-relative" style="max-width: 800px;">
                    <!-- Picker Popup -->
                    <div id="picker-popup" class="d-none position-absolute bottom-100 start-0 mb-3 glass-card flex-column overflow-hidden animate-entrance" style="width: 320px; height: 380px; z-index: 1050;">
                        <div id="emoji-picker-container" class="flex-grow-1 overflow-hidden"></div>
                        <div id="gif-picker-container" class="d-none flex-grow-1 flex-column p-3 overflow-hidden" style="display: flex;">
                             <div class="position-relative mb-3">
                                <input type="text" id="gif-search" placeholder="Search Giphy..." class="form-control form-control-glass ps-5 text-white" style="font-size: 0.8rem; border-radius: 0.75rem;">
                                <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                             </div>
                             <div id="gif-results" class="flex-grow-1 overflow-y-auto d-grid custom-scrollbar gap-2" style="grid-template-columns: 1fr 1fr;"></div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div id="input-container" class="glass-card d-flex align-items-center flex-grow-1 gap-3 p-2 px-4 shadow-lg transition-all" style="border-radius: 2rem; border-color: var(--border-glass) !important; background: rgba(255,255,255,0.03) !important; backdrop-filter: blur(10px);">
                            <input type="file" id="dm-attachment-input" class="d-none" multiple onchange="handleDMAttachment(this)" />
                            <button onclick="document.getElementById('dm-attachment-input').click()" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center shadow-none">
                                <span class="material-symbols-outlined fs-4">add_circle</span>
                            </button>
                            <input type="text" id="message-input" placeholder="Write a message..." class="form-control border-0 bg-transparent text-white shadow-none ps-0 min-w-0" style="font-size: 0.95rem;" />
                            <button id="emoji-btn" class="btn btn-link p-1 text-muted hover-glow text-decoration-none d-flex flex-center shadow-none">
                                <span class="material-symbols-outlined fs-4">mood</span>
                            </button>
                        </div>
                        <button id="send-btn" onclick="sendMessage()" class="btn btn-premium d-flex align-items-center justify-content-center rounded-pill px-4" style="height: 52px; min-width: 100px; font-size: 0.85rem; font-weight: 700;">Send</button>
                    </div>
                </div>
            </footer>
        }
        else
        {
            <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center p-5">
                <div class="position-relative mb-4">
                    <div class="position-absolute translate-middle top-50 start-50 rounded-circle opacity-25" style="width: 200px; height: 200px; background: var(--color-mint-bright); filter: blur(60px);"></div>
                    <div class="rounded-fluid glass-card p-5 d-flex align-items-center justify-content-center position-relative z-1" style="width: 140px; height: 140px;">
                        <span class="material-symbols-outlined text-aurora display-1">forum</span>
                    </div>
                </div>
                <h3 class="display-6 fw-bold text-white mb-3">Direct <span class="text-aurora">Messages</span></h3>
                <p class="text-muted fs-5 mb-5" style="max-width: 400px;">Select a conversation from the sidebar to start chatting.</p>
            </div>
        }
    </main>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/emoji-mart@latest/dist/browser.js"></script>
    <script>
        const msgList = document.getElementById('messages-container');
        if (msgList) msgList.scrollTop = msgList.scrollHeight;

        let localStream = null;
        let currentConversationId = "@Model?.Id";
        let currentUserId = "@currentUserId";
        const peers = {};
        const iceServers = { iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] };
        let isVideoOn = false;
        let isMuted = false;

        function setupSignalRHandlers() {
            if (!currentConversationId || !window.connection) return;

            // Remove old handlers to prevent memory leaks and duplicates
            window.connection.off("ReceiveMessage");
            window.connection.off("ReceiveSignal");
            window.connection.off("UserJoinedVoice");
            window.connection.off("UserLeftVoice");

            window.connection.on("ReceiveMessage", (message) => {
                const incomingConvId = (message.conversationId || message.channelId || "").toString().toLowerCase();
                const activeConvId = (currentConversationId || "").toLowerCase();
                
                // 1. Update Sidebar always
                updateSidebarPreview(message);

                // 2. Update Chat Area if it's the active conversation
                if (activeConvId && incomingConvId === activeConvId) {
                    appendMessage(message);
                }
            });

            window.connection.on("ReceiveSignal", async (signal, fromConnectionId) => {
                const data = JSON.parse(signal);
                let peer = peers[fromConnectionId];
                if (data.sdp) {
                    if (!peer) peer = await createPeerConnection(fromConnectionId, false);
                    await peer.pc.setRemoteDescription(new RTCSessionDescription(data.sdp));
                    if (data.sdp.type === "offer") {
                        const answer = await peer.pc.createAnswer();
                        await peer.pc.setLocalDescription(answer);
                        window.connection.invoke("SendSignal", JSON.stringify({ sdp: answer }), fromConnectionId);
                    }
                } else if (data.candidate) {
                    if (peer) await peer.pc.addIceCandidate(new RTCIceCandidate(data.candidate));
                }
            });

            window.connection.on("UserJoinedVoice", async (data) => {
                if (data.channelId === currentConversationId) {
                    await createPeerConnection(data.connectionId, true);
                }
            });

            window.connection.on("UserLeftVoice", (connectionId) => {
                if (peers[connectionId]) {
                    peers[connectionId].pc.close();
                    delete peers[connectionId];
                    const audio = document.getElementById(`peer-audio-${connectionId}`);
                    if (audio) audio.remove();
                    const video = document.getElementById(`peer-video-container-${connectionId}`);
                    if (video) video.remove();
                    updateVideoGrid();
                }
            });

            // Join all conversation groups and active channel
            if(window.connection.state === signalR.HubConnectionState.Connected) {
                @foreach (var conv in conversations) {
                    <text>window.connection.invoke("JoinChannel", "@conv.ConversationId");</text>
                }
            } else {
                window.connection.onreconnected(() => {
                    @foreach (var conv in conversations) {
                        <text>window.connection.invoke("JoinChannel", "@conv.ConversationId");</text>
                    }
                });
            }
        }

        function updateSidebarPreview(msg) {
            const convId = (msg.conversationId || msg.channelId || "").toString().toLowerCase();
            const lastMsgEl = document.getElementById(`last-msg-${convId}`);
            const badgeEl = document.getElementById(`unread-badge-${convId}`);
            
            if (lastMsgEl) {
                lastMsgEl.innerText = msg.content.startsWith('http') ? 'Sent a GIF' : msg.content;
                lastMsgEl.classList.add('fw-bold', 'text-light', 'italic');
            }

            // If not active, increment unread count
            const activeConvId = (currentConversationId || "").toLowerCase();
            if (convId !== activeConvId && msg.authorId !== currentUserId) {
                if (badgeEl) {
                    let count = parseInt(badgeEl.innerText.split(' ')[1]) || 0;
                    badgeEl.innerText = `+ ${count + 1} new messages`;
                    badgeEl.classList.remove('d-none');
                } else {
                    // Create badge if it didn't exist
                    if (lastMsgEl) {
                        const badgeHtml = `<span id="unread-badge-${convId}" class="badge bg-aurora-glass text-aurora rounded-pill px-2 py-1 fw-bold flex-shrink-0" style="font-size: 0.65rem;">
                                            + 1 new messages
                                         </span>`;
                        lastMsgEl.parentElement.insertAdjacentHTML('beforeend', badgeHtml);
                    }
                }
            }
        }

            // Deduplication: prevent adding the same message twice (e.g. optimistic UI + broadcast)
            if (document.getElementById(`msg-${msg.id}`)) return;

            const msgHtml = `
                <div class="d-flex w-100 ${isMine ? 'justify-content-end' : 'justify-content-start'} animate-slide-up" id="msg-${msg.id}">
                    <div class="d-flex ${isMine ? 'flex-row-reverse' : ''} gap-3 align-items-end" style="max-width: 85%;">
                        ${!isMine ? `<img src="${msg.authorAvatar}" class="avatar-sm rounded-lg shadow-sm border" style="border-color: var(--border-glass) !important;"/>` : ''}
                        <div class="d-flex flex-column gap-1 ${isMine ? 'align-items-end' : 'align-items-start'}">
                            <div class="d-flex align-items-center gap-2 px-1">
                                <span class="fw-black text-muted text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">${msg.authorName}</span>
                                <span class="fw-bold text-muted" style="font-size: 0.55rem;">${msg.createdAt}</span>
                            </div>
                            <div class="p-3 shadow-lg" style="border-radius: 1.5rem; ${isMine ? 'background: var(--gradient-aurora); color: var(--bg-universe); border-top-right-radius: 0.25rem;' : 'background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: white; border-top-left-radius: 0.25rem; backdrop-filter: blur(10px);'}">
                                ${msg.content.startsWith('http') && (msg.content.includes('giphy.com') || msg.content.includes('tenor.com')) ? `<img src="${msg.content}" class="img-fluid rounded-3" style="max-width: 250px;" />` : `<p class="mb-0 fw-medium" style="font-size: 0.9rem; line-height: 1.5;">${msg.content}</p>`}
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', msgHtml);
            container.scrollTop = container.scrollHeight;
        }

        window.sendMessage = async function() {
            const input = document.getElementById('message-input');
            const content = input.value.trim();
            if (!content || !window.connection) return;
            
            // Optimistic UI for immediate feedback
            const tempId = 'temp-' + Date.now();
            appendMessage({
                id: tempId,
                content: content,
                authorId: currentUserId,
                authorName: "You",
                authorAvatar: document.querySelector('.avatar-md img')?.src || '',
                createdAt: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
                conversationId: "@Model?.Id"
            });

            input.value = '';
            input.focus();

            try {
                await window.connection.invoke("SendMessage", "@Model?.Id", content);
                // Remove temp message once broadcast arrives (broadcast will use appendMessage with real ID)
                const tempMsg = document.getElementById(`msg-${tempId}`);
                if (tempMsg) tempMsg.remove();
            } catch (err) { 
                console.error("SignalR Send Error:", err);
                const tempMsg = document.getElementById(`msg-${tempId}`);
                if (tempMsg) tempMsg.classList.add('opacity-50'); // Show error state
                input.focus();
            }
        }

        // --- Interaction Logic ---
        document.addEventListener('DOMContentLoaded', () => {
             const input = document.getElementById('message-input');
             if (input) {
                 input.onkeydown = (e) => { if (e.key === 'Enter') sendMessage(); };
             }

             const emojiBtn = document.getElementById('emoji-btn');
             const pickerPopup = document.getElementById('picker-popup');
             if (emojiBtn && pickerPopup) {
                 emojiBtn.onclick = (e) => {
                     e.stopPropagation();
                     pickerPopup.classList.toggle('d-none');
                     if (!pickerPopup.classList.contains('d-none')) initDMEmojiPicker();
                 };
             }
             
             const gifSearch = document.getElementById('gif-search');
             if (gifSearch) {
                 gifSearch.oninput = (e) => {
                     clearTimeout(window.dmGifTimeout);
                     window.dmGifTimeout = setTimeout(() => searchDMGifs(e.target.value), 500);
                 };
             }

             if (currentConversationId) setupSignalRHandlers();
        });

        function initDMEmojiPicker() {
            const container = document.getElementById('emoji-picker-container');
            if (container && !container.hasChildNodes()) {
                const picker = new EmojiMart.Picker({
                    onEmojiSelect: (emoji) => {
                        const input = document.getElementById('message-input');
                        input.value += emoji.native;
                        document.getElementById('picker-popup').classList.add('d-none');
                        input.focus();
                    },
                    theme: 'dark', set: 'native',
                    icons: 'outline',
                    skinTonePosition: 'none',
                    previewPosition: 'none'
                });
                container.appendChild(picker);
            }
        }

        function switchPickerTab(tab) {
             const emojiS = document.getElementById('emoji-picker-container');
             const gifS = document.getElementById('gif-picker-container');
             const tabE = document.getElementById('tab-emoji');
             const tabG = document.getElementById('tab-gif');
             if (tab === 'emoji') {
                 emojiS.classList.remove('d-none'); gifS.classList.add('d-none');
                 tabE.style.borderBottomColor = 'var(--color-emerald)'; tabG.style.borderBottomColor = 'transparent';
             } else {
                 emojiS.classList.add('d-none'); gifS.classList.remove('d-none');
                 tabG.style.borderBottomColor = 'var(--color-emerald)'; tabE.style.borderBottomColor = 'transparent';
                 searchDMGifs();
             }
        }

        async function searchDMGifs(q = 'trending') {
            const results = document.getElementById('gif-results');
            results.innerHTML = '<div class="spinner-border text-aurora mx-auto"></div>';
            try {
                const resp = await fetch(`https://api.giphy.com/v1/gifs/${q === 'trending' ? 'trending' : 'search'}?api_key=dc6zaTOxFJmzC&q=${q}&limit=10`);
                const data = await resp.json();
                results.innerHTML = data.data.map(g => `<img src="${g.images.fixed_height_small.url}" onclick="sendGif('${g.images.fixed_height.url}')" class="rounded cursor-pointer hover-glow w-100" />`).join('');
            } catch(e) { results.innerHTML = 'Error'; }
        }

        function sendGif(url) {
            document.getElementById('message-input').value = url;
            sendMessage();
            document.getElementById('picker-popup').classList.add('d-none');
        }

        function handleDMAttachment(input) {
            if (input.files.length > 0) window.Notify.success(`${input.files.length} files attached.`);
        }

        async function createPeerConnection(connectionId, isOffer) {
            const pc = new RTCPeerConnection(iceServers);
            peers[connectionId] = { pc };

            pc.onicecandidate = (event) => {
                if (event.candidate) connection.invoke("SendSignal", JSON.stringify({ candidate: event.candidate }), connectionId);
            };

            pc.ontrack = (event) => {
                if (event.track.kind === 'audio') {
                    let audio = document.getElementById(`peer-audio-${connectionId}`);
                    if (!audio) {
                        audio = document.createElement('audio');
                        audio.id = `peer-audio-${connectionId}`;
                        audio.autoplay = true;
                        document.body.appendChild(audio);
                    }
                    audio.srcObject = event.streams[0];
                } else if (event.track.kind === 'video') {
                    let container = document.getElementById(`peer-video-container-${connectionId}`);
                    if (!container) {
                        container = document.createElement('div');
                        container.id = `peer-video-container-${connectionId}`;
                        container.className = 'position-relative bg-black rounded-xl overflow-hidden border border-glass shadow-lg flex-shrink-0';
                        container.style.width = '200px';
                        container.style.height = '150px';
                        container.innerHTML = `
                            <video id="peer-video-${connectionId}" autoplay playsinline class="w-100 h-100 object-cover"></video>
                            <div class="position-absolute bottom-0 start-0 m-2 px-2 py-0.5 glass-card rounded-lg" style="background: rgba(0,0,0,0.5);">
                                <span class="fw-bold text-white text-uppercase" style="font-size: 0.6rem;">Partner</span>
                            </div>
                        `;
                        document.getElementById('videoGrid').appendChild(container);
                    }
                    const video = document.getElementById(`peer-video-${connectionId}`);
                    video.srcObject = event.streams[0];
                    updateVideoGrid();
                }
            };

            if (localStream) localStream.getTracks().forEach(track => pc.addTrack(track, localStream));

            if (isOffer) {
                const offer = await pc.createOffer();
                await pc.setLocalDescription(offer);
                connection.invoke("SendSignal", JSON.stringify({ sdp: offer }), connectionId);
            }
            return peers[connectionId];
        }

        async function startCall(withVideo = false) {
            try {
                if (localStream) {
                    localStream.getTracks().forEach(t => t.stop());
                }
                localStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: withVideo });
                isVideoOn = withVideo;
                await connection.invoke("JoinVoice", currentConversationId);
                
                document.getElementById('call-controls').classList.remove('d-none');
                updateVideoGrid();
            } catch (err) { window.Notify.error("Media access denied: " + err); }
        }

        async function endCall() {
            if (connection) {
                try {
                    await connection.invoke("LeaveVoice", currentConversationId);
                } catch (err) { console.error("Error leaving voice:", err); }
            }
            
            if (localStream) {
                localStream.getTracks().forEach(t => t.stop());
                localStream = null;
            }
            
            isVideoOn = false; // Reset video state
            isMuted = false;
            
            Object.keys(peers).forEach(id => {
                if (peers[id].pc) peers[id].pc.close();
                delete peers[id];
                const audio = document.getElementById(`peer-audio-${id}`);
                if (audio) audio.remove();
                const video = document.getElementById(`peer-video-container-${id}`);
                if (video) video.remove();
            });

            const localVideo = document.getElementById('localVideo');
            if (localVideo) localVideo.srcObject = null;
            
            document.getElementById('call-controls').classList.add('d-none');
            updateVideoGrid();
        }

        function updateVideoGrid() {
            const grid = document.getElementById('videoGrid');
            const hasPeers = Object.keys(peers).length > 0;
            const showLocal = isVideoOn && localStream;

            if (!showLocal && !hasPeers) {
                grid.classList.add('d-none');
                return;
            }

            grid.classList.remove('d-none');
            const localContainer = document.getElementById('localVideoContainer');
            if (showLocal) {
                localContainer.classList.remove('d-none');
                document.getElementById('localVideo').srcObject = localStream;
            } else {
                localContainer.classList.add('d-none');
            }
        }

        if (currentConversationId) {
            startSignalR();
        }
    </script>
}

