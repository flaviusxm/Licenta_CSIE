@using AskNLearn.Domain.Entities.Messaging
@using AskNLearn.Web.Models
@model DirectConversation
@inject Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser> UserManager

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Direct Messages";
    ViewData["HideProfileCompletion"] = true;
    ViewData["AppLayout"] = true;
    var conversations = ViewBag.Conversations as List<ConversationPreviewViewModel> ?? new List<ConversationPreviewViewModel>();
    var currentUserId = (await UserManager.GetUserAsync(User))?.Id;
}

@section Sidebar {
    <div class="d-flex flex-column h-100 w-100 bg-transparent animate-entrance">
        <div class="p-4 border-bottom" style="border-color: var(--border-glass) !important;">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="h4 fw-bold text-white mb-0 tracking-tighter">
                    Direct <span class="text-aurora">Messages</span>
                </h2>
                <div class="rounded-circle bg-success shadow-sm" style="width: 8px; height: 8px;"></div>
            </div>
            <div class="position-relative">
                <span class="material-symbols-outlined position-absolute start-0 top-50 translate-middle-y ms-3 text-muted">search</span>
                <input type="text" placeholder="Search..." class="form-control form-control-glass ps-5 py-2" style="font-size: 0.85rem;" />
            </div>
        </div>

        <div class="flex-grow-1 overflow-y-auto custom-scrollbar">
            @if (conversations.Any())
            {
                foreach (var conv in conversations)
                {
                    bool isActive = Model?.Id == conv.ConversationId;
                    <a asp-action="Index" asp-route-id="@conv.ConversationId" class="d-flex align-items-center gap-3 p-3 transition-all text-decoration-none border-bottom position-relative @(isActive ? "active-chat" : "chat-item-hover")" style="border-color: rgba(255,255,255,0.03) !important;">
                        @if (isActive)
                        {
                            <div class="position-absolute start-0 top-0 bottom-0 bg-aurora" style="width: 3px;"></div>
                        }
                        <div class="flex-shrink-0 position-relative">
                            <div class="avatar-md rounded-xl overflow-hidden border @(isActive ? "border-aurora" : "border-glass") shadow-sm">
                                <img src="@(string.IsNullOrEmpty(conv.OtherUserAvatar) ? $"https://api.dicebear.com/7.x/avataaars/svg?seed={conv.OtherUserName}" : conv.OtherUserAvatar)" class="w-100 h-100 object-cover" alt="@conv.OtherUserName" />
                            </div>
                            @if (conv.IsUnread)
                            {
                                <div class="position-absolute top-0 end-0 rounded-circle bg-aurora shadow-sm" style="width: 10px; height: 10px; border: 2px solid var(--bg-universe);"></div>
                            }
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <span class="fw-bold text-white text-truncate" style="font-size: 0.9rem;">@conv.OtherUserName</span>
                                <span class="text-muted" style="font-size: 0.65rem;">@conv.LastMessageAt.ToString("HH:mm")</span>
                            </div>
                            <p class="text-muted text-truncate mb-0 @(conv.IsUnread ? "fw-bold text-light italic" : "")" style="font-size: 0.75rem;">
                                @conv.LastMessageContent
                            </p>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="p-5 text-center opacity-50">
                    <span class="material-symbols-outlined display-4 mb-3 text-muted">chat_bubble</span>
                    <p class="text-muted fw-bold text-uppercase tracking-widest" style="font-size: 0.65rem;">No conversations</p>
                </div>
            }
        </div>
    </div>
}

<div class="d-flex flex-column h-100 flex-grow-1 bg-transparent w-100">
    <!-- Chat Area -->
    <main class="flex-grow-1 d-flex flex-column h-100 bg-transparent">
        @if (Model != null)
        {
            var otherParticipant = Model.Participants.FirstOrDefault(p => p.UserId != currentUserId);

            <!-- Chat Header -->
            <header class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom position-relative z-index-3" style="min-height: 80px; border-color: var(--border-glass) !important; background: rgba(15, 23, 42, 0.3); backdrop-filter: blur(20px);">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-md rounded-xl overflow-hidden border border-aurora shadow-lg">
                        <img src="@(otherParticipant?.User?.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={otherParticipant?.User?.UserName}")" class="w-100 h-100 object-cover" alt="User Avatar" />
                    </div>
                    <div>
                        <h4 class="h5 fw-bold text-white mb-0 tracking-tight">@(otherParticipant?.User?.FullName ?? otherParticipant?.User?.UserName)</h4>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <span class="rounded-circle bg-success" style="width: 6px; height: 6px;"></span>
                            <span class="text-muted small fw-bold text-uppercase tracking-widest" style="font-size: 0.65rem;">Online</span>
                        </div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-glass px-3 py-2 d-flex align-items-center justify-content-center">
                        <span class="material-symbols-outlined">call</span>
                    </button>
                    <button class="btn btn-glass px-3 py-2 d-flex align-items-center justify-content-center">
                        <span class="material-symbols-outlined">videocam</span>
                    </button>
                    <button class="btn btn-glass px-3 py-2 d-flex align-items-center justify-content-center">
                        <span class="material-symbols-outlined">more_vert</span>
                    </button>
                </div>
            </header>

            <!-- Messages List -->
            <div id="messages-container" class="flex-grow-1 overflow-y-auto p-4 p-md-5 d-flex flex-column gap-3 custom-scrollbar">
                @foreach (var message in Model.Messages.OrderBy(m => m.CreatedAt))
                {
                    bool isMine = message.AuthorId == currentUserId;
                    <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") animate-slide-up">
                        <div class="d-flex flex-column @(isMine ? "align-items-end" : "align-items-start")" style="max-width: 75%;">
                            <div class="px-4 py-3 rounded-xl shadow-sm position-relative @(isMine ? "bg-aurora text-dark fw-bold rounded-top-end-0" : "glass-card text-white rounded-top-start-0 border-glass")" style="font-size: 0.9rem;">
                                @message.Content
                            </div>
                            <span class="text-muted mt-2 mx-2 opacity-75 fw-bold" style="font-size: 0.65rem;">@message.CreatedAt.ToString("HH:mm")</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Chat Input -->
            <footer class="p-4 border-top" style="border-color: var(--border-glass) !important; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(20px);">
                <div class="container-fluid p-0">
                    <div class="glass-card p-2 d-flex align-items-center gap-2" style="border-radius: 2rem; background: rgba(255,255,255,0.03);">
                        <button class="btn btn-link text-muted p-2 hover-glow text-decoration-none flex-shrink-0">
                            <span class="material-symbols-outlined">add_circle</span>
                        </button>
                        <input type="text" placeholder="Write a message..." class="form-control border-0 bg-transparent text-white shadow-none ps-0 min-w-0" style="font-size: 0.9rem;" />
                        <button class="btn btn-link text-muted p-2 hover-glow text-decoration-none flex-shrink-0">
                            <span class="material-symbols-outlined">sentiment_satisfied</span>
                        </button>
                        <button class="btn btn-premium d-flex align-items-center justify-content-center p-0 flex-shrink-0" style="width: 48px; height: 48px; border-radius: 1.25rem;">
                            <span class="material-symbols-outlined" style="font-size: 1.5rem;">send</span>
                        </button>
                    </div>
                </div>
            </footer>
        }
        else
        {
            <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-center p-5">
                <div class="position-relative mb-4">
                    <div class="position-absolute translate-middle top-50 start-50 rounded-circle opacity-25" style="width: 200px; height: 200px; background: var(--color-mint-bright); filter: blur(60px);"></div>
                    <div class="rounded-fluid glass-card p-5 d-flex align-items-center justify-content-center position-relative z-1" style="width: 140px; height: 140px;">
                        <span class="material-symbols-outlined text-aurora display-1">forum</span>
                    </div>
                </div>
                <h3 class="display-6 fw-bold text-white mb-3 tracking-tighter">Direct <span class="text-aurora">Messages</span></h3>
                <p class="text-muted fs-5 mb-5" style="max-width: 400px;">Select a conversation from the sidebar to start chatting.</p>
                <div class="d-flex gap-3">
                    <div class="px-4 py-2 glass-card rounded-xl border border-glass d-flex align-items-center gap-2" style="font-size: 0.7rem;">
                        <span class="rounded-circle bg-success" style="width: 6px; height: 6px;"></span>
                        <span class="text-muted fw-bold text-uppercase tracking-widest">Secure Connection</span>
                    </div>
                    <div class="px-4 py-2 glass-card rounded-xl border border-glass d-flex align-items-center gap-2" style="font-size: 0.7rem;">
                        <span class="rounded-circle bg-primary" style="width: 6px; height: 6px;"></span>
                        <span class="text-muted fw-bold text-uppercase tracking-widest">History Synced</span>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

@section Scripts {
    <script>
        const msgList = document.getElementById('messages-container');
        if (msgList) msgList.scrollTop = msgList.scrollHeight;
    </script>
}

<style>
    .bg-aurora {
        background: var(--gradient-aurora);
    }
    .text-aurora {
        background: var(--gradient-aurora);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .border-aurora {
        border-color: var(--color-mint-bright) !important;
    }
    .active-chat {
        background: rgba(52, 211, 153, 0.05);
    }
    .chat-item-hover:hover {
        background: rgba(255,255,255,0.02);
    }
    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up {
        animation: slide-up 0.4s ease-out forwards;
    }
    .rounded-top-start-0 { border-top-left-radius: 0 !important; }
    .rounded-top-end-0 { border-top-right-radius: 0 !important; }
</style>