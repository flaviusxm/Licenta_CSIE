@using AskNLearn.Web.Models
@using AskNLearn.Domain.Entities.Messaging
@using AskNLearn.Application.Common.Interfaces
@model InboxViewModel
@inject IPresenceTracker PresenceTracker
@inject Microsoft.AspNetCore.Identity.UserManager<AskNLearn.Domain.Entities.Core.ApplicationUser> UserManager
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Communication Hub";
    ViewData["AppLayout"] = true; // Use full height layout
    var currentUserId = UserManager.GetUserId(User);
}

@section Sidebar {
    <div class="d-flex flex-column h-100 animate-entrance">
        <!-- Search -->
        <div class="px-4 py-3 position-relative" style="min-height: 70px;">
            <div class="position-relative w-100">
                <span class="material-symbols-outlined position-absolute start-0 top-50 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                <input type="text" id="global-search-input" placeholder="Search people..." class="form-control form-control-glass ps-5" style="font-size: 0.85rem;" oninput="MessagingManager.handleGlobalSearch(this.value)" />
            </div>

            <!-- Search Results Overlay -->
            <div id="search-results-overlay" class="d-none position-absolute start-0 end-0 px-4 mt-1 z-5" style="top: 100%;">
                <div id="search-results-content" class="glass-card shadow-2xl border-glass overflow-y-auto custom-scrollbar" style="border-radius: 12px; background: rgba(15, 15, 17, 0.98); backdrop-filter: blur(40px); max-height: 400px;">
                    <!-- Results injected by JS -->
                </div>
            </div>
        </div>

        <!-- Scrollable Navigation -->
        <div class="flex-grow-1 overflow-y-auto custom-scrollbar">
            <!-- MESSAGES SECTION -->
            <div class="px-2 pt-3">
                <div class="section-header d-flex align-items-center justify-content-between px-3 py-2 rounded-lg hover-bg-glass cursor-pointer" onclick="MessagingManager.toggleSection('messages')">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-muted" style="font-size: 1.1rem;">chat_bubble</span>
                        <span class="text-uppercase tracking-widest fw-bold text-muted" style="font-size: 0.65rem;">Messages</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        @if (Model.RecentMessages.Sum(m => m.UnreadCount) > 0)
                        {
                            <span class="badge rounded-pill bg-danger text-white px-2 shadow-lg" style="font-size: 0.65rem; min-width: 1.4rem; height: 1.4rem; display: flex; align-items: center; justify-content: center; font-weight: 900; background: #FF3B30 !important; box-shadow: 0 0 10px rgba(255, 59, 48, 0.4);">
                                @Model.RecentMessages.Sum(m => m.UnreadCount)
                            </span>
                        }
                    </div>
                </div>
                
                <div id="content-messages" class="sidebar-section-content show gap-1 mt-1 px-1">
                    @if (Model.RecentMessages.Any())
                    {
                        foreach (var conv in Model.RecentMessages)
                        {
                            bool isActive = Model.SelectedConversation?.Id == conv.ConversationId;
                            <a asp-action="Index" asp-route-id="@conv.ConversationId" 
                               class="d-flex align-items-center gap-3 px-3 py-2 rounded-xl transition-all text-decoration-none conversation-item @(isActive ? "bg-accent-soft active-chat" : "hover-bg-glass")">
                                <div class="flex-shrink-0 position-relative">
                                    <div class="avatar-md rounded-circle overflow-hidden border @(isActive ? "border-accent" : "border-glass") shadow-sm" style="width: 38px; height: 38px;">
                                        <img src="@conv.OtherUserAvatar" class="w-100 h-100 object-cover" />
                                        @if (conv.UnreadCount > 0)
                                        {
                                            <div class="position-absolute top-0 end-0 translate-middle badge rounded-circle p-0 border border-2 border-dark shadow-sm" style="width: 12px; height: 12px; z-index: 5; background: #FF3B30 !important; box-shadow: 0 0 8px rgba(255, 59, 48, 0.6);"></div>
                                        }
                                    </div>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex justify-content-between align-items-baseline">
                                        <span class="fw-bold @(isActive || conv.UnreadCount > 0 ? "text-white" : "text-secondary") text-truncate small">@conv.OtherUserName</span>
                                        <span class="text-muted" style="font-size: 0.55rem;">@conv.LastMessageAt.ToString("HH:mm")</span>
                                    </div>
                                    <p id="sidebar-msg-@conv.ConversationId.ToString().ToLower()" class="text-truncate-ellipsis mb-0 @(isActive || conv.UnreadCount == 0 ? "text-muted" : "text-light fw-bold")" style="font-size: 0.7rem;">
                                        @conv.LastMessageContent
                                    </p>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>

            <!-- CONNECTIONS SECTION -->
            <div class="px-2 pt-2">
                <div class="section-header d-flex align-items-center justify-content-between px-3 py-2 rounded-lg hover-bg-glass cursor-pointer collapsed" onclick="MessagingManager.toggleSection('connections')">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-muted" style="font-size: 1.1rem;">group</span>
                        <span class="text-uppercase tracking-widest fw-bold text-muted" style="font-size: 0.65rem;">Connections</span>
                    </div>
                </div>
                <div id="content-connections" class="sidebar-section-content gap-1 mt-1 px-1">
                    @if (Model.Connections != null && Model.Connections.Any())
                    {
                        foreach (var friend in Model.Connections)
                        {
                            <a asp-controller="Profile" asp-action="Index" asp-route-id="@friend.Id" class="d-flex align-items-center gap-3 px-3 py-2 rounded-xl transition-all text-decoration-none hover-bg-glass cursor-pointer">
                                <div class="avatar-sm rounded-circle overflow-hidden border border-glass flex-shrink-0" style="width: 32px; height: 32px;">
                                    <img src="@(friend.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={friend.UserName}")" class="w-100 h-100 object-cover" />
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <span class="text-secondary small text-truncate d-block">@(friend.FullName ?? friend.UserName)</span>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-3 text-center opacity-50">
                            <p class="text-muted mb-0" style="font-size: 0.65rem;">No connections yet</p>
                        </div>
                    }
                </div>
            </div>

            <!-- REQUESTS SECTION -->
            <div class="px-2 pt-2 pb-4">
                <div class="section-header d-flex align-items-center justify-content-between px-3 py-2 rounded-lg hover-bg-glass cursor-pointer @(Model.PendingRequests.Any() ? "" : "collapsed")" onclick="MessagingManager.toggleSection('requests')">
                    <div class="d-flex align-items-center gap-2">
                        <span class="material-symbols-outlined text-muted" style="font-size: 1.1rem;">person_add</span>
                        <span class="text-uppercase tracking-widest fw-bold text-muted" style="font-size: 0.65rem;">Requests</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        @if (Model.PendingRequests.Any())
                        {
                            <span class="badge rounded-pill bg-danger text-white px-2 shadow-lg" style="font-size: 0.65rem; min-width: 1.4rem; height: 1.4rem; display: flex; align-items: center; justify-content: center; font-weight: 900; background: #FF3B30 !important; box-shadow: 0 0 10px rgba(255, 59, 48, 0.4);">
                                @Model.PendingRequests.Count()
                            </span>
                        }
                    </div>
                </div>
                <div id="content-requests" class="sidebar-section-content @(Model.PendingRequests.Any() ? "show" : "") gap-2 px-2 mt-2">
                    @foreach (var req in Model.PendingRequests)
                    {
                        <div class="d-flex align-items-center gap-3 px-3 py-2 rounded-xl hover-bg-glass cursor-pointer" id="sidebar-request-@req.RequesterId">
                            <div class="avatar-sm rounded-circle overflow-hidden border border-glass flex-shrink-0" style="width: 32px; height: 32px;">
                                <img src="@(req.Requester.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={req.Requester.UserName}")" class="w-100 h-100 object-cover" />
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <p class="fw-bold text-white mb-0 text-truncate" style="font-size: 0.85rem; line-height: 1.2;">@(req.Requester.FullName ?? req.Requester.UserName)</p>
                            </div>
                            <div class="d-flex gap-2 flex-shrink-0 align-items-center">
                                <button onclick="MessagingManager.handleFriendRequest('@req.RequesterId', 'AcceptRequest')" 
                                        class="btn btn-accent p-0 d-flex align-items-center justify-content-center rounded-circle shadow-sm" 
                                        style="width: 28px; height: 28px;" title="Accept">
                                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">check</span>
                                </button>
                                <button onclick="MessagingManager.handleFriendRequest('@req.RequesterId', 'DeclineRequest')" 
                                        class="btn btn-glass p-0 d-flex align-items-center justify-content-center rounded-circle border-danger-thin" 
                                        style="width: 28px; height: 28px; background: rgba(239, 68, 68, 0.05);" title="Decline">
                                    <span class="material-symbols-outlined text-danger" style="font-size: 1.1rem;">close</span>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

        <!-- Main Content Area -->
        <div class="h-100 d-flex flex-column" style="background: transparent;">
            @if (Model.SelectedConversation != null)
            {
                var otherParticipant = Model.SelectedConversation.Participants.FirstOrDefault(p => p.UserId != currentUserId);
                
                <!-- Chat Header -->
                <header class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom border-glass" style="min-height: 70px; background: rgba(10, 10, 11, 0.4); backdrop-filter: blur(20px);">
                    <div class="d-flex align-items-center gap-3">
                        <a asp-controller="Profile" asp-action="Index" asp-route-id="@otherParticipant?.UserId" class="d-flex align-items-center gap-3 text-decoration-none">
                            <div class="avatar-md rounded-circle overflow-hidden border border-accent shadow-lg" style="width: 42px; height: 42px;">
                                <img src="@(otherParticipant?.User?.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={otherParticipant?.User?.UserName}")" class="w-100 h-100 object-cover" />
                            </div>
                            <div>
                                <h4 class="small fw-bold text-white mb-0">@(otherParticipant?.User?.FullName ?? otherParticipant?.User?.UserName)</h4>
                                <div class="d-flex align-items-center gap-1">
                                    <span class="rounded-circle bg-success" style="width: 6px; height: 6px;"></span>
                                    <span class="text-muted" style="font-size: 0.6rem;">Online</span>
                                </div>
                            </div>
                        </a>
                    </div>
                </header>

                <!-- Messages -->
                <div id="messages-container" class="flex-grow-1 overflow-y-auto p-4 d-flex flex-column gap-3 custom-scrollbar">
                    @{
                        var messages = Model.SelectedConversation?.Messages ?? new List<AskNLearn.Domain.Entities.Messaging.Message>();
                    }
                    @foreach (var message in messages)
                    {
                        bool isMine = message.AuthorId == currentUserId;
                        <div class="d-flex w-100 @(isMine ? "justify-content-end" : "justify-content-start") animate-slide-up">
                            <div class="d-flex @(isMine ? "flex-row-reverse" : "") gap-2 align-items-end" style="max-width: 75%;">
                                <div class="d-flex flex-column gap-1 @(isMine ? "align-items-end" : "align-items-start") position-relative group">
                                    <div class="px-3 py-2 shadow-sm message-bubble" id="msg-bubble-@message.Id" 
                                         style="border-radius: 18px; @(isMine ? "background: var(--color-accent); color: white;" : "background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.05); color: white;")">
                                        <p class="mb-0" style="font-size: 0.9rem; line-height: 1.4;">@message.Content</p>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 px-1">
                                        <span class="text-muted" style="font-size: 0.55rem;">@message.CreatedAt.ToString("HH:mm")</span>
                                        @if (isMine)
                                        {
                                            <button onclick="MessagingManager.deleteDM('@message.Id')" class="btn btn-link p-0 text-muted hover-text-danger opacity-0 group-hover-opacity-100 transition-all">
                                                <span class="material-symbols-outlined" style="font-size: 12px;">delete</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Input -->
                <footer class="p-3">
                    <div class="position-relative">
                        <!-- Emoji Picker -->
                        <div id="emoji-picker" class="d-none position-absolute bottom-100 start-0 mb-3 glass-card p-3 shadow-2xl border-glass animate-slide-up" style="width: 280px; z-index: 1000; border-radius: 20px; background: rgba(15, 15, 17, 0.95); backdrop-filter: blur(40px);">
                            <div class="d-flex flex-wrap gap-1 custom-scrollbar overflow-y-auto" style="max-height: 200px;" id="emoji-list">
                                <!-- Emojis injected by JS -->
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2 glass-card p-2 px-3" style="border-radius: 24px;">
                            <button class="btn btn-link text-muted p-1 hover-text-accent transition-all"><span class="material-symbols-outlined">add</span></button>
                            <button type="button" onclick="MessagingManager.toggleEmojiPicker()" class="btn btn-link text-muted p-1 hover-text-accent transition-all" id="emoji-btn">
                                <span class="material-symbols-outlined">sentiment_satisfied</span>
                            </button>
                            <input type="text" id="message-input" placeholder="Message..." class="form-control border-0 bg-transparent shadow-none text-white py-1" style="font-size: 0.9rem;" />
                            <button onclick="MessagingManager.sendMessage()" class="btn btn-accent rounded-circle p-2 d-flex align-items-center justify-content-center shadow-lg" style="width: 32px; height: 32px;">
                                <span class="material-symbols-outlined fs-6">send</span>
                            </button>
                        </div>
                    </div>
                </footer>
            }
            else
            {
                <!-- Empty State -->
                <div class="flex-grow-1 d-flex flex-column items-center justify-content-center text-center p-5">
                    <h2 class="h4 fw-bold text-white mb-2">Your Messages</h2>
                    <p class="text-muted small max-w-xs mx-auto">Select a conversation from the sidebar or start a new one to begin chatting.</p>
                </div>
            }
        </div>

@section Scripts {
<script type="module" src="~/js/module.messaging.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const recentConvIds = [
            @foreach (var conv in Model.RecentMessages) {
                <text>"@conv.ConversationId",</text>
            }
        ];
        MessagingManager.init("@(Model.SelectedConversation?.Id)", "@currentUserId", recentConvIds);
    });
</script>
}

<style>
    .bg-accent { background: var(--color-accent) !important; }
    .bg-accent-soft { background: var(--color-accent-soft) !important; }
    .text-accent { color: var(--color-accent) !important; }
    .border-accent { border-color: var(--color-accent) !important; }
    
    .conversation-item {
        border-bottom: 0px !important;
        margin-bottom: 2px;
    }
    
    .hover-bg-glass:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    
    .message-bubble {
        transition: all 0.2s ease;
    }

    .btn-accent {
        background: var(--color-accent);
        border: none;
        color: white;
        transition: all 0.2s var(--ease-apple);
    }
    .btn-accent:hover {
        background: #0071E3;
        transform: scale(1.05);
    }

    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up { animation: slide-up 0.4s ease-out forwards; }
    
    .group:hover .group-hover-opacity-100 { opacity: 1 !important; }
    .transition-all { transition: all 0.2s ease; }

    .text-truncate-ellipsis {
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }
</style>
