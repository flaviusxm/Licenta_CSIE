@using AskNLearn.Web.Models
@model InboxViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inbox";
}

<div class="container py-5 max-w-7xl">
    
    <div class="d-flex flex-column gap-5 position-relative z-1">
        <!-- Header Section -->
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
                <h2 class="display-5 fw-bold text-white tracking-tight mb-1">Inbox</h2>
                <p class="text-muted fw-bold text-uppercase tracking-widest mb-0" style="font-size: 0.7rem;">Manage your communications and network</p>
            </div>
            <button onclick="markAllInboxRead()" class="btn btn-glass px-4 py-3 fw-bold text-uppercase tracking-widest shadow-lg" style="font-size: 0.7rem; border-radius: 1rem;">
                Mark All Read
            </button>
        </div>

        <!-- Main Workspace Grid -->
        <div class="row g-5">
            <!-- Central Feed: Communications -->
            <section class="col-12 col-xl-8 d-flex flex-column gap-4">
                <div class="d-flex align-items-center justify-content-between px-2">
                        Recent Messages
                    </h3>
                    <a asp-controller="Direct" asp-action="Index" class="fw-bold text-aurora text-uppercase tracking-widest hover-text-white d-flex align-items-center gap-1 transition-all text-decoration-none" style="font-size: 0.75rem; transition: transform 0.3s var(--ease-snappy);">
                        Open Chat <span class="material-symbols-outlined" style="font-size: 1rem;">arrow_forward</span>
                    </a>
                </div>
                
                <div class="glass-card overflow-hidden shadow-lg border-glass-strong" style="border-radius: 2.5rem; transition: all 0.6s var(--ease-smooth);">
                    @if (Model.RecentMessages.Any())
                    {
                        <div class="d-flex flex-column">
                            @foreach (var conv in Model.RecentMessages)
                            {
                                <a asp-controller="Direct" asp-action="Index" asp-route-id="@conv.ConversationId" class="d-flex align-items-center gap-4 p-4 p-md-5 transition-all group position-relative text-decoration-none @(conv.IsUnread ? "bg-primary bg-opacity-10" : "hover-bg-glass")" style="border-bottom: 1px solid rgba(255,255,255,0.05); transition: all 0.4s var(--ease-smooth);">
                                    <div class="position-relative flex-shrink-0">
                                        <div class="rounded-4 shadow-lg position-relative z-1 bg-cover bg-center border border-glass transition-transform" style="width: 80px; height: 80px; background-image: url('@conv.OtherUserAvatar'); background-color: rgba(255,255,255,0.05); transition: transform 0.5s var(--ease-snappy);"></div>
                                        @if(conv.IsUnread) {
                                            <div class="position-absolute rounded-circle shadow-sm z-2 border border-dark border-2" style="top: -4px; right: -4px; width: 16px; height: 16px; background: var(--color-mint-bright);"></div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 min-vw-0 d-flex flex-column justify-content-center">
                                        <div class="d-flex justify-content-between align-items-baseline mb-2">
                                            <h5 class="fw-bold text-white fs-5 tracking-tight m-0 text-truncate">@conv.OtherUserName</h5>
                                            <span class="text-muted fw-bold text-uppercase tracking-widest flex-shrink-0 ms-3" style="font-size: 0.6rem; opacity: 0.5;">@conv.LastMessageAt.ToShortTimeString()</span>
                                        </div>
                                        <p class="text-truncate lh-base m-0 @(conv.IsUnread ? "fw-bold text-white" : "text-muted")" style="font-size: 0.9rem;">
                                            @conv.LastMessageContent
                                        </p>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center d-flex flex-column align-items-center">
                            <div class="w-100 h-100 py-5 rounded-4 d-flex align-items-center justify-content-center text-muted position-relative z-1" style="background: rgba(255,255,255,0.02);">
                                <span class="material-symbols-outlined fw-bold opacity-25" style="font-size: 5rem;">mail</span>
                            </div>
                            <h4 class="fs-4 fw-bold text-white mt-4 mb-2">Secure Channels Empty</h4>
                            <p class="text-muted fw-bold small text-uppercase tracking-widest">Initialization required</p>
                        </div>
                    }
                </div>
            </section>

            <!-- Peripheral Hub -->
            <aside class="col-12 col-xl-4 d-flex flex-column gap-5">
                <!-- Pending Connections -->
                <div class="d-flex flex-column gap-4">
                        Friend Requests
                    </h3>
                    <div class="glass-card overflow-hidden shadow-lg border-glass-strong d-flex flex-column animate-entrance" style="border-radius: 2.5rem; transition: all 0.6s var(--ease-smooth);">
                        @if (Model.PendingRequests.Any())
                        {
                            <div class="d-flex flex-column">
                                @foreach (var request in Model.PendingRequests)
                                {
                                    <div class="p-4 border-bottom border-glass hover-bg-glass transition-all" id="request-row-@request.RequesterId" style="transition: all 0.4s var(--ease-smooth);">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-md rounded-4 overflow-hidden border border-glass" style="width: 50px; height: 50px;">
                                                <img src="@(request.Requester.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={request.Requester.UserName}")" class="w-100 h-100 object-cover" />
                                            </div>
                                            <div class="flex-grow-1 min-w-0">
                                                <p class="fw-bold text-white mb-0 text-truncate" style="font-size: 0.85rem;">@(request.Requester.FullName ?? request.Requester.UserName)</p>
                                                <p class="text-muted small mb-0">Wants to connect</p>
                                            </div>
                                            <div class="d-flex gap-1">
                                                <button onclick="handleRequest('@request.RequesterId', 'AcceptRequest')" class="btn btn-glass p-2 text-success hover-glow" title="Accept" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; transition: all 0.3s var(--ease-snappy);">
                                                    <span class="material-symbols-outlined fs-5">check</span>
                                                </button>
                                                <button onclick="handleRequest('@request.RequesterId', 'DeclineRequest')" class="btn btn-glass p-2 text-danger hover-glow" title="Decline" style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; transition: all 0.3s var(--ease-snappy);">
                                                    <span class="material-symbols-outlined fs-5">close</span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="p-5 text-center">
                                <p class="fw-bold text-muted text-uppercase tracking-widest m-0" style="font-size: 0.65rem; opacity: 0.6;">No pending requests</p>
                            </div>
                        }
                    </div>
                </div>

            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.group').forEach(group => {
            group.addEventListener('mouseenter', () => {
                const btn = group.querySelector('button.opacity-0');
                if (btn) btn.classList.replace('opacity-0', 'opacity-100');
            });
            group.addEventListener('mouseleave', () => {
                const btn = group.querySelector('button.opacity-100');
                if (btn) btn.classList.replace('opacity-100', 'opacity-0');
            });
        });

        async function markRead(id, btn) {
            try {
                const response = await fetch(`/Inbox/MarkAsRead/${id}`, { method: 'POST' });
                if(response.ok) {
                    const group = btn.closest('.group');
                    group.classList.add('opacity-50', 'hover-bg-glass');
                    group.classList.remove('bg-warning', 'bg-opacity-10');
                    btn.remove();
                }
            } catch (e) { console.error(e); }
        }

        async function markAllInboxRead() {
            try {
                const response = await fetch('/Inbox/MarkAllAsRead', { method: 'POST' });
                if(response.ok) location.reload();
            } catch (e) { console.error(e); }
        }

        async function handleRequest(userId, action) {
            const btnRow = document.getElementById(`request-row-${userId}`);
            if (btnRow) {
                btnRow.style.opacity = '0.5';
                btnRow.style.pointerEvents = 'none';
                btnRow.style.transform = 'translateX(20px)';
            }
            try {
                const resp = await fetch(`/Connections/${action}?userId=${userId}`, { method: 'POST' });
                if (resp.ok) {
                    if (btnRow) {
                        btnRow.style.height = '0';
                        btnRow.style.padding = '0';
                        btnRow.style.margin = '0';
                        btnRow.style.overflow = 'hidden';
                        setTimeout(() => btnRow.remove(), 400);
                    }
                } else {
                    if (btnRow) {
                        btnRow.style.opacity = '1';
                        btnRow.style.pointerEvents = 'all';
                        btnRow.style.transform = 'translateX(0)';
                    }
                }
            } catch(e) { console.error(e); }
        }
    </script>
}
