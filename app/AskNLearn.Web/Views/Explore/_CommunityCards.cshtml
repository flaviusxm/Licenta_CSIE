@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@model List<CommunityDto>

@if (Model != null)
{
    @foreach (var forum in Model)
    {
        <a asp-controller="Forum" asp-action="Details" asp-route-id="@forum.Id" 
           class="community-item d-flex align-items-center gap-4 p-3 rounded-xl hover-bg-glass transition-all border-bottom border-glass-soft text-decoration-none group animate-entrance">
            
            <div class="community-icon rounded-4 d-flex align-items-center justify-content-center flex-shrink-0 shadow-sm transition-transform group-hover-scale" 
                 style="width: 52px; height: 52px; background: rgba(52, 211, 153, 0.05); border: 1px solid var(--border-glass-strong);">
                @if (!string.IsNullOrEmpty(forum.ImageUrl))
                {
                    <img src="@forum.ImageUrl" class="w-100 h-100 object-cover rounded-4" alt="@forum.Name" />
                }
                else
                {
                    <span class="material-symbols-outlined fs-3 text-aurora">groups</span>
                }
            </div>

            <div class="flex-grow-1 min-w-0">
                <div class="d-flex align-items-center justify-content-between mb-1">
                    <h4 class="h6 fw-bold text-white mb-0 text-truncate group-hover-text-aurora transition-colors">@forum.Name</h4>
                    <span class="text-muted" style="font-size: 0.65rem;">Created @forum.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="text-muted text-truncate small lh-sm" style="max-width: 90%;">
                    @forum.Description
                </div>
            </div>

            <div class="flex-shrink-0 text-muted opacity-0 group-hover-opacity-100 transition-all transform-translate-x-10 group-hover-translate-x-0">
                <span class="material-symbols-outlined">chevron_right</span>
            </div>
        </a>
    }
}

<style>
    .community-item:hover {
        background: rgba(255, 255, 255, 0.04);
    }
    .group-hover-scale:hover {
        transform: scale(1.05);
    }
    .group:hover .group-hover-scale {
        transform: scale(1.05);
    }
    .group:hover .group-hover-text-aurora {
        color: var(--color-aurora) !important;
    }
    .transform-translate-x-10 {
        transform: translateX(-10px);
    }
    .group:hover .group-hover-translate-x-0 {
        transform: translateX(0);
    }
</style>
