@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@model List<CommunityDto>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Explore Communities";
}

<div class="container py-5 max-w-7xl">
    
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-4 mb-5">
        <div>
            <h2 class="display-6 fw-bold text-white tracking-tight mb-2">Explore Communities</h2>
            <p class="text-muted fs-5 m-0" style="max-width: 600px;">Discover study groups and forums tailored to your curriculum.</p>
        </div>
        <div class="flex-shrink-0">
            <a asp-controller="Forum" asp-action="Create" class="btn btn-premium d-flex align-items-center gap-2 shadow-lg">
                <span class="material-symbols-outlined fs-5">add_circle</span>
                Create New Forum
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="mb-5 position-relative">
        <div class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1.5rem;">search</span>
            <input id="explore-search" class="form-control form-control-glass w-100 shadow-lg" style="padding: 1rem 1.5rem 1rem 3.5rem; border-radius: 1.5rem;" placeholder="Search for a specific forum..." type="text" value="@Context.Request.Query["searchTerm"]" oninput="debounceSearch()"/>
        </div>
    </div>

    <!-- Forum List -->
    <div id="communities-container" class="row g-4">
        @await Html.PartialAsync("_CommunityCards", Model)
    </div>

    <!-- Loading Spinner -->
    <div id="communities-load-spinner" class="d-none text-center py-5">
        <div class="spinner-border text-aurora" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <!-- Sentinel -->
    <div id="communities-sentinel" class="py-2"></div>
</div>

@section Scripts {
    <script>
        let communitiesSkip = 12;
        let communitiesLoading = false;
        let communitiesAllLoaded = false;
        let searchTimeout;
        
        const sentinel = document.getElementById('communities-sentinel');
        const container = document.getElementById('communities-container');
        const spinner = document.getElementById('communities-load-spinner');
        const searchInput = document.getElementById('explore-search');

        const observer = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting && !communitiesLoading && !communitiesAllLoaded) {
                await loadMoreCommunities();
            }
        }, { threshold: 0.1 });

        if (sentinel) {
            observer.observe(sentinel);
        }

        function debounceSearch() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(performSearch, 400);
        }

        async function performSearch() {
            communitiesSkip = 0;
            communitiesAllLoaded = false;
            container.innerHTML = '';
            spinner.classList.remove('d-none');
            await loadMoreCommunities();
        }

        async function loadMoreCommunities() {
            if (communitiesLoading) return;
            communitiesLoading = true;
            spinner.classList.remove('d-none');

            const currentSearch = searchInput.value.trim();
            try {
                const url = `/Explore/GetCommunities?skip=${communitiesSkip}${currentSearch ? '&searchTerm=' + encodeURIComponent(currentSearch) : ''}`;
                const response = await fetch(url);
                if (response.ok) {
                    const html = await response.text();
                    
                    if (!html.trim()) {
                        communitiesAllLoaded = true;
                        if (communitiesSkip === 0) {
                             container.innerHTML = `<div class="col-12 text-center py-5 opacity-50"><span class="material-symbols-outlined display-4 mb-3">search_off</span><p class="fw-bold">No forums found matching "${currentSearch}"</p></div>`;
                        }
                    } else {
                        container.insertAdjacentHTML('beforeend', html);
                        communitiesSkip += 12;
                    }
                }
            } catch (error) {
                console.error('Error loading more communities:', error);
            } finally {
                communitiesLoading = false;
                spinner.classList.add('d-none');
            }
        }
    </script>
}
