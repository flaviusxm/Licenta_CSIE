@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@model List<CommunityDto>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Explore Communities";
}

<div class="container py-5 max-w-7xl">
    
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-4 mb-5">
        <div>
            <h2 class="display-6 fw-bold text-white tracking-tight mb-2">Explore Communities</h2>
            <p class="text-muted fs-5 m-0" style="max-width: 600px;">Discover study groups and forums tailored to your curriculum.</p>
        </div>
        <div class="flex-shrink-0">
            <a asp-controller="Forum" asp-action="Create" class="btn btn-premium d-flex align-items-center gap-2 shadow-lg">
                <span class="material-symbols-outlined fs-5">add_circle</span>
                Create New Forum
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="mb-5 position-relative">
        <form method="get" asp-action="Index" class="position-relative">
            <span class="material-symbols-outlined position-absolute top-50 translate-middle-y text-muted" style="left: 1.5rem;">search</span>
            <input name="searchTerm" class="form-control form-control-glass w-100 shadow-lg" style="padding: 1rem 1.5rem 1rem 3.5rem; border-radius: 1.5rem;" placeholder="Search for a specific forum..." type="text" value="@Context.Request.Query["searchTerm"]"/>
        </form>
    </div>

    <!-- Forum List -->
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="glass-card text-center py-5 d-flex flex-column align-items-center justify-content-center shadow-lg" style="min-height: 300px;">
                    <span class="material-symbols-outlined display-1 text-muted mb-4" style="opacity: 0.5;">forum</span>
                    <p class="text-muted fs-5 fw-bold">No forums found. Why not create one?</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var forum in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="glass-card p-4 d-flex flex-column h-100 gap-3 group transition-all hover-glow border-glass-strong shadow-lg">
                        
                        <div class="d-flex justify-content-between align-items-start">
                            @if (!string.IsNullOrEmpty(forum.ImageUrl))
                            {
                                <div class="rounded-4 overflow-hidden flex-shrink-0" style="width: 64px; height: 64px; border: 1px solid var(--border-glass-strong); background: rgba(0,0,0,0.2);">
                                    <img src="@forum.ImageUrl" class="w-100 h-100 object-cover" alt="@forum.Name" />
                                </div>
                            }
                            else
                            {
                                <div class="rounded-4 flex-shrink-0 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px; background: rgba(52, 211, 153, 0.1); border: 1px solid rgba(52, 211, 153, 0.2);">
                                    <span class="material-symbols-outlined fs-1 text-aurora">groups</span>
                                </div>
                            }
                            <span class="badge rounded-pill fw-bold" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-glass); color: #cbd5e1; padding: 0.4rem 0.8rem;">
                                @forum.PostCount posts
                            </span>
                        </div>

                        <div class="flex-grow-1 mt-2 position-relative">
                            <h3 class="fs-5 fw-bold text-white mb-2 text-truncate transition-colors" style="max-width: 100%;">
                                <a asp-controller="Forum" asp-action="Details" asp-route-id="@forum.Id" class="stretched-link text-decoration-none text-white hover-glow">
                                    @forum.Name
                                </a>
                            </h3>
                            <div class="text-muted small lh-base" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @forum.Description
                            </div>
                        </div>
                        
                        <div class="mt-3 pt-3" style="border-top: 1px solid var(--border-glass);">
                            <span class="text-muted small fst-italic">Created @forum.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
