
@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@model List<CommunityDto>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Explore Communities";
}

<div class="p-8 flex flex-col gap-8 pb-20">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Explore Communities</h2>
            <p class="text-slate-500 dark:text-slate-400">Discover study groups and forums tailored to your curriculum.</p>
        </div>
        <div class="flex gap-3">
            <a asp-controller="Forum" asp-action="Create" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border border-border-light dark:border-border-dark hover:bg-slate-50 dark:hover:bg-white/10 font-bold transition-all text-slate-700 dark:text-white">
                <span class="material-symbols-outlined">add_circle</span>
                Create New Forum
            </a>
        </div>
    </div>

    <!-- Search & Filters -->
    <form method="get" asp-action="Index" class="flex flex-col md:flex-row gap-4">
        <div class="flex-1 relative">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input name="searchTerm" class="w-full bg-white dark:bg-surface-dark border border-border-light dark:border-border-dark rounded-xl py-3 pl-12 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all text-slate-900 dark:text-white placeholder:text-slate-400" placeholder="Search for a specific forum..." type="text" value="@Context.Request.Query["searchTerm"]"/>
        </div>
       
    </form>

    <!-- Forum List -->
    <div class="flex flex-col gap-6">
        @if (!Model.Any())
        {
            <div class="text-center py-20  rounded-2xl">
                <span class="material-symbols-outlined text-6xl text-slate-300 dark:text-slate-700 mb-4">forum</span>
                <p class="text-slate-500">No forums found. Why not create one?</p>
            </div>
        }
        else
        {
            @foreach (var forum in Model)
            {
                <div class="bg-surface-light dark:bg-surface-dark rounded-2xl p-6 border border-border-light dark:border-border-dark hover:border-primary/50 transition-all group flex flex-col md:flex-row gap-6 items-start md:items-center shadow-sm">
                    <div class="flex justify-between items-start md:items-center w-full md:w-auto gap-4">
                        @if (!string.IsNullOrEmpty(forum.ImageUrl))
                        {
                            <div class="size-16 rounded-2xl border border-border-light dark:border-border-dark overflow-hidden shrink-0">
                                <img src="@forum.ImageUrl" class="w-full h-full object-cover" alt="@forum.Name" />
                            </div>
                        }
                        else
                        {
                            <div class="size-16 rounded-2xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-3xl">groups</span>
                            </div>
                        }
                        <div class="flex flex-col md:hidden">
                            <span class="text-xs text-slate-500">@forum.PostCount posts</span>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-1">
                            <h3 class="text-xl font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors truncate">
                                <a asp-controller="Forum" asp-action="Details" asp-route-id="@forum.Id">@forum.Name</a>
                            </h3>
                        </div>
                        <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">@forum.Description</p>
                        <div class="flex items-center gap-4 mt-3">
                            <span class="text-xs text-slate-500 dark:text-slate-400 italic">Created @forum.CreatedAt.ToString("MMM dd, yyyy")</span>
                            <span class="hidden md:inline-block text-xs text-slate-500 dark:text-slate-400">• @forum.PostCount posts</span>
                        </div>
                    </div>
                    
                </div>
            }
        }
    </div>
</div>
