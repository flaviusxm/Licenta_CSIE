@using AskNLearn.Application.Features.Communities.Queries.GetCommunities
@model List<CommunityDto>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Explore Communities";
}

@section Sidebar {
    <div class="p-4 border-bottom border-glass">
        <h2 class="h5 fw-bold text-white mb-2 d-flex align-items-center gap-2">
            <span class="material-symbols-outlined text-aurora">explore</span>
            Explore Communities
        </h2>
        <p class="text-muted small mb-4">Discover communities and forums tailored to your curriculum.</p>

        <a asp-controller="Forum" asp-action="Create" class="btn btn-premium w-100 d-flex align-items-center justify-content-center gap-2 py-3 mb-2 shadow-lg">
            <span class="material-symbols-outlined fs-5">add_circle</span>
            New Forum
        </a>
    </div>

    <div class="flex-grow-1 p-3 overflow-y-auto custom-scrollbar">
        <div class="mb-4">
            <label class="text-muted small fw-bold text-uppercase tracking-widest mb-3 d-block">Search</label>
            <div class="position-relative">
                <span class="material-symbols-outlined position-absolute start-0 top-50 translate-middle-y ms-3 text-muted" style="font-size: 1rem;">search</span>
                <input type="text" id="explore-search" class="form-control form-control-glass ps-5" placeholder="Search for a specific forum..." value="@Context.Request.Query["searchTerm"]" oninput="debounceSearch()" />
            </div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center justify-content-center gap-2 py-4 mt-auto text-muted hover-text-white transition-all text-decoration-none border-top border-glass">
        <span class="material-symbols-outlined fs-5">arrow_back</span>
        <span class="fw-bold text-uppercase tracking-widest fs-xs">Back</span>
    </a>
}

<div class="max-w-4xl mx-auto p-4 animate-entrance">
    <!-- Forum List -->
    <div id="communities-container" class="d-flex flex-column gap-2">
        @await Html.PartialAsync("_CommunityCards", Model)
    </div>

    <!-- Loading Spinner -->
    <div id="communities-load-spinner" class="d-none text-center py-5">
        <div class="spinner-border text-aurora" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <!-- Sentinel -->
    <div id="communities-sentinel" class="py-2"></div>
</div>

@section Scripts {
    <script>
        let communitiesSkip = 12;
        let communitiesLoading = false;
        let communitiesAllLoaded = false;
        let searchTimeout;
        
        const sentinel = document.getElementById('communities-sentinel');
        const container = document.getElementById('communities-container');
        const spinner = document.getElementById('communities-load-spinner');
        const searchInput = document.getElementById('explore-search');

        const observer = new IntersectionObserver(async (entries) => {
            if (entries[0].isIntersecting && !communitiesLoading && !communitiesAllLoaded) {
                await loadMoreCommunities();
            }
        }, { threshold: 0.1 });

        if (sentinel) {
            observer.observe(sentinel);
        }

        function debounceSearch() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(performSearch, 400);
        }

        async function performSearch() {
            communitiesSkip = 0;
            communitiesAllLoaded = false;
            container.innerHTML = '';
            spinner.classList.remove('d-none');
            await loadMoreCommunities();
        }

        async function loadMoreCommunities() {
            if (communitiesLoading) return;
            communitiesLoading = true;
            spinner.classList.remove('d-none');

            const currentSearch = searchInput.value.trim();
            try {
                const url = `/hubs/communities/explore/v1/batch?skip=${communitiesSkip}${currentSearch ? '&searchTerm=' + encodeURIComponent(currentSearch) : ''}`;
                const response = await fetch(url);
                if (response.ok) {
                    const html = await response.text();
                    
                    if (!html.trim()) {
                        communitiesAllLoaded = true;
                        if (communitiesSkip === 0) {
                             container.innerHTML = `<div class="text-center py-5 opacity-50"><span class="material-symbols-outlined display-4 mb-3">search_off</span><p class="fw-bold">No forums found matching "${currentSearch}"</p></div>`;
                        }
                    } else {
                        container.insertAdjacentHTML('beforeend', html);
                        communitiesSkip += 12;
                    }
                }
            } catch (error) {
                console.error('Error loading more communities:', error);
            } finally {
                communitiesLoading = false;
                spinner.classList.add('d-none');
            }
        }
    </script>
}
