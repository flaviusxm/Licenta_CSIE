@model AskNLearn.Web.Models.LeaderboardViewModel
@using System.Security.Claims
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Student Leaderboard";
}

<style>
    .table, .table th, .table td, .table tr { 
        --bs-table-bg: transparent !important;
        --bs-table-color: #e5e7eb !important;
        --bs-table-hover-bg: rgba(255,255,255,0.05) !important;
        background-color: transparent !important;
        color: #e5e7eb !important;
    }
    .table-responsive { background-color: transparent !important; }
    
    .pagination-premium .page-link {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass);
        color: #e5e7eb;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50% !important;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s var(--ease-apple);
    }
    
    .pagination-premium .page-link:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
        color: white;
    }
    
    .pagination-premium .page-item.active .page-link {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: white;
        box-shadow: 0 0 15px rgba(0, 122, 255, 0.3);
    }
    
    .pagination-premium .page-item.disabled .page-link {
        background: transparent;
        opacity: 0.3;
        cursor: not-allowed;
    }
</style>


<div class="container py-5 max-w-7xl">
    <!-- Header -->
    <div class="row align-items-center mb-5 g-4">
        <div class="col-md-8 text-center text-md-start">
            <h2 class="display-6 fw-bold text-white tracking-tight mb-2">Leaderboard</h2>
            <p class="text-muted fs-5 m-0">See who's topping the charts this semester.</p>
        </div>
        @if (!User.IsInRole("Admin"))
        {
            <div class="col-md-4 text-center text-md-end d-flex justify-content-md-end">
                <div class="glass-card p-4 d-inline-flex align-items-center gap-4 shadow-lg border-glass-strong" style="border-radius: 1.5rem;">
                    <div class="text-center">
                        <span class="d-block text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Your Rank</span>
                        <span class="fs-4 fw-bold text-aurora">@(Model.CurrentUserRank > 0 ? $"#{Model.CurrentUserRank}" : "-")</span>
                    </div>
                    <div style="width: 1px; height: 3rem; background: var(--border-glass-strong);"></div>
                    <div class="text-center">
                        <span class="d-block text-muted fw-bold text-uppercase tracking-widest mb-1" style="font-size: 0.65rem;">Points</span>
                        <span class="fs-4 fw-bold text-white">@Model.CurrentUserPoints</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Global Podiums (Always Top 3) -->
    <div class="d-flex align-items-end justify-content-center mb-5 mx-auto gap-3 gap-md-5 overflow-visible pb-4 pt-5 hide-scrollbar" style="max-width: 900px;">
        
        <!-- 2nd Place -->
        @if (Model.TopUsers.Count > 1) {
            var second = Model.TopUsers[1];
            <div class="d-flex flex-column align-items-center text-center order-2 order-md-1" style="width: 30%; min-width: 140px; max-width: 200px;">
                <div class="position-relative mb-4" style="width: 80px; height: 80px;">
                    <div class="position-absolute start-50 translate-middle-x rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-lg border border-dark z-3" style="top: -1rem; width: 32px; height: 32px; background: #94a3b8; font-size: 0.85rem; border-width: 4px !important;">2</div>
                    <img src="@(second.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={second.FullName}")" class="w-100 h-100 rounded-circle object-cover border border-dark shadow-lg" style="background: rgba(255,255,255,0.1); border-color: #94a3b8 !important; border-width: 4px !important;" />
                </div>
                <div class="glass-card w-100 p-3 p-md-4 border-bottom-0 d-flex flex-column align-items-center shadow-lg" style="border-radius: 2rem 2rem 0 0; border-color: var(--border-glass-strong);">
                    <p class="fw-bold text-white mb-1 text-truncate w-100">@second.FullName</p>
                    <p class="text-aurora small fw-bold mb-4">@second.ReputationPoints pts</p>
                    <div class="w-100 mt-auto rounded-top-3" style="height: 100px; background: linear-gradient(to top, rgba(148,163,184,0.2), transparent);"></div>
                </div>
            </div>
        }

        <!-- 1st Place -->
        @if (Model.TopUsers.Count > 0) {
            var first = Model.TopUsers[0];
            <div class="d-flex flex-column align-items-center text-center order-1 order-md-2 position-relative z-3 mb-4 mb-md-5" style="width: 35%; min-width: 160px; max-width: 240px; transform: scale(1.1);">
                <div class="position-relative mb-4" style="width: 100px; height: 100px;">
                    <div class="position-absolute start-50 translate-middle-x rounded-circle d-flex align-items-center justify-content-center fw-bold text-dark shadow-lg border border-dark z-3" style="top: -1.25rem; width: 40px; height: 40px; background: #fbbf24; font-size: 1rem; border-width: 4px !important;">1</div>
                    <img src="@(first.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={first.FullName}")" class="w-100 h-100 rounded-circle object-cover border border-dark shadow-lg" style="background: rgba(255,255,255,0.1); border-color: #fbbf24 !important; border-width: 4px !important; box-shadow: 0 0 30px rgba(251,191,36,0.3) !important;" />
                </div>
                <div class="glass-card w-100 p-4 p-md-5 border-bottom-0 d-flex flex-column align-items-center shadow-lg" style="border-radius: 2rem 2rem 0 0; background: rgba(251,191,36,0.05); border-color: rgba(251,191,36,0.2);">
                    <p class="fw-bold text-white fs-5 mb-1 text-truncate w-100">@first.FullName</p>
                    <p class="text-aurora fw-bold mb-5">@first.ReputationPoints pts</p>
                    <div class="w-100 mt-auto rounded-top-3 position-relative d-flex align-items-center justify-content-center overflow-hidden" style="height: 140px; background: linear-gradient(to top, rgba(251,191,36,0.2), transparent);">
                        <span class="material-symbols-outlined position-absolute top-50 start-50 translate-middle" style="color: rgba(251,191,36,0.3); font-size: 5rem; animation: aurora-pulse 3s infinite alternate;">workspace_premium</span>
                    </div>
                </div>
            </div>
        }

        <!-- 3rd Place -->
        @if (Model.TopUsers.Count > 2) {
            var third = Model.TopUsers[2];
            <div class="d-flex flex-column align-items-center text-center order-3 order-md-3" style="width: 30%; min-width: 140px; max-width: 200px;">
                <div class="position-relative mb-4" style="width: 80px; height: 80px;">
                    <div class="position-absolute start-50 translate-middle-x rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-lg border border-dark z-3" style="top: -1rem; width: 32px; height: 32px; background: #fb923c; font-size: 0.85rem; border-width: 4px !important;">3</div>
                    <img src="@(third.AvatarUrl ?? $"https://api.dicebear.com/7.x/avataaars/svg?seed={third.FullName}")" class="w-100 h-100 rounded-circle object-cover border border-dark shadow-lg" style="background: rgba(255,255,255,0.1); border-color: #fb923c !important; border-width: 4px !important;" />
                </div>
                <div class="glass-card w-100 p-3 p-md-4 border-bottom-0 d-flex flex-column align-items-center shadow-lg" style="border-radius: 2rem 2rem 0 0; border-color: var(--border-glass-strong);">
                    <p class="fw-bold text-white mb-1 text-truncate w-100">@third.FullName</p>
                    <p class="text-aurora small fw-bold mb-4">@third.ReputationPoints pts</p>
                    <div class="w-100 mt-auto rounded-top-3" style="height: 80px; background: linear-gradient(to top, rgba(251,146,60,0.2), transparent);"></div>
                </div>
            </div>
        }
    </div>

    <!-- Filters -->
    <div class="mb-4 animate-entrance delay-100">
        <form onsubmit="return false;" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label text-muted small fw-black text-uppercase tracking-widest ms-1 mb-2" style="font-size: 0.65rem;">Search Student</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1.1rem;">search</span>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control form-control-glass ps-5 py-2 fw-bold text-white" style="border-radius: 0.75rem; font-size: 0.85rem;" placeholder="Name or username...">
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted small fw-black text-uppercase tracking-widest ms-1 mb-2" style="font-size: 0.65rem;">Institution</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1.1rem;">account_balance</span>
                    <input type="text" name="institution" value="@Model.Institution" class="form-control form-control-glass ps-5 py-2 fw-bold text-white" style="border-radius: 0.75rem; font-size: 0.85rem;" placeholder="University...">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small fw-black text-uppercase tracking-widest ms-1 mb-2" style="font-size: 0.65rem;">Sort By</label>
                <div class="position-relative">
                    <span class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="font-size: 1.1rem; z-index: 5;">sort</span>
                    <select name="sortBy" class="form-select form-select-glass ps-5 py-2 fw-bold text-white" style="border-radius: 0.75rem; font-size: 0.85rem; appearance: none;">
                        <option value="PointsDesc" selected="@(Model.SortBy == "PointsDesc")">Points: High to Low</option>
                        <option value="PointsAsc" selected="@(Model.SortBy == "PointsAsc")">Points: Low to High</option>
                        <option value="NameAsc" selected="@(Model.SortBy == "NameAsc")">Name: A-Z</option>
                        <option value="NameDesc" selected="@(Model.SortBy == "NameDesc")">Name: Z-A</option>
                    </select>
                </div>
            </div>
        </form>
    </div>

    <div id="leaderboard-data-container" class="animate-entrance delay-200">
        <partial name="_LeaderboardData" model="Model" />
    </div>
</div>

@section Scripts {
<script type="module" src="~/js/module.leaderboard.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        LeaderboardManager.init();
    });
</script>
}
