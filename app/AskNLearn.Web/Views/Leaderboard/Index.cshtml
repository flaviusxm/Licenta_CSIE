@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Student Leaderboard";
}

<div class="p-8 flex flex-col gap-8 pb-20">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Leaderboard</h2>
            <p class="text-slate-500 dark:text-slate-400">See who's topping the charts this semester.</p>
        </div>
        <div class="flex items-center gap-4 bg-surface-light dark:bg-surface-dark px-4 py-2 rounded-xl border border-border-light dark:border-border-dark">
            <div class="flex flex-col items-center">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Your Rank</span>
                <span class="text-lg font-bold text-primary">#42</span>
            </div>
            <div class="w-[1px] h-8 bg-border-light dark:bg-border-dark"></div>
            <div class="flex flex-col items-center">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Points</span>
                <span class="text-lg font-bold text-slate-900 dark:text-white">1,250</span>
            </div>
        </div>
    </div>

    <!-- Podiums (Top 3) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end max-w-4xl mx-auto w-full mt-8">
        <!-- 2nd Place -->
        <div class="order-2 md:order-1 flex flex-col items-center">
            <div class="size-20 rounded-full border-4 border-slate-300 relative mb-4">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-slate-300 text-white rounded-full size-6 flex items-center justify-center font-bold text-xs ring-4 ring-background-light dark:ring-background-dark">2</div>
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Sarah" class="w-full h-full rounded-full bg-slate-100" />
            </div>
            <div class="bg-surface-light dark:bg-surface-dark w-full rounded-t-2xl p-6 text-center border-x border-t border-border-light dark:border-border-dark shadow-sm">
                <p class="font-bold text-slate-900 dark:text-white">Sarah Smith</p>
                <p class="text-primary text-sm font-bold">2,840 pts</p>
                <div class="h-24 md:h-32 mt-4 bg-gradient-to-b from-slate-200 to-transparent dark:from-slate-700/50 rounded-lg"></div>
            </div>
        </div>

        <!-- 1st Place -->
        <div class="order-1 md:order-2 flex flex-col items-center scale-110 z-10">
            <div class="size-24 rounded-full border-4 border-yellow-400 relative mb-4">
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-yellow-400 text-white rounded-full size-8 flex items-center justify-center font-bold text-base ring-4 ring-background-light dark:ring-background-dark shadow-lg">1</div>
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=John" class="w-full h-full rounded-full bg-slate-100" />
            </div>
            <div class="bg-surface-light dark:bg-surface-dark w-full rounded-t-2xl p-8 text-center border-x border-t border-border-light dark:border-border-dark shadow-xl">
                <p class="font-bold text-slate-900 dark:text-white text-lg">John Doe</p>
                <p class="text-primary text-base font-bold">3,120 pts</p>
                <div class="h-32 md:h-48 mt-4 bg-gradient-to-b from-yellow-400/20 to-transparent rounded-lg relative overflow-hidden">
                    <span class="material-symbols-outlined absolute inset-0 flex items-center justify-center text-4xl text-yellow-400/30 animate-pulse">workspace_premium</span>
                </div>
            </div>
        </div>

        <!-- 3rd Place -->
        <div class="order-3 md:order-3 flex flex-col items-center">
            <div class="size-20 rounded-full border-4 border-orange-400/60 relative mb-4">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-orange-400/60 text-white rounded-full size-6 flex items-center justify-center font-bold text-xs ring-4 ring-background-light dark:ring-background-dark">3</div>
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Mike" class="w-full h-full rounded-full bg-slate-100" />
            </div>
            <div class="bg-surface-light dark:bg-surface-dark w-full rounded-t-2xl p-6 text-center border-x border-t border-border-light dark:border-border-dark shadow-sm">
                <p class="font-bold text-slate-900 dark:text-white">Mike Ross</p>
                <p class="text-primary text-sm font-bold">2,450 pts</p>
                <div class="h-20 md:h-24 mt-4 bg-gradient-to-b from-orange-400/20 to-transparent rounded-lg"></div>
            </div>
        </div>
    </div>

    <!-- Ranking Table -->
    <div class="max-w-4xl mx-auto w-full bg-surface-light dark:bg-surface-dark rounded-2xl border border-border-light dark:border-border-dark overflow-hidden shadow-sm">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-background-dark/50 border-b border-border-light dark:border-border-dark">
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Rank</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Student</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider">Major</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-wider text-right">Points</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-light dark:divide-border-dark">
                <!-- Row 4 -->
                <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-700 dark:text-slate-300">#4</td>
                    <td class="px-6 py-4 flex items-center gap-3">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Emily" class="size-8 rounded-full bg-slate-100" />
                        <span class="font-bold text-slate-900 dark:text-white">Emily Blunt</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2.5 py-1 rounded-md bg-indigo-500/10 text-indigo-500 dark:text-indigo-400 text-[10px] font-bold border border-indigo-500/20">Computer Science</span>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 dark:text-white">2,120</td>
                </tr>
                <!-- Row 5 -->
                <tr class="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                    <td class="px-6 py-4 font-bold text-slate-700 dark:text-slate-300">#5</td>
                    <td class="px-6 py-4 flex items-center gap-3">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Dave" class="size-8 rounded-full bg-slate-100" />
                        <span class="font-bold text-slate-900 dark:text-white">Dave Wilson</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2.5 py-1 rounded-md bg-emerald-500/10 text-emerald-500 dark:text-emerald-400 text-[10px] font-bold border border-emerald-500/20">Mathematics</span>
                    </td>
                    <td class="px-6 py-4 text-right font-bold text-slate-900 dark:text-white">1,980</td>
                </tr>
                <!-- Global/Local Row (Simplified for Demo, but adding logic for Admin) -->
                <tr class="@(User.IsInRole("Admin") ? "bg-red-500/5" : "bg-primary/5 dark:bg-primary/10") transition-colors">
                    <td class="px-6 py-4 font-bold @(User.IsInRole("Admin") ? "text-red-500" : "text-primary")">
                        @(User.IsInRole("Admin") ? "SYSTEM" : "#42")
                    </td>
                    <td class="px-6 py-4 flex items-center gap-3">
                        <div class="size-8 rounded-full bg-cover bg-center border @(User.IsInRole("Admin") ? "border-red-500/50" : "border-primary/50")" 
                             style='background-image: url("@(User.IsInRole("Admin") ? "https://api.dicebear.com/7.x/bottts/svg?seed=Admin" : "https://api.dicebear.com/7.x/avataaars/svg?seed=Alex")");'></div>
                        <div class="flex flex-col">
                            <span class="font-bold text-slate-900 dark:text-white">@(User.Identity.Name)</span>
                            <span class="text-[10px] @(User.IsInRole("Admin") ? "text-red-500" : "text-primary") font-bold">@(User.IsInRole("Admin") ? "ADMINISTRATOR" : "You")</span>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2.5 py-1 rounded-md @(User.IsInRole("Admin") ? "bg-red-500/10 text-red-500" : "bg-indigo-500/10 text-indigo-500 dark:text-indigo-400") text-[10px] font-bold border @(User.IsInRole("Admin") ? "border-red-500/20" : "border-indigo-500/20")">
                            @(User.IsInRole("Admin") ? "Authority" : "Computer Science")
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right font-bold @(User.IsInRole("Admin") ? "text-red-400" : "text-primary")">
                        @(User.IsInRole("Admin") ? "REDACTED" : "1,250")
                    </td>
                </tr>
            </tbody>
        </table>
        <div class="p-4 text-center border-t border-border-light dark:border-border-dark">
            <button class="text-sm font-bold text-slate-400 hover:text-primary transition-colors">Show full rankings</button>
        </div>
    </div>
</div>
