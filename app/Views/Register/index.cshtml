@{
    Layout = null;
    ViewData["Title"] = "Welcome Guest";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AskNLearn</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-card: rgba(30, 41, 59, 0.6);
            --accent-mint: #2dd4bf;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        body {
            font-family: 'Nunito', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            background-image: radial-gradient(circle at 50% 0%, rgba(45, 212, 191, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(59, 130, 246, 0.08) 0%, transparent 40%);
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .glass-panel {
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            border-radius: 24px;
            padding: 3rem;
            max-width: 600px;
            width: 100%;
            text-align: center;
        }


        .brand-title {
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            font-size: 3rem;
        }

    
        .btn-mint {
            background: var(--accent-mint);
            color: #0f172a;
            font-weight: 800;
            border: none;
            padding: 12px 30px;
            border-radius: 12px;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
            margin-top: 20px;
        }

            .btn-mint:hover {
                background: #14b8a6;
                color: white;
                transform: scale(1.05);
            }

        .btn-outline-light {
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 700;
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center">

        <div class="glass-panel position-relative overflow-hidden">
            <div style="position: absolute; top: -10px; right: -10px; opacity: 0.05; font-size: 100px; transform: rotate(15deg);">🚀</div>

            <h1 class="brand-title mb-3">AskNLearn</h1>
            <p class="lead text-muted mb-5" style="color: var(--text-muted);">
                Bine ai venit pe pagina pentru vizitatori! <br>
                Aceasta este o zonă publică, accesibilă fără cont.
            </p>

            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a href="/Identity/Account/Login" class="btn btn-mint px-4">Log In</a>

                <a href="/Home/Index" class="btn btn-outline-light px-4">Înapoi la Home</a>
            </div>
        </div>

    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>